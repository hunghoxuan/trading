# Web UI Configuration
# Copy to .env and adjust values

# The base URL of your Webhook Server
# For local dev: http://localhost:80/signal
# For production: https://your-domain.com/signal
VITE_API_BASE=http://localhost:80/signal

# The SIGNAL_API_KEY defined in your webhook/.env
VITE_API_KEY=YOUR_SIGNAL_API_KEY
