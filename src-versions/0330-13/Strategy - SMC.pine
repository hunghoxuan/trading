    bool msHtf1ZigzagShow = true
    bool msHtf2SwingShow = true
    bool msHtf2ZigzagShow = true
    int htfZoneBgTransp = 90
    int zoneCurrMinWidthBars = 6
    bool htfShowProjectedZones = true

get_ui_cfg(KitCore.Theme th) =>
    UIConfig cfg = UIConfig.new()
    cfg.colorBearish := color.new(th.COLOR_BEARISH, th.T_NORMAL)
    cfg.colorBullish := color.new(th.COLOR_BULLISH, th.T_NORMAL)
    cfg.colorBg := color.new(th.COLOR_NEUTRAL, th.T_NORMAL)
    cfg.colorText := color.new(th.TEXT_COLOR, th.T_NORMAL)
    cfg.ltfColor := color.new(color.rgb(215, 215, 215), 0)
    cfg

get_data_local_cfg(int globalLookbackBars) =>
    LocalCfg cfg = LocalCfg.new()
    cfg.htfZoneLookbackBars := globalLookbackBars <= 0 ? 1000000 : globalLookbackBars
    cfg.entryZoneMinQualityPct := 35.0
    cfg.htfProjectionMinQualityPct := 25.0
    cfg.zoneCapPerType := 100000
    cfg.zoneCapTotal := 100000
    cfg.zoneCurrMaxPerTypeSide := 100000
    cfg.zonePriorityAgeDecay := 0.010
    cfg

get_data_core_swings_snapshot_from_tf(KitSMC.TFData tfData) =>
    array<float> hi = array.new_float()
    array<int> hiT = array.new_int()
    array<float> lo = array.new_float()
    array<int> loT = array.new_int()
    if not na(tfData.mss.swings) and array.size(tfData.mss.swings) > 0
        for i = 0 to array.size(tfData.mss.swings) - 1
            KitSMC.Swing s = array.get(tfData.mss.swings, i)
            if s.isSwingHigh
                array.push(hi, s.price)
                array.push(hiT, s.time)
            else
                array.push(lo, s.price)
                array.push(loT, s.time)
    [hi, hiT, lo, loT]

get_data_core_structure_snapshot(KitSMC.SMCContext ctx) =>
    snap = KitCore.StructureSnapshot.new()
    snap.dir0 := ctx.ltfData.mss.msBias != 0 ? ctx.ltfData.mss.msBias : ctx.ltfData.mss.prevBreakout
    [ltfHi, ltfHiT, ltfLo, ltfLoT] = get_data_core_swings_snapshot_from_tf(ctx.ltfData)
    [h1Hi, h1HiT, h1Lo, h1LoT] = get_data_core_swings_snapshot_from_tf(ctx.htf1Data)
    [h2Hi, h2HiT, h2Lo, h2LoT] = get_data_core_swings_snapshot_from_tf(ctx.htf2Data)
    snap.ltfSwingHighPrices := ltfHi
    snap.ltfSwingHighTimes := ltfHiT
    snap.ltfSwingLowPrices := ltfLo
    snap.ltfSwingLowTimes := ltfLoT
    snap.htf1SwingHighPrices := h1Hi
    snap.htf1SwingHighTimes := h1HiT
    snap.htf1SwingLowPrices := h1Lo
    snap.htf1SwingLowTimes := h1LoT
    snap.htf2SwingHighPrices := h2Hi
    snap.htf2SwingHighTimes := h2HiT
    snap.htf2SwingLowPrices := h2Lo
    snap.htf2SwingLowTimes := h2LoT
    snap

