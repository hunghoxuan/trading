 (KitUI.get_tf_seconds(timeframe.period) <= 300 ? PIVOT_LEN_SCALP :
  KitUI.get_tf_seconds(timeframe.period) <= 3600 ? PIVOT_LEN_INTRADAY :
  KitUI.get_tf_seconds(timeframe.period) <= 14400 ? PIVOT_LEN_MULTI_DAY :
  KitUI.get_tf_seconds(timeframe.period) <= 86400 ? PIVOT_LEN_SWING : PIVOT_LEN_POSITION)

