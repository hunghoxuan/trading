    KitSMC.get_working_first_time_for_source_tf(timeframe.period, sourceTf, tf1Local, tf2Local, WORKING_MAX_BARS, htf1Data.mss, htf2Data.mss)

get_data_real_htf_swings(string tfName, int pivotLen) =>
    float sh = na
    int shT = na
    float sl = na
    int slT = na
    if not na(tfName) and tfName != ""
        sh := request.security(syminfo.tickerid, tfName, ta.pivothigh(high, pivotLen, pivotLen), lookahead = barmerge.lookahead_off)
        sl := request.security(syminfo.tickerid, tfName, ta.pivotlow(low, pivotLen, pivotLen), lookahead = barmerge.lookahead_off)
        shT := int(request.security(syminfo.tickerid, tfName, not na(ta.pivothigh(high, pivotLen, pivotLen)) ? time[pivotLen] : int(na), lookahead = barmerge.lookahead_off))
        slT := int(request.security(syminfo.tickerid, tfName, not na(ta.pivotlow(low, pivotLen, pivotLen)) ? time[pivotLen] : int(na), lookahead = barmerge.lookahead_off))
    [sh, shT, sl, slT]

get_data_map_htf_swing_to_ltf_idx(bool isHigh, int swingT, float swingP) =>
    int fallbackIdx = not na(swingT) ? KitUI.closest_bar_index_from_time(swingT) : na
    int outIdx = fallbackIdx
    int bestDt = na
    float bestDp = na
    if not na(ltfData.mss.swings) and array.size(ltfData.mss.swings) > 0 and not na(swingT)
        for i = 0 to array.size(ltfData.mss.swings) - 1
            KitSMC.Swing s = array.get(ltfData.mss.swings, i)
            if s.isSwingHigh == isHigh and not na(s.barIndex) and not na(s.time)
                int dt = math.abs(s.time - swingT)
                float dp = not na(swingP) ? math.abs(s.price - swingP) : 0.0
                bool better = na(bestDt) or dt < bestDt or (dt == bestDt and (na(bestDp) or dp < bestDp))
                if better
                    bestDt := dt
                    bestDp := dp
                    outIdx := s.barIndex
    outIdx

get_data_working_first_idx_for_source_tf(string sourceTf) =>
    int cutoffTime = get_data_working_first_time_for_source_tf(sourceTf)
    int cutoffIdx = KitUI.closest_bar_index_from_time(cutoffTime)
    na(cutoffIdx) ? get_working_first_bar() : cutoffIdx

// Relaxed TF cutoff: ratio-window only (ignores structural anchor tightening).
get_data_relaxed_first_idx_for_source_tf(string sourceTf) =>
    if na(sourceTf) or sourceTf == "" or sourceTf == timeframe.period
        get_working_first_bar()
    else
        int cutoffTime = get_working_first_time_for_tf(sourceTf)
        int cutoffIdx = KitUI.closest_bar_index_from_time(cutoffTime)
        na(cutoffIdx) ? get_working_first_bar() : cutoffIdx

is_in_working_zone_idx_for_source_tf(int idx, string sourceTf) =>
    not na(idx) and idx >= get_data_working_first_idx_for_source_tf(sourceTf)

get_data_level_anchor_idx(KitSMC.PDArray z) =>
    int idx = na
    if not na(z.barEnd)
        idx := z.barEnd
    else if not na(z.barStart)
        bool isTimestamp = z.barStart > 1000000000
        idx := isTimestamp ? na : z.barStart
    idx

process_data_prune_outside_working_zone_levels(array<KitSMC.PDArray> levels) =>
    if array.size(levels) > 0
        for i = array.size(levels) - 1 to 0 by 1
            KitSMC.PDArray z = array.get(levels, i)
            int anchorIdx = get_data_level_anchor_idx(z)
            string sourceTf = na(z.labelText) or z.labelText == "" ? timeframe.period : z.labelText
            int firstIdx = get_data_working_first_idx_for_source_tf(sourceTf)
            if not na(anchorIdx) and anchorIdx < firstIdx
                KitUI.delete_line_label(z.visualLine, z.visualLabel)
                array.remove(levels, i)
    bool(na)

// ==================== INPUTS ====================

PSEUDO_SWEEP_FROM_BOS = true
PSEUDO_SWEEP_RECLAIM_BARS = 6
strategyRiskPerRRUsd = input.float(100.0, "Risk Per 1R ($)", minval = 0.01, step = 10.0, group = "0. Strategy Config")

showSR = input.bool(true, "S/R", inline="ui0", group="1. UI Config")

liquidityBool = input.bool(true, "Swing Liq", inline = "ui0", group = "1. UI Config")
showPDH_PDL = input.bool(true, "PdH/L", inline = "ui0", group = "1. UI Config")
msShowLtf = input.bool(true, "LTF", inline = "ui1", group = "1. UI Config")
msShowTf1 = input.bool(true, "TF1", inline = "ui1", group = "1. UI Config")
msShowTf2 = input.bool(true, "TF2", inline = "ui1", group = "1. UI Config")
msShowBosMss = input.bool(true, "BOS/MSS", inline = "ui2", group = "1. UI Config")
msShowZigzag = input.bool(true, "Zigzag", inline = "ui2", group = "1. UI Config")
msShowSwings = input.bool(true, "Swings", inline = "ui2", group = "1. UI Config")
modelMss = input.bool(true, "MS - MSS.", inline = "m0", group = "2. Trade Models")
modelMssWhen = input.string(TRIGGER_WHEN_RETEST, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m0", group = "2. Trade Models")
modelMssType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m0", group = "2. Trade Models")
modelMssRr = input.float(2.0, "RR", minval = 0.1, step = 0.1, inline = "m0", group = "2. Trade Models")
modelBos = input.bool(true, "BO - BOS.", inline = "m1", group = "2. Trade Models")
modelBosWhen = input.string(TRIGGER_WHEN_RETEST, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m1", group = "2. Trade Models")
modelBosType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m1", group = "2. Trade Models")
modelBosRr = input.float(2.0, "RR", minval = 0.1, step = 0.1, inline = "m1", group = "2. Trade Models")
modelSweep = input.bool(true, "SW - Sweep.", inline = "m2", group = "2. Trade Models")
modelSweepWhen = input.string(TRIGGER_WHEN_RETEST, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m2", group = "2. Trade Models")
modelSweepType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m2", group = "2. Trade Models")
modelSweepRr = input.float(2.0, "RR", minval = 0.1, step = 0.1, inline = "m2", group = "2. Trade Models")
modelSweepMss = input.bool(true, "SM - SW>MS.", inline = "m3", group = "2. Trade Models")
modelSweepMssWhen = input.string(TRIGGER_WHEN_TOUCH, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m3", group = "2. Trade Models")
modelSweepMssType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m3", group = "2. Trade Models")
modelSweepMssRr = input.float(2.0, "RR", minval = 0.1, step = 0.1, inline = "m3", group = "2. Trade Models")
modelSweepMssFvg = input.bool(false, "SF - SW>MS>FVG.", inline = "m4", group = "2. Trade Models")
modelSweepMssFvgWhen = input.string(TRIGGER_WHEN_TOUCH, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m4", group = "2. Trade Models")
modelSweepMssFvgType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m4", group = "2. Trade Models")
modelSweepMssFvgRr = input.float(2.0, "RR", minval = 0.1, step = 0.1, inline = "m4", group = "2. Trade Models")
gateUseEntryDirection = input.bool(true, "Dir gate", inline = "g0", group = "3. Gate Debug")
gateUseDynamicBiasModes = input.bool(true, "Dyn bias", inline = "g0", group = "3. Gate Debug")
gateUseDynamicMemory = input.bool(true, "Dyn mem", inline = "g1", group = "3. Gate Debug")
gateUseDynamicBiasDirection = input.bool(true, "Dyn side", inline = "g1", group = "3. Gate Debug")
gateUseDynamicRequiredEvents = input.bool(true, "Dyn req", inline = "g2", group = "3. Gate Debug")
gateUseMaxActive = input.bool(true, "Max active", inline = "g2", group = "3. Gate Debug")
gateUseEntryMode = input.bool(true, "Entry mode", inline = "g3", group = "3. Gate Debug")
gateUseRetestConfirm = input.bool(true, "Retest confirm", inline = "g3", group = "3. Gate Debug")
gateUseRetestInvalidation = input.bool(true, "Retest invalid", inline = "g4", group = "3. Gate Debug")
gateUseTradePlan = input.bool(true, "Plan RR/size", inline = "g4", group = "3. Gate Debug")
gateUsePretouchCancel = input.bool(true, "Pre-touch cancel", inline = "g5", group = "3. Gate Debug")

if barstate.isfirst
    localCfg := get_data_local_cfg()
    uiCfg := get_ui_cfg(THEME)
    ZONE_VIS_CFG.minWidthBars := uiCfg.zoneCurrMinWidthBars
localCfg.riskPerRRUsd := strategyRiskPerRRUsd

localCfg.minTradeSizeTicks := 30.0
localCfg.minTradeRR := 1.0

// ==================== FEATURES ====================

get_data_color_sig(color c) =>
    str.tostring(color.r(c)) + ":" + str.tostring(color.g(c)) + ":" + str.tostring(color.b(c)) + ":" + str.tostring(color.t(c))

// LIQ-specific swept flag (separate semantics from generic lifecycle touched state).
get_data_is_liq_swept(KitSMC.PDArray z) =>
    KitCore.is_life_broken(z.lifeState, CONST) or KitCore.is_life_reclaimed(z.lifeState, CONST)

get_data_tf_priority(string tfLbl) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    tfLbl == tf2Local ? 3 : tfLbl == tf1Local ? 2 : tfLbl == timeframe.period ? 1 : 0

get_data_liq_label_align(string liqTxt) =>
    if liqTxt != "$"
        text.align_center
    else
        localCfg.liqDollarXPos == "Right" ? text.align_right : localCfg.liqDollarXPos == "Left" ? text.align_left : text.align_center

get_data_liq_label_y(string liqTxt, float basePrice) =>
    if liqTxt != "$"
        basePrice
    else
        float yPad = syminfo.mintick * math.max(localCfg.liqDollarYOffsetTicks, 0.0)
        localCfg.liqDollarYPos == "Above" ? (basePrice + yPad) : localCfg.liqDollarYPos == "Below" ? (basePrice - yPad) : basePrice

get_data_liq_label_x(line liqLine, string liqTxt) =>
    int x1 = liqLine.get_x1()
    int x2 = liqLine.get_x2()
    int midX = int(math.round((x1 + x2) * 0.5))
    if liqTxt != "$"
        midX
    else
        localCfg.liqDollarXPos == "Right" ? x2 : localCfg.liqDollarXPos == "Left" ? x1 : midX

get_data_liq_has_stronger_overlap(array<KitSMC.PDArray> levels, int selfIdx, KitSMC.PDArray self, float tolPrice) =>
    bool hasStronger = false
    int selfPrio = get_data_tf_priority(self.labelText)
    bool scopeDollarOnly = localCfg.liqOverlapScope == "Dollar Only"
    bool selfIsDollar = self.labelText != timeframe.period
    if array.size(levels) > 0
        for j = 0 to array.size(levels) - 1
            if j == selfIdx
                continue
            KitSMC.PDArray other = array.get(levels, j)
            bool sameFamily = other.type == "LIQ"
            bool otherIsDollar = other.labelText != timeframe.period
            bool scopeOk = scopeDollarOnly ? (selfIsDollar and otherIsDollar) : true
            bool near = math.abs(other.price - self.price) <= tolPrice
            bool active = not get_data_is_liq_swept(other)
            if sameFamily and scopeOk and near and active
                int otherPrio = get_data_tf_priority(other.labelText)
                if otherPrio > selfPrio
                    hasStronger := true
                    break
    hasStronger

process_data_init_strategy_defs() =>
    array.clear(strategyDefs)
    array.push(strategyDefs, KitCore.EntryModelDef.new("MSS", "MS", 3, modelMss, modelMssType, modelMssWhen, modelMssRr, "edge", 1, 1, 0, "", 100, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, KitCore.EntryModelDef.new("BOS", "BO", 2, modelBos, modelBosType, modelBosWhen, modelBosRr, "edge", 1, 1, 0, "", 100, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, KitCore.EntryModelDef.new("SWEEP", "SW", 6, modelSweep, modelSweepType, modelSweepWhen, modelSweepRr, "edge", 1, 0, 0, "", 100, "na", 2, true, 0.20, ENTRY_MODE_LIMIT))
    array.push(strategyDefs, KitCore.EntryModelDef.new("SWEEP_MSS", "SW", 6, modelSweepMss, modelSweepMssType, modelSweepMssWhen, modelSweepMssRr, "edge", 1, 0, 0, "SWEEP,MSS", 100, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, KitCore.EntryModelDef.new("SWEEP_FVG", "SW", 7, modelSweepMssFvg, modelSweepMssFvgType, modelSweepMssFvgWhen, modelSweepMssFvgRr, "middle", 1, 0, 0, "SWEEP,MSS,BOS", 140, "na", 1, true, 0.16, ENTRY_MODE_AFTER_RETEST))
    bool(na)

get_data_strategy_defs_sig() =>
    int sig = 0
    sig += (modelMss ? 1 : 0) * 100000 + KitSMC.trigger_type_code(modelMssType, TRIGGER_TYPE_SIGNAL) * 10000 + KitSMC.trigger_when_code(modelMssWhen, TRIGGER_WHEN_TOUCH) * 1000
    sig += (modelBos ? 1 : 0) * 100 + KitSMC.trigger_type_code(modelBosType, TRIGGER_TYPE_SIGNAL) * 10 + KitSMC.trigger_when_code(modelBosWhen, TRIGGER_WHEN_TOUCH)
    sig += (modelSweep ? 1 : 0) * 31 + KitSMC.trigger_type_code(modelSweepType, TRIGGER_TYPE_SIGNAL) * 37 + KitSMC.trigger_when_code(modelSweepWhen, TRIGGER_WHEN_TOUCH) * 41
    sig += (modelSweepMss ? 1 : 0) * 43 + KitSMC.trigger_type_code(modelSweepMssType, TRIGGER_TYPE_SIGNAL) * 47 + KitSMC.trigger_when_code(modelSweepMssWhen, TRIGGER_WHEN_TOUCH) * 53
    sig += (modelSweepMssFvg ? 1 : 0) * 59 + KitSMC.trigger_type_code(modelSweepMssFvgType, TRIGGER_TYPE_SIGNAL) * 61 + KitSMC.trigger_when_code(modelSweepMssFvgWhen, TRIGGER_WHEN_TOUCH) * 67
    sig

process_data_refresh_strategy_defs() =>
    int nextSig = get_data_strategy_defs_sig()
    int cachedSig = array.get(strategyDefsSigBox, 0)
    if na(cachedSig) or cachedSig != nextSig or array.size(strategyDefs) == 0
        process_data_init_strategy_defs()
        array.set(strategyDefsSigBox, 0, nextSig)
    bool(na)

get_data_strategy_meta_by_key(string key) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(key)
    process_data_reset_runtime_context_if_new_bar()
    int cachedIdx = na
    if array.size(rtStrategyKeys) > 0
        for i = 0 to array.size(rtStrategyKeys) - 1
            if array.get(rtStrategyKeys, i) == k
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtStrategyEnabled, cachedIdx), array.get(rtStrategyScore, cachedIdx), array.get(rtStrategyShort, cachedIdx), array.get(rtStrategyTriggerType, cachedIdx), array.get(rtStrategyTriggerWhen, cachedIdx)]
    else
        bool enabled = false
        int score = 0
        string shortName = ""
        string triggerType = TRIGGER_TYPE_TRADE
        string triggerWhen = TRIGGER_WHEN_RETEST
        for i = 0 to array.size(strategyDefs) - 1
            KitCore.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                enabled := s.enabled
                score := s.baseScore
                shortName := s.shortName
                triggerType := s.trigger_type
                triggerWhen := s.trigger_when
                break
        array.push(rtStrategyKeys, k)
        array.push(rtStrategyEnabled, enabled)
        array.push(rtStrategyScore, score)
        array.push(rtStrategyShort, shortName)
        array.push(rtStrategyTriggerType, triggerType)
        array.push(rtStrategyTriggerWhen, triggerWhen)
        [enabled, score, shortName, triggerType, triggerWhen]

get_data_cached_bar_index_from_time(int t) =>
    process_data_reset_runtime_context_if_new_bar()
    if na(t)
        na
    else
        int idx = na
        if array.size(rtTimeToIdxKeys) > 0
            for i = 0 to array.size(rtTimeToIdxKeys) - 1
                if array.get(rtTimeToIdxKeys, i) == t
                    idx := i
                    break
        if not na(idx)
            array.get(rtTimeToIdxVals, idx)
        else
            int v = KitUI.closest_bar_index_from_time(t)
            array.push(rtTimeToIdxKeys, t)
            array.push(rtTimeToIdxVals, v)
            v

get_data_ms_track_slot(string tfName) =>
    int slot = na
    if array.size(msTrackTf) > 0
        for i = 0 to array.size(msTrackTf) - 1
            if array.get(msTrackTf, i) == tfName
                slot := i
                break
    if na(slot)
        array.push(msTrackTf, tfName)
        array.push(msTrackLine, na)
        array.push(msTrackLabel, na)
        array.push(msTrackLevel, na)
        array.push(msTrackDir, 0)
        array.push(msTrackBar, na)
        array.push(msTrackActive, false)
        slot := array.size(msTrackTf) - 1
    slot

process_data_clear_ms_track_slot(int slot) =>
    array.set(msTrackLine, slot, na)
    array.set(msTrackLabel, slot, na)
    array.set(msTrackLevel, slot, na)
    array.set(msTrackDir, slot, 0)
    array.set(msTrackBar, slot, na)
    array.set(msTrackActive, slot, false)
    bool(na)

get_data_ms_reclass_invalidated(int dir, float lvl) =>
    bool useWick = localCfg.msReclassBasis == "Wick"
    dir == 1 ? (useWick ? low < lvl : close < lvl) : (useWick ? high > lvl : close > lvl)

process_data_register_ms_track(string tfName, line evtLine, label evtLabel, float level, int direction) =>
    int slot = get_data_ms_track_slot(tfName)
    array.set(msTrackLine, slot, evtLine)
    array.set(msTrackLabel, slot, evtLabel)
    array.set(msTrackLevel, slot, level)
    array.set(msTrackDir, slot, direction)
    array.set(msTrackBar, slot, bar_index)
    array.set(msTrackActive, slot, true)
    bool(na)

process_data_update_ms_track(string tfName) =>
    int slot = get_data_ms_track_slot(tfName)
    bool active = array.get(msTrackActive, slot)
    if not active
        bool(na)
    else
        int bornBar = array.get(msTrackBar, slot)
        int ageBars = na(bornBar) ? 1000000 : (bar_index - bornBar)
        if ageBars > localCfg.msReclassBars
            process_data_clear_ms_track_slot(slot)
        else
            float lvl = array.get(msTrackLevel, slot)
            int dir = array.get(msTrackDir, slot)
            bool invalidated = get_data_ms_reclass_invalidated(dir, lvl)
            if invalidated
                line evtLine = array.get(msTrackLine, slot)
                label evtLabel = array.get(msTrackLabel, slot)
                if not na(evtLine)
                    evtLine.set_style(line.style_dotted)
                if not na(evtLabel)
                    string oldTxt = evtLabel.get_text()
                    string cleanTxt = str.replace(oldTxt, " x", "")
                    if evtLabel.get_text() != cleanTxt
                        evtLabel.set_text(cleanTxt)
                string invDir = dir == 1 ? "Sell" : "Buy"
                string invIcon = dir == -1 ? "X↑" : "X"
                string invTip = "BOS/MSS invalidated (reclaim through level)"
                KitUI.draw_strategy_marker(true, localCfg.msInvalidMarkerMode, invDir, invIcon, invTip, UI_THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
                process_data_clear_ms_track_slot(slot)
    bool(na)

get_entry_model_dynamic_cfg(string modelKey) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(modelKey)
    float rrCfg = 2.0
    string entryPoint = "edge"
    int biasLtfMode = 1
    int biasHtf1Mode = 0
    int biasHtf2Mode = 0
    string requiredPrevEvents = ""
    int requiredWindowBars = 100
    string biasDirection = "na"
    int maxActiveCfg = 1
    bool dynamicTpCfg = true
    float riskZonePctCfg = 0.20
    string entryModeCfg = ENTRY_MODE_AFTER_RETEST
    if array.size(strategyDefs) > 0
        for i = 0 to array.size(strategyDefs) - 1
            KitCore.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                rrCfg := s.rr
                entryPoint := s.entry_point
                biasLtfMode := s.bias_ltf
                biasHtf1Mode := s.bias_htf1
                biasHtf2Mode := s.bias_htf2
                requiredPrevEvents := s.required_previous_events
                requiredWindowBars := s.required_window_bars
                biasDirection := s.bias_direction
                maxActiveCfg := s.max_active
                dynamicTpCfg := s.dynamic_tp_sl
                riskZonePctCfg := s.risk_zone_pct
                entryModeCfg := s.entry_mode
                break
    [rrCfg, entryPoint, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, maxActiveCfg, dynamicTpCfg, riskZonePctCfg, entryModeCfg]

check_entry_model_dynamic(string modelKey, string direction, int memDir) =>
    [_, _, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, _, _, _, _] = get_entry_model_dynamic_cfg(modelKey)
    int bLtf = array.size(tradeBiasVals) > 0 ? array.get(tradeBiasVals, 0) : 0
    int bH1 = array.size(tradeBiasVals) > 1 ? array.get(tradeBiasVals, 1) : 0
    int bH2 = array.size(tradeBiasVals) > 2 ? array.get(tradeBiasVals, 2) : 0
    int tLtf = array.size(tradeTrendVals) > 0 ? array.get(tradeTrendVals, 0) : 0
    int tH1 = array.size(tradeTrendVals) > 1 ? array.get(tradeTrendVals, 1) : 0
    int tH2 = array.size(tradeTrendVals) > 2 ? array.get(tradeTrendVals, 2) : 0
    bool allowPullback = KitSMC.has_pullback_preference(biasLtfMode, biasHtf1Mode, biasHtf2Mode)
    bool dirModeOk = KitSMC.check_direction_by_mode(direction, biasLtfMode, tLtf, bLtf, allowPullback) and KitSMC.check_direction_by_mode(direction, biasHtf1Mode, tH1, bH1, allowPullback) and KitSMC.check_direction_by_mode(direction, biasHtf2Mode, tH2, bH2, allowPullback)
    bool memOk = KitSMC.direction_allowed_raw(direction, memDir)
    string bd = str.upper(biasDirection)
    bool biasDirOk = bd == "" or bd == "NA" or (bd == "LONG" and direction == "Buy") or (bd == "SHORT" and direction == "Sell")
    bool requiredOk = KitSMC.check_required_previous_events(smcCtx.signalHist, requiredPrevEvents, requiredWindowBars, bar_index)
    (not gateUseDynamicBiasModes or dirModeOk) and (not gateUseDynamicMemory or memOk) and (not gateUseDynamicBiasDirection or biasDirOk) and (not gateUseDynamicRequiredEvents or requiredOk)

entry_direction_allowed(string direction, int biasVal) =>
    int cachedBar = array.get(rtBarBox, 0)
    int cachedBias = array.get(rtBiasBox, 0)
    bool canUseCache = not na(cachedBar) and cachedBar == bar_index and cachedBias == biasVal
    if canUseCache
        not gateUseEntryDirection or (direction == "Buy" ? array.get(rtAllowBuyBox, 0) == 1 : array.get(rtAllowSellBox, 0) == 1)
    else
        not gateUseEntryDirection or KitSMC.direction_allowed_raw(direction, chartCtx.signalMemoryDir)

get_data_is_trade_size_valid(float entry, float stoploss, float takeprofit) =>
    if na(entry) or na(stoploss) or na(takeprofit) or na(syminfo.mintick) or syminfo.mintick <= 0.0
        false
    else
        float minTicks = math.max(localCfg.minTradeSizeTicks, 0.0)
        float sizeTicks = (math.abs(entry - stoploss) + math.abs(takeprofit - entry)) / math.max(syminfo.mintick, 1e-10)
        minTicks <= 0.0 or (not na(sizeTicks) and sizeTicks >= minTicks)

get_data_is_trade_rr_valid(float entry, float stoploss, float takeprofit) =>
    if na(entry) or na(stoploss) or na(takeprofit)
        false
    else
        float risk = math.max(math.abs(entry - stoploss), syminfo.mintick)
        float reward = math.abs(takeprofit - entry)
        float rr = reward / risk
        rr >= math.max(localCfg.minTradeRR, 0.1)

get_data_is_trade_plan_valid(float entry, float stoploss, float takeprofit) =>
    get_data_is_trade_size_valid(entry, stoploss, takeprofit) and get_data_is_trade_rr_valid(entry, stoploss, takeprofit)

get_data_order_qty(float entry, float stoploss) =>
    if na(entry) or na(stoploss)
        na
    else
        float riskPerUnitUsd = math.abs(entry - stoploss) * math.max(math.abs(syminfo.pointvalue), 1e-10)
        riskPerUnitUsd <= 0.0 ? na : (localCfg.riskPerRRUsd / riskPerUnitUsd)

process_data_add_entry(string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal) =>
    bool isBuy = direction == "Buy"
    string modelKey = str.upper(type)
    [rrCfg, entryPointCfg, _, _, _, _, _, _, maxActiveCfg, _, riskZonePctCfg, entryModeCfg] = get_entry_model_dynamic_cfg(modelKey)
    bool passMax = not gateUseMaxActive or KitCore.count_start_trades(trades, CONST) < math.max(maxActiveCfg, 1)
    bool passDir = true
    bool passDynamic = check_entry_model_dynamic(modelKey, direction, chartCtx.signalMemoryDir)
    bool passEntryMode = not gateUseEntryMode or entryModeCfg != ENTRY_MODE_OFF
    if passMax and passDir and passDynamic and passEntryMode
        float tick = syminfo.mintick
        float zoneTop = math.max(levelTop, levelBtm)
        float zoneBtm = math.min(levelTop, levelBtm)
        float rrUsed = math.max(rrCfg, 0.1)
        float zoneHeight = math.max(zoneTop - zoneBtm, tick)
        float riskDist = math.max(zoneHeight * math.max(riskZonePctCfg, 0.01), tick)
        float entry = entryPointCfg == "middle" ? ((zoneTop + zoneBtm) * 0.5) : entryPointCfg == "end" ? (isBuy ? zoneBtm : zoneTop) : (isBuy ? zoneTop : zoneBtm)
        float slRaw = isBuy ? zoneBtm : zoneTop
        float stoploss = isBuy ? (slRaw - riskDist) : (slRaw + riskDist)
        float takeprofit = isBuy ? (entry + riskDist * rrUsed) : (entry - riskDist * rrUsed)
        float orderQty = get_data_order_qty(entry, stoploss)
        if (gateUseTradePlan and not get_data_is_trade_plan_valid(entry, stoploss, takeprofit)) or na(orderQty) or orderQty <= 0.0
            bool(na)
        else
            KitCore.Trade e = KitCore.create_trade_if_valid(direction, type, levelTop, levelBtm, entry, stoploss, takeprofit, rrUsed, bar_index, reason, scoreVal, CONST, tick)
            if not na(e)
                string orderId = "MSS_" + type + "_" + str.tostring(bar_index) + "_" + str.tostring(array.size(trades))
                array.push(trades, e)
                array.push(tradeOrderIds, orderId)
                strategy.entry(orderId, direction == "Buy" ? strategy.long : strategy.short, qty = orderQty, limit = entry, comment = type)
                strategy.exit(orderId + "_x", from_entry = orderId, stop = stoploss, limit = takeprofit, comment_profit = "TP", comment_loss = "SL")
                KitSMC.cache_signal_memory_event(smcCtx.signalHist, KitSMC.Event.new(type, direction, levelTop, levelBtm, na, bar_index, int(na), false, reason, qualityPct, scoreVal), tick, 80)
    bool(na)

process_data_structure_from_ledger(KitSMC.TFData tfData, KitSMC.TFConfig cfg, string tfName, int recentTsCut, string htf1Name, string htf2Name, bool canEmitSignals, KitSMC.MSSContext msSource) =>
    process_data_update_ms_track(tfName)
    bool highArmedNext = tfData.mss.highArmed
    bool lowArmedNext = tfData.mss.lowArmed
    int prevBreakoutNext = tfData.mss.prevBreakout
    int msBiasNext = tfData.mss.msBias
    bool highBroken = false
    bool lowBroken = false
    int highBreakIdx = na
    int lowBreakIdx = na
    float lastHigh = na
    int lastHighTime = na
    int lastHighIdx = na
    float lastLow = na
    int lastLowTime = na
    int lastLowIdx = na
    [msHi, msHiT, msLo, msLoT] = KitSMC.market_structure_latest_hilo(msSource)
    lastHigh := msHi
    lastHighTime := msHiT
    lastLow := msLo
    lastLowTime := msLoT
    lastHighIdx := not na(msHiT) ? get_data_cached_bar_index_from_time(msHiT) : na
    lastLowIdx := not na(msLoT) ? get_data_cached_bar_index_from_time(msLoT) : na

    if highArmedNext and not na(lastHigh) and high > lastHigh
        highBroken := true
        highBreakIdx := bar_index
        highArmedNext := false
    if lowArmedNext and not na(lastLow) and low < lastLow
        lowBroken := true
        lowBreakIdx := bar_index
        lowArmedNext := false

    bool highRecent = not na(lastHighTime) and lastHighTime >= recentTsCut
    bool lowRecent = not na(lastLowTime) and lastLowTime >= recentTsCut
    evtCfgUp = KitUI.LineTextVisualCfg.new(lineStyle = cfg.zigzagStyle, lineWidth = math.max(cfg.zigzagWidth, 1), textSize = KitSMC.ms_get_tf_text_size(tfName, htf1Name, htf2Name), vPos = 0, yPadTicks = 0.0, xRatio = 0.5, xPadBars = 0, textAlign = text.align_center)
    evtCfgDn = KitUI.LineTextVisualCfg.new(lineStyle = cfg.zigzagStyle, lineWidth = math.max(cfg.zigzagWidth, 1), textSize = KitSMC.ms_get_tf_text_size(tfName, htf1Name, htf2Name), vPos = -1, yPadTicks = 6.0, xRatio = 0.5, xPadBars = 0, textAlign = text.align_center)

    if msShowBosMss and highBroken and highRecent and is_in_working_zone_current()
        if KitSMC.ms_should_emit_structure_event(tfName, 1, lastHighTime, msEmitTf, msEmitSide, msEmitPivotTime)
            bool isMssUp = prevBreakoutNext != 0 and prevBreakoutNext != 1
            string eventTxt = (tfName == timeframe.period ? str.lower(isMssUp ? "MSS" : "BOS") : (isMssUp ? "MSS" : "BOS")) + " " + CONST.SYM_ARR2_UP
            int x1 = na(lastHighIdx) ? bar_index : lastHighIdx
            int x2 = na(highBreakIdx) ? bar_index : highBreakIdx
            line upEvtLine = na
            label upEvtLabel = na
            if STRATEGY_ENABLE_VISUALS
                [upEvtLine, upEvtLabel] = KitUI.draw_line_with_text(x1, lastHigh, x2, lastHigh, xloc.bar_index, color.new(cfg.zigzagColor, 55), eventTxt, true, color.new(cfg.zigzagColor, 0), "", evtCfgUp, UI_THEME)
            process_data_register_ms_track(tfName, upEvtLine, upEvtLabel, lastHigh, 1)
            float msBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
            string evtType = isMssUp ? "MSS" : "BOS"
            string modelKeyUp = isMssUp ? "MSS" : "BOS"
            [enabledUp, scoreUp, shortUp, typeUp, whenUp] = get_data_strategy_meta_by_key(modelKeyUp)
            if canEmitSignals and enabledUp
                if typeUp == TRIGGER_TYPE_TRADE and whenUp == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(shortUp, "Buy", evtType + " up break", lastHigh + msBand, lastHigh - msBand, 100.0, scoreUp)
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, shortUp, "Buy", evtType + " up break", lastHigh + msBand, lastHigh - msBand, 100.0, scoreUp, bar_index, syminfo.mintick, 80)
            if canEmitSignals and PSEUDO_SWEEP_FROM_BOS and not isMssUp
                array.set(pseudoBosBreakLvl, 0, lastHigh)
                array.set(pseudoBosBreakBar, 0, bar_index)
            prevBreakoutNext := 1
            msBiasNext := 1
            tfData.mss.legEventTime := lastHighTime

    if msShowBosMss and lowBroken and lowRecent and is_in_working_zone_current()
        if KitSMC.ms_should_emit_structure_event(tfName, -1, lastLowTime, msEmitTf, msEmitSide, msEmitPivotTime)
            bool isMssDn = prevBreakoutNext != 0 and prevBreakoutNext != -1
            string eventTxt = (tfName == timeframe.period ? str.lower(isMssDn ? "MSS" : "BOS") : (isMssDn ? "MSS" : "BOS")) + " " + CONST.SYM_ARR2_DN
            int x1 = na(lastLowIdx) ? bar_index : lastLowIdx
            int x2 = na(lowBreakIdx) ? bar_index : lowBreakIdx
            line dnEvtLine = na
            label dnEvtLabel = na
            if STRATEGY_ENABLE_VISUALS
                [dnEvtLine, dnEvtLabel] = KitUI.draw_line_with_text(x1, lastLow, x2, lastLow, xloc.bar_index, color.new(cfg.zigzagColor, 55), eventTxt, true, color.new(cfg.zigzagColor, 0), "", evtCfgDn, UI_THEME)
            process_data_register_ms_track(tfName, dnEvtLine, dnEvtLabel, lastLow, -1)
            float msBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
            string evtType = isMssDn ? "MSS" : "BOS"
            string modelKeyDn = isMssDn ? "MSS" : "BOS"
            [enabledDn, scoreDn, shortDn, typeDn, whenDn] = get_data_strategy_meta_by_key(modelKeyDn)
            if canEmitSignals and enabledDn
                if typeDn == TRIGGER_TYPE_TRADE and whenDn == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(shortDn, "Sell", evtType + " down break", lastLow + msBand, lastLow - msBand, 100.0, scoreDn)
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, shortDn, "Sell", evtType + " down break", lastLow + msBand, lastLow - msBand, 100.0, scoreDn, bar_index, syminfo.mintick, 80)
            if canEmitSignals and PSEUDO_SWEEP_FROM_BOS and not isMssDn
                array.set(pseudoBosBreakLvl, 1, lastLow)
                array.set(pseudoBosBreakBar, 1, bar_index)
            prevBreakoutNext := -1
            msBiasNext := -1
            tfData.mss.legEventTime := lastLowTime

    tfData.mss.highArmed := highArmedNext
    tfData.mss.lowArmed := lowArmedNext
    tfData.mss.prevBreakout := prevBreakoutNext
    tfData.mss.msBias := msBiasNext

process_data_market_structure(string htf1NameRaw, string htf2NameRaw, int currPivotOffSafe, int structRecentTsCut, int structRecentIdxCut, float currSh, float currSl, float sh1Real, float sl1Real, int sh1RealT, int sl1RealT, int sh1RealIdx, int sl1RealIdx, float sh2Real, float sl2Real, int sh2RealT, int sl2RealT, int sh2RealIdx, int sl2RealIdx, bool canEmitSignals) =>
    msLtfCfg.showSwings := msShowLtf and msShowSwings
    msLtfCfg.showZigzag := msShowLtf and msShowZigzag
    msHtf1Cfg.showSwings := msShowTf1 and msShowSwings
    msHtf1Cfg.showZigzag := msShowTf1 and msShowZigzag
    msHtf2Cfg.showSwings := msShowTf2 and msShowSwings
    msHtf2Cfg.showZigzag := msShowTf2 and msShowZigzag

    string htf1Name = na(htf1NameRaw) ? "" : htf1NameRaw
    string htf2Name = na(htf2NameRaw) ? "" : htf2NameRaw
    KitSMC.process_tf_swing_markers(ltfData, msLtfCfg, true, timeframe.period, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentTsCut, "·")
    KitSMC.process_tf_swing_markers(htf1Data, msHtf1Cfg, not na(htf1NameRaw), htf1NameRaw, sh1Real, sh1RealT, sh1RealIdx, sl1Real, sl1RealT, sl1RealIdx, structRecentTsCut, CONST.SYM_DOT)
    KitSMC.process_tf_swing_markers(htf2Data, msHtf2Cfg, not na(htf2NameRaw), htf2NameRaw, sh2Real, sh2RealT, sh2RealIdx, sl2Real, sl2RealT, sl2RealIdx, structRecentTsCut, CONST.SYM_DOT)

    KitSMC.process_tf_zigzag_from_pivots(ltfData, msLtfCfg, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentIdxCut)
    KitSMC.process_tf_zigzag_from_pivots(htf1Data, msHtf1Cfg, not na(htf1NameRaw), sh1Real, sh1RealT, sh1RealIdx, sl1Real, sl1RealT, sl1RealIdx, structRecentIdxCut)
    KitSMC.process_tf_zigzag_from_pivots(htf2Data, msHtf2Cfg, not na(htf2NameRaw), sh2Real, sh2RealT, sh2RealIdx, sl2Real, sl2RealT, sl2RealIdx, structRecentIdxCut)

    process_data_structure_from_ledger(ltfData, msLtfCfg, timeframe.period, structRecentTsCut, htf1Name, htf2Name, canEmitSignals, ltfData.mss)
    if not na(htf1NameRaw)
        process_data_structure_from_ledger(htf1Data, msHtf1Cfg, htf1NameRaw, structRecentTsCut, htf1Name, htf2Name, canEmitSignals, htf1Data.mss)
    if not na(htf2NameRaw)
        process_data_structure_from_ledger(htf2Data, msHtf2Cfg, htf2NameRaw, structRecentTsCut, htf1Name, htf2Name, canEmitSignals, htf2Data.mss)
    bool(na)

get_data_label_size_for_source_tf(string sourceTf) =>
    [tf1, tf2] = KitCore.get_htf_pair()
    sourceTf == tf2 ? THEME.SIZE_SMALL : sourceTf == tf1 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL

[htf1, htf2] = KitCore.get_htf_pair()
process_data_chart_context() =>
    chartCfg.useBias := true
    chartCfg.allowLong := true
    chartCfg.allowShort := true
    ctxDataCfg.needBias := true
    ctxDataCfg.needMsTrendDirs := true
    ctxDataCfg.needPdPw := true
    ctxDataCfg.needPriceRange := true
    ctxDataCfg.needHtfCandles := false
    ctxDataCfg.needMsSwingArrays := true
    ctxDataCfg.initBiasFactorArrays := true
    ctxDataCfg.rangeLookbackBars := math.max(effectiveCurrLookbackBars, 50)
    smcCtx.ltfData := ltfData
    smcCtx.htf1Data := htf1Data
    smcCtx.htf2Data := htf2Data
    KitCore.ChartContext ctx = KitCore.get_data_context(ctxDataCfg, SETTINGS, BIAS_TOG, get_data_core_structure_snapshot(smcCtx))
    string h1Name = ctx.htf1Name
    string h2Name = ctx.htf2Name
    int h1Bias = KitCore.get_ctx_bias_for_tf(ctx, h1Name)
    int h2Bias = KitCore.get_ctx_bias_for_tf(ctx, h2Name)
    int h1Trend = KitCore.get_ctx_trend_for_tf(ctx, h1Name)
    int h2Trend = KitCore.get_ctx_trend_for_tf(ctx, h2Name)
    array.set(tradeBiasVals, 0, ctx.b0)
    array.set(tradeBiasVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.b0 : h1Bias)
    array.set(tradeBiasVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.b0 : h2Bias)
    array.set(tradeTrendVals, 0, ctx.dir0)
    array.set(tradeTrendVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.dir0 : h1Trend)
    array.set(tradeTrendVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.dir0 : h2Trend)
    [memScore, memDir, bullCount, bearCount] = KitSMC.compute_signal_memory_bias(smcCtx.signalHist, 20)
    ctx.signalMemoryScore := memScore
    ctx.signalMemoryDir := memDir
    ctx.signalBullCount := bullCount
    ctx.signalBearCount := bearCount
    int effBias = ctx.activeBias
    if memDir != 0
        if effBias == 0
            effBias := memDir
        else if effBias != memDir
            effBias := 0
    ctx.biasVal := effBias
    process_data_reset_runtime_context_if_new_bar()
    array.set(rtBiasBox, 0, ctx.biasVal)
    array.set(rtAllowBuyBox, 0, KitSMC.direction_allowed_raw("Buy", memDir) ? 1 : 0)
    array.set(rtAllowSellBox, 0, KitSMC.direction_allowed_raw("Sell", memDir) ? 1 : 0)
    ctx

// Keep TF swing ledgers updated in ICT (data-only; no structure drawing here),
// because SR/LIQ/IDM/Sweep pipelines still seed from TFData swings.
runtimeCtx := KitCore.update_runtime_context(runtimeCtx)
bool canEmitSignals = barstate.isconfirmed
bool calcOnClosedBar = barstate.ishistory or barstate.isconfirmed
if calcOnClosedBar
    int currPivotLen = PIVOT_LEN_BASE
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    [sh1Real, sh1RealT, sl1Real, sl1RealT] = get_data_real_htf_swings(htf1, currPivotLen)
    [sh2Real, sh2RealT, sl2Real, sl2RealT] = get_data_real_htf_swings(htf2, currPivotLen)
    int structRecentTsCut = KitCore.get_recent_time_cutoff(effectiveCurrLookbackBars)
    int structRecentIdxCut = get_working_first_bar()
    KitSMC.process_tf_armed_state(ltfData, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, SETTINGS.SWING_HISTORY_MAX)
    KitSMC.process_tf_armed_state(htf1Data, not na(htf1), sh1Real, int(sh1RealT), sl1Real, int(sl1RealT), SETTINGS.SWING_HISTORY_MAX)
    KitSMC.process_tf_armed_state(htf2Data, not na(htf2), sh2Real, int(sh2RealT), sl2Real, int(sl2RealT), SETTINGS.SWING_HISTORY_MAX)
    int sh1RealIdx = get_data_map_htf_swing_to_ltf_idx(true, sh1RealT, sh1Real)
    int sl1RealIdx = get_data_map_htf_swing_to_ltf_idx(false, sl1RealT, sl1Real)
    int sh2RealIdx = get_data_map_htf_swing_to_ltf_idx(true, sh2RealT, sh2Real)
    int sl2RealIdx = get_data_map_htf_swing_to_ltf_idx(false, sl2RealT, sl2Real)
    if na(htf1)
        KitSMC.market_structure_reset(htf1Data.mss)
    if na(htf2)
        KitSMC.market_structure_reset(htf2Data.mss)
    process_data_market_structure(htf1, htf2, currPivotOffSafe, structRecentTsCut, structRecentIdxCut, currSh, currSl, sh1Real, sl1Real, sh1RealT, sl1RealT, sh1RealIdx, sl1RealIdx, sh2Real, sl2Real, sh2RealT, sl2RealT, sh2RealIdx, sl2RealIdx, canEmitSignals)
    KitSMC.process_tf_ms_trend_light(ltfData, true, ltfData.mss)
    KitSMC.process_tf_ms_trend_light(htf1Data, not na(htf1), htf1Data.mss)
    KitSMC.process_tf_ms_trend_light(htf2Data, not na(htf2), htf2Data.mss)
    [h2LastHi, h2LastHiT, h2LastLo, h2LastLoT] = KitSMC.market_structure_latest_hilo(htf2Data.mss)
    int htf2SwingAnchorTs = KitCore.get_latest_time4(h2LastHiT, h2LastLoT, int(na), int(na))
    bool recalcByHtf2 = not na(htf2) and ta.change(time(htf2)) != 0
    bool shouldDynRecalc = SETTINGS.DYN_LOOKBACK_ENABLE and (barstate.isfirst or recalcByHtf2) // Controls how often dynamic lookback/candle widths update.
    if shouldDynRecalc
        int dynHtf1Candles = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf1) ? KitCore.get_candles_to_anchor(htf1, htf2SwingAnchorTs, SETTINGS.DYN_HTF1_CANDLES_MIN, SETTINGS.DYN_HTF1_CANDLES_MAX, SETTINGS.HTF_CANDLES_BASE) : SETTINGS.HTF_CANDLES_BASE
        int htf1SecForDyn = not na(htf1) ? math.max(KitUI.get_tf_seconds(htf1), 1) : na
        int htf2SecForDyn = not na(htf2) ? math.max(KitUI.get_tf_seconds(htf2), 1) : na
        float htf2PerHtf1Dyn = not na(htf1SecForDyn) and not na(htf2SecForDyn) and htf2SecForDyn > htf1SecForDyn ? float(htf2SecForDyn) / float(htf1SecForDyn) : na
        // Keep HTF1/HTF2 panels on equivalent time span:
        // pass-1: derive HTF2 from HTF1 / ratio
        int dynHtf2Candles = not na(htf2PerHtf1Dyn) ? int(math.round(float(dynHtf1Candles) / htf2PerHtf1Dyn)) : SETTINGS.DYN_HTF2_CANDLES_FALLBACK
        dynHtf2Candles := math.max(SETTINGS.DYN_HTF2_CANDLES_MIN, math.min(dynHtf2Candles, SETTINGS.DYN_HTF2_CANDLES_MAX))
        // pass-2: back-project HTF1 from HTF2 * ratio and keep the larger (stability against rounding loss)
        int dynHtf1FromHtf2 = not na(htf2PerHtf1Dyn) ? int(math.ceil(float(dynHtf2Candles) * htf2PerHtf1Dyn)) : dynHtf1Candles
        dynHtf1Candles := math.max(dynHtf1Candles, dynHtf1FromHtf2)
        dynHtf1Candles := math.max(SETTINGS.DYN_HTF1_CANDLES_MIN, math.min(dynHtf1Candles, SETTINGS.DYN_HTF1_CANDLES_MAX))
        int dynCurrLookbackBars = KitCore.get_curr_lookback_from_htf2(htf2, dynHtf2Candles, SETTINGS.DYN_CURR_LOOKBACK_MIN_BARS, SETTINGS.DYN_CURR_LOOKBACK_MAX_BARS)
        dynCachedCurrLookbackBars := dynCurrLookbackBars
    effectiveCurrLookbackBars := SETTINGS.DYN_LOOKBACK_ENABLE ? dynCachedCurrLookbackBars : LOOKBACK_BARS_WORK // Master working lookback for pruning + keylevel lifecycle.
    effectiveCurrLookbackBars := math.max(bar_index - get_working_first_bar() + 1, 1)
    perfLookbackBars := effectiveCurrLookbackBars
    htfProjectionSpanBars := effectiveCurrLookbackBars
    workingFirstBar := get_working_first_bar()
    workingFirstBarLine := process_data_update_working_bar_line(workingFirstBarLine, workingFirstBar)
    int ltfOffSafe = math.max(0, math.min(math.min(bar_index - workingFirstBar, bar_index), 10000))
    int ltfFirstTime = int(time[ltfOffSafe])
    int htf1FirstTime = not na(htf1) ? get_data_working_first_time_for_source_tf(htf1) : na
    int htf2FirstTime = not na(htf2) ? get_data_working_first_time_for_source_tf(htf2) : na
    if not na(htf1FirstTime) and htf1FirstTime > ltfFirstTime
        htf1FirstTime := ltfFirstTime
    int htf2MaxTime = not na(htf1FirstTime) ? htf1FirstTime : ltfFirstTime
    if not na(htf2FirstTime) and htf2FirstTime > htf2MaxTime
        htf2FirstTime := htf2MaxTime
    process_data_prune_outside_working_zone_levels(smcCtx.zones)
    chartCtx := process_data_chart_context()

get_data_should_drop_level(KitSMC.PDArray z, int srcIdx) =>
    bar_index - srcIdx > effectiveCurrLookbackBars

get_data_first_fvg_between(int fromBar, int toBar, bool isBullFvg) =>
    process_data_reset_runtime_context_if_new_bar()
    string key = str.tostring(fromBar) + "|" + str.tostring(toBar) + "|" + (isBullFvg ? "1" : "0")
    int idx = na
    if array.size(rtFvgScanKeys) > 0
        for i = 0 to array.size(rtFvgScanKeys) - 1
            if array.get(rtFvgScanKeys, i) == key
                idx := i
                break
    if not na(idx)
        [array.get(rtFvgScanTopVals, idx), array.get(rtFvgScanBtmVals, idx), array.get(rtFvgScanBarVals, idx)]
    else
        float outTop = na
        float outBtm = na
        int outBar = na
        int maxScan = math.max(2, math.min(90, bar_index - 2))
        int bo = maxScan
        while bo >= 2
            int bIdx = bar_index - bo
            bool inRange = bIdx >= fromBar and bIdx <= toBar
            if inRange
                bool hasFvg = isBullFvg ? (low[bo] > high[bo + 2]) : (high[bo] < low[bo + 2])
                if hasFvg
                    outTop := isBullFvg ? low[bo] : low[bo + 2]
                    outBtm := isBullFvg ? high[bo + 2] : high[bo]
                    outBar := bIdx
                    break
            bo -= 1
        array.push(rtFvgScanKeys, key)
        array.push(rtFvgScanTopVals, outTop)
        array.push(rtFvgScanBtmVals, outBtm)
        array.push(rtFvgScanBarVals, outBar)
        [outTop, outBtm, outBar]

process_data_sweep_mss_fvg_model() =>
    [swEnabled, _, _, _, _] = get_data_strategy_meta_by_key("SWEEP")
    if not swEnabled
        bool(na)
    else
        int bearSweepBar = array.get(sweepMssBarState, 0)
        int bullSweepBar = array.get(sweepMssBarState, 1)
        int bearMssBar = array.get(sweepMssConfirmedState, 0)
        int bullMssBar = array.get(sweepMssConfirmedState, 1)
        float bearFvgTop = array.get(sweepMssFvgTopState, 0)
        float bullFvgTop = array.get(sweepMssFvgTopState, 1)
        float bearFvgBtm = array.get(sweepMssFvgBtmState, 0)
        float bullFvgBtm = array.get(sweepMssFvgBtmState, 1)

        int evN = array.size(smcCtx.events)
        if evN > 0
            for i = evN - 1 to 0
                KitSMC.Event e = array.get(smcCtx.events, i)
                if e.type == "SWEEP"
                    if e.direction == "Sell"
                        bearSweepBar := e.barDetected
                        bearMssBar := na
                        bearFvgTop := na
                        bearFvgBtm := na
                    else if e.direction == "Buy"
                        bullSweepBar := e.barDetected
                        bullMssBar := na
                        bullFvgTop := na
                        bullFvgBtm := na
                    array.remove(smcCtx.events, i)

        int chochBarsLimit = 50
        int fvgWaitMaxBars = 80
        int lastLtfLegBar = get_data_cached_bar_index_from_time(ltfData.mss.legEventTime)
        [swMsEnabled, swMsScore, swMsShort, swMsType, swMsWhen] = get_data_strategy_meta_by_key("SWEEP_MSS")
        [swFvgEnabled, swFvgScore, swFvgShort, swFvgType, swFvgWhen] = get_data_strategy_meta_by_key("SWEEP_FVG")

        bool bearSweepValid = not na(bearSweepBar) and (bar_index - bearSweepBar) <= chochBarsLimit
        bool bullSweepValid = not na(bullSweepBar) and (bar_index - bullSweepBar) <= chochBarsLimit

        if bearSweepValid and ltfData.mss.msBias == -1 and lastLtfLegBar > bearSweepBar and na(bearMssBar)
            bearMssBar := bar_index
            [ft, fb, _] = get_data_first_fvg_between(bearSweepBar, lastLtfLegBar, false)
            bearFvgTop := ft
            bearFvgBtm := fb
            if swMsEnabled and entry_direction_allowed("Sell", chartCtx.biasVal)
                float mssBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
                [ltfLastHiForBear, ltfLastHiTForBear, ltfLastLoForBear, ltfLastLoTForBear] = KitSMC.market_structure_latest_hilo(ltfData.mss)
                float mssLvl = not na(ltfLastLoForBear) ? ltfLastLoForBear : close
                if swMsType == TRIGGER_TYPE_TRADE and swMsWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swMsShort, "Sell", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore)
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, swMsShort, "Sell", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore, bar_index, syminfo.mintick, 80)

        if bullSweepValid and ltfData.mss.msBias == 1 and lastLtfLegBar > bullSweepBar and na(bullMssBar)
            bullMssBar := bar_index
            [ft, fb, _] = get_data_first_fvg_between(bullSweepBar, lastLtfLegBar, true)
            bullFvgTop := ft
            bullFvgBtm := fb
            if swMsEnabled and entry_direction_allowed("Buy", chartCtx.biasVal)
                float mssBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
                [ltfLastHiForBull, ltfLastHiTForBull, ltfLastLoForBull, ltfLastLoTForBull] = KitSMC.market_structure_latest_hilo(ltfData.mss)
                float mssLvl = not na(ltfLastHiForBull) ? ltfLastHiForBull : close
                if swMsType == TRIGGER_TYPE_TRADE and swMsWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swMsShort, "Buy", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore)
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, swMsShort, "Buy", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore, bar_index, syminfo.mintick, 80)

        bool bearMssActive = not na(bearMssBar) and (bar_index - bearMssBar) <= fvgWaitMaxBars
        bool bullMssActive = not na(bullMssBar) and (bar_index - bullMssBar) <= fvgWaitMaxBars

        if swFvgEnabled and bearMssActive
            if na(bearFvgTop) or na(bearFvgBtm)
                [ft, fb, _] = get_data_first_fvg_between(bearSweepBar, bar_index, false)
                bearFvgTop := ft
                bearFvgBtm := fb
            bool pullbackBear = close > open or high > high[1]
            bool touchedBearFvg = not na(bearFvgTop) and not na(bearFvgBtm) and pullbackBear and KitSMC.check_touch(bearFvgTop, bearFvgBtm, localCfg.detBasis, open, high, low, close)
            if touchedBearFvg and entry_direction_allowed("Sell", chartCtx.biasVal)
                if swFvgType == TRIGGER_TYPE_TRADE and swFvgWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swFvgShort, "Sell", "Sweep -> MSS -> first FVG touch", bearFvgTop, bearFvgBtm, 100.0, swFvgScore)
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, swFvgShort, "Sell", "Sweep -> MSS -> first FVG touch", bearFvgTop, bearFvgBtm, 100.0, swFvgScore, bar_index, syminfo.mintick, 80)
                bearSweepBar := na
                bearMssBar := na
                bearFvgTop := na
                bearFvgBtm := na
        else if not bearMssActive and not na(bearMssBar)
            bearSweepBar := na
            bearMssBar := na
            bearFvgTop := na
            bearFvgBtm := na

        if swFvgEnabled and bullMssActive
            if na(bullFvgTop) or na(bullFvgBtm)
                [ft, fb, _] = get_data_first_fvg_between(bullSweepBar, bar_index, true)
                bullFvgTop := ft
                bullFvgBtm := fb
            bool pullbackBull = close < open or low < low[1]
            bool touchedBullFvg = not na(bullFvgTop) and not na(bullFvgBtm) and pullbackBull and KitSMC.check_touch(bullFvgTop, bullFvgBtm, localCfg.detBasis, open, high, low, close)
            if touchedBullFvg and entry_direction_allowed("Buy", chartCtx.biasVal)
                if swFvgType == TRIGGER_TYPE_TRADE and swFvgWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swFvgShort, "Buy", "Sweep -> MSS -> first FVG touch", bullFvgTop, bullFvgBtm, 100.0, swFvgScore)
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, swFvgShort, "Buy", "Sweep -> MSS -> first FVG touch", bullFvgTop, bullFvgBtm, 100.0, swFvgScore, bar_index, syminfo.mintick, 80)
                bullSweepBar := na
                bullMssBar := na
                bullFvgTop := na
                bullFvgBtm := na
        else if not bullMssActive and not na(bullMssBar)
            bullSweepBar := na
            bullMssBar := na
            bullFvgTop := na
            bullFvgBtm := na

        array.set(sweepMssBarState, 0, bearSweepBar)
        array.set(sweepMssBarState, 1, bullSweepBar)
        array.set(sweepMssConfirmedState, 0, bearMssBar)
        array.set(sweepMssConfirmedState, 1, bullMssBar)
        array.set(sweepMssFvgTopState, 0, bearFvgTop)
        array.set(sweepMssFvgTopState, 1, bullFvgTop)
        array.set(sweepMssFvgBtmState, 0, bearFvgBtm)
        array.set(sweepMssFvgBtmState, 1, bullFvgBtm)
        bool(na)

process_data_pseudo_sweep_from_bos() =>
    if not PSEUDO_SWEEP_FROM_BOS
        bool(na)
    else
        float upLvl = array.get(pseudoBosBreakLvl, 0)
        float dnLvl = array.get(pseudoBosBreakLvl, 1)
        int upBar = array.get(pseudoBosBreakBar, 0)
        int dnBar = array.get(pseudoBosBreakBar, 1)

        bool upActive = not na(upLvl) and not na(upBar) and (bar_index - upBar) <= PSEUDO_SWEEP_RECLAIM_BARS
        bool dnActive = not na(dnLvl) and not na(dnBar) and (bar_index - dnBar) <= PSEUDO_SWEEP_RECLAIM_BARS

        if upActive
            // Bullish BOS failed quickly: close back below broken high => pseudo-sweep Sell.
            bool reclaimDown = close < upLvl and high >= upLvl
            if reclaimDown
                KitSMC.register_sweep_reclaim_event(smcCtx.events, "Sell", upLvl, bar_index, syminfo.mintick)
                if STRATEGY_ENABLE_VISUALS
                    label.new(bar_index, upLvl, "xxx", xloc = xloc.bar_index, style = label.style_none, textcolor = color.new(THEME.COLOR_NEUTRAL, 0), size = size.tiny)
                upLvl := na
                upBar := na
        else
            upLvl := na
            upBar := na

        if dnActive
            // Bearish BOS failed quickly: close back above broken low => pseudo-sweep Buy.
            bool reclaimUp = close > dnLvl and low <= dnLvl
            if reclaimUp
                KitSMC.register_sweep_reclaim_event(smcCtx.events, "Buy", dnLvl, bar_index, syminfo.mintick)
                if STRATEGY_ENABLE_VISUALS
                    label.new(bar_index, dnLvl, "xxx", xloc = xloc.bar_index, style = label.style_none, textcolor = color.new(THEME.COLOR_NEUTRAL, 0), size = size.tiny)
                dnLvl := na
                dnBar := na
        else
            dnLvl := na
            dnBar := na

        array.set(pseudoBosBreakLvl, 0, upLvl)
        array.set(pseudoBosBreakLvl, 1, dnLvl)
        array.set(pseudoBosBreakBar, 0, upBar)
        array.set(pseudoBosBreakBar, 1, dnBar)
        bool(na)

process_data_trades() =>
    if array.size(trades) > 0 and array.size(tradeOrderIds) == array.size(trades)
        for i = array.size(trades) - 1 to 0
            KitCore.Trade e = array.get(trades, i)
            string orderId = array.get(tradeOrderIds, i)
            if gateUseTradePlan and not get_data_is_trade_plan_valid(e.entry, e.stoploss, e.takeprofit)
                strategy.cancel(orderId)
                strategy.cancel(orderId + "_x")
                if STRATEGY_ENABLE_VISUALS
                    KitCore.delete_trade_visuals(e)
                array.remove(trades, i)
                array.remove(tradeOrderIds, i)
                continue
            [eResolved, outcome] = KitCore.resolve_trade_state(e, high, low, bar_index, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
            e := eResolved
            if outcome == 2 and gateUsePretouchCancel
                strategy.cancel(orderId)
                strategy.cancel(orderId + "_x")
                if STRATEGY_ENABLE_VISUALS
                    KitCore.delete_trade_visuals(e)
                array.remove(trades, i)
                array.remove(tradeOrderIds, i)
                continue
            if outcome == 1 or outcome == -1
                float exitPrice = outcome > 0 ? e.takeprofit : e.stoploss
                float denom = math.max(math.abs(e.entry - e.stoploss), syminfo.mintick)
                float realizedR = math.abs(exitPrice - e.entry) / denom
                float rrForStats = math.max(0.1, realizedR)
                e.rrValue := rrForStats
            string entryDisplayMode = (e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL) ? "RESULT_LINES" : "NORMAL"
            bool signalShowActive = e.state == CONST.SIGNAL_STATE_PENDING or e.state == CONST.SIGNAL_STATE_START or e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL
            if STRATEGY_ENABLE_VISUALS
                e := KitCore.draw_trade_visual(e, CONST, THEME, ENTRY_VIS_CFG, true, signalShowActive, true, true, perfLookbackBars, 10, entryDisplayMode, "RESULT_LINES", 0)
            array.set(trades, i, e)
        int j = array.size(trades) - 1
        while j >= 0
            KitCore.Trade t = array.get(trades, j)
            bool resolved = t.state == CONST.SIGNAL_STATE_TP or t.state == CONST.SIGNAL_STATE_SL
            bool staleResolved = resolved and not na(t.barClosed) and (bar_index - t.barClosed > perfLookbackBars)
            bool overCap = array.size(trades) > 160
            if staleResolved or overCap
                if t.state == CONST.SIGNAL_STATE_PENDING
                    string orderId = array.get(tradeOrderIds, j)
                    strategy.cancel(orderId)
                    strategy.cancel(orderId + "_x")
                if STRATEGY_ENABLE_VISUALS
                    KitCore.delete_trade_visuals(t)
                array.remove(trades, j)
                array.remove(tradeOrderIds, j)
            j -= 1
    bool(na)

process_data_events_queue(array<KitSMC.Event> events) =>
    if events.size() > 0
        for i = events.size() - 1 to 0
            KitSMC.Event e = events.get(i)
            bool isSweep = e.type == "SWEEP"
            bool isBos = e.type == "BOS"
            bool isMss = e.type == "MSS"
            if isSweep
                events.remove(i)
                continue
            string modelKey = isBos ? "BOS" : isMss ? "MSS" : str.upper(e.type)
            [enabledType, modelScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
            [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = get_entry_model_dynamic_cfg(modelKey)
            if not enabledType
                events.remove(i)
                continue
            bool validDirection = entry_direction_allowed(e.direction, chartCtx.biasVal)
            if triggerType == TRIGGER_TYPE_SIGNAL
                events.remove(i)
                continue
            bool useTouchEntry = triggerWhen == TRIGGER_WHEN_TOUCH or modelEntryMode == ENTRY_MODE_LIMIT or not gateUseRetestConfirm
            if useTouchEntry
                if validDirection
                    process_data_add_entry(shortName, e.direction, e.reason, e.zoneTop, e.zoneBtm, e.quality, math.max(e.score, modelScore))
                events.remove(i)
                continue
            bool confirm = e.direction == "Buy" ? close > e.zoneTop : close < e.zoneBtm
            bool invalid = e.direction == "Buy" ? close < e.zoneBtm : close > e.zoneTop
            if gateUseRetestInvalidation and invalid
                events.remove(i)
                continue
            bool passEntryMode = not gateUseEntryMode or modelEntryMode != ENTRY_MODE_OFF
            bool passConfirm = not gateUseRetestConfirm or confirm
            if passEntryMode and passConfirm and validDirection
                process_data_add_entry(shortName, e.direction, e.reason, e.zoneTop, e.zoneBtm, e.quality, math.max(e.score, modelScore))
                events.remove(i)
    bool(na)

process_data_entries(bool canEmitSignals) =>
    if canEmitSignals
        process_data_pseudo_sweep_from_bos()
        process_data_sweep_mss_fvg_model()
        process_data_events_queue(smcCtx.events)
    else
        if array.size(smcCtx.events) > 0
            array.clear(smcCtx.events)
    process_data_trades()
    bool(na)

draw_data_bias_row_under_trades_local(table t, int rowIdx, KitCore.ChartContext ctx, string sourceName) =>
    table.cell(t, 0, rowIdx, sourceName, bgcolor = color.new(THEME.COLOR_UI_BG, 55), text_color = color.white, text_size = size.tiny)
    string[] dashTfs = array.from(timeframe.period, ctx.htf1Name, ctx.htf2Name, KitCore.get_next_higher_tf(ctx.htf2Name))
    for i = 0 to 3
        string tfName = array.get(dashTfs, i)
        int col = i + 1
        if not na(tfName)
            int shortBias = KitCore.get_ctx_bias_for_tf(ctx, tfName)
            int trendVal = KitCore.get_ctx_trend_for_tf(ctx, tfName)
            color txt = shortBias == 1 ? THEME.COLOR_BULLISH : shortBias == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
            string tfLabel = KitUI.get_friendly_tf(tfName)
            string tx = (str.length(tfLabel) > 2 ? str.substring(tfLabel, 0, 2) : tfLabel) + " " + KitUI.get_bias_symbol(shortBias, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
            string state = trendVal == 0 or shortBias == 0 ? "Neutral" : trendVal == shortBias ? "Continuation" : "Pullback"
            table.cell(t, col, rowIdx, tx, bgcolor = KitUI.get_bias_bg_from_trend(trendVal, UI_THEME.COLOR_BULLISH, UI_THEME.COLOR_BEARISH, UI_THEME.COLOR_NEUTRAL), text_color = txt, text_size = size.tiny, tooltip = "Trend: " + str.tostring(trendVal) + " | BG:MSS Trend | Arrow:MSS TF Bias: " + str.tostring(shortBias) + " | State: " + state)
        else
            table.cell(t, col, rowIdx, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    bool(na)

draw_data_trades_dashboard() =>
    if STRATEGY_ENABLE_VISUALS
        var array<KitCore.Trade> dashboardTrades = array.new<KitCore.Trade>()
        KitCore.collect_dashboard_trades(trades, dashboardTrades, true, true, true, true, perfLookbackBars, CONST)
        int dashCount = array.size(dashboardTrades)
        int maxTypes = math.max(1, dashCount)
        if dashCount > 0
            KitCore.render_entries_dashboard_from_entries(true, signalStatsTableBottomCenter, dashboardTrades, maxTypes, THEME, CONST, SIG_METRIC_COUNT)
        else
            table.clear(signalStatsTableBottomCenter, 0, 0, 4, 23)
        draw_data_bias_row_under_trades_local(signalStatsTableBottomCenter, 0, chartCtx, "MSS")
    bool(na)

draw_data_sr_visual(KitSMC.PDArray z, int srRightIdx, int srLabelIdx, string tooltipText) =>
    KitSMC.PDArray out = z
    if STRATEGY_ENABLE_VISUALS
        bool isResNow = KitSMC.is_sr_res_now(z, close)
        bool isUntouched = nz(out.touchCount, 0) <= 0
        string txt = isUntouched ? "$" : (isResNow ? "R" : "S")
        color baseColor = KitCore.get_tf_line_color(out.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
        color txtColor = color.new(baseColor, 0)
        string labelSize = get_data_label_size_for_source_tf(out.labelText)
        SR_VIS_CFG.lineStyle := CFG_SR.lineStyle
        SR_VIS_CFG.lineWidth := CFG_SR.lineWidth
        SR_VIS_CFG.labelSize := labelSize
        SR_VIS_CFG.showLabel := CFG_SR.showLabel
        out := KitSMC.draw_price_zone(out, na(out.barEnd) ? bar_index : out.barEnd, srRightIdx, out.price, out.price, CFG_SR.lineColor, CFG_SR.lineColor, line.style_solid, txt, txtColor, tooltipText, srLabelIdx, out.price, ZONE_VIS_CFG, SR_VIS_CFG, false, true, out.price, CFG_SR.lineColor, "LINE", CFG_SR.showLabel)
        if not na(out.visualLine)
            string srStyle = KitCore.lifecycle_line_style(out.lifeState, CONST.LIFE_TOUCHED, CONST.LIFE_BROKEN, CONST.LIFE_RECLAIMED, line.style_dotted, line.style_dotted, line.style_dashed, line.style_dotted)
            int srAlpha = KitCore.lifecycle_alpha(out.lifeState, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED, CONST.LIFE_BROKEN, SETTINGS.SR_LINE_TRANSP, 72, 65, 55, 85)
            color srColor = color.new(baseColor, srAlpha)
            string srLineStyleSig = "SR_LINE|" + srStyle + "|" + str.tostring(srAlpha) + "|" + get_data_color_sig(baseColor)
            if out.visualLine.get_x2() != srRightIdx
                out.visualLine.set_x2(srRightIdx)
            if out.visLineStyleSig != srLineStyleSig
                out.visualLine.set_color(srColor)
                out.visualLine.set_style(srStyle)
                out.visLineStyleSig := srLineStyleSig
        if not na(out.visualLabel)
            string srLabelStyleSig = "SR_LABEL|" + labelSize + "|" + tooltipText
            if out.visualLabel.get_x() != srLabelIdx
                out.visualLabel.set_x(srLabelIdx)
            if out.visualLabel.get_y() != out.price
                out.visualLabel.set_y(out.price)
            if out.visLabelStyleSig != srLabelStyleSig
                out.visualLabel.set_size(labelSize)
                out.visualLabel.set_tooltip(tooltipText)
                out.visLabelStyleSig := srLabelStyleSig
    out

apply_removed_level_visuals(array<KitSMC.PDArray> removed) =>
    if STRATEGY_ENABLE_VISUALS and array.size(removed) > 0
        for i = 0 to array.size(removed) - 1
            KitSMC.PDArray zDel = array.get(removed, i)
            KitUI.delete_line_label(zDel.visualLine, zDel.visualLabel)
    bool(na)

// Shared lifecycle engine for horizontal PDArray families (LIQ/SR).
process_data_horizontal_levels(int kind, array<KitSMC.PDArray> levels, float areaTop, float areaBottom, float srBand, float atrVal) =>
    int srRightIdx = na
    int srLabelIdx = na
    if array.size(levels) > 0
        for i = array.size(levels) - 1 to 0 by 1
            z = array.get(levels, i)
            z := KitSMC.normalize_pricezone_state(z, SMC_CONST)
            // EQH/EQL is retired and merged into sweep behavior; remove any stale EQ levels.
            if z.type == "eqh" or z.type == "eql"
                KitSMC.PDArray droppedEq = KitSMC.delete_level_at(levels, i)
                KitUI.delete_line_label(droppedEq.visualLine, droppedEq.visualLabel)
                continue
            if not KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                continue
            if not na(z.visualBox)
                z.visualBox.delete()
                z.visualBox := na
            int srcIdx = na(z.barEnd) ? bar_index : z.barEnd
            if get_data_should_drop_level(z, srcIdx)
                KitSMC.PDArray dropped = KitSMC.delete_level_at(levels, i)
                KitUI.delete_line_label(dropped.visualLine, dropped.visualLabel)
                continue
            if kind == HL_KIND_LIQ
                bool isBearishLiq = z.isHigh
                bool liqPenetrated = KitSMC.check_break(isBearishLiq, z.price, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, atrVal, localCfg.detImpulseAtr, open, high, low, close, open[1], high[1], low[1], close[1])
                bool liqSwept = liqPenetrated
                bool isDollarLiq = z.labelText != timeframe.period
                if liqSwept and not get_data_is_liq_swept(z)
                    z.barEnd := bar_index
                    if isDollarLiq
                        KitUI.delete_line_label(z.visualLine, z.visualLabel)
                        z.visualLine := na
                        z.visualLabel := na
                    else
                        if not na(z.visualLine)
                            color liqMitigatedColor = color.new(KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 50)
                            z.visualLine.set_color(liqMitigatedColor)
                            z.visualLine.set_style(line.style_dotted)
                        if STRATEGY_ENABLE_VISUALS and na(z.visualLabel)
                            z.visualLabel := KitUI.draw_text_on_line(z.barStart, z.price, bar_index, z.price, xloc.bar_index, "xxx", color.new(KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 0), get_data_label_size_for_source_tf(z.labelText), 0, 0, 0.5, 0, "", text.align_center, UI_THEME)
                        else if STRATEGY_ENABLE_VISUALS
                            if z.visualLabel.get_text() != "xxx"
                                z.visualLabel.set_text("xxx")
                            if not na(z.visualLine)
                                int midX = int(math.round((z.visualLine.get_x1() + z.visualLine.get_x2()) * 0.5))
                                if z.visualLabel.get_x() != midX
                                    z.visualLabel.set_x(midX)
                            if z.visualLabel.get_y() != z.price
                                z.visualLabel.set_y(z.price)
                    
                    // Emit SWEEP Event for LSR Phase A tracking
                    KitSMC.register_sweep_reclaim_event(smcCtx.events, isBearishLiq ? "Sell" : "Buy", z.price, bar_index, syminfo.mintick)

                bool liqTouched = KitSMC.check_touch(z.price, z.price, localCfg.detBasis, open, high, low, close)
                bool liqReclaimed = isBearishLiq ? close < z.price : close > z.price
                bool liqCooldownOk = na(z.barEnd) or (bar_index - z.barEnd >= localCfg.limSrTouchCountCooldownBars)
                int liqState = KitCore.lifecycle_next_state(liqPenetrated and not liqReclaimed, liqTouched, false, liqSwept and liqReclaimed, liqCooldownOk, z.lifeState, CONST.LIFE_BROKEN, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED)
                [liqTouchCnt, _] = KitCore.lifecycle_next_counts(z.touchCount, z.rejectCount, liqTouched, false, liqCooldownOk)
                if liqTouched and liqCooldownOk
                    z.barEnd := bar_index
                z.touchCount := liqTouchCnt
                z.lifeState := liqState
                z.broken := KitCore.is_life_broken(liqState, CONST)
                if not na(z.visualLine)
                    int liqExt = KitCore.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
                    int liqRightIdx = KitSMC.get_sr_x(bar_index, liqExt, false)
                    string liqStyle = KitCore.lifecycle_line_style(liqState, CONST.LIFE_TOUCHED, CONST.LIFE_BROKEN, CONST.LIFE_RECLAIMED, line.style_solid, line.style_dotted, line.style_dashed, line.style_dotted)
                    int liqAlpha = KitCore.lifecycle_alpha(liqState, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED, CONST.LIFE_BROKEN, 35, 45, 45, 50, 65)
                    color liqBaseColor = KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
                    string liqLineStyleSig = "LIQ_LINE|" + liqStyle + "|" + str.tostring(liqAlpha) + "|" + get_data_color_sig(liqBaseColor)
                    if z.visLineStyleSig != liqLineStyleSig
                        z.visualLine.set_style(liqStyle)
                        z.visualLine.set_color(color.new(liqBaseColor, liqAlpha))
                        z.visLineStyleSig := liqLineStyleSig
                    if not get_data_is_liq_swept(z) and z.visualLine.get_x2() != liqRightIdx
                        z.visualLine.set_x2(liqRightIdx)
                if not na(z.visualLine)
                    string liqTxt = get_data_is_liq_swept(z) ? "xxx" : (z.labelText == timeframe.period ? "idm" : "$")
                    color tfTxtColor = color.new(KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 0)
                    string tfTxtSize = KitSMC.ms_get_tf_text_size(z.labelText, htf1, htf2)
                    string liqAlign = get_data_liq_label_align(liqTxt)
                    float nextY = get_data_liq_label_y(liqTxt, z.price)
                    int nextX = get_data_liq_label_x(z.visualLine, liqTxt)
                    float overlapTol = math.max(commonAtr * math.max(localCfg.liqOverlapTolAtrMult, 0.005), syminfo.mintick * 8.0)
                    bool hideByPriority = localCfg.liqHideOverlapByTf and liqTxt == "$" and get_data_liq_has_stronger_overlap(levels, i, z, overlapTol)
                    string liqLabelStyleSig = "LIQ_LABEL|" + liqTxt + "|" + get_data_color_sig(tfTxtColor) + "|" + tfTxtSize + "|" + liqAlign + "|" + localCfg.liqDollarXPos + "|" + localCfg.liqDollarYPos + "|" + str.tostring(localCfg.liqDollarYOffsetTicks) + "|" + str.tostring(localCfg.liqOverlapTolAtrMult) + "|" + localCfg.liqOverlapScope + "|" + str.tostring(hideByPriority)
                    if hideByPriority
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                            z.visualLabel := na
                            z.visLabelStyleSig := ""
                    else
                        if na(z.visualLabel)
                            z.visualLabel := KitUI.draw_text_on_line(z.visualLine.get_x1(), z.price, z.visualLine.get_x2(), z.price, xloc.bar_index, liqTxt, tfTxtColor, tfTxtSize, 0, 0.0, 0.5, 0, "", liqAlign, UI_THEME)
                        if z.visualLabel.get_text() != liqTxt
                            z.visualLabel.set_text(liqTxt)
                        if z.visualLabel.get_x() != nextX
                            z.visualLabel.set_x(nextX)
                        if z.visualLabel.get_y() != nextY
                            z.visualLabel.set_y(nextY)
                        if z.visLabelStyleSig != liqLabelStyleSig
                            z.visualLabel.set_textcolor(tfTxtColor)
                            z.visualLabel.set_size(tfTxtSize)
                            z.visualLabel.set_textalign(liqAlign)
                            z.visLabelStyleSig := liqLabelStyleSig
            else
                int srExt = KitCore.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
                srRightIdx := KitSMC.get_sr_x(bar_index, srExt, false)
                srLabelIdx := KitSMC.get_sr_x(bar_index, srExt, false)
                int rejectN = math.max(z.rejectCount, 0)
                z.top := z.price + srBand
                z.bottom := z.price - srBand
                bool bodyCross = KitSMC.is_body_cross_level(z.price, open, close)
                bool touchedBand = KitSMC.is_level_wick_touch(z.price, srBand, open, high, low, close, syminfo.mintick)
                bool cooldownOk = na(z.barEnd) or (bar_index - z.barEnd >= localCfg.limSrTouchCountCooldownBars)
                bool sideRespected = z.isHigh ? close < z.price : close > z.price
                int state = KitCore.lifecycle_next_state(bodyCross, touchedBand, sideRespected, sideRespected, cooldownOk, z.lifeState, CONST.LIFE_BROKEN, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED)
                [nextTouchCnt, nextRejectCnt] = KitCore.lifecycle_next_counts(z.touchCount, rejectN, touchedBand, sideRespected, cooldownOk)
                if touchedBand and cooldownOk
                    z.qualityPct := math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                    z.barEnd := bar_index
                z.touchCount := nextTouchCnt
                z.rejectCount := nextRejectCnt
                z.lifeState := state
                z.broken := KitCore.is_life_broken(state, CONST)
                string nextTip = KitSMC.get_data_sr_tooltip_text(nextRejectCnt, state, SMC_CONST)
                z := draw_data_sr_visual(z, srRightIdx, srLabelIdx, nextTip)
            array.set(levels, i, z)
    int kindCount = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            if KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                kindCount += 1
    if kind == HL_KIND_LIQ
        while kindCount > 14
            int dropIdx = na
            for i = 0 to array.size(levels) - 1
                z = array.get(levels, i)
                if KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                    dropIdx := i
                    break
            if na(dropIdx)
                break
            KitSMC.PDArray dropped = KitSMC.delete_level_at(levels, dropIdx)
            KitUI.delete_line_label(dropped.visualLine, dropped.visualLabel)
            kindCount -= 1
    else
        bool(na)
    bool(na)

get_data_level_latest_swing_high() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = KitSMC.market_structure_latest_hilo(ltfData.mss)
    latestHigh

get_data_level_latest_swing_low() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = KitSMC.market_structure_latest_hilo(ltfData.mss)
    latestLow

get_data_level_rank_score(KitSMC.PDArray z, float lastSwingHigh, float lastSwingLow) =>
    float p = z.price
    float tick = math.max(syminfo.mintick, 1e-10)
    float distTicks = math.abs(p - close) / tick
    float score = -distTicks
    if p > close and not na(lastSwingHigh)
        float swingTicks = math.abs(p - lastSwingHigh) / tick
        score += 1000.0 / (1.0 + swingTicks)
    if p < close and not na(lastSwingLow)
        float swingTicks = math.abs(p - lastSwingLow) / tick
        score += 1000.0 / (1.0 + swingTicks)
    score += float(math.max(int(nz(z.extendBars, 0)), 0)) * 8.0
    score += nz(z.qualityPct, 0.0) * 0.05
    score

process_data_prune_levels_by_relevance(array<KitSMC.PDArray> levels) =>
    int n = array.size(levels)
    if n <= 4
        bool(na)
    else
        float lastSwingHigh = get_data_level_latest_swing_high()
        float lastSwingLow = get_data_level_latest_swing_low()
        array<bool> keep = array.new_bool(n, false)
        int side = 0
        while side < 2
            int picked = 0
            while picked < 2
                int bestIdx = na
                float bestScore = na
                int i = 0
                while i < n
                    bool already = array.get(keep, i)
                    if not already
                        KitSMC.PDArray z = array.get(levels, i)
                        bool kindOk = z.type == "LIQ" or z.type == "SR"
                        bool active = kindOk and not get_data_is_liq_swept(z)
                        bool sideOk = side == 0 ? (z.price >= close) : (z.price <= close)
                        if active and sideOk
                            float s = get_data_level_rank_score(z, lastSwingHigh, lastSwingLow)
                            if na(bestIdx) or s > bestScore
                                bestIdx := i
                                bestScore := s
                    i += 1
                if na(bestIdx)
                    break
                array.set(keep, bestIdx, true)
                picked += 1
            side += 1
        int j = n - 1
        while j >= 0
            KitSMC.PDArray z = array.get(levels, j)
            bool kindOk = z.type == "LIQ" or z.type == "SR"
            bool active = kindOk and not get_data_is_liq_swept(z)
            bool selected = array.get(keep, j)
            if active and not selected
                KitUI.delete_line_label(z.visualLine, z.visualLabel)
                array.remove(levels, j)
            j -= 1
        bool(na)

process_data_register_sr_seed(array<KitSMC.PDArray> levels, float price, int pivotIdx, int pivotTime, bool isRes, float tol, float srBand, string sourceTf, int sourcePrio, float areaTop, float areaBottom) =>
    float vTop = price + srBand
    float vBtm = price - srBand
    bool inArea = na(areaTop) or na(areaBottom) or (price <= areaTop and price >= areaBottom)
    if not inArea or not is_in_working_zone_idx_for_source_tf(pivotIdx, sourceTf)
        bool(na)
    else
        if sourcePrio == SR_SOURCE_PRIO_LTF and KitSMC.get_data_has_keylevel_overlap_in_levels(levels, vTop, vBtm)
            bool(na)
        else
            int matchIdx = na
            if array.size(levels) > 0
                for mi = 0 to array.size(levels) - 1
                    mz = array.get(levels, mi)
                    if mz.type == "SR" and math.abs(mz.price - price) <= tol
                        matchIdx := mi
                        break
            if not na(matchIdx)
                z = array.get(levels, matchIdx)
                bool sameSeed = z.barStart == pivotTime and z.isHigh == isRes
                if not sameSeed
                    float touches = math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                    z.price := ((z.price * (touches - 1.0)) + price) / touches
                    z.qualityPct := touches
                    z.barEnd := na(z.barEnd) ? pivotIdx : math.min(z.barEnd, pivotIdx)
                int prevPrio = int(math.max(nz(z.extendBars, 0), 0))
                if sourcePrio >= prevPrio
                    z.labelText := sourceTf
                    z.isHigh := isRes
                z.extendBars := math.max(prevPrio, sourcePrio)
                z.top := z.price + srBand
                z.bottom := z.price - srBand
                array.set(levels, matchIdx, z)
            else
                KitSMC.PDArray z = KitSMC.PDArray.new()
                z.type := "SR"
                z.price := price
                z.top := vTop
                z.bottom := vBtm
                z.barStart := pivotTime
                z.barEnd := pivotIdx
                z.qualityPct := 1.0
                z.isHigh := isRes
                z.labelText := sourceTf
                z.extendBars := sourcePrio
                z.lifeState := CONST.LIFE_FORMED
                z.touchCount := 0
                z.rejectCount := 0
                array.push(levels, z)
            bool(na)

process_data_register_liquidity_seed(array<KitSMC.PDArray> levels, float price, int pivotIdx, int pivotTime, bool isHigh, float tol, string sourceTf, int sourcePrio, float areaTop, float areaBottom) =>
    bool inArea = na(areaTop) or na(areaBottom) or (price <= areaTop and price >= areaBottom)
    if not inArea or not is_in_working_zone_idx_for_source_tf(pivotIdx, sourceTf)
        bool(na)
    else
        int matchIdx = na
        if array.size(levels) > 0
            for mi = 0 to array.size(levels) - 1
                mz = array.get(levels, mi)
                if mz.type == "LIQ" and math.abs(mz.price - price) <= tol
                    matchIdx := mi
                    break
        if not na(matchIdx)
            z = array.get(levels, matchIdx)
            bool sameSeed = z.barStart == pivotTime and z.isHigh == isHigh
            if not sameSeed
                float touches = math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                z.price := ((z.price * (touches - 1.0)) + price) / touches
                z.qualityPct := touches
            int prevPrio = int(math.max(nz(z.extendBars, 0), 0))
            if sourcePrio >= prevPrio
                z.isHigh := isHigh
                z.labelText := sourceTf
            z.extendBars := math.max(prevPrio, sourcePrio)
            z.top := z.price
            z.bottom := z.price
            int liqExt = KitCore.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
            int liqRightIdx = KitSMC.get_sr_x(bar_index, liqExt, false)
            if not get_data_is_liq_swept(z) and not na(z.visualLine) and z.visualLine.get_x2() != liqRightIdx
                z.visualLine.set_x2(liqRightIdx)
            array.set(levels, matchIdx, z)
        else
            KitSMC.PDArray z = KitSMC.PDArray.new()
            z.type := "LIQ"
            z.price := price
            z.top := price
            z.bottom := price
            z.barStart := pivotTime
            z.barEnd := pivotIdx
            z.isHigh := isHigh
            z.labelText := sourceTf
            z.extendBars := sourcePrio
            z.qualityPct := 1.0
            z.lifeState := CONST.LIFE_FORMED
            z.touchCount := 1
            z.rejectCount := 0
            color lvlColor = KitCore.get_tf_line_color(sourceTf, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
            bool isLtfSeed = sourceTf == timeframe.period
            string liqTxt = isLtfSeed ? "idm" : "$"
            string liqTip = KitUI.tt_side(not isHigh, isLtfSeed ? "Internal Dealing Range (IDM)" : "Liquidity")
            int liqExt = KitCore.get_tf_line_ext_bars(sourceTf, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
            int liqRightIdx = KitSMC.get_sr_x(bar_index, liqExt, false)
            if STRATEGY_ENABLE_VISUALS
                [liqLine, liqLabel] = KitUI.draw_line_with_text(pivotIdx, z.price, liqRightIdx, z.price, xloc.bar_index, color.new(lvlColor, 35), liqTxt, true, THEME.COLOR_NEUTRAL, liqTip, LIQ_LINE_VIS_CFG, UI_THEME)
                z.visualLine := liqLine
                z.visualLabel := liqLabel
            array.push(levels, z)
    bool(na)

process_data_seed_from_ms_swings(bool isSrSeed, array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, bool isHigh, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom) =>
    int seeded = 0
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded >= localCfg.limSrSeedSwingsPerTf
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            if s.isSwingHigh == isHigh
                float p = s.price
                int t = s.time
                int idx = get_data_cached_bar_index_from_time(t)
                if is_in_working_zone_idx_for_source_tf(idx, sourceTf)
                    if isSrSeed
                        process_data_register_sr_seed(levels, p, idx, t, isHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    else
                        process_data_register_liquidity_seed(levels, p, idx, t, isHigh, tol, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded += 1
    bool(na)

// Fallback side-balancer: guarantee at least one swing seed above/below current price per TF.
process_data_seed_min_side_from_ms_swings(bool isSrSeed, array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, bool wantAbove) =>
    int relaxedFirstIdx = get_data_relaxed_first_idx_for_source_tf(sourceTf)
    bool seeded = false
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            float p = s.price
            int t = s.time
            bool sideOk = not na(p) and (wantAbove ? p >= close : p <= close)
            if sideOk
                int idx = get_data_cached_bar_index_from_time(t)
                if not na(idx) and idx >= relaxedFirstIdx
                    if isSrSeed
                        process_data_register_sr_seed(levels, p, idx, t, s.isSwingHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    else
                        process_data_register_liquidity_seed(levels, p, idx, t, s.isSwingHigh, tol, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded := true
    bool(na)

process_data_seed_sr_from_ms_swings(array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, bool isHigh, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, float rangeTop, float rangeBottom, int div) =>
    int seeded = 0
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded >= localCfg.limSrSeedSwingsPerTf
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            if s.isSwingHigh == isHigh
                int t = s.time
                int idx = get_data_cached_bar_index_from_time(t)
                if is_in_working_zone_idx_for_source_tf(idx, sourceTf)
                    float p = KitSMC.snap_to_density_grid(s.price, rangeTop, rangeBottom, div)
                    process_data_register_sr_seed(levels, p, idx, t, isHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded += 1
    bool(na)

process_data_seed_min_side_sr_from_ms_swings(array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, bool wantAbove, float rangeTop, float rangeBottom, int div) =>
    int relaxedFirstIdx = get_data_relaxed_first_idx_for_source_tf(sourceTf)
    bool seeded = false
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            float snapped = KitSMC.snap_to_density_grid(s.price, rangeTop, rangeBottom, div)
            bool sideOk = not na(snapped) and (wantAbove ? snapped >= close : snapped <= close)
            if sideOk
                int idx = get_data_cached_bar_index_from_time(s.time)
                if not na(idx) and idx >= relaxedFirstIdx
                    process_data_register_sr_seed(levels, snapped, idx, s.time, s.isSwingHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded := true
    bool(na)

get_data_sr_price_snapped_to_ms_swing(float srPrice, float tol, bool isRes) =>
    float out = srPrice
    float bestD = na
    if not na(ltfData.mss.swings) and array.size(ltfData.mss.swings) > 0
        for i = 0 to array.size(ltfData.mss.swings) - 1
            KitSMC.Swing s = array.get(ltfData.mss.swings, i)
            if s.isSwingHigh == isRes
                float d = math.abs(s.price - srPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    if not na(htf1Data.mss.swings) and array.size(htf1Data.mss.swings) > 0
        for i = 0 to array.size(htf1Data.mss.swings) - 1
            KitSMC.Swing s = array.get(htf1Data.mss.swings, i)
            if s.isSwingHigh == isRes
                float d = math.abs(s.price - srPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    if not na(htf2Data.mss.swings) and array.size(htf2Data.mss.swings) > 0
        for i = 0 to array.size(htf2Data.mss.swings) - 1
            KitSMC.Swing s = array.get(htf2Data.mss.swings, i)
            if s.isSwingHigh == isRes
                float d = math.abs(s.price - srPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    out

get_data_should_seed_refresh(int intervalBars) =>
    [ltfHiP, ltfHi, ltfLoP, ltfLo] = KitSMC.market_structure_latest_hilo(ltfData.mss)
    [h1HiP, h1Hi, h1LoP, h1Lo] = KitSMC.market_structure_latest_hilo(htf1Data.mss)
    [h2HiP, h2Hi, h2LoP, h2Lo] = KitSMC.market_structure_latest_hilo(htf2Data.mss)
    bool changed = na(array.get(seedPulseState, 0)) or ltfHi != array.get(seedPulseState, 0) or ltfLo != array.get(seedPulseState, 1) or h1Hi != array.get(seedPulseState, 2) or h1Lo != array.get(seedPulseState, 3) or h2Hi != array.get(seedPulseState, 4) or h2Lo != array.get(seedPulseState, 5)
    if changed
        array.set(seedPulseState, 0, ltfHi)
        array.set(seedPulseState, 1, ltfLo)
        array.set(seedPulseState, 2, h1Hi)
        array.set(seedPulseState, 3, h1Lo)
        array.set(seedPulseState, 4, h2Hi)
        array.set(seedPulseState, 5, h2Lo)
    bool periodic = intervalBars > 0 and (bar_index % intervalBars == 0)
    barstate.isfirst or changed or periodic

// process_data_liquidity: updates liquidity seeds + lifecycle.
process_data_liquidity(bool doSeed) =>
    if liquidityBool
        float areaTop = na
        float areaBottom = na
        float liqTol = commonAtr * localCfg.limSrTolAtrMult
        if doSeed
            if not na(htf2)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf2Data.mss, true, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf2Data.mss, false, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom, true)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom, false)
            if not na(htf1)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf1Data.mss, true, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf1Data.mss, false, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom, true)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom, false)
        process_data_horizontal_levels(HL_KIND_LIQ, smcCtx.zones, areaTop, areaBottom, 0.0, 0.0)

// process_data_sr: updates SR seeds + lifecycle.
process_data_sr(bool doSeed) =>
    if showSR
        float areaTop = na
        float areaBottom = na
        float srTol = commonAtr * localCfg.limSrTolAtrMult
        float srBand = math.max(commonAtr * localCfg.limSrTouchBandAtrMult, syminfo.mintick * localCfg.limSrTouchBandMinTicks)
        float srMinDist = math.max(commonAtr * localCfg.limZoneMinHeightAtr * localCfg.limSrNearbyMergeMult, syminfo.mintick * 30.0)
        int srLookbackBars = math.max(5, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)
        if doSeed
            int div = 50
            float _maxRange = ta.highest(high, srLookbackBars)
            float _minRange = ta.lowest(low, srLookbackBars)
            process_data_seed_sr_from_ms_swings(smcCtx.zones, ltfData.mss, true, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
            process_data_seed_sr_from_ms_swings(smcCtx.zones, ltfData.mss, false, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
            process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, ltfData.mss, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, true, _maxRange, _minRange, div)
            process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, ltfData.mss, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, false, _maxRange, _minRange, div)
            if not na(htf2)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, true, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, false, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, true, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, false, _maxRange, _minRange, div)
            if not na(htf1)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, true, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, false, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, true, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, false, _maxRange, _minRange, div)
            
        apply_removed_level_visuals(KitSMC.prune_nearby_sr_levels(smcCtx.zones, srMinDist))
        // Bar-only mode: disable SR source/side caps.
        process_data_horizontal_levels(HL_KIND_SR, smcCtx.zones, areaTop, areaBottom, srBand, 0.0)
        if STRATEGY_ENABLE_VISUALS
            KitSMC.draw_sr_rank_labels(smcCtx.zones, close)

if calcOnClosedBar
    int seedRefreshBars = timeframe.isintraday ? 5 : 3
    bool doSeedRefresh = get_data_should_seed_refresh(seedRefreshBars)
    process_data_liquidity(doSeedRefresh)
    process_data_sr(doSeedRefresh)
    process_data_prune_levels_by_relevance(smcCtx.zones)
    process_data_entries(canEmitSignals)

if barstate.islast and STRATEGY_ENABLE_VISUALS
    [lnL50, lnL60, lnL70, lbL50] = SMC_draw_tf_last_leg_fibs(ltfData, timeframe.period, color.new(uiCfg.ltfColor, 0), fibLtf50, fibLtf60, fibLtf70, fibLtf50Label)
    fibLtf50 := lnL50
    fibLtf60 := lnL60
    fibLtf70 := lnL70
    fibLtf50Label := lbL50
    [lnH150, lnH160, lnH170, lbH150] = SMC_draw_tf_last_leg_fibs(htf1Data, htf1, color.new(htf1Cfg.zigzagColor, 0), fibHtf150, fibHtf160, fibHtf170, fibHtf150Label)
    fibHtf150 := lnH150
    fibHtf160 := lnH160
    fibHtf170 := lnH170
    fibHtf150Label := lbH150
    [lnH250, lnH260, lnH270, lbH250] = SMC_draw_tf_last_leg_fibs(htf2Data, htf2, color.new(htf2Cfg.zigzagColor, 0), fibHtf250, fibHtf260, fibHtf270, fibHtf250Label)
    fibHtf250 := lnH250
    fibHtf260 := lnH260
    fibHtf270 := lnH270
    fibHtf250Label := lbH250
    bool showPd = showPDH_PDL and timeframe.isintraday
    int klRight = bar_index + 28
    color klColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorText, 50)
    string klStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
    bool showKlLabels = THEME.SIZE_SMALL != "None"
    [nextPdhLine, nextPdlLine, nextPdhLabel, nextPdlLabel] = KitUI.draw_pd_pw(pdhLine, pdlLine, pdhLabel, pdlLabel, showPd, klRight, klColor, klStyle, showKlLabels, chartCtx.pdh, chartCtx.pdl, chartCtx.pdTime, UI_THEME)
    pdhLine := nextPdhLine
    pdlLine := nextPdlLine
    pdhLabel := nextPdhLabel
    pdlLabel := nextPdlLabel
    draw_data_trades_dashboard()
// Divergence scan moved to bias/signals module.


// Market structure (MTF BOS/MSS + swings) runs above using HTF pair (TF1/TF2).
