//@version=5
// @kit-version: 19
library("KitSMC", dynamic_requests = true)

// SMC domain: visual configuration for line-based level rendering.
export type ZoneDrawConfig
    color lineColor
    string lineStyle
    int lineWidth
    string labelSize
    bool showLabel

// Zone box+label visual configuration.
export type ZoneVisualCfg
    int minWidthBars = 1
    int borderWidth = 1
    string textSize = size.tiny
    color transparentColor = color.white
    string labelStyle = label.style_none
    string textHAlign = text.align_right
    string textVAlign = text.align_bottom

// PDArray line-render visual configuration.
export type PriceZoneLineVisualCfg
    string lineStyle = line.style_solid
    int lineWidth = 1
    string labelSize = size.tiny
    bool showLabel = true

// SMC domain: zone taxonomy + behavior config.
export type ZoneTypeConfig
    int id
    string type
    string shortName
    string name
    string description
    int sigScore
    float activeAreaScore
    int extendBarsCurr
    string borderStyle
    bool noBorder
    bool isDerived
    string spawnOnBreak

// SMC domain: quality filter/scoring config for OB/FVG/RJB/SD zones.
export type ZoneQualityCfg
    float minHeightAtr = 0.1
    bool useVolume = true
    float minRelVolume = 1.1
    bool useImpulse = false
    float minBodyAtr = 0.35
    float sizeStrongMult = 1.8
    float volStrong = 1.5
    float impStrong = 1.0
    float dispMin = 0.65
    int volLen = 20
    int scoreSizeStrong = 2
    int scoreSizeBase = 1
    int scoreVolStrong = 2
    int scoreVolBase = 1
    int scoreImpStrong = 2
    int scoreImpBase = 1
    int scoreDisp = 1

export type Const
    string OB_CLASS_ORIGIN = "O"
    string OB_CLASS_DECISIONAL = "D"
    string OB_CLASS_EXTREME = "X"
    string OB_CLASS_MITIGATION = "M"
    int LIFE_FORMED = 0
    int LIFE_TOUCHED = 1
    int LIFE_RESPECTED = 2
    int LIFE_RECLAIMED = 3
    int LIFE_BROKEN = 4
    int LIFE_INVALID = 5
    int LIFE_RESOLVED = 6

CONST = Const.new()

// Generic swing point payload.
export type Swing
    int id = 0
    string tfName = ""
    int tfIndex = 0
    int currentBarIndex = na
    float price
    int time
    int barIndex
    string tf
    bool isSwingHigh
    line swingLine = na
    bool mitigated = false

// High/low swing pair used by market-structure traversal.
export type SwingLeg
    int id = 0
    string tfName = ""
    int tfIndex = 0
    int highSwingId = na
    int lowSwingId = na
    int startBarIndex = na
    int endBarIndex = na
    int startTime = na
    int endTime = na
    float highPrice = na
    float lowPrice = na
    int dir = 0
    bool active = true
    string breakType = ""
    int breakTime = na
    float quality = na

// Full market-structure runtime state for one timeframe.
export type MSSContext
    string tfName = ""
    int tfIndex = 0
    array<Swing> swings = na
    array<SwingLeg> legs = na
    int activeLegId = na
    int lastBosLegId = na
    int lastMssLegId = na
    int nextSwingId = 1
    int nextLegId = 1
    bool highArmed = false
    bool lowArmed = false
    int prevBreakout = 0
    int msBias = 0
    int lastHighSeenTime = na
    int lastLowSeenTime = na
    label lastHighMarker = na
    label lastLowMarker = na
    float zzLastPrice = na
    int zzLastIndex = na
    bool zzLastIsHigh = false
    line zzLiveLine = na
    label zzLiveLabel = na
    float candHighPrice = na
    int candHighTime = na
    int candHighIndex = na
    float candLowPrice = na
    int candLowTime = na
    int candLowIndex = na
    int zzLastTime = na
    int legId = 0
    int legDir = 0
    int legEventTime = na
    int legLastEventSeen = na
    int legSeqAll = 0
    int legSeqOb = 0
    int legSeqFvg = 0
    int legSeqRjb = 0
    int legSeqSd = 0
    int legSeqLevel = 0

// Per-timeframe wrapper for MSS ownership.
export type TFData
    string tf
    MSSContext mss

// Per-timeframe visual config for structure rendering.
export type TFConfig
    string id
    bool showSwings
    bool showZigzag
    color swingHighColor
    color swingLowColor
    string swingSize
    color zigzagColor
    string zigzagStyle
    int zigzagWidth
    int swingYShiftTicks

// Minimal swing reference payload for zone lookup helpers.
export type SwingRef
    int barIndex
    float price
    bool isHigh

export type DensitySeed
    float lPrice
    bool isRes
    string tfLbl

get_tf_seconds(string tf_period) =>
    tf_period == "1" ? 60 :
     tf_period == "5" ? 300 :
     tf_period == "15" ? 900 :
     tf_period == "60" ? 3600 :
     tf_period == "240" ? 14400 :
     tf_period == "1D" or tf_period == "D" ? 86400 :
     tf_period == "1W" or tf_period == "W" ? 604800 :
     tf_period == "1M" or tf_period == "M" ? 2592000 :
     (not na(str.tonumber(tf_period)) ? int(str.tonumber(tf_period)) * 60 : timeframe.in_seconds(timeframe.period))

get_friendly_tf(string simple_tf) =>
    simple_tf == "1" ? "1m" :
     simple_tf == "3" ? "3m" :
     simple_tf == "5" ? "5m" :
     simple_tf == "15" ? "15m" :
     simple_tf == "30" ? "30m" :
     simple_tf == "45" ? "45m" :
     simple_tf == "60" ? "1h" :
     simple_tf == "120" ? "2h" :
     simple_tf == "180" ? "3h" :
     simple_tf == "240" ? "4h" :
     simple_tf == "1D" or simple_tf == "D" ? "1D" :
     simple_tf == "1W" or simple_tf == "W" ? "1W" :
     simple_tf == "1M" or simple_tf == "M" ? "1M" :
     simple_tf

closest_bar_index_from_time(int t) =>
    int msPerBar = math.max(time - time[1], 1)
    int barsAgo = int(math.round((time - t) / msPerBar))
    int idx = bar_index - barsAgo
    idx >= 0 and idx <= bar_index + 500 ? idx : na

// Convert a lookback budget on current TF into a source-TF anchored time.
export get_working_first_time_for_tf(string currentTf, string targetTf, int lookbackBars) =>
    int currSec = math.max(get_tf_seconds(currentTf), 1)
    int tfSec = math.max(get_tf_seconds(targetTf), currSec)
    int tfBarsBack = int(math.round(float(lookbackBars) * float(tfSec) / float(currSec)))
    int safeOff = math.max(0, math.min(math.min(tfBarsBack, bar_index), 10000))
    int(time[safeOff])

draw_line_segment(int x1, float y1, int x2, float y2, string xLocation, color lnColor, string lnStyle, int lnWidth) =>
    line.new(x1, y1, x2, y2, xloc = xLocation, color = lnColor, style = lnStyle, width = lnWidth)

draw_dline(line ln, int x1, float y1, int x2, float y2, color lnColor, string lnStyle, int lnWidth) =>
    line out = ln
    int minSafeLeft = math.max(bar_index - 450, 0)
    int safeX1 = math.max(x1, minSafeLeft)
    int safeX2 = math.max(x2, minSafeLeft)
    if safeX2 < safeX1
        safeX2 := safeX1
    if na(out)
        out := line.new(safeX1, y1, safeX2, y2, xloc = xloc.bar_index, color = lnColor, style = lnStyle, width = lnWidth)
    else
        out.set_xy1(safeX1, y1)
        out.set_xy2(safeX2, y2)
        out.set_color(lnColor)
        out.set_style(lnStyle)
        out.set_width(lnWidth)
    out

delete_line_safe(line ln) =>
    if not na(ln)
        ln.delete()
    bool(na)

draw_line_label(label lb, int x, float y, string txt, color txtColor, string txtSize, string tipText) =>
    label out = lb
    if na(out)
        out := label.new(x, y, txt, xloc = xloc.bar_index, style = label.style_none, color = color.new(color.white, 100), textcolor = txtColor, size = txtSize, tooltip = tipText, textalign = text.align_left)
    else
        if out.get_x() != x
            out.set_x(x)
        if out.get_y() != y
            out.set_y(y)
        if out.get_text() != txt
            out.set_text(txt)
        out.set_textcolor(txtColor)
        out.set_size(txtSize)
        out.set_tooltip(tipText)
    out

// TFData constructor helper with MSSContext pre-wired.
export tf_data_new(string tfName, int tfIndex) =>
    TFData d = TFData.new()
    MSSContext mss0 = MSSContext.new()
    mss0.tfName := tfName
    mss0.tfIndex := tfIndex
    mss0.swings := array.new<Swing>()
    mss0.legs := array.new<SwingLeg>()
    d.tf := tfName
    d.mss := mss0
    d

// Returns [latestHighPrice, latestHighTime, latestLowPrice, latestLowTime] from MSSContext.
export market_structure_latest_hilo(MSSContext mss) =>
    float latestHigh = na
    int latestHighT = na
    float latestLow = na
    int latestLowT = na
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0 by 1
            Swing s = array.get(mss.swings, i)
            if s.isSwingHigh and na(latestHigh)
                latestHigh := s.price
                latestHighT := s.time
            if not s.isSwingHigh and na(latestLow)
                latestLow := s.price
                latestLowT := s.time
            if not na(latestHigh) and not na(latestLow)
                break
    [latestHigh, latestHighT, latestLow, latestLowT]

// Return earliest valid anchor time from the selected HTF structure pair.
export get_tf_struct_pair_start_time(int tfSlot, MSSContext htf1Mss, MSSContext htf2Mss) =>
    [h1Hi, h1HiT, h1Lo, h1LoT] = market_structure_latest_hilo(htf1Mss)
    [h2Hi, h2HiT, h2Lo, h2LoT] = market_structure_latest_hilo(htf2Mss)
    int h1Start = not na(h1HiT) and not na(h1LoT) ? math.min(h1HiT, h1LoT) : not na(h1HiT) ? h1HiT : h1LoT
    int h2Start = not na(h2HiT) and not na(h2LoT) ? math.min(h2HiT, h2LoT) : not na(h2HiT) ? h2HiT : h2LoT
    tfSlot == 0 ? h1Start : tfSlot == 1 ? h2Start : na

// Working-window start time for a source TF, tightened by structure anchor when available.
export get_working_first_time_for_source_tf(string currentTf, string sourceTf, string htf1Name, string htf2Name, int lookbackBars, MSSContext htf1Mss, MSSContext htf2Mss) =>
    if na(sourceTf) or sourceTf == "" or sourceTf == currentTf
        int safeOff = math.max(0, math.min(math.min(lookbackBars, bar_index), 10000))
        int(time[safeOff])
    else
        int tfSlot = sourceTf == htf1Name ? 0 : sourceTf == htf2Name ? 1 : 0
        int ratioTime = get_working_first_time_for_tf(currentTf, sourceTf, lookbackBars)
        int structTime = get_tf_struct_pair_start_time(tfSlot, htf1Mss, htf2Mss)
        na(structTime) ? ratioTime : math.max(ratioTime, structTime)

// Advances TF leg counters when a new structure event is seen.
export refresh_tf_leg_state(TFData tfData) =>
    if not na(tfData.mss.legEventTime) and tfData.mss.legEventTime != tfData.mss.legLastEventSeen
        tfData.mss.legId += 1
        tfData.mss.legDir := tfData.mss.prevBreakout
        tfData.mss.legSeqAll := 0
        tfData.mss.legSeqOb := 0
        tfData.mss.legSeqFvg := 0
        tfData.mss.legSeqRjb := 0
        tfData.mss.legSeqLevel := 0
        tfData.mss.legLastEventSeen := tfData.mss.legEventTime
    bool(na)

// Lightweight market-structure trend updater (data only, no visuals).
export process_tf_ms_trend_light(TFData tfData, bool enabled, MSSContext mss) =>
    if not enabled
        bool(na)
    else
        [lastHi, _, lastLo, _] = market_structure_latest_hilo(mss)
        bool breakUp = not na(lastHi) and close > lastHi
        bool breakDn = not na(lastLo) and close < lastLo
        int nextDir = mss.prevBreakout
        if breakUp and not breakDn
            nextDir := 1
        else if breakDn and not breakUp
            nextDir := -1
        if nextDir != mss.prevBreakout and nextDir != 0
            mss.prevBreakout := nextDir
            mss.msBias := nextDir
            mss.legEventTime := time
        else if mss.msBias == 0 and mss.prevBreakout != 0
            mss.msBias := mss.prevBreakout
        refresh_tf_leg_state(tfData)
        bool(na)

ms_draw_swing_marker(int xIdx, float yPrice, int xShiftBars, float yShiftPrice, color markerColor, string markerSize, string tooltipText, string symbolDot) =>
    label.new(xIdx + xShiftBars, yPrice - yShiftPrice, symbolDot, xloc = xloc.bar_index, style = label.style_none, color = color.new(color.white, 100), textcolor = markerColor, size = markerSize, tooltip = tooltipText)

ms_get_swing_class_and_index(array<float> swingPrices, bool isHigh) =>
    string outClass = isHigh ? "HH" : "HL"
    int outIdx = na
    int n = array.size(swingPrices)
    if n > 0
        float curr = array.get(swingPrices, n - 1)
        float prev = n > 1 ? array.get(swingPrices, n - 2) : na
        outClass := isHigh ? (na(prev) or curr >= prev ? "HH" : "LH") : (na(prev) or curr >= prev ? "HL" : "LL")
        int cnt = 0
        for i = 0 to n - 1
            float p = array.get(swingPrices, i)
            float pp = i > 0 ? array.get(swingPrices, i - 1) : na
            string cls = isHigh ? (na(pp) or p >= pp ? "HH" : "LH") : (na(pp) or p >= pp ? "HL" : "LL")
            if cls == outClass
                cnt += 1
        outIdx := cnt
    [outClass, outIdx]

ms_collect_swing_prices(MSSContext mss, bool wantHigh) =>
    array<float> out = array.new_float()
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = 0 to array.size(mss.swings) - 1
            Swing s = array.get(mss.swings, i)
            if s.isSwingHigh == wantHigh
                array.push(out, s.price)
    out

ms_get_range_extreme_from_index(int startIdx, bool findLow, int maxScanBars) =>
    bool ok = false
    int outIdx = na
    float outPrice = na
    int dist = bar_index - startIdx
    if dist >= 0
        int safeMax = math.max(maxScanBars, 1)
        int scan = math.min(dist, safeMax)
        int scanSafe = math.min(scan, 90)
        int safeStartIdx = math.max(startIdx, bar_index - scanSafe)
        int safeDist = bar_index - safeStartIdx
        float best = findLow ? 10e10 : -10e10
        for j = 0 to safeDist
            int idx = safeStartIdx + j
            int off = bar_index - idx
            float v = findLow ? low[off] : high[off]
            bool better = findLow ? (v <= best) : (v >= best)
            if better
                best := v
                outIdx := idx
                outPrice := v
                ok := true
    [ok, outIdx, outPrice]

draw_htf_swing_marker_if(bool showFlag, float swingPrice, int swingTime, int swingIdx, int recentTsCut, int lastSeenTime, label prevMarker, string swingTooltip, color clr, string markerSize, int yShiftTicks, string symbolDot) =>
    int nextSeen = lastSeenTime
    label nextMarker = prevMarker
    if showFlag and not na(swingPrice) and not na(swingTime) and not na(swingIdx) and swingTime >= recentTsCut and (na(lastSeenTime) or swingTime > lastSeenTime)
        nextMarker := ms_draw_swing_marker(swingIdx, swingPrice, 0, yShiftTicks, clr, markerSize, swingTooltip, symbolDot)
        nextSeen := swingTime
    [nextSeen, nextMarker]

update_zz_state(bool show, bool isHighPivot, float pivotPrice, int pivotTime, int pivotIdx, int recentIdxCut, int lastTime, int lastIdx, float lastPrice, bool lastIsHigh, color zzColor, string zzStyle, int zzWidth) =>
    int outTime = lastTime
    int outIdx = lastIdx
    float outPrice = lastPrice
    bool outIsHigh = lastIsHigh
    if show and not na(pivotPrice) and not na(pivotTime) and not na(pivotIdx) and pivotIdx >= recentIdxCut and (na(outTime) or pivotTime > outTime)
        if not na(outIdx) and outIdx >= recentIdxCut and outIsHigh != isHighPivot
            draw_line_segment(outIdx, outPrice, pivotIdx, pivotPrice, xloc.bar_index, zzColor, zzStyle, zzWidth)
        outTime := pivotTime
        outIdx := pivotIdx
        outPrice := pivotPrice
        outIsHigh := isHighPivot
    [outTime, outIdx, outPrice, outIsHigh]

export process_tf_swing_markers(TFData tfData, TFConfig cfg, bool enabled, string tf, float swingHigh, int swingHighT, int swingHighIdx, float swingLow, int swingLowT, int swingLowIdx, int recentTsCut, string symbolDot = "●") =>
    bool canDraw = cfg.showSwings and enabled
    if not canDraw
        if not na(tfData.mss.lastHighMarker)
            tfData.mss.lastHighMarker.delete()
            tfData.mss.lastHighMarker := na
        if not na(tfData.mss.lastLowMarker)
            tfData.mss.lastLowMarker.delete()
            tfData.mss.lastLowMarker := na
        tfData.mss.lastHighSeenTime := na
        tfData.mss.lastLowSeenTime := na
    else
        [_, lastHiT, _, lastLoT] = market_structure_latest_hilo(tfData.mss)
        bool acceptedHigh = not na(swingHigh) and not na(swingHighT) and not na(lastHiT) and swingHighT == lastHiT
        bool acceptedLow = not na(swingLow) and not na(swingLowT) and not na(lastLoT) and swingLowT == lastLoT
        array<float> hiPrices = ms_collect_swing_prices(tfData.mss, true)
        array<float> loPrices = ms_collect_swing_prices(tfData.mss, false)
        [highClass, highClassIdx] = ms_get_swing_class_and_index(hiPrices, true)
        [lowClass, lowClassIdx] = ms_get_swing_class_and_index(loPrices, false)
        string tfFriendly = get_friendly_tf(tf)
        string hiTooltip = tfFriendly + " " + highClass + " " + str.tostring(na(highClassIdx) ? 0 : highClassIdx) +
         "\nacc=" + (acceptedHigh ? "Y" : "N") +
         "\ninT=" + str.tostring(swingHighT) +
         "\nmsT=" + str.tostring(lastHiT) +
         "\ninIdx=" + str.tostring(swingHighIdx) +
         "\ncutT=" + str.tostring(recentTsCut)
        string loTooltip = tfFriendly + " " + lowClass + " " + str.tostring(na(lowClassIdx) ? 0 : lowClassIdx) +
         "\nacc=" + (acceptedLow ? "Y" : "N") +
         "\ninT=" + str.tostring(swingLowT) +
         "\nmsT=" + str.tostring(lastLoT) +
         "\ninIdx=" + str.tostring(swingLowIdx) +
         "\ncutT=" + str.tostring(recentTsCut)
        [nextHiSeen, nextHiMarker] = draw_htf_swing_marker_if(canDraw, acceptedHigh ? swingHigh : na, acceptedHigh ? swingHighT : na, acceptedHigh ? swingHighIdx : na, recentTsCut, tfData.mss.lastHighSeenTime, tfData.mss.lastHighMarker, hiTooltip, cfg.swingHighColor, cfg.swingSize, cfg.swingYShiftTicks, symbolDot)
        [nextLoSeen, nextLoMarker] = draw_htf_swing_marker_if(canDraw, acceptedLow ? swingLow : na, acceptedLow ? swingLowT : na, acceptedLow ? swingLowIdx : na, recentTsCut, tfData.mss.lastLowSeenTime, tfData.mss.lastLowMarker, loTooltip, cfg.swingLowColor, cfg.swingSize, cfg.swingYShiftTicks, symbolDot)
        tfData.mss.lastHighSeenTime := nextHiSeen
        tfData.mss.lastLowSeenTime := nextLoSeen
        tfData.mss.lastHighMarker := nextHiMarker
        tfData.mss.lastLowMarker := nextLoMarker
    bool(na)

export process_tf_zigzag_from_pivots(TFData tfData, TFConfig cfg, bool enabled, float swingHigh, int swingHighT, int swingHighIdx, float swingLow, int swingLowT, int swingLowIdx, int recentIdxCut) =>
    [_, lastHiT, _, lastLoT] = market_structure_latest_hilo(tfData.mss)
    bool acceptedHigh = not na(swingHigh) and not na(swingHighT) and not na(lastHiT) and swingHighT == lastHiT
    bool acceptedLow = not na(swingLow) and not na(swingLowT) and not na(lastLoT) and swingLowT == lastLoT
    [outTimeA, outIdxA, outPriceA, outIsHighA] = update_zz_state(cfg.showZigzag and enabled, true, acceptedHigh ? swingHigh : na, acceptedHigh ? swingHighT : na, acceptedHigh ? swingHighIdx : na, recentIdxCut, tfData.mss.zzLastTime, tfData.mss.zzLastIndex, tfData.mss.zzLastPrice, tfData.mss.zzLastIsHigh, cfg.zigzagColor, cfg.zigzagStyle, cfg.zigzagWidth)
    [outTimeB, outIdxB, outPriceB, outIsHighB] = update_zz_state(cfg.showZigzag and enabled, false, acceptedLow ? swingLow : na, acceptedLow ? swingLowT : na, acceptedLow ? swingLowIdx : na, recentIdxCut, outTimeA, outIdxA, outPriceA, outIsHighA, cfg.zigzagColor, cfg.zigzagStyle, cfg.zigzagWidth)
    tfData.mss.zzLastTime := outTimeB
    tfData.mss.zzLastIndex := outIdxB
    tfData.mss.zzLastPrice := outPriceB
    tfData.mss.zzLastIsHigh := outIsHighB
    bool(na)

export process_tf_live_tail(TFData tfData, TFConfig cfg, bool enabled, string tfName, int recentIdxCut, string symbolDot) =>
    if cfg.showZigzag and enabled and not na(tfData.mss.zzLastIndex) and tfData.mss.zzLastIndex >= recentIdxCut and not na(tfData.mss.zzLastPrice)
        bool wantLow = tfData.mss.zzLastIsHigh
        int liveScanStart = tfData.mss.zzLastIndex
        int liveScanBars = math.min(math.max(bar_index - tfData.mss.zzLastIndex, 1), 90)
        bool anchorFresh = (bar_index - tfData.mss.zzLastIndex) <= liveScanBars
        [liveOk, liveIdx, livePrice] = ms_get_range_extreme_from_index(liveScanStart, wantLow, liveScanBars)
        bool validStep = anchorFresh and liveOk and not na(liveIdx) and liveIdx > tfData.mss.zzLastIndex
        bool validDir = validStep and not na(livePrice) and (wantLow ? livePrice <= tfData.mss.zzLastPrice : livePrice >= tfData.mss.zzLastPrice)
        if validDir
            color liveColor = color.new(cfg.zigzagColor, 55)
            tfData.mss.zzLiveLine := draw_dline(tfData.mss.zzLiveLine, tfData.mss.zzLastIndex, tfData.mss.zzLastPrice, liveIdx, livePrice, liveColor, cfg.zigzagStyle, math.max(cfg.zigzagWidth, 1))
            if cfg.showSwings
                color markerColor = color.new(wantLow ? cfg.swingLowColor : cfg.swingHighColor, 35)
                string tt = "Live Swing " + tfName
                float markerY = livePrice - (syminfo.mintick * cfg.swingYShiftTicks)
                tfData.mss.zzLiveLabel := draw_line_label(tfData.mss.zzLiveLabel, liveIdx, markerY, symbolDot, markerColor, cfg.swingSize, tt)
            else
                if not na(tfData.mss.zzLiveLabel)
                    tfData.mss.zzLiveLabel.delete()
                    tfData.mss.zzLiveLabel := na
        else
            delete_line_safe(tfData.mss.zzLiveLine)
            tfData.mss.zzLiveLine := na
            if not na(tfData.mss.zzLiveLabel)
                tfData.mss.zzLiveLabel.delete()
                tfData.mss.zzLiveLabel := na
    else
        delete_line_safe(tfData.mss.zzLiveLine)
        tfData.mss.zzLiveLine := na
        if not na(tfData.mss.zzLiveLabel)
            tfData.mss.zzLiveLabel.delete()
            tfData.mss.zzLiveLabel := na
    bool(na)

// TF pipeline mutator: arm candidate swings from raw pivots.
export process_tf_armed_state(TFData tfData, bool enabled, float swingHigh, int swingHighT, float swingLow, int swingLowT, int maxHistory) =>
    if enabled
        if na(tfData.mss.swings)
            tfData.mss.swings := array.new<Swing>()
        if na(tfData.mss.legs)
            tfData.mss.legs := array.new<SwingLeg>()
        int hiIdx = not na(swingHighT) ? int(ta.valuewhen(time == swingHighT, bar_index, 0)) : na
        int loIdx = not na(swingLowT) ? int(ta.valuewhen(time == swingLowT, bar_index, 0)) : na
        bool nextHighArmed = tfData.mss.highArmed
        bool nextLowArmed = tfData.mss.lowArmed
        if not na(swingHigh) and not na(swingHighT)
            Swing sHi = Swing.new()
            sHi.id := tfData.mss.nextSwingId
            tfData.mss.nextSwingId += 1
            sHi.tfName := tfData.tf
            sHi.tfIndex := tfData.mss.tfIndex
            sHi.currentBarIndex := bar_index
            sHi.price := swingHigh
            sHi.time := swingHighT
            sHi.barIndex := hiIdx
            sHi.tf := tfData.tf
            sHi.isSwingHigh := true
            array.push(tfData.mss.swings, sHi)
            nextHighArmed := true
        if not na(swingLow) and not na(swingLowT)
            Swing sLo = Swing.new()
            sLo.id := tfData.mss.nextSwingId
            tfData.mss.nextSwingId += 1
            sLo.tfName := tfData.tf
            sLo.tfIndex := tfData.mss.tfIndex
            sLo.currentBarIndex := bar_index
            sLo.price := swingLow
            sLo.time := swingLowT
            sLo.barIndex := loIdx
            sLo.tf := tfData.tf
            sLo.isSwingHigh := false
            array.push(tfData.mss.swings, sLo)
            nextLowArmed := true
        while array.size(tfData.mss.swings) > maxHistory
            array.remove(tfData.mss.swings, 0)
        tfData.mss.highArmed := nextHighArmed
        tfData.mss.lowArmed := nextLowArmed
    bool(na)

// Market-structure scaffold: initialize swing/leg container for one TF.
export market_structure_new(string tfName, int tfIndex) =>
    MSSContext mss = MSSContext.new()
    mss.tfName := tfName
    mss.tfIndex := tfIndex
    mss.swings := array.new<Swing>()
    mss.legs := array.new<SwingLeg>()
    mss

// Market-structure scaffold: clear state but preserve TF identity.
export market_structure_reset(MSSContext mss) =>
    if na(mss.swings)
        mss.swings := array.new<Swing>()
    else
        array.clear(mss.swings)
    if na(mss.legs)
        mss.legs := array.new<SwingLeg>()
    else
        array.clear(mss.legs)
    mss.activeLegId := na
    mss.lastBosLegId := na
    mss.lastMssLegId := na
    mss.nextSwingId := 1
    mss.nextLegId := 1
    mss.highArmed := false
    mss.lowArmed := false
    mss.prevBreakout := 0
    mss.msBias := 0
    mss.lastHighSeenTime := na
    mss.lastLowSeenTime := na
    delete_line_safe(mss.zzLiveLine)
    mss.zzLiveLine := na
    if not na(mss.lastHighMarker)
        mss.lastHighMarker.delete()
    if not na(mss.lastLowMarker)
        mss.lastLowMarker.delete()
    if not na(mss.zzLiveLabel)
        mss.zzLiveLabel.delete()
    mss.lastHighMarker := na
    mss.lastLowMarker := na
    mss.zzLiveLabel := na
    mss.zzLastPrice := na
    mss.zzLastIndex := na
    mss.zzLastIsHigh := false
    mss.zzLastTime := na
    mss.candHighPrice := na
    mss.candHighTime := na
    mss.candHighIndex := na
    mss.candLowPrice := na
    mss.candLowTime := na
    mss.candLowIndex := na
    mss.legId := 0
    mss.legDir := 0
    mss.legEventTime := na
    mss.legLastEventSeen := na
    mss.legSeqAll := 0
    mss.legSeqOb := 0
    mss.legSeqFvg := 0
    mss.legSeqRjb := 0
    mss.legSeqSd := 0
    mss.legSeqLevel := 0
    bool(na)

// Swing constructor helper used by migration/adapters.
export swing_new(string tfName, int tfIndex, int currentBarIndex, float price, int swingTime, int swingBarIndex, bool isSwingHigh, line swingLine, bool mitigated, int id) =>
    Swing s = Swing.new()
    s.id := id
    s.tfName := tfName
    s.tfIndex := tfIndex
    s.currentBarIndex := currentBarIndex
    s.price := price
    s.time := swingTime
    s.barIndex := swingBarIndex
    s.tf := tfName
    s.isSwingHigh := isSwingHigh
    s.swingLine := swingLine
    s.mitigated := mitigated
    s

// Incremental write-path helper: record one swing point into MSSContext.
export market_structure_record_swing(MSSContext mss, string tfName, int tfIndex, int currentBarIndex, float price, int swingTime, int swingBarIndex, bool isSwingHigh, int maxHistory) =>
    bool changed = false
    if na(mss.swings)
        mss.swings := array.new<Swing>()
    if na(mss.legs)
        mss.legs := array.new<SwingLeg>()
    mss.tfName := tfName
    mss.tfIndex := tfIndex
    if na(price) or na(swingTime)
        false
    else
        int n = array.size(mss.swings)
        if n == 0
            Swing s0 = swing_new(tfName, tfIndex, currentBarIndex, price, swingTime, swingBarIndex, isSwingHigh, na, false, mss.nextSwingId)
            mss.nextSwingId += 1
            array.push(mss.swings, s0)
            changed := true
        else
            Swing last = array.get(mss.swings, n - 1)
            if isSwingHigh == last.isSwingHigh
                bool better = isSwingHigh ? price >= last.price : price <= last.price
                if better and swingTime >= last.time
                    last.price := price
                    last.time := swingTime
                    last.barIndex := swingBarIndex
                    last.currentBarIndex := currentBarIndex
                    array.set(mss.swings, n - 1, last)
                    changed := true
                    int legN = array.size(mss.legs)
                    if legN > 0
                        SwingLeg lastLeg = array.get(mss.legs, legN - 1)
                        if isSwingHigh
                            lastLeg.highPrice := price
                            lastLeg.highSwingId := last.id
                        else
                            lastLeg.lowPrice := price
                            lastLeg.lowSwingId := last.id
                        lastLeg.endTime := swingTime
                        lastLeg.endBarIndex := swingBarIndex
                        array.set(mss.legs, legN - 1, lastLeg)
            else
                Swing sn = swing_new(tfName, tfIndex, currentBarIndex, price, swingTime, swingBarIndex, isSwingHigh, na, false, mss.nextSwingId)
                mss.nextSwingId += 1
                array.push(mss.swings, sn)
                SwingLeg leg = SwingLeg.new()
                leg.id := mss.nextLegId
                mss.nextLegId += 1
                leg.tfName := tfName
                leg.tfIndex := tfIndex
                leg.startTime := last.time
                leg.endTime := sn.time
                leg.startBarIndex := last.barIndex
                leg.endBarIndex := sn.barIndex
                leg.highSwingId := last.isSwingHigh ? last.id : sn.id
                leg.lowSwingId := last.isSwingHigh ? sn.id : last.id
                leg.highPrice := last.isSwingHigh ? last.price : sn.price
                leg.lowPrice := last.isSwingHigh ? sn.price : last.price
                leg.dir := sn.isSwingHigh ? 1 : -1
                leg.active := true
                if array.size(mss.legs) > 0
                    SwingLeg prevLeg = array.get(mss.legs, array.size(mss.legs) - 1)
                    prevLeg.active := false
                    array.set(mss.legs, array.size(mss.legs) - 1, prevLeg)
                array.push(mss.legs, leg)
                mss.activeLegId := leg.id
                changed := true
        while array.size(mss.swings) > maxHistory
            array.remove(mss.swings, 0)
        while array.size(mss.legs) > maxHistory
            array.remove(mss.legs, 0)
        changed

// Snaps a reference price to the nearest swing price (same side) across LTF/HTF1/HTF2 MSS stores.
export get_price_snapped_to_ms_swings(float refPrice, float tol, bool isSwingHigh, MSSContext mssLtf, MSSContext mssHtf1, MSSContext mssHtf2) =>
    float out = refPrice
    float bestD = na
    if not na(mssLtf.swings) and array.size(mssLtf.swings) > 0
        for i = 0 to array.size(mssLtf.swings) - 1
            Swing s = array.get(mssLtf.swings, i)
            if s.isSwingHigh == isSwingHigh
                float d = math.abs(s.price - refPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    if not na(mssHtf1.swings) and array.size(mssHtf1.swings) > 0
        for i = 0 to array.size(mssHtf1.swings) - 1
            Swing s = array.get(mssHtf1.swings, i)
            if s.isSwingHigh == isSwingHigh
                float d = math.abs(s.price - refPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    if not na(mssHtf2.swings) and array.size(mssHtf2.swings) > 0
        for i = 0 to array.size(mssHtf2.swings) - 1
            Swing s = array.get(mssHtf2.swings, i)
            if s.isSwingHigh == isSwingHigh
                float d = math.abs(s.price - refPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    out

// Returns/updates swing references from source TF (high+low pivots merged by time).
export get_swingrefs_from_tf(string sourceTf, int maxCount) =>
    var string _srTf = ""
    var array<SwingRef> _srRefs = array.new<SwingRef>()
    var int _lastHighTs = na
    var int _lastLowTs = na
    string tf = sourceTf == "" ? timeframe.period : sourceTf
    int piv = 5
    int cap = math.max(maxCount, 1)
    if tf != _srTf
        _srTf := tf
        _lastHighTs := na
        _lastLowTs := na
        array.clear(_srRefs)

    float ph = request.security(syminfo.tickerid, tf, ta.pivothigh(high, piv, piv), gaps = barmerge.gaps_off)
    int phT = request.security(syminfo.tickerid, tf, not na(ta.pivothigh(high, piv, piv)) ? time[piv] : na, gaps = barmerge.gaps_off)
    float pl = request.security(syminfo.tickerid, tf, ta.pivotlow(low, piv, piv), gaps = barmerge.gaps_off)
    int plT = request.security(syminfo.tickerid, tf, not na(ta.pivotlow(low, piv, piv)) ? time[piv] : na, gaps = barmerge.gaps_off)

    if not na(ph) and not na(phT) and (na(_lastHighTs) or phT > _lastHighTs)
        int msPerBarH = math.max(time - time[1], 1)
        int barsAgoH = int(math.round((time - phT) / msPerBarH))
        int idxH = bar_index - barsAgoH
        idxH := idxH >= 0 and idxH <= bar_index + 500 ? idxH : na
        if not na(idxH)
            array.push(_srRefs, SwingRef.new(idxH, ph, true))
            _lastHighTs := phT
    if not na(pl) and not na(plT) and (na(_lastLowTs) or plT > _lastLowTs)
        int msPerBarL = math.max(time - time[1], 1)
        int barsAgoL = int(math.round((time - plT) / msPerBarL))
        int idxL = bar_index - barsAgoL
        idxL := idxL >= 0 and idxL <= bar_index + 500 ? idxL : na
        if not na(idxL)
            array.push(_srRefs, SwingRef.new(idxL, pl, false))
            _lastLowTs := plT

    while array.size(_srRefs) > cap
        array.shift(_srRefs)
    _srRefs

// Returns nearest swing top above currentPrice and nearest swing bottom below currentPrice from source TF.
export get_first_swingrefs_around_price(string sourceTf, int maxCount, float currentPrice) =>
    array<SwingRef> refs = get_swingrefs_from_tf(sourceTf, maxCount)
    SwingRef topRef = na
    SwingRef btmRef = na
    float topDist = na
    float btmDist = na
    if array.size(refs) > 0 and not na(currentPrice)
        for i = 0 to array.size(refs) - 1
            SwingRef s = array.get(refs, i)
            if s.isHigh and s.price > currentPrice
                float dTop = s.price - currentPrice
                if na(topDist) or dTop < topDist
                    topDist := dTop
                    topRef := s
            if (not s.isHigh) and s.price < currentPrice
                float dBtm = currentPrice - s.price
                if na(btmDist) or dBtm < btmDist
                    btmDist := dBtm
                    btmRef := s
    [topRef, btmRef]

// Builds density seeds from recent swing distributions.
export get_density_seeds(TFData tfData, float _maxRange, float _minRange, string sourceTf, int sourcePrio, int lookback, int div, int barIndex, float closeV) =>
    array<DensitySeed> out = array.new<DensitySeed>()
    int swCount = not na(tfData.mss.swings) ? array.size(tfData.mss.swings) : 0
    bool isHtf = sourcePrio > 0
    if swCount > 0 and div > 0
        float sR = (_maxRange - _minRange) / div
        if sR > 0
            array<float> rProf = array.new_float(div, 0.0)
            array<float> sProf = array.new_float(div, 0.0)
            int safeBarsBack = barIndex < lookback ? barIndex : lookback
            int cutoffTime = time[safeBarsBack]
            for i = 0 to swCount - 1
                Swing s = array.get(tfData.mss.swings, i)
                if s.time >= cutoffTime
                    float p = s.price
                    if s.isSwingHigh
                        int bin = math.max(0, math.min(int((_maxRange - p) / sR), div - 1))
                        array.set(rProf, bin, array.get(rProf, bin) + 1.0)
                    else
                        int bin = math.max(0, math.min(int((p - _minRange) / sR), div - 1))
                        array.set(sProf, bin, array.get(sProf, bin) + 1.0)
            float reqDensity = isHtf ? 2.0 : 3.0
            for b = 1 to div - 2
                float v = array.get(rProf, b)
                if v >= reqDensity and v > array.get(rProf, b - 1) and v >= array.get(rProf, b + 1)
                    float top = _maxRange - b * sR
                    float btm = _maxRange - (b + 1) * sR
                    float lPrice = math.avg(top, btm)
                    bool isRes = lPrice > closeV
                    array.push(out, DensitySeed.new(lPrice, isRes, sourceTf))
            for b = 1 to div - 2
                float v = array.get(sProf, b)
                if v >= reqDensity and v > array.get(sProf, b - 1) and v >= array.get(sProf, b + 1)
                    float btm = _minRange + b * sR
                    float top = _minRange + (b + 1) * sR
                    float lPrice = math.avg(top, btm)
                    bool isRes = lPrice > closeV
                    array.push(out, DensitySeed.new(lPrice, isRes, sourceTf))
    out

// Finds nearest swing target above and below reference price across LTF/HTF stores.
export get_nearest_swing_targets_from_tf_data(TFData ltfData, TFData htf1Data, TFData htf2Data, float refPrice) =>
    float above = na
    float below = na
    if not na(ltfData.mss.swings) and array.size(ltfData.mss.swings) > 0
        for i = 0 to array.size(ltfData.mss.swings) - 1
            Swing s = array.get(ltfData.mss.swings, i)
            float p = s.price
            if s.isSwingHigh and p > refPrice and (na(above) or p < above)
                above := p
            if (not s.isSwingHigh) and p < refPrice and (na(below) or p > below)
                below := p
    if not na(htf1Data.mss.swings) and array.size(htf1Data.mss.swings) > 0
        for i = 0 to array.size(htf1Data.mss.swings) - 1
            Swing s = array.get(htf1Data.mss.swings, i)
            float p = s.price
            if s.isSwingHigh and p > refPrice and (na(above) or p < above)
                above := p
            if (not s.isSwingHigh) and p < refPrice and (na(below) or p > below)
                below := p
    if not na(htf2Data.mss.swings) and array.size(htf2Data.mss.swings) > 0
        for i = 0 to array.size(htf2Data.mss.swings) - 1
            Swing s = array.get(htf2Data.mss.swings, i)
            float p = s.price
            if s.isSwingHigh and p > refPrice and (na(above) or p < above)
                above := p
            if (not s.isSwingHigh) and p < refPrice and (na(below) or p > below)
                below := p
    [above, below]

// Shared area-based price-zone object shape.
export type PDArray
    string type
    float top
    float bottom
    int barStart
    bool mitigated = false
    bool broken = false
    box visualBox = na
    label visualLabel = na
    line visualLine = na
    int barEnd = na
    float price = na
    bool isHigh = false
    bool isBullish = false
    string labelText = ""
    int extendBars = 0
    float qualityPct = na
    string sourceTf = ""
    int sourceTfRank = 0
    int legId = 0
    int legDir = 0
    int legSeqAll = 0
    int legSeqType = 0
    int lifeState = 0
    int touchCount = 0
    int rejectCount = 0
    bool createsFvg = false
    float extremeDist = na
    int originLevel = 0
    float volScore = na
    float relVolume = na
    float zoneHeightAtr = na
    float displacementAtr = na
    float displacementPct = na
    int createdBar = na
    string parentType = ""
    string visAreaGeomSig = ""
    string visAreaStyleSig = ""
    string visLineGeomSig = ""
    string visLineStyleSig = ""
    string visLabelGeomSig = ""
    string visLabelStyleSig = ""

// Shared setup signal object shape before an actual entry is created.
export type Event
    string type
    string direction
    float zoneTop
    float zoneBtm
    float zonePrice
    int barDetected
    int barBreak
    bool retestSeen
    string reason
    float quality
    int score

// Top-level SMC runtime owner for one indicator instance.
export type SMCContext
    array<Event> events = na
    array<Event> signalHist = na
    array<PDArray> zones = na
    TFData ltfData = na
    TFData htf1Data = na
    TFData htf2Data = na

// SMCContext constructor with shared event/zone stores and the 3 default TF ledgers.
export smc_context_new(string ltfName, string htf1Name, string htf2Name) =>
    SMCContext ctx = SMCContext.new()
    ctx.events := array.new<Event>()
    ctx.signalHist := array.new<Event>()
    ctx.zones := array.new<PDArray>()
    ctx.ltfData := tf_data_new(ltfName, 0)
    ctx.htf1Data := tf_data_new(htf1Name, 1)
    ctx.htf2Data := tf_data_new(htf2Name, 2)
    ctx

color_sig(color c) =>
    str.tostring(color.r(c)) + ":" + str.tostring(color.g(c)) + ":" + str.tostring(color.b(c)) + ":" + str.tostring(color.t(c))

// Human-readable lifecycle name.
export get_lifecycle_name(int state, int formed, int touched, int respected, int reclaimed) =>
    state == formed ? "FORMED" :
     state == touched ? "TOUCHED" :
     state == respected ? "RESPECTED" :
     state == reclaimed ? "RECLAIMED" :
     "BROKEN"

// Merge lifecycle states with BROKEN precedence.
export merge_lifecycle_state(int a, int b, int brokenState) =>
    a == brokenState or b == brokenState ? brokenState : math.max(a, b)

// Returns minimum right X for one zone after width clamping.
export get_pdarray_min_right_idx(PDArray z, int desiredRight, int minWidthBars) =>
    math.max(desiredRight, z.barStart + minWidthBars)

get_rel_volume(int off, int len) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    avgVol = ta.sma(volume, len)
    base = nz(avgVol[safeOff], volume[safeOff])
    base > 0 ? (volume[safeOff] / base) : 0.0

// Unified renderer for PDArray visuals (area box, line, or mixed).
export draw_price_zone(PDArray z, int leftIdx, int rightIdx, float top, float btm, color areaFillColor, color areaBorderColor, string areaBorderStyle, string labelText, color labelColor, string tooltipText, int labelX, float labelY, ZoneVisualCfg areaCfg, PriceZoneLineVisualCfg lineCfg, bool showArea = true, bool showLine = false, float linePrice = na, color lineColor = na, string labelMode = "AREA", bool showLabel = true) =>
    int rightClamped = math.max(rightIdx, leftIdx + math.max(areaCfg.minWidthBars, 1))
    float resolvedLinePrice = na(linePrice) ? (top + btm) / 2.0 : linePrice
    color resolvedLineColor = na(lineColor) ? areaBorderColor : lineColor
    string mode = str.upper(labelMode)
    bool wantAreaLabel = showLabel and mode == "AREA" and showArea
    bool wantLineLabel = showLabel and mode == "LINE" and showLine and lineCfg.showLabel
    bool wantAnyLabel = wantAreaLabel or wantLineLabel
    int resolvedLabelX = wantLineLabel ? rightClamped : labelX
    float resolvedLabelY = wantLineLabel ? resolvedLinePrice : labelY
    string resolvedLabelSize = wantLineLabel ? lineCfg.labelSize : areaCfg.textSize
    string resolvedLabelStyle = wantLineLabel ? label.style_none : areaCfg.labelStyle
    color resolvedLabelBg = wantLineLabel ? color.new(color.white, 100) : areaCfg.transparentColor
    string areaGeomSig = str.tostring(leftIdx) + "|" + str.tostring(rightClamped) + "|" + str.tostring(top, format.mintick) + "|" + str.tostring(btm, format.mintick)
    string areaStyleSig = color_sig(areaFillColor) + "|" + color_sig(areaBorderColor) + "|" + areaBorderStyle + "|" + str.tostring(areaCfg.borderWidth)
    string lineGeomSig = str.tostring(leftIdx) + "|" + str.tostring(rightClamped) + "|" + str.tostring(resolvedLinePrice, format.mintick)
    string lineStyleSig = color_sig(resolvedLineColor) + "|" + lineCfg.lineStyle + "|" + str.tostring(lineCfg.lineWidth)
    string labelGeomSig = str.tostring(resolvedLabelX) + "|" + str.tostring(resolvedLabelY, format.mintick)
    string labelStyleSig = labelText + "|" + color_sig(resolvedLabelBg) + "|" + color_sig(labelColor) + "|" + resolvedLabelStyle + "|" + resolvedLabelSize + "|" + tooltipText

    if showArea
        if na(z.visualBox)
            z.visualBox := box.new(left = leftIdx, top = top, right = rightClamped, bottom = btm, border_color = areaBorderColor, border_style = areaBorderStyle, border_width = areaCfg.borderWidth, bgcolor = areaFillColor, text = "", text_halign = areaCfg.textHAlign, text_valign = areaCfg.textVAlign, text_size = areaCfg.textSize, text_color = labelColor)
            z.visAreaGeomSig := areaGeomSig
            z.visAreaStyleSig := areaStyleSig
        else
            if z.visAreaGeomSig != areaGeomSig
                z.visualBox.set_lefttop(leftIdx, top)
                z.visualBox.set_rightbottom(rightClamped, btm)
                z.visAreaGeomSig := areaGeomSig
            if z.visAreaStyleSig != areaStyleSig
                z.visualBox.set_bgcolor(areaFillColor)
                z.visualBox.set_border_color(areaBorderColor)
                z.visualBox.set_border_style(areaBorderStyle)
                z.visualBox.set_border_width(areaCfg.borderWidth)
                z.visAreaStyleSig := areaStyleSig
    else if not na(z.visualBox)
        z.visualBox.delete()
        z.visualBox := na
        z.visAreaGeomSig := ""
        z.visAreaStyleSig := ""

    if showLine
        if na(z.visualLine)
            z.visualLine := line.new(leftIdx, resolvedLinePrice, rightClamped, resolvedLinePrice, xloc = xloc.bar_index, color = resolvedLineColor, style = lineCfg.lineStyle, width = lineCfg.lineWidth)
            z.visLineGeomSig := lineGeomSig
            z.visLineStyleSig := lineStyleSig
        else
            if z.visLineGeomSig != lineGeomSig
                z.visualLine.set_xy1(leftIdx, resolvedLinePrice)
                z.visualLine.set_xy2(rightClamped, resolvedLinePrice)
                z.visLineGeomSig := lineGeomSig
            if z.visLineStyleSig != lineStyleSig
                z.visualLine.set_color(resolvedLineColor)
                z.visualLine.set_style(lineCfg.lineStyle)
                z.visualLine.set_width(lineCfg.lineWidth)
                z.visLineStyleSig := lineStyleSig
        z.price := resolvedLinePrice
    else if not na(z.visualLine)
        z.visualLine.delete()
        z.visualLine := na
        z.visLineGeomSig := ""
        z.visLineStyleSig := ""

    if wantAnyLabel
        if na(z.visualLabel)
            z.visualLabel := label.new(resolvedLabelX, resolvedLabelY, text = labelText, xloc = xloc.bar_index, color = resolvedLabelBg, style = resolvedLabelStyle, textcolor = labelColor, size = resolvedLabelSize, tooltip = tooltipText)
            z.visLabelGeomSig := labelGeomSig
            z.visLabelStyleSig := labelStyleSig
        else
            if z.visLabelGeomSig != labelGeomSig
                z.visualLabel.set_xy(resolvedLabelX, resolvedLabelY)
                z.visLabelGeomSig := labelGeomSig
            if z.visLabelStyleSig != labelStyleSig
                z.visualLabel.set_text(labelText)
                z.visualLabel.set_color(resolvedLabelBg)
                z.visualLabel.set_textcolor(labelColor)
                z.visualLabel.set_style(resolvedLabelStyle)
                z.visualLabel.set_size(resolvedLabelSize)
                z.visualLabel.set_tooltip(tooltipText)
                z.visLabelStyleSig := labelStyleSig
    else if not na(z.visualLabel)
        z.visualLabel.delete()
        z.visualLabel := na
        z.visLabelGeomSig := ""
        z.visLabelStyleSig := ""
    z

// Deletes box/label/line drawings owned by one PDArray.
export delete_pd_array_drawings(PDArray z) =>
    if not na(z.visualBox)
        z.visualBox.delete()
    if not na(z.visualLabel)
        z.visualLabel.delete()
    if not na(z.visualLine)
        z.visualLine.delete()
    bool(na)

// Returns TF text-size by hierarchy (LTF < HTF1/HTF2).
export ms_get_tf_text_size(string tfName, string htf1Name, string htf2Name) =>
    tfName == htf2Name ? size.small : tfName == htf1Name ? size.small : size.tiny

// Deduplicates structure events by (tf, side, pivotTime).
// Mutates ledgers in-place and returns whether event should be emitted.
export ms_should_emit_structure_event(string tfName, int side, int pivotTime, array<string> emitTf, array<int> emitSide, array<int> emitPivotTime) =>
    bool out = true
    if na(pivotTime)
        out := false
    else
        int found = -1
        if array.size(emitTf) > 0
            for i = 0 to array.size(emitTf) - 1
                if array.get(emitTf, i) == tfName and array.get(emitSide, i) == side
                    found := i
                    break
        if found == -1
            array.push(emitTf, tfName)
            array.push(emitSide, side)
            array.push(emitPivotTime, pivotTime)
            out := true
        else
            int prev = array.get(emitPivotTime, found)
            out := prev != pivotTime
            if out
                array.set(emitPivotTime, found, pivotTime)
    out

// Encodes trigger type into a compact numeric signature bit.
export trigger_type_code(string v, string triggerSignal) =>
    v == triggerSignal ? 1 : 2

// Encodes trigger timing into a compact numeric signature bit.
export trigger_when_code(string v, string triggerTouch) =>
    v == triggerTouch ? 1 : 2

// Basic memory-direction allow check for Buy/Sell.
export direction_allowed_raw(string direction, int memDir) =>
    memDir == 0 or (direction == "Buy" and memDir == 1) or (direction == "Sell" and memDir == -1)

// Returns true when new zone formation is allowed on closed history only.
export zone_formation_allowed(int lockBars) =>
    barstate.isconfirmed and bar_index <= (last_bar_index - lockBars)

// Returns true when current candle structure forms a valid OB.
export smc_is_ob(bool isBull, int index, int lockBars) =>
    zone_formation_allowed(lockBars) and (isBull ? (close[index + 1] < open[index + 1] and close[index] > open[index] and close[index] > high[index + 1]) : (close[index + 1] > open[index + 1] and close[index] < open[index] and close[index] < low[index + 1]))

// Returns true when current candle structure forms a valid FVG.
export smc_is_fvg(bool isBull, int index, int lockBars) =>
    zone_formation_allowed(lockBars) and (isBull ? (low[index] > high[index + 2]) : (high[index] < low[index + 2]))

// Signal/display labels by SMC zone type.
export signal_reason_text(string type, bool isBullishZone) =>
    type == "OB" ? (isBullishZone ? "Bullish OB retest" : "Bearish OB retest") :
     type == "BB" ? (isBullishZone ? "Bullish BB retest" : "Bearish BB retest") :
     type == "FVG" ? (isBullishZone ? "Bullish FVG retest" : "Bearish FVG retest") :
     type == "IFVG" ? (isBullishZone ? "Bullish iFVG retest" : "Bearish iFVG retest") :
     type == "RJB" ? (isBullishZone ? "Bullish RJB retest" : "Bearish RJB retest") :
     (isBullishZone ? "Bullish zone retest" : "Bearish zone retest")

// OB classification helpers.
export ob_class_name(string cls, Const c) =>
    cls == c.OB_CLASS_ORIGIN ? c.OB_CLASS_ORIGIN :
     cls == c.OB_CLASS_DECISIONAL ? c.OB_CLASS_DECISIONAL :
     cls == c.OB_CLASS_EXTREME ? c.OB_CLASS_EXTREME :
     cls == c.OB_CLASS_MITIGATION ? c.OB_CLASS_MITIGATION : c.OB_CLASS_ORIGIN

export ob_label_text(string cls) =>
    cls == "D" ? "OB.d" :
     cls == "X" ? "OB.x" :
     cls == "M" ? "OB.m" : "OB.o"

export get_ob_class_from_label(string labelText, Const c) =>
    str.contains(labelText, ".d") ? c.OB_CLASS_DECISIONAL :
     str.contains(labelText, ".x") ? c.OB_CLASS_EXTREME :
     str.contains(labelText, ".m") ? c.OB_CLASS_MITIGATION :
     c.OB_CLASS_ORIGIN

export get_ob_border_style(string cls, string fallbackStyle, Const c) =>
    cls == c.OB_CLASS_ORIGIN or cls == c.OB_CLASS_EXTREME ? line.style_solid :
     cls == c.OB_CLASS_DECISIONAL or cls == c.OB_CLASS_MITIGATION ? line.style_dotted :
     fallbackStyle

export get_pdarray_border_style(string type, string labelText, string fallbackStyle, Const c) =>
    type == "OB" ? get_ob_border_style(ob_class_name(get_ob_class_from_label(labelText, c), c), fallbackStyle, c) :
     type == "IFVG" ? line.style_solid :
     fallbackStyle

export get_pdarray_cap_family(string type) =>
    type == "OB" or type == "BB" or type == "RJB" ? "OBF" :
     type == "FVG" or type == "IFVG" ? "FVGF" : type

export get_current_pdarray_extend(string type, int extFvgIfvg, int extObFamily) =>
    type == "FVG" or type == "IFVG" ? extFvgIfvg : extObFamily

export get_htf_pdarray_extend(int tfSlot, int extHtf1, int extHtf2) =>
    tfSlot == 0 ? extHtf1 : extHtf2

export is_signal_bias_valid(bool isBullishZone, int biasVal, bool useBiasFilter) =>
    not useBiasFilter or (isBullishZone ? biasVal >= 0 : biasVal <= 0)

export is_body_cross_level(float level, float openV, float closeV) =>
    (openV > level and closeV < level) or (openV < level and closeV > level)

export is_level_wick_touch(float level, float band, float openV, float highV, float lowV, float closeV, float mintick) =>
    float tol = math.max(band, mintick * 0.5)
    bool nearWick = (highV >= level - tol and lowV <= level + tol)
    bool bodyCross = is_body_cross_level(level, openV, closeV)
    nearWick and not bodyCross


// Returns true when two PDArray price ranges overlap.
export pd_arrays_overlap(float topA, float btmA, float topB, float btmB) =>
    math.min(topA, topB) >= math.max(btmA, btmB)

export has_nearby_pd_array(array<PDArray> pdArrays, array<string> types, bool isBull, float top, float btm, int startIdx, int maxBarsApart) =>
    bool found = false
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            z = array.get(pdArrays, i)
            bool isTarget = array.includes(types, z.type) and z.isBullish == isBull
            if isTarget and not z.broken
                bool nearBar = math.abs(startIdx - z.barStart) <= maxBarsApart
                bool overlap = pd_arrays_overlap(top, btm, z.top, z.bottom)
                if nearBar or overlap
                    found := true
                    break
    found

export has_active_pd_array_same_side(array<PDArray> pdArrays, array<string> types, bool isBull) =>
    bool found = false
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            z = array.get(pdArrays, i)
            if array.includes(types, z.type) and z.isBullish == isBull and not z.broken
                found := true
                break
    found

export is_extreme_pd_array_candidate(array<PDArray> pdArrays, array<string> types, bool isBull, float top, float btm) =>
    bool extreme = true
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            z = array.get(pdArrays, i)
            if array.includes(types, z.type) and z.isBullish == isBull and not z.broken
                if isBull and btm > z.bottom
                    extreme := false
                    break
                if not isBull and top < z.top
                    extreme := false
                    break
    extreme

export can_merge_ob_sd(string existingType, string incomingType) =>
    (existingType == "OB" and incomingType == "SD") or (existingType == "SD" and incomingType == "OB") or (existingType == "SD" and incomingType == "SD")

export build_ob_sd_merged_label(string oldLabel, string existingType, string incomingType) =>
    bool needsSdTag = existingType == "SD" or incomingType == "SD"
    string core = oldLabel == "" ? "OB" : oldLabel
    if needsSdTag and not str.contains(core, "SD")
        core += "+SD"
    core

export try_merge_ob_sd_pdarray(array<PDArray> zones, string incomingType, bool isBull, float top, float btm, int ext, float qualityPct, string tooltipText, float tickSize, int mergeTolTicks, int minWidthBars) =>
    bool merged = false
    bool isFamily = incomingType == "OB" or incomingType == "SD"
    if isFamily and array.size(zones) > 0
        float pad = mergeTolTicks * tickSize
        float inTop = top + pad
        float inBtm = btm - pad
        for i = array.size(zones) - 1 to 0
            PDArray z = array.get(zones, i)
            if not z.broken and z.isBullish == isBull and can_merge_ob_sd(z.type, incomingType)
                float zTop = z.top + pad
                float zBtm = z.bottom - pad
                bool overlap = math.min(inTop, zTop) >= math.max(inBtm, zBtm)
                if overlap
                    string oldType = z.type
                    z.top := math.max(z.top, top)
                    z.bottom := math.min(z.bottom, btm)
                    z.extendBars := math.max(z.extendBars, ext)
                    z.qualityPct := math.max(nz(z.qualityPct, 0.0), nz(qualityPct, 0.0))
                    z.type := "OB"
                    z.labelText := build_ob_sd_merged_label(z.labelText, oldType, incomingType)
                    if not na(z.visualBox)
                        z.visualBox.set_top(z.top)
                        z.visualBox.set_bottom(z.bottom)
                        z.visualBox.set_right(math.max(bar_index + z.extendBars, z.barStart + minWidthBars))
                    if not na(z.visualLabel)
                        z.visualLabel.set_text(z.labelText)
                        if tooltipText != ""
                            z.visualLabel.set_tooltip(tooltipText)
                    array.set(zones, i, z)
                    merged := true
                    break
    merged

export has_nearby_ob(array<PDArray> zones, bool isBull, float top, float btm, int startIdx, int maxBarsApart) =>
    has_nearby_pd_array(zones, array.new<string>(1, "OB"), isBull, top, btm, startIdx, maxBarsApart)

export has_active_ob_same_side(array<PDArray> zones, bool isBull) =>
    has_active_pd_array_same_side(zones, array.new<string>(1, "OB"), isBull)

export is_extreme_ob_candidate(array<PDArray> zones, bool isBull, float top, float btm) =>
    is_extreme_pd_array_candidate(zones, array.new<string>(1, "OB"), isBull, top, btm)

export classify_new_ob(array<PDArray> zones, bool isBull, float top, float btm, float q, Const c) =>
    bool isOrigin = not has_active_ob_same_side(zones, isBull)
    bool isExtreme = is_extreme_ob_candidate(zones, isBull, top, btm)
    isOrigin ? c.OB_CLASS_ORIGIN : isExtreme ? c.OB_CLASS_EXTREME : q >= 70 ? c.OB_CLASS_DECISIONAL : c.OB_CLASS_DECISIONAL

// Compatibility helper during lifeState-first migration.
// A zone is treated as "post-touch" when lifecycle advanced beyond FORMED,
export is_pdarray_post_touch(PDArray z) =>
    z.lifeState == 1 or z.lifeState == 2 or z.lifeState == 3

append_pdarray_removed(array<PDArray> dst, array<PDArray> src) =>
    if array.size(src) > 0
        for i = 0 to array.size(src) - 1
            array.push(dst, array.get(src, i))
    bool(na)

export prune_pdarray_bucket_weakest(array<PDArray> zones, string type, bool isBull, int bucketMax) =>
    array<PDArray> removed = array.new<PDArray>()
    int bucketCount = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.type == type and z.isBullish == isBull and not z.broken and not is_pdarray_post_touch(z)
                bucketCount += 1
    while bucketCount > bucketMax
        int weakestIdx = na
        float weakestScore = 10e10
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                z = array.get(zones, i)
                if z.type == type and z.isBullish == isBull and not z.broken and not is_pdarray_post_touch(z)
                    float s = nz(z.qualityPct, 0.0)
                    if na(weakestIdx) or s < weakestScore
                        weakestScore := s
                        weakestIdx := i
        if not na(weakestIdx)
            zDel = array.get(zones, weakestIdx)
            array.push(removed, zDel)
            array.remove(zones, weakestIdx)
        bucketCount -= 1
    removed

// Computes zone quality component data for one zone and impulse candle offset.
export get_pdarray_quality_data(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    int maxSafeOff = 300
    int off = math.max(0, math.min(impulseOff, maxSafeOff))
    float atrRef = nz(atrSeries[off], atrSeries)
    float safeAtr = atrRef > 0 ? atrRef : tickSize
    float zoneAtr = (top - btm) / safeAtr
    float relVol = get_rel_volume(off, cfg.volLen)
    float bodyAtr = math.abs(close[off] - open[off]) / safeAtr
    float barRange = math.max(high[off] - low[off], tickSize)
    float dispRatio = math.abs(close[off] - open[off]) / barRange

    int sizePts = zoneAtr >= (cfg.minHeightAtr * cfg.sizeStrongMult) ? cfg.scoreSizeStrong : zoneAtr >= cfg.minHeightAtr ? cfg.scoreSizeBase : 0
    int volPts = relVol >= cfg.volStrong ? cfg.scoreVolStrong : relVol >= cfg.minRelVolume ? cfg.scoreVolBase : 0
    int impPts = bodyAtr >= cfg.impStrong ? cfg.scoreImpStrong : bodyAtr >= cfg.minBodyAtr ? cfg.scoreImpBase : 0
    int dispPts = dispRatio >= cfg.dispMin ? cfg.scoreDisp : 0

    int score = sizePts + volPts + impPts + dispPts
    int maxScore = cfg.scoreSizeStrong + cfg.scoreVolStrong + cfg.scoreImpStrong + cfg.scoreDisp
    [score, maxScore, zoneAtr, relVol, bodyAtr, dispRatio]

// Returns normalized zone quality percentage (0..100).
export get_pdarray_quality_pct(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    [score, maxScore, _, _, _, _] = get_pdarray_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    maxScore > 0 ? (score * 100.0 / maxScore) : 0.0

// Builds zone quality tooltip text.
export build_pdarray_quality_tooltip(string baseText, float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    [score, maxScore, zoneAtr, relVol, bodyAtr, dispRatio] = get_pdarray_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    baseText + "\nQ " + str.tostring(score) + "/" + str.tostring(maxScore) + " (" + str.tostring(math.round(score * 100.0 / maxScore)) + "%)" +
     "\nATR " + str.tostring(zoneAtr, "#.##") + " | Vol " + str.tostring(relVol, "#.##") + " | Body " + str.tostring(bodyAtr, "#.##") + " | Disp " + str.tostring(dispRatio, "#.##")

passes_pdarray_quality(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    bool sizeOk = (top - btm) >= (cfg.minHeightAtr * nz(atrSeries, tickSize))
    [_, _, _, relVol, bodyAtr, _] = get_pdarray_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    bool volOk = not cfg.useVolume or relVol >= cfg.minRelVolume
    bool impulseOk = not cfg.useImpulse or bodyAtr >= cfg.minBodyAtr
    sizeOk and volOk and impulseOk

// Evaluates zone quality once and returns [ok, qualityPct, tooltipText].
export zone_quality_eval(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg, string baseTooltipText, bool showTooltip) =>
    bool ok = passes_pdarray_quality(top, btm, impulseOff, atrSeries, tickSize, cfg)
    float q = ok ? get_pdarray_quality_pct(top, btm, impulseOff, atrSeries, tickSize, cfg) : 0.0
    string tt = showTooltip and ok ? build_pdarray_quality_tooltip(baseTooltipText, top, btm, impulseOff, atrSeries, tickSize, cfg) : ""
    [ok, q, tt]

export prune_old_current_zones(array<PDArray> zones, int lookbackBars, int lastBarIndex) =>
    array<PDArray> removed = array.new<PDArray>()
    if array.size(zones) > 0
        for i = array.size(zones) - 1 to 0
            z = array.get(zones, i)
            bool tooOld = z.barStart < math.max(lastBarIndex - math.max(lookbackBars, 1), 0)
            if tooOld
                array.push(removed, z)
                array.remove(zones, i)
    removed

export prune_current_pdarray_side_caps(array<PDArray> zones, int perTypeSideMax, float closeV, int barIndex, float ageDecay) =>
    array<PDArray> removed = array.new<PDArray>()
    string[] zTypes = array.from("OB_FAMILY", "FVG_FAMILY")
    for t = 0 to array.size(zTypes) - 1
        string zt = array.get(zTypes, t)
        for side = 0 to 1
            bool wantAbove = side == 0
            int count = 0
            if array.size(zones) > 0
                for i = 0 to array.size(zones) - 1
                    z = array.get(zones, i)
                    bool sideMatch = ((z.top + z.bottom) * 0.5 > closeV) == wantAbove
                    if get_pdarray_cap_family(z.type) == zt and sideMatch and not z.broken and not is_pdarray_post_touch(z)
                        count += 1
            while count > perTypeSideMax
                int weakestIdx = na
                float weakestScore = 10e10
                if array.size(zones) > 0
                    for i = 0 to array.size(zones) - 1
                        z = array.get(zones, i)
                        bool sideMatch = ((z.top + z.bottom) * 0.5 > closeV) == wantAbove
                        if get_pdarray_cap_family(z.type) == zt and sideMatch and not z.broken and not is_pdarray_post_touch(z)
                            float s = nz(z.qualityPct, 0.0) - (math.max(barIndex - z.barStart, 0) * ageDecay)
                            if na(weakestIdx) or s < weakestScore
                                weakestScore := s
                                weakestIdx := i
                if not na(weakestIdx)
                    zDel = array.get(zones, weakestIdx)
                    array.push(removed, zDel)
                    array.remove(zones, weakestIdx)
                    count -= 1
                else
                    count := perTypeSideMax
    removed

export add_active_zone(array<PDArray> zones, PDArray z, int bucketMax, int totalMax, int perTypeSideMax, int lookbackBars, int lastBarIndex, float closeV, int barIndex, float ageDecay) =>
    array<PDArray> removed = array.new<PDArray>()
    array.push(zones, z)
    append_pdarray_removed(removed, prune_old_current_zones(zones, lookbackBars, lastBarIndex))
    append_pdarray_removed(removed, prune_pdarray_bucket_weakest(zones, z.type, z.isBullish, bucketMax))
    append_pdarray_removed(removed, prune_current_pdarray_side_caps(zones, perTypeSideMax, closeV, barIndex, ageDecay))
    while array.size(zones) > totalMax
        old = array.shift(zones)
        array.push(removed, old)
    removed

// Unified detection basis helper.
export get_detection_series(bool isBullBreak, string basis, float o, float h, float l, float c) =>
    if basis == "Body"
        isBullBreak ? math.max(o, c) : math.min(o, c)
    else if basis == "Close"
        c
    else
        isBullBreak ? h : l

export check_impulse_filter(bool useImpulse, float atrVal, float atrMult, float o, float c) =>
    not useImpulse or math.abs(c - o) >= (atrVal * atrMult)

export check_break(bool isBullBreak, float level, int method, int methodCross, string basis, bool useImpulse, float atrVal, float atrMult,
 float o0, float h0, float l0, float c0, float o1, float h1, float l1, float c1) =>
    bool crossed = method == methodCross ? (isBullBreak ? (o0 <= level and c0 > level) : (o0 >= level and c0 < level)) :
     (get_detection_series(isBullBreak, basis, o0, h0, l0, c0) > level and get_detection_series(isBullBreak, basis, o1, h1, l1, c1) <= level ? isBullBreak : get_detection_series(isBullBreak, basis, o0, h0, l0, c0) < level and get_detection_series(isBullBreak, basis, o1, h1, l1, c1) >= level)
    crossed and check_impulse_filter(useImpulse, atrVal, atrMult, o0, c0)

export check_touch(float zoneTop, float zoneBtm, string basis, float o, float h, float l, float c) =>
    float hiRef = basis == "Body" ? math.max(o, c) : basis == "Close" ? c : h
    float loRef = basis == "Body" ? math.min(o, c) : basis == "Close" ? c : l
    hiRef >= zoneBtm and loRef <= zoneTop

export check_pdarray_respect(bool isBullZone, float zoneTop, float zoneBtm, float highV, float lowV, float closeV) =>
    isBullZone ? (lowV <= zoneTop and closeV > zoneTop) : (highV >= zoneBtm and closeV < zoneBtm)

export check_mitigation(string type, bool isBullZone, float zoneTop, float zoneBtm, int method, int methodCross, string basis, bool useImpulse, float atrVal, float atrMult,
 float o0, float h0, float l0, float c0, float o1, float h1, float l1, float c1) =>
    bool isFVG = type == "FVG" or type == "IFVG"
    if isFVG
        float mid = (zoneTop + zoneBtm) / 2.0
        check_break(not isBullZone, mid, method, methodCross, basis, useImpulse, atrVal, atrMult, o0, h0, l0, c0, o1, h1, l1, c1)
    else
        check_touch(zoneTop, zoneBtm, basis, o0, h0, l0, c0)

export has_sweep_event_for(array<Event> events, string direction, float price, float tickSize) =>
    bool found = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            e = array.get(events, i)
            if e.direction == direction and math.abs(e.zonePrice - price) <= tickSize * 2
                found := true
                break
    found

export register_sweep_reclaim_event(array<Event> events, string direction, float price, int barIdx, float tickSize) =>
    if not has_sweep_event_for(events, direction, price, tickSize)
        Event e = Event.new()
        e.type := "SWEEP"
        e.direction := direction
        e.zonePrice := price
        e.barDetected := barIdx
        array.push(events, e)
    bool(na)

export has_break_retest_event_for(array<Event> events, string type, string direction, float top, float btm, float tickSize) =>
    bool found = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            e = array.get(events, i)
            bool sameZone = math.abs(e.zoneTop - top) <= tickSize * 2 and math.abs(e.zoneBtm - btm) <= tickSize * 2
            bool isBreakRetestEvent = not na(e.barBreak)
            if isBreakRetestEvent and e.type == type and e.direction == direction and sameZone
                found := true
                break
    found

export register_break_retest_event(array<Event> events, string type, string direction, float top, float btm, int barIdx, float quality, float tickSize) =>
    if not has_break_retest_event_for(events, type, direction, top, btm, tickSize)
        Event e = Event.new()
        e.type := type
        e.direction := direction
        e.zoneTop := top
        e.zoneBtm := btm
        e.quality := quality
        e.barDetected := barIdx
        e.barBreak := barIdx
        array.push(events, e)
    bool(na)

export direction_matches_bias(string direction, int biasDir) =>
    direction == "Buy" ? biasDir > 0 : direction == "Sell" ? biasDir < 0 : false

export check_direction_by_mode(string direction, int mode, int trendVal, int biasVal, bool allowPullback) =>
    mode == 0 ? true : mode == 1 ? direction_matches_bias(direction, allowPullback ? (biasVal != 0 ? biasVal : trendVal) : (trendVal != 0 ? trendVal : biasVal)) : direction_matches_bias(direction, biasVal)

export has_pullback_preference(int biasLtfMode, int biasHtf1Mode, int biasHtf2Mode) =>
    biasLtfMode == 2 or biasHtf1Mode == 2 or biasHtf2Mode == 2

export has_recent_signal_event(array<Event> signalHist, string eventType, int lookbackBars, int currentBarIndex) =>
    bool hit = false
    int n = array.size(signalHist)
    if n > 0
        for i = n - 1 to 0
            Event ev = array.get(signalHist, i)
            if (currentBarIndex - ev.barDetected) <= lookbackBars and str.upper(ev.type) == eventType
                hit := true
                break
    hit

export normalize_required_events(string requiredPrevEvents) =>
    string req = str.upper(requiredPrevEvents)
    req := str.replace_all(req, " ", "")
    req := str.replace_all(req, "|", ",")
    req := str.replace_all(req, "+", ",")
    req := str.replace_all(req, ";", ",")
    req := str.replace_all(req, "/", ",")
    req

export resolve_event_alias(string tokenRaw) =>
    string t = str.upper(tokenRaw)
    t == "MS" ? "MSS" : t == "BO" ? "BOS" : t == "SW" ? "SWEEP" : t

export check_required_previous_events(array<Event> signalHist, string requiredPrevEvents, int lookbackBars, int currentBarIndex) =>
    string norm = normalize_required_events(requiredPrevEvents)
    if str.length(norm) == 0
        true
    else
        bool ok = true
        array<string> toks = str.split(norm, ",")
        if array.size(toks) > 0
            for i = 0 to array.size(toks) - 1
                string token = resolve_event_alias(array.get(toks, i))
                if str.length(token) > 0
                    if not has_recent_signal_event(signalHist, token, lookbackBars, currentBarIndex)
                        ok := false
                        break
        ok

get_array_int_or_zero(array<int> vals, int idx) =>
    array.size(vals) > idx ? array.get(vals, idx) : 0

export check_entry_model_dynamic(array<int> tradeBiasVals, array<int> tradeTrendVals, array<Event> signalHist, string direction, int memDir, int biasLtfMode, int biasHtf1Mode, int biasHtf2Mode, string requiredPrevEvents, int requiredWindowBars, string biasDirection, int currentBarIndex) =>
    int bLtf = get_array_int_or_zero(tradeBiasVals, 0)
    int bH1 = get_array_int_or_zero(tradeBiasVals, 1)
    int bH2 = get_array_int_or_zero(tradeBiasVals, 2)
    int tLtf = get_array_int_or_zero(tradeTrendVals, 0)
    int tH1 = get_array_int_or_zero(tradeTrendVals, 1)
    int tH2 = get_array_int_or_zero(tradeTrendVals, 2)
    bool allowPullback = has_pullback_preference(biasLtfMode, biasHtf1Mode, biasHtf2Mode)
    bool dirModeOk = check_direction_by_mode(direction, biasLtfMode, tLtf, bLtf, allowPullback) and check_direction_by_mode(direction, biasHtf1Mode, tH1, bH1, allowPullback) and check_direction_by_mode(direction, biasHtf2Mode, tH2, bH2, allowPullback)
    bool memOk = memDir == 0 or (direction == "Buy" and memDir == 1) or (direction == "Sell" and memDir == -1)
    string bd = str.upper(biasDirection)
    bool biasDirOk = bd == "" or bd == "NA" or (bd == "LONG" and direction == "Buy") or (bd == "SHORT" and direction == "Sell")
    bool requiredOk = check_required_previous_events(signalHist, requiredPrevEvents, requiredWindowBars, currentBarIndex)
    dirModeOk and memOk and biasDirOk and requiredOk

export has_pending_trade_signal(array<Event> events, string type, string direction, float top, float btm, float tickSize) =>
    bool result = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            Event e = array.get(events, i)
            bool sameZone = math.abs(e.zoneTop - top) < tickSize * 2 and math.abs(e.zoneBtm - btm) < tickSize * 2
            bool isSignalEvent = e.type != "SWEEP" and na(e.barBreak)
            if isSignalEvent and e.type == type and e.direction == direction and sameZone
                result := true
                break
    result

export is_signal_memory_candidate(Event e) =>
    e.direction != "" and e.score > 0

export has_signal_memory_duplicate(array<Event> hist, Event e, float tickSize) =>
    bool dup = false
    if array.size(hist) > 0
        for i = array.size(hist) - 1 to 0
            Event x = array.get(hist, i)
            bool sameBar = x.barDetected == e.barDetected
            bool sameDir = x.direction == e.direction
            bool sameType = x.type == e.type
            bool sameZone = (na(x.zoneTop) and na(e.zoneTop)) or (math.abs(nz(x.zoneTop, 0.0) - nz(e.zoneTop, 0.0)) <= tickSize * 2 and math.abs(nz(x.zoneBtm, 0.0) - nz(e.zoneBtm, 0.0)) <= tickSize * 2)
            if sameBar and sameDir and sameType and sameZone
                dup := true
                break
    dup

export cache_signal_memory_event(array<Event> hist, Event e, float tickSize, int maxEvents) =>
    if is_signal_memory_candidate(e) and not has_signal_memory_duplicate(hist, e, tickSize)
        array.push(hist, e)
        while array.size(hist) > maxEvents
            array.remove(hist, 0)
    bool(na)

export add_signal(array<Event> signalsList, array<Event> signalMemoryEvents, string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal, int barIdx, float tickSize, int memMaxEvents) =>
    if not has_pending_trade_signal(signalsList, type, direction, levelTop, levelBtm, tickSize)
        Event e = Event.new(type, direction, levelTop, levelBtm, na, barIdx, int(na), false, reason, qualityPct, scoreVal)
        array.push(signalsList, e)
        cache_signal_memory_event(signalMemoryEvents, e, tickSize, memMaxEvents)
    bool(na)

export normalize_event_token(string eventType) =>
    string u = str.upper(eventType)
    (u == "SWEEP" or u == "SW" or u == "X") ? "x" : str.lower(u)

export get_recent_events_text(array<Event> hist, string focusDirection, bool sameDirectionOnly, int maxEvents, int lookbackBars, int maxScan, string upSym, string dnSym, string dashSym) =>
    string out = ""
    int added = 0
    string prevTypeNorm = ""
    string prevDir = ""
    int n = array.size(hist)
    if n > 0
        int startIdx = math.max(0, n - math.max(maxScan, 1))
        for i = n - 1 to startIdx
            Event ev = array.get(hist, i)
            bool recent = na(ev.barDetected) or (bar_index - ev.barDetected <= lookbackBars)
            bool dirOk = not sameDirectionOnly or ev.direction == focusDirection
            if recent and dirOk
                string typeNorm = normalize_event_token(ev.type)
                bool sameAsPrev = typeNorm == prevTypeNorm and ev.direction == prevDir
                if sameAsPrev
                    continue
                string dirSym = ev.direction == "Buy" ? upSym : ev.direction == "Sell" ? dnSym : dashSym
                string token = typeNorm + dirSym
                out := out == "" ? token : token + ", " + out
                prevTypeNorm := typeNorm
                prevDir := ev.direction
                added += 1
                if added >= maxEvents
                    break
    out == "" ? "na" : out

export get_trade_gap_profile_floors(string slProfile, int strictLv, string slProfileStrict, string slProfileLoose) =>
    float baseTicks = slProfile == slProfileStrict ? 10.0 : slProfile == slProfileLoose ? 3.0 : 6.0
    float baseAtr = slProfile == slProfileStrict ? 0.50 : slProfile == slProfileLoose ? 0.20 : 0.35
    float strictTicksAdd = strictLv >= 3 ? 2.0 : strictLv == 2 ? 1.0 : 0.0
    float strictAtrMult = strictLv >= 3 ? 1.20 : strictLv == 2 ? 1.10 : 1.00
    float minTicks = baseTicks + strictTicksAdd
    float minAtr = baseAtr * strictAtrMult
    [minTicks, minAtr]

export get_trade_score_min(int profileId) =>
    profileId == 0 ? 45.0 : profileId == 2 ? 65.0 : profileId == 3 ? 74.0 : 55.0

export compute_trade_score(float qualityPct, float riskTicks, float riskAtr, float rrReal, float relVol, bool alignBias, bool useBiasFilter) =>
    float tickScore = riskTicks < 2.0 ? 10.0 : riskTicks < 4.0 ? 35.0 : riskTicks <= 24.0 ? 100.0 : riskTicks <= 48.0 ? 75.0 : 45.0
    float atrScore = riskAtr < 0.10 ? 10.0 : riskAtr < 0.20 ? 35.0 : riskAtr <= 1.80 ? 100.0 : riskAtr <= 3.00 ? 75.0 : 45.0
    float sRisk = (tickScore + atrScore) * 0.5
    float sBias = useBiasFilter ? (alignBias ? 100.0 : 40.0) : 60.0
    float sQ = math.min(math.max(nz(qualityPct, 50.0), 0.0), 100.0)
    float sRr = rrReal < 0.85 ? 15.0 : rrReal < 1.0 ? 35.0 : rrReal < 1.2 ? 55.0 : rrReal < 1.5 ? 72.0 : rrReal < 2.0 ? 88.0 : 100.0
    float sVol = na(relVol) ? 50.0 : relVol < 0.8 ? 35.0 : relVol < 1.0 ? 50.0 : relVol < 1.5 ? 75.0 : relVol < 2.0 ? 90.0 : 100.0
    (sRisk * 0.35) + (sQ * 0.30) + (sRr * 0.20) + (sVol * 0.10) + (sBias * 0.05)

export compute_signal_memory_bias(array<Event> hist, int memWindowBars) =>
    float score = 0.0
    int bullCount = 0
    int bearCount = 0
    if array.size(hist) > 0
        for i = array.size(hist) - 1 to 0
            Event e = array.get(hist, i)
            int age = bar_index - e.barDetected
            if age > memWindowBars
                continue
            float decay = 1.0 - (float(age) / float(memWindowBars + 1))
            float weight = math.max(float(e.score), 1.0) * math.max(decay, 0.1)
            if e.direction == "Buy"
                score += weight
                bullCount += 1
            else if e.direction == "Sell"
                score -= weight
                bearCount += 1
    int memDir = score > 1.0 ? 1 : score < -1.0 ? -1 : 0
    [score, memDir, bullCount, bearCount]

export get_last_leg_from_swings(TFData tfData) =>
    bool ok = false
    int startIdx = na
    int endIdx = na
    float startPrice = na
    float endPrice = na
    [hiP, hiT, loP, loT] = market_structure_latest_hilo(tfData.mss)
    if not na(hiP) and not na(hiT) and not na(loP) and not na(loT) and hiT != loT
        int hiIdx = closest_bar_index_from_time(hiT)
        int loIdx = closest_bar_index_from_time(loT)
        bool hiIsLast = hiT > loT
        startIdx := hiIsLast ? loIdx : hiIdx
        endIdx := hiIsLast ? hiIdx : loIdx
        startPrice := hiIsLast ? loP : hiP
        endPrice := hiIsLast ? hiP : loP
        ok := not na(startIdx) and not na(endIdx)
    [ok, startIdx, endIdx, startPrice, endPrice]

export snap_to_density_grid(float price, float rangeMax, float rangeMin, int div) =>
    float out = price
    float span = rangeMax - rangeMin
    float rawStep = div > 0 ? span / div : na
    if not na(rawStep) and rawStep > 0
        float step = math.max(rawStep, syminfo.mintick)
        float slot = math.round((price - rangeMin) / step)
        float snapped = rangeMin + slot * step
        out := math.max(rangeMin, math.min(rangeMax, snapped))
    out

// Returns true when a zone belongs to the OB/SD overlap family.
export is_ob_sd_family(string type) =>
    type == "OB" or type == "SD"

// Returns SR x-position for line end or label placement.
export get_sr_x(int barIndex, int extendBars, bool forLabel) =>
    barIndex + extendBars + (forLabel ? 1 : 0)

// Returns true when SR source label implies higher-timeframe origin.
export is_sr_source_htf(PDArray z, string currentTf) =>
    z.labelText != "" and z.labelText != currentTf

// Returns true when SR level is above current price and acts as resistance.
export is_sr_res_now(PDArray z, float closeV) =>
    z.price > closeV

// Returns SR label text from HTF/source role and touch count.
export get_sr_label_text(bool isHtfSource, bool isResNow, int touchN) =>
    touchN <= 1 ? (isHtfSource ? "IDM" : "idm") : (isResNow ? "R" : "S") + str.tostring(math.max(touchN, 1))

export get_score_sr_strength(PDArray z) =>
    float q = nz(z.qualityPct, 1.0)
    float rej = math.max(z.rejectCount, 0)
    float agePenalty = math.max(bar_index - z.barStart, 0) * 0.0005
    q + rej * 0.5 - agePenalty

export get_sr_rank_text(bool isRes, int rank) =>
    (isRes ? "R" : "S") + str.tostring(math.max(rank, 1))

// Shared lifecycle state normalization for horizontal-level engines.
export normalize_pricezone_state(PDArray z, Const c) =>
    PDArray out = z
    bool postTouch = is_pdarray_post_touch(out)
    if out.lifeState == c.LIFE_FORMED
        if out.broken
            out.lifeState := c.LIFE_BROKEN
        else if postTouch
            out.lifeState := c.LIFE_TOUCHED
    if out.touchCount < 0
        out.touchCount := 0
    if out.rejectCount < 0
        out.rejectCount := 0
    out

// Finds nearest swing price within tolerance.
export get_data_nearest_swing_price_in_tol(array<float> prices, float refPrice, float tol) =>
    float bestPrice = na
    float bestDist = na
    if array.size(prices) > 0
        for i = 0 to array.size(prices) - 1
            float p = array.get(prices, i)
            float d = math.abs(p - refPrice)
            if d <= tol and (na(bestDist) or d < bestDist)
                bestDist := d
                bestPrice := p
    [bestPrice, bestDist]

// Snaps SR seed to nearest swing among LTF/HTF1/HTF2.
export get_data_sr_price_snapped_to_swing(float srPrice, float tol, array<float> ltfSw, array<float> h1Sw, array<float> h2Sw) =>
    [p0, d0] = get_data_nearest_swing_price_in_tol(ltfSw, srPrice, tol)
    [p1, d1] = get_data_nearest_swing_price_in_tol(h1Sw, srPrice, tol)
    [p2, d2] = get_data_nearest_swing_price_in_tol(h2Sw, srPrice, tol)
    float out = srPrice
    float bestD = na
    if not na(p0)
        out := p0
        bestD := d0
    if not na(p1) and (na(bestD) or d1 < bestD)
        out := p1
        bestD := d1
    if not na(p2) and (na(bestD) or d2 < bestD)
        out := p2
    out

// Kind matcher for unified horizontal-level processing.
export get_data_level_matches_kind(int kind, string levelType, int hlKindLiq, int hlKindEq, int hlKindSr) =>
    kind == hlKindLiq ? levelType == "LIQ" : kind == hlKindEq ? (levelType == "eqh" or levelType == "eql") : kind == hlKindSr ? levelType == "SR" : false

export is_in_virtual_price_zone(float price, float top, float btm) =>
    not na(price) and not na(top) and not na(btm) and price <= top and price >= btm

// Checks whether zone or LIQ/EQ keylevels overlap a virtual zone range.
export get_data_has_keylevel_overlap_in_zone(array<PDArray> zones, array<PDArray> levels, float top, float btm) =>
    bool overlap = false
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.top >= btm and z.bottom <= top
                overlap := true
                break
    if not overlap and array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            bool isLevelType = z.type == "LIQ" or z.type == "eqh" or z.type == "eql"
            if isLevelType and is_in_virtual_price_zone(z.price, top, btm)
                overlap := true
                break
    overlap

// LIQ/EQ-only overlap helper for MSS line-seed flow.
export get_data_has_keylevel_overlap_in_levels(array<PDArray> levels, float top, float btm) =>
    bool overlap = false
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            bool isLevelType = z.type == "LIQ" or z.type == "eqh" or z.type == "eql"
            if isLevelType and is_in_virtual_price_zone(z.price, top, btm)
                overlap := true
                break
    overlap

export get_data_sr_tooltip_text(int rejectCount, int state, Const c) =>
    "Rejects: " + str.tostring(math.max(rejectCount, 0)) + "\nState: " + get_lifecycle_name(state, c.LIFE_FORMED, c.LIFE_TOUCHED, c.LIFE_RESPECTED, c.LIFE_RECLAIMED)

export delete_level_at(array<PDArray> levels, int idx) =>
    PDArray z = array.get(levels, idx)
    array.remove(levels, idx)
    z

export draw_sr_rank_labels(array<PDArray> levels, float closeV) =>
    int rRank = 0
    int sRank = 0
    array<int> used = array.new_int()
    if array.size(levels) > 0
        for pass = 0 to 1
            int remain = 99
            while remain > 0
                int bestIdx = na
                float bestScore = -10e10
                for i = 0 to array.size(levels) - 1
                    PDArray z = array.get(levels, i)
                    if z.type == "SR"
                        bool isRes = is_sr_res_now(z, closeV)
                        bool sidePass = (pass == 0 and isRes) or (pass == 1 and not isRes)
                        if sidePass and not array.includes(used, i)
                            float s = get_score_sr_strength(z)
                            if na(bestIdx) or s > bestScore
                                bestScore := s
                                bestIdx := i
                if na(bestIdx)
                    break
                PDArray zBest = array.get(levels, bestIdx)
                bool isResBest = pass == 0
                if isResBest
                    rRank += 1
                else
                    sRank += 1
                string rankTxt = get_sr_rank_text(isResBest, isResBest ? rRank : sRank)
                if not na(zBest.visualLabel)
                    zBest.visualLabel.set_text(rankTxt)
                array.set(levels, bestIdx, zBest)
                array.push(used, bestIdx)
                remain -= 1
    bool(na)

export prune_sr_side_cap(array<PDArray> levels, int maxPerSide, float closeV) =>
    array<PDArray> removed = array.new<PDArray>()
    int keptRes = 0
    int keptSup = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            PDArray z = array.get(levels, i)
            if z.type == "SR"
                bool isRes = is_sr_res_now(z, closeV)
                if isRes
                    keptRes += 1
                else
                    keptSup += 1
    while keptRes > maxPerSide or keptSup > maxPerSide
        int dropIdx = na
        float weakest = 10e10
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                PDArray z = array.get(levels, i)
                if z.type == "SR"
                    bool isRes = is_sr_res_now(z, closeV)
                    bool overCap = (isRes and keptRes > maxPerSide) or ((not isRes) and keptSup > maxPerSide)
                    if overCap
                        float s = get_score_sr_strength(z)
                        if na(dropIdx) or s < weakest
                            weakest := s
                            dropIdx := i
        if na(dropIdx)
            break
        PDArray zDrop = array.get(levels, dropIdx)
        bool dropIsRes = is_sr_res_now(zDrop, closeV)
        array.push(removed, delete_level_at(levels, dropIdx))
        if dropIsRes
            keptRes -= 1
        else
            keptSup -= 1
    removed

export prune_sr_source_cap(array<PDArray> levels, int sourcePrio, int maxPerSide, float closeV) =>
    array<PDArray> removed = array.new<PDArray>()
    int keptRes = 0
    int keptSup = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            PDArray z = array.get(levels, i)
            if z.type == "SR" and int(math.max(nz(z.extendBars, 0), 0)) == sourcePrio
                bool isRes = is_sr_res_now(z, closeV)
                if isRes
                    keptRes += 1
                else
                    keptSup += 1
    while keptRes > maxPerSide or keptSup > maxPerSide
        int dropIdx = na
        float weakest = 10e10
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                PDArray z = array.get(levels, i)
                bool sameSrc = int(math.max(nz(z.extendBars, 0), 0)) == sourcePrio
                if z.type == "SR" and sameSrc
                    bool isRes = is_sr_res_now(z, closeV)
                    bool overCap = (isRes and keptRes > maxPerSide) or ((not isRes) and keptSup > maxPerSide)
                    if overCap
                        float s = get_score_sr_strength(z)
                        if na(dropIdx) or s < weakest
                            weakest := s
                            dropIdx := i
        if na(dropIdx)
            break
        PDArray zDrop = array.get(levels, dropIdx)
        bool dropIsRes = is_sr_res_now(zDrop, closeV)
        array.push(removed, delete_level_at(levels, dropIdx))
        if dropIsRes
            keptRes -= 1
        else
            keptSup -= 1
    removed

export prune_nearby_sr_levels(array<PDArray> levels, float minDist) =>
    array<PDArray> removed = array.new<PDArray>()
    int i = array.size(levels) - 1
    while i >= 1 and array.size(levels) > 1
        if i >= array.size(levels)
            i := array.size(levels) - 1
            continue
        PDArray zi = array.get(levels, i)
        if zi.type != "SR"
            i -= 1
            continue
        int j = i - 1
        bool merged = false
        while j >= 0 and j < array.size(levels)
            PDArray zj = array.get(levels, j)
            bool sameSide = zi.isHigh == zj.isHigh
            bool sameSourcePrio = int(math.max(nz(zi.extendBars, 0), 0)) == int(math.max(nz(zj.extendBars, 0), 0))
            if zj.type == "SR" and sameSide and sameSourcePrio and math.abs(zi.price - zj.price) <= minDist
                bool keepI = get_score_sr_strength(zi) >= get_score_sr_strength(zj)
                int dropIdx = keepI ? j : i
                int keepIdx = keepI ? i : j
                PDArray zKeep = array.get(levels, keepIdx)
                PDArray zDrop = array.get(levels, dropIdx)
                zKeep.qualityPct := math.max(nz(zKeep.qualityPct, 1.0), nz(zDrop.qualityPct, 1.0))
                int keepReject = math.max(zKeep.rejectCount, 0)
                int dropReject = math.max(zDrop.rejectCount, 0)
                int mergedReject = math.max(keepReject, dropReject)
                int keepState = zKeep.lifeState
                int dropState = zDrop.lifeState
                int mergedState = merge_lifecycle_state(keepState, dropState, CONST.LIFE_BROKEN)
                zKeep.rejectCount := mergedReject
                zKeep.lifeState := mergedState
                if keepI and i < array.size(levels)
                    array.set(levels, i, zKeep)
                else if not keepI and j < array.size(levels)
                    array.set(levels, j, zKeep)
                if dropIdx >= 0 and dropIdx < array.size(levels)
                    array.push(removed, delete_level_at(levels, dropIdx))
                merged := true
                break
            j -= 1
        if not merged
            i -= 1
    removed

export get_nearest_barriers(array<PDArray> zones, float refPrice, float tickSize) =>
    float above = na
    float below = na
    float aboveH = na
    float belowH = na
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            PDArray z = array.get(zones, i)
            bool isHtf = z.sourceTfRank >= 2
            bool isObBb = z.type == "OB" or z.type == "BB"
            if not z.broken and isHtf and isObBb
                float zHi = z.top
                float zLo = z.bottom
                float zH = math.max(zHi - zLo, tickSize)
                if zLo > refPrice and (na(above) or zLo < above)
                    above := zLo
                    aboveH := zH
                if zHi < refPrice and (na(below) or zHi > below)
                    below := zHi
                    belowH := zH
    [above, below, aboveH, belowH]

// Builds one HTF zone snapshot tuple (OB/FVG + quality).
export get_htf_pdarray_snapshot(int zoneFormationLockBars, ZoneQualityCfg zqCfg, int atrLen) =>
    bool obUp = smc_is_ob(true, 1, zoneFormationLockBars)
    bool obDn = smc_is_ob(false, 1, zoneFormationLockBars)
    bool fvgUp = smc_is_fvg(true, 0, zoneFormationLockBars)
    bool fvgDn = smc_is_fvg(false, 0, zoneFormationLockBars)
    float atrRef = ta.atr(atrLen)
    float obUpQTop = high[2]
    float obUpQBtm = math.min(low[2], low[1])
    float obDnQTop = math.max(high[2], high[1])
    float obDnQBtm = low[2]
    float fvgUpQTop = low
    float fvgUpQBtm = high[2]
    float fvgDnQTop = low[2]
    float fvgDnQBtm = high
    float obUpTop = ta.valuewhen(obUp, high[2], 0)
    float obUpBtm = ta.valuewhen(obUp, math.min(low[2], low[1]), 0)
    int obUpStart = ta.valuewhen(obUp, time[2], 0)
    float obDnTop = ta.valuewhen(obDn, math.max(high[2], high[1]), 0)
    float obDnBtm = ta.valuewhen(obDn, low[2], 0)
    int obDnStart = ta.valuewhen(obDn, time[2], 0)
    float fvgUpTop = ta.valuewhen(fvgUp, low, 0)
    float fvgUpBtm = ta.valuewhen(fvgUp, high[2], 0)
    int fvgUpStart = ta.valuewhen(fvgUp, time[2], 0)
    float fvgDnTop = ta.valuewhen(fvgDn, low[2], 0)
    float fvgDnBtm = ta.valuewhen(fvgDn, high, 0)
    int fvgDnStart = ta.valuewhen(fvgDn, time[2], 0)
    float obUpQ = ta.valuewhen(obUp, get_pdarray_quality_pct(obUpQTop, obUpQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float obDnQ = ta.valuewhen(obDn, get_pdarray_quality_pct(obDnQTop, obDnQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float fvgUpQ = ta.valuewhen(fvgUp, get_pdarray_quality_pct(fvgUpQTop, fvgUpQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float fvgDnQ = ta.valuewhen(fvgDn, get_pdarray_quality_pct(fvgDnQTop, fvgDnQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ]

// Builds one HTF SR snapshot tuple.
export get_htf_sr_snapshot(int srPivotLen) =>
    float srHi = ta.valuewhen(not na(ta.pivothigh(high, srPivotLen, srPivotLen)), ta.pivothigh(high, srPivotLen, srPivotLen), 0)
    float srLo = ta.valuewhen(not na(ta.pivotlow(low, srPivotLen, srPivotLen)), ta.pivotlow(low, srPivotLen, srPivotLen), 0)
    int srHiT = ta.valuewhen(not na(ta.pivothigh(high, srPivotLen, srPivotLen)), time[srPivotLen], 0)
    int srLoT = ta.valuewhen(not na(ta.pivotlow(low, srPivotLen, srPivotLen)), time[srPivotLen], 0)
    [srHi, srHiT, srLo, srLoT]

// Bundles HTF zone + SR snapshots in one tuple.
export get_htf_pdarray_sr_snapshot(int zoneFormationLockBars, ZoneQualityCfg zqCfg, int atrLen, int srPivotLen) =>
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ] = get_htf_pdarray_snapshot(zoneFormationLockBars, zqCfg, atrLen)
    [srHi, srHiT, srLo, srLoT] = get_htf_sr_snapshot(srPivotLen)
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ, srHi, srHiT, srLo, srLoT]

export has_zone_side_in_range_from_start(array<PDArray> zones, int startIdx, bool wantAbove, float refPrice) =>
    bool found = false
    int n = array.size(zones)
    if n > startIdx
        for i = startIdx to n - 1
            PDArray z = array.get(zones, i)
            bool typeOk = z.type == "OB" or z.type == "FVG"
            float mid = (z.top + z.bottom) * 0.5
            bool sideOk = wantAbove ? mid >= refPrice : mid <= refPrice
            if typeOk and sideOk
                found := true
                break
    found

export pick_htf_side_fallback(array<PDArray> zones, int startIdx, bool showTf, bool wantAbove, float refPrice, int recentTsCut, float minQualityPct, float lowPrice, float highPrice, float minTick,
 bool showType0, string type0, bool bull0, float top0, float btm0, int st0, float q0,
 bool showType1, string type1, bool bull1, float top1, float btm1, int st1, float q1,
 bool showType2, string type2, bool bull2, float top2, float btm2, int st2, float q2,
 bool showType3, string type3, bool bull3, float top3, float btm3, int st3, float q3) =>
    bool hasChoice = false
    string zType = ""
    bool isBull = false
    float top = na
    float btm = na
    int st = na
    float q = na
    if showTf and not has_zone_side_in_range_from_start(zones, startIdx, wantAbove, refPrice)
        int bestIdx = na
        float bestScore = na
        for i = 0 to 3
            bool showType = i == 0 ? showType0 : i == 1 ? showType1 : i == 2 ? showType2 : showType3
            string zType_i = i == 0 ? type0 : i == 1 ? type1 : i == 2 ? type2 : type3
            bool isBull_i = i == 0 ? bull0 : i == 1 ? bull1 : i == 2 ? bull2 : bull3
            float top_i = i == 0 ? top0 : i == 1 ? top1 : i == 2 ? top2 : top3
            float btm_i = i == 0 ? btm0 : i == 1 ? btm1 : i == 2 ? btm2 : btm3
            int st_i = i == 0 ? st0 : i == 1 ? st1 : i == 2 ? st2 : st3
            float q_i = i == 0 ? q0 : i == 1 ? q1 : i == 2 ? q2 : q3
            bool baseValid = showType and not na(st_i) and not na(top_i) and not na(btm_i) and top_i > btm_i
            float mid = (top_i + btm_i) * 0.5
            bool sideOk = wantAbove ? mid >= refPrice : mid <= refPrice
            if baseValid and sideOk
                bool recent = st_i >= recentTsCut
                bool qOk = nz(q_i, 0) >= minQualityPct
                bool unmitigated = isBull_i ? (lowPrice > top_i) : (highPrice < btm_i)
                float score = (recent ? 1000.0 : 0.0) + (qOk ? 100.0 : 0.0) + (unmitigated ? 10.0 : 0.0) - math.abs(mid - refPrice) / math.max(minTick, 0.0000001)
                if na(bestIdx) or score > bestScore
                    bestIdx := i
                    bestScore := score
        if not na(bestIdx)
            hasChoice := true
            zType := bestIdx == 0 ? type0 : bestIdx == 1 ? type1 : bestIdx == 2 ? type2 : type3
            isBull := bestIdx == 0 ? bull0 : bestIdx == 1 ? bull1 : bestIdx == 2 ? bull2 : bull3
            top := bestIdx == 0 ? top0 : bestIdx == 1 ? top1 : bestIdx == 2 ? top2 : top3
            btm := bestIdx == 0 ? btm0 : bestIdx == 1 ? btm1 : bestIdx == 2 ? btm2 : btm3
            st := bestIdx == 0 ? st0 : bestIdx == 1 ? st1 : bestIdx == 2 ? st2 : st3
            q := bestIdx == 0 ? q0 : bestIdx == 1 ? q1 : bestIdx == 2 ? q2 : q3
    [hasChoice, zType, isBull, top, btm, st, q]
