strategy("Hung - Core", overlay = true, scale = scale.right, max_bars_back = 5000, pyramiding = 20, process_orders_on_close = false, calc_on_order_fills = true, calc_on_every_tick = false, use_bar_magnifier = false, currency = currency.USD)

