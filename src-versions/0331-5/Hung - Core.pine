CORE_ENABLE_STRATEGY_VISUALS = true

get_ui_theme(KitCore.Theme th) =>
    KitUI.Theme.new(COLOR_BEARISH = th.COLOR_BEARISH, COLOR_BULLISH = th.COLOR_BULLISH, COLOR_NEUTRAL = th.COLOR_NEUTRAL, COLOR_TRANSPARENT = th.COLOR_TRANSPARENT, COLOR_UI_BG = th.COLOR_UI_BG, COLOR_UI_FG = th.COLOR_UI_FG, STYLE_LABEL_NONE = th.STYLE_LABEL_NONE, SIZE_TINY = th.SIZE_TINY, SIZE_SMALL = th.SIZE_SMALL, SIZE_NORMAL = th.SIZE_NORMAL)

get_data_local_technical_ctx(string tf) =>
    [atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down] = KitCore.get_data_technical(tf)
    KitCore.get_data_technical_ctx_from_tuple(atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down)

get_data_core_swings_snapshot_from_tf(KitSMC.TFData tfData) =>
    array<float> hi = array.new_float()
    array<int> hiT = array.new_int()
    array<float> lo = array.new_float()
    array<int> loT = array.new_int()
    if not na(tfData.mss.swings) and array.size(tfData.mss.swings) > 0
        for i = 0 to array.size(tfData.mss.swings) - 1
            KitSMC.Swing s = array.get(tfData.mss.swings, i)
            if s.isSwingHigh
                array.push(hi, s.price)
                array.push(hiT, s.time)
            else
                array.push(lo, s.price)
                array.push(loT, s.time)
    [hi, hiT, lo, loT]

get_data_core_structure_snapshot(KitSMC.TFData ltfData, KitSMC.TFData htf1Data, KitSMC.TFData htf2Data) =>
    snap = KitCore.StructureSnapshot.new()
    snap.dir0 := ltfData.mss.msBias != 0 ? ltfData.mss.msBias : ltfData.mss.prevBreakout
    [ltfHi, ltfHiT, ltfLo, ltfLoT] = get_data_core_swings_snapshot_from_tf(ltfData)
    [h1Hi, h1HiT, h1Lo, h1LoT] = get_data_core_swings_snapshot_from_tf(htf1Data)
    [h2Hi, h2HiT, h2Lo, h2LoT] = get_data_core_swings_snapshot_from_tf(htf2Data)
    snap.ltfSwingHighPrices := ltfHi
    snap.ltfSwingHighTimes := ltfHiT
    snap.ltfSwingLowPrices := ltfLo
    snap.ltfSwingLowTimes := ltfLoT
    snap.htf1SwingHighPrices := h1Hi
    snap.htf1SwingHighTimes := h1HiT
    snap.htf1SwingLowPrices := h1Lo
    snap.htf1SwingLowTimes := h1LoT
    snap.htf2SwingHighPrices := h2Hi
    snap.htf2SwingHighTimes := h2HiT
    snap.htf2SwingLowPrices := h2Lo
    snap.htf2SwingLowTimes := h2LoT
    snap

