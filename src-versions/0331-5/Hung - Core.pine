perfLookbackBars = WORKING_MAX_BARS // Unified working zone bars.

is_in_working_zone_current() =>
    not na(workingFirstBar) and bar_index >= workingFirstBar

is_in_working_zone_idx(int idx) =>
    not na(workingFirstBar) and not na(idx) and idx >= workingFirstBar

process_data_cache_ltf_bias_event(array<int> bars, array<float> vals, string dir, int scoreVal, int maxEvents) =>
    if dir == "Buy" or dir == "Sell"
        if array.size(bars) != array.size(vals)
            array.clear(bars)
            array.clear(vals)
        float baseScore = na(scoreVal) ? 1.0 : math.max(float(scoreVal), 1.0)
        float signedScore = (dir == "Buy" ? 1.0 : -1.0) * baseScore
        int n = array.size(bars)
        if n > 0
            int lastBar = array.get(bars, n - 1)
            if lastBar == bar_index
                array.set(vals, n - 1, array.get(vals, n - 1) + signedScore)
            else
                array.push(bars, bar_index)
                array.push(vals, signedScore)
        else
            array.push(bars, bar_index)
            array.push(vals, signedScore)
        while array.size(bars) > maxEvents and array.size(vals) > 0
            array.remove(bars, 0)
            array.remove(vals, 0)
    bool(na)

get_data_ltf_bias_memory_score(array<int> bars, array<float> vals, int windowBars) =>
    float out = 0.0
    int n = array.size(bars)
    int i = n - 1
    while i >= 0
        int age = bar_index - array.get(bars, i)
        if age > windowBars
            array.remove(bars, i)
            array.remove(vals, i)
        else
            float decay = 1.0 - (float(age) / float(math.max(windowBars, 1)))
            out += array.get(vals, i) * math.max(decay, 0.0)
        i -= 1
    out

