ENTRY_MODE_AFTER_RETEST = "AFTER RETEST"
TRIGGER_TYPE_SIGNAL = "Signal"
TRIGGER_TYPE_TRADE = "Trade"
TRIGGER_WHEN_TOUCH = "Touch"
TRIGGER_WHEN_RETEST = "Retest"
SIG_METRIC_COUNT = 3

