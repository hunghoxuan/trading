//@version=5
// @file-version: 0327-35
indicator("Hung - MSS", overlay = true, scale = scale.right, max_bars_back = 5000, dynamic_requests = true)

import hunghoxuan/KitCore/9 as CORE
import hunghoxuan/KitUI/8 as UI
import hunghoxuan/KitSMC/8 as SMC

WORKING_MAX_BARS = 672

// ==================== CONSTANTS (LOGIC) ====================
// Library singletons (persistent)
var THEME = CORE.Theme.new()
var SETTINGS = CORE.Settings.new()
var CONST = CORE.Const.new()

// ==================== VISUAL CONFIG OVERRIDES (SINGLE SOURCE OF TRUTH) ====================
// Keep all indicator-level visual overrides in this section (no inline cfg.new in logic).

// Persistent runtime state across bars.
var array<CORE.Trade> trades = array.new<CORE.Trade>()

// UI theme-derived colors (declared after THEME exists).
type LocalCfg
    // Detection
    int detMethod = 0 // 0 = state, 1 = cross.
    int detMethodCross = 1 // Cross method value.
    string detBasis = "Wick" // Wick/Close basis.
    bool detUseImpulse = false // Enable impulse filter.
    float detImpulseAtr = 0.5 // Impulse threshold in ATR.
    // Limitations
    float limZoneMinHeightAtr = 0.05 // Min zone height in ATR.
    float limSrTolAtrMult = 0.25 // SR merge/touch tolerance in ATR.
    float limSrNearbyMergeMult = 2.0 // SR min-distance multiplier for de-dup.
    float limSrTouchBandAtrMult = 0.10 // SR touch band in ATR.
    float limSrTouchBandMinTicks = 2.0 // SR touch band minimum ticks.
    int limSrTouchCountCooldownBars = 2 // Cooldown between SR touch increments.
    int limSrSeedSwingsPerTf = 2 // Number of latest swings used as SR seeds per TF.
    // LIQ label behavior (non-UI configurable defaults).
    string liqDollarXPos = "Right" // Left/Middle/Right.
    string liqDollarYPos = "Center" // Above/Center/Below.
    bool liqHideOverlapByTf = true // Hide weaker overlapped HTF markers.
    float liqDollarYOffsetTicks = 4.0 // Y offset in ticks for $ label.
    float liqOverlapTolAtrMult = 0.03 // Overlap tolerance in ATR.
    string liqOverlapScope = "Dollar Only" // Dollar Only/All LIQ.
    // MSS reclass
    int msReclassBars = 3 // Mutable window in bars for BOS/MSS reclass.
    string msReclassBasis = "Close" // Reclass basis: Close/Wick.
    string msInvalidMarkerMode = "Marker" // Marker/Event output mode.

type UIConfig
    color colorText = color.white // Generic text color.
    color ltfColor = color.gray // Base-TF color.
    int ltfLineBarsExt = 8 // LTF line extension.
    bool msShowSwings = true // Show base-TF swings by default.
    bool msShowZigzag = true // Show base-TF zigzag by default.
    bool msHtf1SwingShow = true // Show HTF1 swings by default.
    bool msHtf1ZigzagShow = true // Show HTF1 zigzag by default.
    bool msHtf2SwingShow = true // Show HTF2 swings by default.
    bool msHtf2ZigzagShow = true // Show HTF2 zigzag by default.
    int zoneCurrMinWidthBars = 6 // Minimum zone width in bars.

get_data_local_cfg() =>
    LocalCfg cfg = LocalCfg.new()
    cfg

get_ui_cfg(CORE.Theme th) =>
    UIConfig cfg = UIConfig.new()
    cfg.colorText := color.new(th.TEXT_COLOR, th.T_NORMAL)
    cfg.ltfColor := color.new(color.rgb(215, 215, 215), 0)
    cfg

// PIVOTS: base/current and HTF-mimic model.
PIVOT_LEN_SCALP = 15 // <= 5m
PIVOT_LEN_INTRADAY = 12 // > 5m and <= 1h
PIVOT_LEN_MULTI_DAY = 8 // > 1h and <= 4h
PIVOT_LEN_SWING = 6 // > 4h and <= 1D
PIVOT_LEN_POSITION = 4 // > 1D
PIVOT_LEN_BASE = "" == CONST.PIVOT_MODE_FIXED ? 10 :
 (CORE.get_tf_seconds(timeframe.period) <= 300 ? PIVOT_LEN_SCALP :
  CORE.get_tf_seconds(timeframe.period) <= 3600 ? PIVOT_LEN_INTRADAY :
  CORE.get_tf_seconds(timeframe.period) <= 14400 ? PIVOT_LEN_MULTI_DAY :
  CORE.get_tf_seconds(timeframe.period) <= 86400 ? PIVOT_LEN_SWING : PIVOT_LEN_POSITION)

SR_SOURCE_PRIO_LTF = 1
SR_SOURCE_PRIO_HTF1 = 2
SR_SOURCE_PRIO_HTF2 = 3

// BREAK: detection mode and sensitivity basis.

// Active trading area: auto from nearest HTF1 swings around current price.

HL_KIND_LIQ = 0
HL_KIND_SR = 2

ENTRY_MODE_OFF = "NO ENTRY"
