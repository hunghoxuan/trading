if barstate.isfirst
    localCfg := get_data_local_cfg()
    uiCfg := get_ui_cfg(THEME)
    ZONE_VIS_CFG.minWidthBars := uiCfg.zoneCurrMinWidthBars

// ==================== FEATURES ====================

get_data_color_sig(color c) =>
    str.tostring(color.r(c)) + ":" + str.tostring(color.g(c)) + ":" + str.tostring(color.b(c)) + ":" + str.tostring(color.t(c))

// LIQ-specific swept flag (separate semantics from generic lifecycle touched state).
get_data_is_liq_swept(CORE.PDArray z) =>
    CORE.is_life_broken(z.lifeState, CONST) or CORE.is_life_reclaimed(z.lifeState, CONST)

get_data_tf_priority(string tfLbl) =>
    [tf1Local, tf2Local] = CORE.get_htf_pair()
    tfLbl == tf2Local ? 3 : tfLbl == tf1Local ? 2 : tfLbl == timeframe.period ? 1 : 0

get_data_liq_label_align(string liqTxt) =>
    if liqTxt != "$"
        text.align_center
    else
        localCfg.liqDollarXPos == "Right" ? text.align_right : localCfg.liqDollarXPos == "Left" ? text.align_left : text.align_center

get_data_liq_label_y(string liqTxt, float basePrice) =>
    if liqTxt != "$"
        basePrice
    else
        float yPad = syminfo.mintick * math.max(localCfg.liqDollarYOffsetTicks, 0.0)
        localCfg.liqDollarYPos == "Above" ? (basePrice + yPad) : localCfg.liqDollarYPos == "Below" ? (basePrice - yPad) : basePrice

get_data_liq_label_x(line liqLine, string liqTxt) =>
    int x1 = liqLine.get_x1()
    int x2 = liqLine.get_x2()
    int midX = int(math.round((x1 + x2) * 0.5))
    if liqTxt != "$"
        midX
    else
        localCfg.liqDollarXPos == "Right" ? x2 : localCfg.liqDollarXPos == "Left" ? x1 : midX

get_data_liq_has_stronger_overlap(array<CORE.PDArray> levels, int selfIdx, CORE.PDArray self, float tolPrice) =>
    bool hasStronger = false
    int selfPrio = get_data_tf_priority(self.labelText)
    bool scopeDollarOnly = localCfg.liqOverlapScope == "Dollar Only"
    bool selfIsDollar = self.labelText != timeframe.period
    if array.size(levels) > 0
        for j = 0 to array.size(levels) - 1
            if j == selfIdx
                continue
            CORE.PDArray other = array.get(levels, j)
            bool sameFamily = other.type == "LIQ"
            bool otherIsDollar = other.labelText != timeframe.period
            bool scopeOk = scopeDollarOnly ? (selfIsDollar and otherIsDollar) : true
            bool near = math.abs(other.price - self.price) <= tolPrice
            bool active = not get_data_is_liq_swept(other)
            if sameFamily and scopeOk and near and active
                int otherPrio = get_data_tf_priority(other.labelText)
                if otherPrio > selfPrio
                    hasStronger := true
                    break
    hasStronger

get_data_required_events_preset(string modelKey) =>
    string k = str.upper(modelKey)
    k == "SWEEP_MSS" ? "SWEEP,MSS" : k == "SWEEP_MSS_FVG" ? "SWEEP,MSS,BOS" : ""

process_data_init_strategy_defs() =>
    array.clear(strategyDefs)
    array.push(strategyDefs, CORE.EntryModelDef.new("MSS", "MS", 3, modelMss, modelMssType, modelMssWhen, 2.0, "edge", 1, 1, 0, get_data_required_events_preset("MSS"), 100, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, CORE.EntryModelDef.new("BOS", "BO", 2, modelBos, modelBosType, modelBosWhen, 1.8, "edge", 1, 1, 0, get_data_required_events_preset("BOS"), 100, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, CORE.EntryModelDef.new("SWEEP", "SW", 6, modelSweep, modelSweepType, modelSweepWhen, 2.2, "edge", 1, 0, 0, get_data_required_events_preset("SWEEP"), 100, "na", 2, true, 0.20, ENTRY_MODE_LIMIT))
    array.push(strategyDefs, CORE.EntryModelDef.new("SWEEP_MSS", "SW", 6, modelSweepMss, modelSweepMssType, modelSweepMssWhen, 2.4, "edge", 1, 0, 0, get_data_required_events_preset("SWEEP_MSS"), 100, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, CORE.EntryModelDef.new("SWEEP_MSS_FVG", "SW", 7, modelSweepMssFvg, modelSweepMssFvgType, modelSweepMssFvgWhen, 2.6, "middle", 1, 0, 0, get_data_required_events_preset("SWEEP_MSS_FVG"), 140, "na", 1, true, 0.16, ENTRY_MODE_AFTER_RETEST))
    bool(na)

get_data_trigger_type_code(string v) =>
    v == TRIGGER_TYPE_SIGNAL ? 1 : 2

get_data_trigger_when_code(string v) =>
    v == TRIGGER_WHEN_TOUCH ? 1 : 2

get_data_strategy_defs_sig() =>
    int sig = 0
    sig += (modelMss ? 1 : 0) * 100000 + get_data_trigger_type_code(modelMssType) * 10000 + get_data_trigger_when_code(modelMssWhen) * 1000
    sig += (modelBos ? 1 : 0) * 100 + get_data_trigger_type_code(modelBosType) * 10 + get_data_trigger_when_code(modelBosWhen)
    sig += (modelSweep ? 1 : 0) * 31 + get_data_trigger_type_code(modelSweepType) * 37 + get_data_trigger_when_code(modelSweepWhen) * 41
    sig += (modelSweepMss ? 1 : 0) * 43 + get_data_trigger_type_code(modelSweepMssType) * 47 + get_data_trigger_when_code(modelSweepMssWhen) * 53
    sig += (modelSweepMssFvg ? 1 : 0) * 59 + get_data_trigger_type_code(modelSweepMssFvgType) * 61 + get_data_trigger_when_code(modelSweepMssFvgWhen) * 67
    sig

process_data_refresh_strategy_defs() =>
    int nextSig = get_data_strategy_defs_sig()
    int cachedSig = array.get(strategyDefsSigBox, 0)
    if na(cachedSig) or cachedSig != nextSig or array.size(strategyDefs) == 0
        process_data_init_strategy_defs()
        array.set(strategyDefsSigBox, 0, nextSig)
    bool(na)

process_data_reset_runtime_context_if_new_bar() =>
    int cachedBar = array.get(rtBarBox, 0)
    if na(cachedBar) or cachedBar != bar_index
        array.set(rtBarBox, 0, bar_index)
        array.clear(rtStrategyKeys)
        array.clear(rtStrategyEnabled)
        array.clear(rtStrategyScore)
        array.clear(rtStrategyShort)
        array.clear(rtStrategyTriggerType)
        array.clear(rtStrategyTriggerWhen)
        array.clear(rtTimeToIdxKeys)
        array.clear(rtTimeToIdxVals)
        array.clear(rtFvgScanKeys)
        array.clear(rtFvgScanTopVals)
        array.clear(rtFvgScanBtmVals)
        array.clear(rtFvgScanBarVals)
    bool(na)

get_data_strategy_meta_by_key(string key) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(key)
    process_data_reset_runtime_context_if_new_bar()
    int cachedIdx = na
    if array.size(rtStrategyKeys) > 0
        for i = 0 to array.size(rtStrategyKeys) - 1
            if array.get(rtStrategyKeys, i) == k
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtStrategyEnabled, cachedIdx), array.get(rtStrategyScore, cachedIdx), array.get(rtStrategyShort, cachedIdx), array.get(rtStrategyTriggerType, cachedIdx), array.get(rtStrategyTriggerWhen, cachedIdx)]
    else
        bool enabled = false
        int score = 0
        string shortName = ""
        string triggerType = TRIGGER_TYPE_TRADE
        string triggerWhen = TRIGGER_WHEN_RETEST
        for i = 0 to array.size(strategyDefs) - 1
            CORE.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                enabled := s.enabled
                score := s.baseScore
                shortName := s.shortName
                triggerType := s.trigger_type
                triggerWhen := s.trigger_when
                break
        array.push(rtStrategyKeys, k)
        array.push(rtStrategyEnabled, enabled)
        array.push(rtStrategyScore, score)
        array.push(rtStrategyShort, shortName)
        array.push(rtStrategyTriggerType, triggerType)
        array.push(rtStrategyTriggerWhen, triggerWhen)
        [enabled, score, shortName, triggerType, triggerWhen]

get_data_cached_bar_index_from_time(int t) =>
    process_data_reset_runtime_context_if_new_bar()
    if na(t)
        na
    else
        int idx = na
        if array.size(rtTimeToIdxKeys) > 0
            for i = 0 to array.size(rtTimeToIdxKeys) - 1
                if array.get(rtTimeToIdxKeys, i) == t
                    idx := i
                    break
        if not na(idx)
            array.get(rtTimeToIdxVals, idx)
        else
            int v = CORE.closest_bar_index_from_time(t)
            array.push(rtTimeToIdxKeys, t)
            array.push(rtTimeToIdxVals, v)
            v

process_data_refresh_tf_leg_state(CORE.TFData tfData) =>
    if not na(tfData.legEventTime) and tfData.legEventTime != tfData.legLastEventSeen
        tfData.legId += 1
        tfData.legDir := tfData.prevBreakout
        tfData.legSeqAll := 0
        tfData.legSeqOb := 0
        tfData.legSeqFvg := 0
        tfData.legSeqRjb := 0
        tfData.legSeqLevel := 0
        tfData.legLastEventSeen := tfData.legEventTime

get_data_ms_track_slot(string tfName) =>
    int slot = na
    if array.size(msTrackTf) > 0
        for i = 0 to array.size(msTrackTf) - 1
            if array.get(msTrackTf, i) == tfName
                slot := i
                break
    if na(slot)
        array.push(msTrackTf, tfName)
        array.push(msTrackLine, na)
        array.push(msTrackLabel, na)
        array.push(msTrackLevel, na)
        array.push(msTrackDir, 0)
        array.push(msTrackBar, na)
        array.push(msTrackActive, false)
        slot := array.size(msTrackTf) - 1
    slot

process_data_clear_ms_track_slot(int slot) =>
    array.set(msTrackLine, slot, na)
    array.set(msTrackLabel, slot, na)
    array.set(msTrackLevel, slot, na)
    array.set(msTrackDir, slot, 0)
    array.set(msTrackBar, slot, na)
    array.set(msTrackActive, slot, false)
    bool(na)

get_data_ms_reclass_invalidated(int dir, float lvl) =>
    bool useWick = localCfg.msReclassBasis == "Wick"
    dir == 1 ? (useWick ? low < lvl : close < lvl) : (useWick ? high > lvl : close > lvl)

process_data_register_ms_track(string tfName, line evtLine, label evtLabel, float level, int direction) =>
    int slot = get_data_ms_track_slot(tfName)
    array.set(msTrackLine, slot, evtLine)
    array.set(msTrackLabel, slot, evtLabel)
    array.set(msTrackLevel, slot, level)
    array.set(msTrackDir, slot, direction)
    array.set(msTrackBar, slot, bar_index)
    array.set(msTrackActive, slot, true)
    bool(na)

process_data_update_ms_track(string tfName) =>
    int slot = get_data_ms_track_slot(tfName)
    bool active = array.get(msTrackActive, slot)
    if not active
        bool(na)
    else
        int bornBar = array.get(msTrackBar, slot)
        int ageBars = na(bornBar) ? 1000000 : (bar_index - bornBar)
        if ageBars > localCfg.msReclassBars
            process_data_clear_ms_track_slot(slot)
        else
            float lvl = array.get(msTrackLevel, slot)
            int dir = array.get(msTrackDir, slot)
            bool invalidated = get_data_ms_reclass_invalidated(dir, lvl)
            if invalidated
                line evtLine = array.get(msTrackLine, slot)
                label evtLabel = array.get(msTrackLabel, slot)
                if not na(evtLine)
                    evtLine.set_style(line.style_dotted)
                if not na(evtLabel)
                    string oldTxt = evtLabel.get_text()
                    string cleanTxt = str.replace(oldTxt, " x", "")
                    if evtLabel.get_text() != cleanTxt
                        evtLabel.set_text(cleanTxt)
                string invDir = dir == 1 ? "Sell" : "Buy"
                string invIcon = dir == -1 ? "X↑" : "X"
                string invTip = "BOS/MSS invalidated (reclaim through level)"
                UI.draw_strategy_marker(true, localCfg.msInvalidMarkerMode, invDir, invIcon, invTip, THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
                process_data_clear_ms_track_slot(slot)
    bool(na)

// Lightweight MS trend updater (data-only, no visuals).
// Cost: O(1) per TF per bar (reads latest swing high/low only).
process_data_tf_ms_trend_light(CORE.TFData tfData, bool enabled, CORE.MarketStructure ms) =>
    if not enabled
        bool(na)
    else
        [lastHi, msHiTUnused, lastLo, msLoTUnused] = CORE.market_structure_latest_hilo(ms)
        bool breakUp = not na(lastHi) and close > lastHi
        bool breakDn = not na(lastLo) and close < lastLo
        int nextDir = tfData.prevBreakout
        if breakUp and not breakDn
            nextDir := 1
        else if breakDn and not breakUp
            nextDir := -1
        if nextDir != tfData.prevBreakout and nextDir != 0
            tfData.prevBreakout := nextDir
            tfData.msBias := nextDir
            tfData.legEventTime := time
        else if tfData.msBias == 0 and tfData.prevBreakout != 0
            tfData.msBias := tfData.prevBreakout
        process_data_refresh_tf_leg_state(tfData)
        bool(na)

direction_allowed_raw(string direction, int memDir) =>
    bool allowMem = memDir == 0 or (direction == "Buy" and memDir == 1) or (direction == "Sell" and memDir == -1)
    allowMem

MSS_get_entry_model_dynamic_cfg(string modelKey) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(modelKey)
    float rrCfg = 2.0
    string entryPoint = "edge"
    int biasLtfMode = 1
    int biasHtf1Mode = 0
    int biasHtf2Mode = 0
    string requiredPrevEvents = ""
    int requiredWindowBars = 100
    string biasDirection = "na"
    int maxActiveCfg = 1
    bool dynamicTpCfg = true
    float riskZonePctCfg = 0.20
    string entryModeCfg = ENTRY_MODE_AFTER_RETEST
    if array.size(strategyDefs) > 0
        for i = 0 to array.size(strategyDefs) - 1
            CORE.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                rrCfg := s.rr
                entryPoint := s.entry_point
                biasLtfMode := s.bias_ltf
                biasHtf1Mode := s.bias_htf1
                biasHtf2Mode := s.bias_htf2
                requiredPrevEvents := s.required_previous_events
                requiredWindowBars := s.required_window_bars
                biasDirection := s.bias_direction
                maxActiveCfg := s.max_active
                dynamicTpCfg := s.dynamic_tp_sl
                riskZonePctCfg := s.risk_zone_pct
                entryModeCfg := s.entry_mode
                break
    [rrCfg, entryPoint, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, maxActiveCfg, dynamicTpCfg, riskZonePctCfg, entryModeCfg]

MSS_check_direction_by_mode(string direction, int mode, int trendVal, int biasVal, bool allowPullback) =>
    mode == 0 ? true : mode == 1 ? SMC.direction_matches_bias(direction, allowPullback ? (biasVal != 0 ? biasVal : trendVal) : (trendVal != 0 ? trendVal : biasVal)) : SMC.direction_matches_bias(direction, biasVal)

MSS_has_pullback_preference(int biasLtfMode, int biasHtf1Mode, int biasHtf2Mode) =>
    biasLtfMode == 2 or biasHtf1Mode == 2 or biasHtf2Mode == 2

MSS_has_recent_signal_event(string eventType, int lookbackBars) =>
    bool hit = false
    int n = array.size(chartCtx.signalHist)
    if n > 0
        for i = n - 1 to 0
            CORE.Event ev = array.get(chartCtx.signalHist, i)
            if (bar_index - ev.barDetected) <= lookbackBars and str.upper(ev.type) == eventType
                hit := true
                break
    hit

MSS_normalize_required_events(string requiredPrevEvents) =>
    string req = str.upper(requiredPrevEvents)
    req := str.replace_all(req, " ", "")
    req := str.replace_all(req, "|", ",")
    req := str.replace_all(req, "+", ",")
    req := str.replace_all(req, ";", ",")
    req := str.replace_all(req, "/", ",")
    req

MSS_resolve_event_alias(string tokenRaw) =>
    string t = str.upper(tokenRaw)
    t == "MS" ? "MSS" : t == "BO" ? "BOS" : t == "SW" ? "SWEEP" : t

MSS_check_required_previous_events(string requiredPrevEvents, int lookbackBars) =>
    string norm = MSS_normalize_required_events(requiredPrevEvents)
    if str.length(norm) == 0
        true
    else
        bool ok = true
        array<string> toks = str.split(norm, ",")
        if array.size(toks) > 0
            for i = 0 to array.size(toks) - 1
                string token = MSS_resolve_event_alias(array.get(toks, i))
                if str.length(token) > 0
                    if not MSS_has_recent_signal_event(token, lookbackBars)
                        ok := false
                        break
        ok

MSS_check_entry_model_dynamic(string modelKey, string direction, int memDir) =>
    [_, _, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, _, _, _, _] = MSS_get_entry_model_dynamic_cfg(modelKey)
    int bLtf = array.get(tradeBiasVals, 0)
    int bH1 = array.get(tradeBiasVals, 1)
    int bH2 = array.get(tradeBiasVals, 2)
    int tLtf = array.get(tradeTrendVals, 0)
    int tH1 = array.get(tradeTrendVals, 1)
    int tH2 = array.get(tradeTrendVals, 2)
    bool allowPullback = MSS_has_pullback_preference(biasLtfMode, biasHtf1Mode, biasHtf2Mode)
    bool dirModeOk = MSS_check_direction_by_mode(direction, biasLtfMode, tLtf, bLtf, allowPullback) and MSS_check_direction_by_mode(direction, biasHtf1Mode, tH1, bH1, allowPullback) and MSS_check_direction_by_mode(direction, biasHtf2Mode, tH2, bH2, allowPullback)
    bool memOk = memDir == 0 or (direction == "Buy" and memDir == 1) or (direction == "Sell" and memDir == -1)
    string bd = str.upper(biasDirection)
    bool biasDirOk = bd == "" or bd == "NA" or (bd == "LONG" and direction == "Buy") or (bd == "SHORT" and direction == "Sell")
    bool requiredOk = MSS_check_required_previous_events(requiredPrevEvents, requiredWindowBars)
    dirModeOk and memOk and biasDirOk and requiredOk

entry_direction_allowed(string direction, int biasVal) =>
    int cachedBar = array.get(rtBarBox, 0)
    int cachedBias = array.get(rtBiasBox, 0)
    bool canUseCache = not na(cachedBar) and cachedBar == bar_index and cachedBias == biasVal
    if canUseCache
        direction == "Buy" ? array.get(rtAllowBuyBox, 0) == 1 : array.get(rtAllowSellBox, 0) == 1
    else
        direction_allowed_raw(direction, chartCtx.signalMemoryDir)

process_data_add_entry(string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal) =>
    bool isBuy = direction == "Buy"
    string modelKey = str.upper(type)
    [rrCfg, entryPointCfg, _, _, _, _, _, _, maxActiveCfg, _, riskZonePctCfg, entryModeCfg] = MSS_get_entry_model_dynamic_cfg(modelKey)
    bool passMax = CORE.count_start_trades(trades, CONST) < math.max(maxActiveCfg, 1)
    bool passDir = true
    bool passDynamic = MSS_check_entry_model_dynamic(modelKey, direction, chartCtx.signalMemoryDir)
    bool passEntryMode = entryModeCfg != ENTRY_MODE_OFF
    if passMax and passDir and passDynamic and passEntryMode
        float tick = syminfo.mintick
        float zoneTop = math.max(levelTop, levelBtm)
        float zoneBtm = math.min(levelTop, levelBtm)
        float rrUsed = math.max(rrCfg, 0.1)
        float zoneHeight = math.max(zoneTop - zoneBtm, tick)
        float riskDist = math.max(zoneHeight * math.max(riskZonePctCfg, 0.01), tick)
        float entry = entryPointCfg == "middle" ? ((zoneTop + zoneBtm) * 0.5) : entryPointCfg == "end" ? (isBuy ? zoneBtm : zoneTop) : (isBuy ? zoneTop : zoneBtm)
        float slRaw = isBuy ? zoneBtm : zoneTop
        float stoploss = isBuy ? (slRaw - riskDist) : (slRaw + riskDist)
        float takeprofit = isBuy ? (entry + riskDist * rrUsed) : (entry - riskDist * rrUsed)
        CORE.Trade e = CORE.create_trade_if_valid(direction, type, levelTop, levelBtm, entry, stoploss, takeprofit, rrUsed, bar_index, reason, scoreVal, CONST, tick)
        if not na(e)
            array.push(trades, e)
            SMC.cache_signal_memory_event(chartCtx.signalHist, CORE.Event.new(type, direction, levelTop, levelBtm, na, bar_index, int(na), false, reason, qualityPct, scoreVal), tick, 80)
    bool(na)

process_data_structure_from_ledger(CORE.TFData tfData, CORE.TFConfig cfg, string tfName, int recentTsCut, string htf1Name, string htf2Name, bool canEmitSignals, CORE.MarketStructure msSource) =>
    process_data_update_ms_track(tfName)
    bool highArmedNext = tfData.highArmed
    bool lowArmedNext = tfData.lowArmed
    int prevBreakoutNext = tfData.prevBreakout
    int msBiasNext = tfData.msBias
    bool highBroken = false
    bool lowBroken = false
    int highBreakIdx = na
    int lowBreakIdx = na
    float lastHigh = na
    int lastHighTime = na
    int lastHighIdx = na
    float lastLow = na
    int lastLowTime = na
    int lastLowIdx = na
    [msHi, msHiT, msLo, msLoT] = CORE.market_structure_latest_hilo(msSource)
    lastHigh := msHi
    lastHighTime := msHiT
    lastLow := msLo
    lastLowTime := msLoT
    lastHighIdx := not na(msHiT) ? get_data_cached_bar_index_from_time(msHiT) : na
    lastLowIdx := not na(msLoT) ? get_data_cached_bar_index_from_time(msLoT) : na

    if highArmedNext and not na(lastHigh) and high > lastHigh
        highBroken := true
        highBreakIdx := bar_index
        highArmedNext := false
    if lowArmedNext and not na(lastLow) and low < lastLow
        lowBroken := true
        lowBreakIdx := bar_index
        lowArmedNext := false

    bool highRecent = not na(lastHighTime) and lastHighTime >= recentTsCut
    bool lowRecent = not na(lastLowTime) and lastLowTime >= recentTsCut
    CORE.LineTextVisualCfg evtCfgUp = CORE.LineTextVisualCfg.new(lineStyle = cfg.zigzagStyle, lineWidth = math.max(cfg.zigzagWidth, 1), textSize = SMC.ms_get_tf_text_size(tfName, htf1Name, htf2Name), vPos = 0, yPadTicks = 0.0, xRatio = 0.5, xPadBars = 0, textAlign = text.align_center)
    CORE.LineTextVisualCfg evtCfgDn = CORE.LineTextVisualCfg.new(lineStyle = cfg.zigzagStyle, lineWidth = math.max(cfg.zigzagWidth, 1), textSize = SMC.ms_get_tf_text_size(tfName, htf1Name, htf2Name), vPos = -1, yPadTicks = 6.0, xRatio = 0.5, xPadBars = 0, textAlign = text.align_center)

    if msShowBosMss and highBroken and highRecent and is_in_working_zone_current()
        if SMC.ms_should_emit_structure_event(tfName, 1, lastHighTime, msEmitTf, msEmitSide, msEmitPivotTime)
            bool isMssUp = prevBreakoutNext == -1
            string eventTxt = (tfName == timeframe.period ? str.lower(isMssUp ? "MSS" : "BOS") : (isMssUp ? "MSS" : "BOS")) + " " + CONST.SYM_ARR2_UP
            int x1 = na(lastHighIdx) ? bar_index : lastHighIdx
            int x2 = na(highBreakIdx) ? bar_index : highBreakIdx
            [upEvtLine, upEvtLabel] = UI.draw_line_with_text(x1, lastHigh, x2, lastHigh, xloc.bar_index, color.new(cfg.zigzagColor, 55), eventTxt, true, color.new(cfg.zigzagColor, 0), "", evtCfgUp, THEME)
            process_data_register_ms_track(tfName, upEvtLine, upEvtLabel, lastHigh, 1)
            float msBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
            string evtType = isMssUp ? "MSS" : "BOS"
            string modelKeyUp = isMssUp ? "MSS" : "BOS"
            [enabledUp, scoreUp, shortUp, typeUp, whenUp] = get_data_strategy_meta_by_key(modelKeyUp)
            if canEmitSignals and enabledUp
                if typeUp == TRIGGER_TYPE_TRADE and whenUp == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(shortUp, "Buy", evtType + " up break", lastHigh + msBand, lastHigh - msBand, 100.0, scoreUp)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, shortUp, "Buy", evtType + " up break", lastHigh + msBand, lastHigh - msBand, 100.0, scoreUp, bar_index, syminfo.mintick, 80)
            if canEmitSignals and PSEUDO_SWEEP_FROM_BOS and not isMssUp
                array.set(pseudoBosBreakLvl, 0, lastHigh)
                array.set(pseudoBosBreakBar, 0, bar_index)
            prevBreakoutNext := 1
            msBiasNext := 1
            tfData.legEventTime := lastHighTime

    if msShowBosMss and lowBroken and lowRecent and is_in_working_zone_current()
        if SMC.ms_should_emit_structure_event(tfName, -1, lastLowTime, msEmitTf, msEmitSide, msEmitPivotTime)
            bool isMssDn = prevBreakoutNext == 1
            string eventTxt = (tfName == timeframe.period ? str.lower(isMssDn ? "MSS" : "BOS") : (isMssDn ? "MSS" : "BOS")) + " " + CONST.SYM_ARR2_DN
            int x1 = na(lastLowIdx) ? bar_index : lastLowIdx
            int x2 = na(lowBreakIdx) ? bar_index : lowBreakIdx
            [dnEvtLine, dnEvtLabel] = UI.draw_line_with_text(x1, lastLow, x2, lastLow, xloc.bar_index, color.new(cfg.zigzagColor, 55), eventTxt, true, color.new(cfg.zigzagColor, 0), "", evtCfgDn, THEME)
            process_data_register_ms_track(tfName, dnEvtLine, dnEvtLabel, lastLow, -1)
            float msBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
            string evtType = isMssDn ? "MSS" : "BOS"
            string modelKeyDn = isMssDn ? "MSS" : "BOS"
            [enabledDn, scoreDn, shortDn, typeDn, whenDn] = get_data_strategy_meta_by_key(modelKeyDn)
            if canEmitSignals and enabledDn
                if typeDn == TRIGGER_TYPE_TRADE and whenDn == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(shortDn, "Sell", evtType + " down break", lastLow + msBand, lastLow - msBand, 100.0, scoreDn)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, shortDn, "Sell", evtType + " down break", lastLow + msBand, lastLow - msBand, 100.0, scoreDn, bar_index, syminfo.mintick, 80)
            if canEmitSignals and PSEUDO_SWEEP_FROM_BOS and not isMssDn
                array.set(pseudoBosBreakLvl, 1, lastLow)
                array.set(pseudoBosBreakBar, 1, bar_index)
            prevBreakoutNext := -1
            msBiasNext := -1
            tfData.legEventTime := lastLowTime

    tfData.highArmed := highArmedNext
    tfData.lowArmed := lowArmedNext
    tfData.prevBreakout := prevBreakoutNext
    tfData.msBias := msBiasNext

process_data_market_structure(string htf1NameRaw, string htf2NameRaw, int currPivotOffSafe, int structRecentTsCut, int structRecentIdxCut, float currSh, float currSl, float sh1Mimic, float sl1Mimic, int sh1MimicT, int sl1MimicT, int sh1MimicIdx, int sl1MimicIdx, float sh2Mimic, float sl2Mimic, int sh2MimicT, int sl2MimicT, int sh2MimicIdx, int sl2MimicIdx, bool canEmitSignals) =>
    msLtfCfg.showSwings := msShowLtf and msShowSwings
    msLtfCfg.showZigzag := msShowLtf and msShowZigzag
    msHtf1Cfg.showSwings := msShowTf1 and msShowSwings
    msHtf1Cfg.showZigzag := msShowTf1 and msShowZigzag
    msHtf2Cfg.showSwings := msShowTf2 and msShowSwings
    msHtf2Cfg.showZigzag := msShowTf2 and msShowZigzag

    string htf1Name = na(htf1NameRaw) ? "" : htf1NameRaw
    string htf2Name = na(htf2NameRaw) ? "" : htf2NameRaw
    UI.process_tf_swing_markers(ltfData, msLtfCfg, true, timeframe.period, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentTsCut, CONST.SYM_DOT)
    UI.process_tf_swing_markers(htf1Data, msHtf1Cfg, not na(htf1NameRaw), htf1NameRaw, sh1Mimic, sh1MimicT, sh1MimicIdx, sl1Mimic, sl1MimicT, sl1MimicIdx, structRecentTsCut, CONST.SYM_DOT)
    UI.process_tf_swing_markers(htf2Data, msHtf2Cfg, not na(htf2NameRaw), htf2NameRaw, sh2Mimic, sh2MimicT, sh2MimicIdx, sl2Mimic, sl2MimicT, sl2MimicIdx, structRecentTsCut, CONST.SYM_DOT)

    UI.process_tf_zigzag_from_pivots(ltfData, msLtfCfg, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentIdxCut)
    UI.process_tf_zigzag_from_pivots(htf1Data, msHtf1Cfg, not na(htf1NameRaw), sh1Mimic, sh1MimicT, sh1MimicIdx, sl1Mimic, sl1MimicT, sl1MimicIdx, structRecentIdxCut)
    UI.process_tf_zigzag_from_pivots(htf2Data, msHtf2Cfg, not na(htf2NameRaw), sh2Mimic, sh2MimicT, sh2MimicIdx, sl2Mimic, sl2MimicT, sl2MimicIdx, structRecentIdxCut)

    process_data_structure_from_ledger(ltfData, msLtfCfg, timeframe.period, structRecentTsCut, htf1Name, htf2Name, canEmitSignals, ltfData.ms)
    if not na(htf1NameRaw)
        process_data_structure_from_ledger(htf1Data, msHtf1Cfg, htf1NameRaw, structRecentTsCut, htf1Name, htf2Name, canEmitSignals, htf1Data.ms)
    if not na(htf2NameRaw)
        process_data_structure_from_ledger(htf2Data, msHtf2Cfg, htf2NameRaw, structRecentTsCut, htf1Name, htf2Name, canEmitSignals, htf2Data.ms)
    bool(na)

get_data_label_size_for_source_tf(string sourceTf) =>
    [tf1, tf2] = CORE.get_htf_pair()
    sourceTf == tf2 ? THEME.SIZE_SMALL : sourceTf == tf1 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL

[htf1, htf2] = CORE.get_htf_pair()
process_data_chart_context() =>
    chartCfg.useBias := true
    chartCfg.allowLong := true
    chartCfg.allowShort := true
    chartCfg.showPending := signalShowPending
    chartCfg.showStart := signalShowStart
    chartCfg.showTp := signalShowTp
    chartCfg.showSl := signalShowSl
    ctxDataCfg.needBias := true
    ctxDataCfg.needMsTrendDirs := true
    ctxDataCfg.needPdPw := true
    ctxDataCfg.needPriceRange := true
    ctxDataCfg.needHtfCandles := false
    ctxDataCfg.needMsSwingArrays := true
    ctxDataCfg.initBiasFactorArrays := true
    ctxDataCfg.rangeLookbackBars := math.max(effectiveCurrLookbackBars, 50)
    CORE.ChartContext ctx = CORE.get_data_context(ctxDataCfg, SETTINGS, BIAS_TOG, chartCtx.zones, chartCtx.levels, chartCtx.events, chartCtx.signalHist, ltfData, htf1Data, htf2Data)
    string h1Name = ctx.htf1Name
    string h2Name = ctx.htf2Name
    int h1Bias = h1Name == "15" ? ctx.b15 : h1Name == "240" ? ctx.b240 : h1Name == "1D" ? ctx.b1d : h1Name == "1W" ? ctx.b1w : ctx.b0
    int h2Bias = h2Name == "15" ? ctx.b15 : h2Name == "240" ? ctx.b240 : h2Name == "1D" ? ctx.b1d : h2Name == "1W" ? ctx.b1w : ctx.b0
    int h1Trend = h1Name == "15" ? ctx.dir15 : h1Name == "240" ? ctx.dir240 : h1Name == "1D" ? ctx.dir1d : h1Name == "1W" ? ctx.dir1w : ctx.dir0
    int h2Trend = h2Name == "15" ? ctx.dir15 : h2Name == "240" ? ctx.dir240 : h2Name == "1D" ? ctx.dir1d : h2Name == "1W" ? ctx.dir1w : ctx.dir0
    array.set(tradeBiasVals, 0, ctx.b0)
    array.set(tradeBiasVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.b0 : h1Bias)
    array.set(tradeBiasVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.b0 : h2Bias)
    array.set(tradeTrendVals, 0, ctx.dir0)
    array.set(tradeTrendVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.dir0 : h1Trend)
    array.set(tradeTrendVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.dir0 : h2Trend)
    [memScore, memDir, bullCount, bearCount] = SMC.compute_signal_memory_bias(chartCtx.signalHist, 20)
    ctx.signalMemoryScore := memScore
    ctx.signalMemoryDir := memDir
    ctx.signalBullCount := bullCount
    ctx.signalBearCount := bearCount
    int effBias = ctx.activeBias
    if memDir != 0
        if effBias == 0
            effBias := memDir
        else if effBias != memDir
            effBias := 0
    ctx.biasVal := effBias
    process_data_reset_runtime_context_if_new_bar()
    array.set(rtBiasBox, 0, ctx.biasVal)
    array.set(rtAllowBuyBox, 0, direction_allowed_raw("Buy", memDir) ? 1 : 0)
    array.set(rtAllowSellBox, 0, direction_allowed_raw("Sell", memDir) ? 1 : 0)
    ctx

// Keep TF swing ledgers updated in ICT (data-only; no structure drawing here),
// because SR/LIQ/IDM/Sweep pipelines still seed from TFData swings.
runtimeCtx := CORE.update_runtime_context(runtimeCtx)
bool canEmitSignals = barstate.isconfirmed and runtimeCtx.tradeScanEnabled and entryEngineEnabled
bool calcOnClosedBar = barstate.ishistory or barstate.isconfirmed
if calcOnClosedBar
    int currPivotLen = PIVOT_LEN_BASE
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    int htf1MimicPivotLen = not na(htf1) ? CORE.get_mimic_pivot_len(timeframe.period, htf1, PIVOT_LEN_BASE, PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION) : na
    int htf2MimicPivotLen = not na(htf2) ? CORE.get_mimic_pivot_len(timeframe.period, htf2, PIVOT_LEN_BASE, PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION) : na
    int htf1PivotOffSafe = not na(htf1MimicPivotLen) ? math.max(0, math.min(htf1MimicPivotLen, maxSafeHistOff)) : na
    int htf2PivotOffSafe = not na(htf2MimicPivotLen) ? math.max(0, math.min(htf2MimicPivotLen, maxSafeHistOff)) : na
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    int htf1LenSafe = not na(htf1MimicPivotLen) ? htf1MimicPivotLen : currPivotLen
    float sh1Raw = ta.pivothigh(high, htf1LenSafe, htf1LenSafe)
    float sl1Raw = ta.pivotlow(low, htf1LenSafe, htf1LenSafe)
    float sh1Mimic = not na(htf1MimicPivotLen) ? sh1Raw : na
    float sl1Mimic = not na(htf1MimicPivotLen) ? sl1Raw : na
    int sh1MimicT = not na(sh1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
    int sl1MimicT = not na(sl1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
    int sh1MimicIdx = not na(sh1Mimic) and not na(htf1PivotOffSafe) ? bar_index[htf1PivotOffSafe] : na
    int sl1MimicIdx = not na(sl1Mimic) and not na(htf1PivotOffSafe) ? bar_index[htf1PivotOffSafe] : na
    int htf2LenSafe = not na(htf2MimicPivotLen) ? htf2MimicPivotLen : currPivotLen
    float sh2Raw = ta.pivothigh(high, htf2LenSafe, htf2LenSafe)
    float sl2Raw = ta.pivotlow(low, htf2LenSafe, htf2LenSafe)
    float sh2Mimic = not na(htf2MimicPivotLen) ? sh2Raw : na
    float sl2Mimic = not na(htf2MimicPivotLen) ? sl2Raw : na
    int sh2MimicT = not na(sh2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
    int sl2MimicT = not na(sl2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
    int sh2MimicIdx = not na(sh2Mimic) and not na(htf2PivotOffSafe) ? bar_index[htf2PivotOffSafe] : na
    int sl2MimicIdx = not na(sl2Mimic) and not na(htf2PivotOffSafe) ? bar_index[htf2PivotOffSafe] : na
    int structRecentTsCut = CORE.get_recent_time_cutoff(effectiveCurrLookbackBars)
    int structRecentIdxCut = get_working_first_bar()
    CORE.process_tf_armed_state(ltfData, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, SETTINGS.SWING_HISTORY_MAX)
    CORE.process_tf_armed_state(htf1Data, not na(htf1), sh1Mimic, int(sh1MimicT), sl1Mimic, int(sl1MimicT), SETTINGS.SWING_HISTORY_MAX)
    CORE.process_tf_armed_state(htf2Data, not na(htf2), sh2Mimic, int(sh2MimicT), sl2Mimic, int(sl2MimicT), SETTINGS.SWING_HISTORY_MAX)
    if na(htf1)
        CORE.market_structure_reset(htf1Data.ms)
    if na(htf2)
        CORE.market_structure_reset(htf2Data.ms)
    process_data_tf_ms_trend_light(ltfData, true, ltfData.ms)
    process_data_tf_ms_trend_light(htf1Data, not na(htf1), htf1Data.ms)
    process_data_tf_ms_trend_light(htf2Data, not na(htf2), htf2Data.ms)
    process_data_market_structure(htf1, htf2, currPivotOffSafe, structRecentTsCut, structRecentIdxCut, currSh, currSl, sh1Mimic, sl1Mimic, sh1MimicT, sl1MimicT, sh1MimicIdx, sl1MimicIdx, sh2Mimic, sl2Mimic, sh2MimicT, sl2MimicT, sh2MimicIdx, sl2MimicIdx, canEmitSignals)
    [h2LastHi, h2LastHiT, h2LastLo, h2LastLoT] = CORE.market_structure_latest_hilo(htf2Data.ms)
    int htf2SwingAnchorTs = CORE.get_latest_time4(h2LastHiT, h2LastLoT, int(na), int(na))
    bool recalcByHtf2 = not na(htf2) and ta.change(time(htf2)) != 0
    bool shouldDynRecalc = SETTINGS.DYN_LOOKBACK_ENABLE and (barstate.isfirst or recalcByHtf2) // Controls how often dynamic lookback/candle widths update.
    if shouldDynRecalc
        int dynHtf1Candles = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf1) ? CORE.get_candles_to_anchor(htf1, htf2SwingAnchorTs, SETTINGS.DYN_HTF1_CANDLES_MIN, SETTINGS.DYN_HTF1_CANDLES_MAX, SETTINGS.HTF_CANDLES_BASE) : SETTINGS.HTF_CANDLES_BASE
        int htf1SecForDyn = not na(htf1) ? math.max(CORE.get_tf_seconds(htf1), 1) : na
        int htf2SecForDyn = not na(htf2) ? math.max(CORE.get_tf_seconds(htf2), 1) : na
        float htf2PerHtf1Dyn = not na(htf1SecForDyn) and not na(htf2SecForDyn) and htf2SecForDyn > htf1SecForDyn ? float(htf2SecForDyn) / float(htf1SecForDyn) : na
        // Keep HTF1/HTF2 panels on equivalent time span:
        // pass-1: derive HTF2 from HTF1 / ratio
        int dynHtf2Candles = not na(htf2PerHtf1Dyn) ? int(math.round(float(dynHtf1Candles) / htf2PerHtf1Dyn)) : SETTINGS.DYN_HTF2_CANDLES_FALLBACK
        dynHtf2Candles := math.max(SETTINGS.DYN_HTF2_CANDLES_MIN, math.min(dynHtf2Candles, SETTINGS.DYN_HTF2_CANDLES_MAX))
        // pass-2: back-project HTF1 from HTF2 * ratio and keep the larger (stability against rounding loss)
        int dynHtf1FromHtf2 = not na(htf2PerHtf1Dyn) ? int(math.ceil(float(dynHtf2Candles) * htf2PerHtf1Dyn)) : dynHtf1Candles
        dynHtf1Candles := math.max(dynHtf1Candles, dynHtf1FromHtf2)
        dynHtf1Candles := math.max(SETTINGS.DYN_HTF1_CANDLES_MIN, math.min(dynHtf1Candles, SETTINGS.DYN_HTF1_CANDLES_MAX))
        int dynCurrLookbackBars = CORE.get_curr_lookback_from_htf2(htf2, dynHtf2Candles, SETTINGS.DYN_CURR_LOOKBACK_MIN_BARS, SETTINGS.DYN_CURR_LOOKBACK_MAX_BARS)
        dynCachedCurrLookbackBars := dynCurrLookbackBars
    effectiveCurrLookbackBars := SETTINGS.DYN_LOOKBACK_ENABLE ? dynCachedCurrLookbackBars : LOOKBACK_BARS_WORK // Master working lookback for pruning + keylevel lifecycle.
    effectiveCurrLookbackBars := math.max(bar_index - get_working_first_bar() + 1, 1)
    perfLookbackBars := effectiveCurrLookbackBars
    htfProjectionSpanBars := effectiveCurrLookbackBars
    workingFirstBar := get_working_first_bar()
    workingFirstBarLine := process_data_update_working_bar_line(workingFirstBarLine, workingFirstBar)
    int ltfOffSafe = math.max(0, math.min(math.min(bar_index - workingFirstBar, bar_index), 10000))
    int ltfFirstTime = int(time[ltfOffSafe])
    int htf1FirstTime = not na(htf1) ? get_data_working_first_time_for_source_tf(htf1) : na
    int htf2FirstTime = not na(htf2) ? get_data_working_first_time_for_source_tf(htf2) : na
    if not na(htf1FirstTime) and htf1FirstTime > ltfFirstTime
        htf1FirstTime := ltfFirstTime
    int htf2MaxTime = not na(htf1FirstTime) ? htf1FirstTime : ltfFirstTime
    if not na(htf2FirstTime) and htf2FirstTime > htf2MaxTime
        htf2FirstTime := htf2MaxTime
    int htf1FirstIdx = not na(htf1FirstTime) ? CORE.closest_bar_index_from_time(htf1FirstTime) : na
    int htf2FirstIdx = not na(htf2FirstTime) ? CORE.closest_bar_index_from_time(htf2FirstTime) : na
    if not na(htf1FirstIdx)
        workingFirstBarLineHtf1 := process_data_update_working_debug_line(workingFirstBarLineHtf1, htf1FirstIdx, THEME.COLOR_HTF1)
    if not na(htf2FirstIdx)
        workingFirstBarLineHtf2 := process_data_update_working_debug_line(workingFirstBarLineHtf2, htf2FirstIdx, THEME.COLOR_HTF2)
    process_data_prune_outside_working_zone_levels(chartCtx.levels)
    chartCtx := process_data_chart_context()

get_data_should_drop_level(CORE.PDArray z, int srcIdx) =>
    bar_index - srcIdx > effectiveCurrLookbackBars

get_data_first_fvg_between(int fromBar, int toBar, bool isBullFvg) =>
    process_data_reset_runtime_context_if_new_bar()
    string key = str.tostring(fromBar) + "|" + str.tostring(toBar) + "|" + (isBullFvg ? "1" : "0")
    int idx = na
    if array.size(rtFvgScanKeys) > 0
        for i = 0 to array.size(rtFvgScanKeys) - 1
            if array.get(rtFvgScanKeys, i) == key
                idx := i
                break
    if not na(idx)
        [array.get(rtFvgScanTopVals, idx), array.get(rtFvgScanBtmVals, idx), array.get(rtFvgScanBarVals, idx)]
    else
        float outTop = na
        float outBtm = na
        int outBar = na
        int maxScan = math.max(2, math.min(90, bar_index - 2))
        int bo = maxScan
        while bo >= 2
            int bIdx = bar_index - bo
            bool inRange = bIdx >= fromBar and bIdx <= toBar
            if inRange
                bool hasFvg = isBullFvg ? (low[bo] > high[bo + 2]) : (high[bo] < low[bo + 2])
                if hasFvg
                    outTop := isBullFvg ? low[bo] : low[bo + 2]
                    outBtm := isBullFvg ? high[bo + 2] : high[bo]
                    outBar := bIdx
                    break
            bo -= 1
        array.push(rtFvgScanKeys, key)
        array.push(rtFvgScanTopVals, outTop)
        array.push(rtFvgScanBtmVals, outBtm)
        array.push(rtFvgScanBarVals, outBar)
        [outTop, outBtm, outBar]

process_data_sweep_mss_fvg_model() =>
    [swEnabled, _, _, _, _] = get_data_strategy_meta_by_key("SWEEP")
    if not swEnabled
        bool(na)
    else
        int bearSweepBar = array.get(sweepMssBarState, 0)
        int bullSweepBar = array.get(sweepMssBarState, 1)
        int bearMssBar = array.get(sweepMssConfirmedState, 0)
        int bullMssBar = array.get(sweepMssConfirmedState, 1)
        float bearFvgTop = array.get(sweepMssFvgTopState, 0)
        float bullFvgTop = array.get(sweepMssFvgTopState, 1)
        float bearFvgBtm = array.get(sweepMssFvgBtmState, 0)
        float bullFvgBtm = array.get(sweepMssFvgBtmState, 1)

        int evN = array.size(chartCtx.events)
        if evN > 0
            for i = evN - 1 to 0
                CORE.Event e = array.get(chartCtx.events, i)
                if e.type == "SWEEP"
                    if e.direction == "Sell"
                        bearSweepBar := e.barDetected
                        bearMssBar := na
                        bearFvgTop := na
                        bearFvgBtm := na
                    else if e.direction == "Buy"
                        bullSweepBar := e.barDetected
                        bullMssBar := na
                        bullFvgTop := na
                        bullFvgBtm := na
                    array.remove(chartCtx.events, i)

        int chochBarsLimit = 50
        int fvgWaitMaxBars = 80
        int lastLtfLegBar = get_data_cached_bar_index_from_time(ltfData.legEventTime)
        [swMsEnabled, swMsScore, swMsShort, swMsType, swMsWhen] = get_data_strategy_meta_by_key("SWEEP_MSS")
        [swFvgEnabled, swFvgScore, swFvgShort, swFvgType, swFvgWhen] = get_data_strategy_meta_by_key("SWEEP_MSS_FVG")

        bool bearSweepValid = not na(bearSweepBar) and (bar_index - bearSweepBar) <= chochBarsLimit
        bool bullSweepValid = not na(bullSweepBar) and (bar_index - bullSweepBar) <= chochBarsLimit

        if bearSweepValid and ltfData.msBias == -1 and lastLtfLegBar > bearSweepBar and na(bearMssBar)
            bearMssBar := bar_index
            [ft, fb, _] = get_data_first_fvg_between(bearSweepBar, lastLtfLegBar, false)
            bearFvgTop := ft
            bearFvgBtm := fb
            if swMsEnabled and entry_direction_allowed("Sell", chartCtx.biasVal)
                float mssBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
                [ltfLastHiForBear, ltfLastHiTForBear, ltfLastLoForBear, ltfLastLoTForBear] = CORE.market_structure_latest_hilo(ltfData.ms)
                float mssLvl = not na(ltfLastLoForBear) ? ltfLastLoForBear : close
                if swMsType == TRIGGER_TYPE_TRADE and swMsWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swMsShort, "Sell", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, swMsShort, "Sell", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore, bar_index, syminfo.mintick, 80)

        if bullSweepValid and ltfData.msBias == 1 and lastLtfLegBar > bullSweepBar and na(bullMssBar)
            bullMssBar := bar_index
            [ft, fb, _] = get_data_first_fvg_between(bullSweepBar, lastLtfLegBar, true)
            bullFvgTop := ft
            bullFvgBtm := fb
            if swMsEnabled and entry_direction_allowed("Buy", chartCtx.biasVal)
                float mssBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
                [ltfLastHiForBull, ltfLastHiTForBull, ltfLastLoForBull, ltfLastLoTForBull] = CORE.market_structure_latest_hilo(ltfData.ms)
                float mssLvl = not na(ltfLastHiForBull) ? ltfLastHiForBull : close
                if swMsType == TRIGGER_TYPE_TRADE and swMsWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swMsShort, "Buy", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, swMsShort, "Buy", "Sweep -> MSS", mssLvl + mssBand, mssLvl - mssBand, 100.0, swMsScore, bar_index, syminfo.mintick, 80)

        bool bearMssActive = not na(bearMssBar) and (bar_index - bearMssBar) <= fvgWaitMaxBars
        bool bullMssActive = not na(bullMssBar) and (bar_index - bullMssBar) <= fvgWaitMaxBars

        if swFvgEnabled and bearMssActive
            if na(bearFvgTop) or na(bearFvgBtm)
                [ft, fb, _] = get_data_first_fvg_between(bearSweepBar, bar_index, false)
                bearFvgTop := ft
                bearFvgBtm := fb
            bool pullbackBear = close > open or high > high[1]
            bool touchedBearFvg = not na(bearFvgTop) and not na(bearFvgBtm) and pullbackBear and SMC.check_touch(bearFvgTop, bearFvgBtm, localCfg.detBasis, open, high, low, close)
            if touchedBearFvg and entry_direction_allowed("Sell", chartCtx.biasVal)
                if swFvgType == TRIGGER_TYPE_TRADE and swFvgWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swFvgShort, "Sell", "Sweep -> MSS -> first FVG touch", bearFvgTop, bearFvgBtm, 100.0, swFvgScore)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, swFvgShort, "Sell", "Sweep -> MSS -> first FVG touch", bearFvgTop, bearFvgBtm, 100.0, swFvgScore, bar_index, syminfo.mintick, 80)
                bearSweepBar := na
                bearMssBar := na
                bearFvgTop := na
                bearFvgBtm := na
        else if not bearMssActive and not na(bearMssBar)
            bearSweepBar := na
            bearMssBar := na
            bearFvgTop := na
            bearFvgBtm := na

        if swFvgEnabled and bullMssActive
            if na(bullFvgTop) or na(bullFvgBtm)
                [ft, fb, _] = get_data_first_fvg_between(bullSweepBar, bar_index, true)
                bullFvgTop := ft
                bullFvgBtm := fb
            bool pullbackBull = close < open or low < low[1]
            bool touchedBullFvg = not na(bullFvgTop) and not na(bullFvgBtm) and pullbackBull and SMC.check_touch(bullFvgTop, bullFvgBtm, localCfg.detBasis, open, high, low, close)
            if touchedBullFvg and entry_direction_allowed("Buy", chartCtx.biasVal)
                if swFvgType == TRIGGER_TYPE_TRADE and swFvgWhen == TRIGGER_WHEN_TOUCH
                    process_data_add_entry(swFvgShort, "Buy", "Sweep -> MSS -> first FVG touch", bullFvgTop, bullFvgBtm, 100.0, swFvgScore)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, swFvgShort, "Buy", "Sweep -> MSS -> first FVG touch", bullFvgTop, bullFvgBtm, 100.0, swFvgScore, bar_index, syminfo.mintick, 80)
                bullSweepBar := na
                bullMssBar := na
                bullFvgTop := na
                bullFvgBtm := na
        else if not bullMssActive and not na(bullMssBar)
            bullSweepBar := na
            bullMssBar := na
            bullFvgTop := na
            bullFvgBtm := na

        array.set(sweepMssBarState, 0, bearSweepBar)
        array.set(sweepMssBarState, 1, bullSweepBar)
        array.set(sweepMssConfirmedState, 0, bearMssBar)
        array.set(sweepMssConfirmedState, 1, bullMssBar)
        array.set(sweepMssFvgTopState, 0, bearFvgTop)
        array.set(sweepMssFvgTopState, 1, bullFvgTop)
        array.set(sweepMssFvgBtmState, 0, bearFvgBtm)
        array.set(sweepMssFvgBtmState, 1, bullFvgBtm)
        bool(na)

process_data_pseudo_sweep_from_bos() =>
    if not PSEUDO_SWEEP_FROM_BOS
        bool(na)
    else
        float upLvl = array.get(pseudoBosBreakLvl, 0)
        float dnLvl = array.get(pseudoBosBreakLvl, 1)
        int upBar = array.get(pseudoBosBreakBar, 0)
        int dnBar = array.get(pseudoBosBreakBar, 1)

        bool upActive = not na(upLvl) and not na(upBar) and (bar_index - upBar) <= PSEUDO_SWEEP_RECLAIM_BARS
        bool dnActive = not na(dnLvl) and not na(dnBar) and (bar_index - dnBar) <= PSEUDO_SWEEP_RECLAIM_BARS

        if upActive
            // Bullish BOS failed quickly: close back below broken high => pseudo-sweep Sell.
            bool reclaimDown = close < upLvl and high >= upLvl
            if reclaimDown
                SMC.register_sweep_reclaim_event(chartCtx.events, "Sell", upLvl, bar_index, syminfo.mintick)
                label.new(bar_index, upLvl, "xxx", xloc = xloc.bar_index, style = label.style_none, textcolor = color.new(THEME.COLOR_NEUTRAL, 0), size = size.tiny)
                upLvl := na
                upBar := na
        else
            upLvl := na
            upBar := na

        if dnActive
            // Bearish BOS failed quickly: close back above broken low => pseudo-sweep Buy.
            bool reclaimUp = close > dnLvl and low <= dnLvl
            if reclaimUp
                SMC.register_sweep_reclaim_event(chartCtx.events, "Buy", dnLvl, bar_index, syminfo.mintick)
                label.new(bar_index, dnLvl, "xxx", xloc = xloc.bar_index, style = label.style_none, textcolor = color.new(THEME.COLOR_NEUTRAL, 0), size = size.tiny)
                dnLvl := na
                dnBar := na
        else
            dnLvl := na
            dnBar := na

        array.set(pseudoBosBreakLvl, 0, upLvl)
        array.set(pseudoBosBreakLvl, 1, dnLvl)
        array.set(pseudoBosBreakBar, 0, upBar)
        array.set(pseudoBosBreakBar, 1, dnBar)
        bool(na)

process_data_trades() =>
    if array.size(trades) > 0
        for i = array.size(trades) - 1 to 0
            CORE.Trade e = array.get(trades, i)
            [eResolved, outcome] = CORE.resolve_trade_state(e, high, low, bar_index, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
            e := eResolved
            if outcome == 2
                UI.delete_trade_visuals(e)
                array.remove(trades, i)
                continue
            if outcome == 1 or outcome == -1
                float exitPrice = outcome > 0 ? e.takeprofit : e.stoploss
                float denom = math.max(math.abs(e.entry - e.stoploss), syminfo.mintick)
                float realizedR = math.abs(exitPrice - e.entry) / denom
                float rrForStats = math.max(0.1, realizedR)
                e.rrValue := rrForStats
            string entryDisplayMode = (e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL) ? "RESULT_LINES" : "NORMAL"
            bool signalShowActive = e.state == CONST.SIGNAL_STATE_PENDING ? chartCfg.showPending : e.state == CONST.SIGNAL_STATE_START ? chartCfg.showStart : e.state == CONST.SIGNAL_STATE_TP ? chartCfg.showTp : e.state == CONST.SIGNAL_STATE_SL ? chartCfg.showSl : false
            e := UI.draw_trade_visual(e, CONST, THEME, ENTRY_VIS_CFG, true, signalShowActive, chartCfg.showTp, chartCfg.showSl, perfLookbackBars, 10, entryDisplayMode, "RESULT_LINES", 0)
            array.set(trades, i, e)
        int j = array.size(trades) - 1
        while j >= 0
            CORE.Trade t = array.get(trades, j)
            bool resolved = t.state == CONST.SIGNAL_STATE_TP or t.state == CONST.SIGNAL_STATE_SL
            bool staleResolved = resolved and not na(t.barClosed) and (bar_index - t.barClosed > perfLookbackBars)
            bool overCap = array.size(trades) > 160
            if staleResolved or overCap
                UI.delete_trade_visuals(t)
                array.remove(trades, j)
            j -= 1
    bool(na)

process_data_events_queue(array<CORE.Event> events) =>
    if events.size() > 0
        for i = events.size() - 1 to 0
            CORE.Event e = events.get(i)
            bool isSweep = e.type == "SWEEP"
            bool isBos = e.type == "BOS"
            bool isMss = e.type == "MSS"
            if isSweep
                events.remove(i)
                continue
            string modelKey = isBos ? "BOS" : isMss ? "MSS" : str.upper(e.type)
            [enabledType, modelScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
            [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = MSS_get_entry_model_dynamic_cfg(modelKey)
            if not enabledType
                events.remove(i)
                continue
            bool validDirection = entry_direction_allowed(e.direction, chartCtx.biasVal)
            if triggerType == TRIGGER_TYPE_SIGNAL
                events.remove(i)
                continue
            if triggerWhen == TRIGGER_WHEN_TOUCH or modelEntryMode == ENTRY_MODE_LIMIT
                if validDirection
                    process_data_add_entry(shortName, e.direction, e.reason, e.zoneTop, e.zoneBtm, e.quality, math.max(e.score, modelScore))
                events.remove(i)
                continue
            bool confirm = e.direction == "Buy" ? close > e.zoneTop : close < e.zoneBtm
            bool invalid = e.direction == "Buy" ? close < e.zoneBtm : close > e.zoneTop
            if invalid
                events.remove(i)
                continue
            if modelEntryMode != ENTRY_MODE_OFF and confirm and validDirection
                process_data_add_entry(shortName, e.direction, e.reason, e.zoneTop, e.zoneBtm, e.quality, math.max(e.score, modelScore))
                events.remove(i)
    bool(na)

process_data_entries(bool canEmitSignals, bool entryEngineOn) =>
    if canEmitSignals
        process_data_pseudo_sweep_from_bos()
        process_data_sweep_mss_fvg_model()
        process_data_events_queue(chartCtx.events)
    else
        if array.size(chartCtx.events) > 0
            array.clear(chartCtx.events)
    if entryEngineOn
        process_data_trades()
    bool(na)

draw_data_bias_row_under_trades_local(table t, int rowIdx, CORE.ChartContext ctx, string sourceName) =>
    int currSec = CORE.get_tf_seconds(timeframe.period)
    bool show15 = CORE.get_tf_seconds("15") > currSec
    bool show240 = CORE.get_tf_seconds("240") > currSec
    bool show1d = CORE.get_tf_seconds("1D") > currSec
    bool show1w = CORE.get_tf_seconds("1W") > currSec
    string tf0Raw = timeframe.period
    int trend0 = tf0Raw == "15" ? ctx.dir15 : tf0Raw == "240" ? ctx.dir240 : (tf0Raw == "1D" or tf0Raw == "D") ? ctx.dir1d : (tf0Raw == "1W" or tf0Raw == "W") ? ctx.dir1w : ctx.dir0
    int shortBias0 = tf0Raw == "15" ? ctx.b15 : tf0Raw == "240" ? ctx.b240 : (tf0Raw == "1D" or tf0Raw == "D") ? ctx.b1d : (tf0Raw == "1W" or tf0Raw == "W") ? ctx.b1w : ctx.b0
    int shortBias15 = ctx.b15
    int shortBias240 = ctx.b240
    int shortBias1d = ctx.b1d
    int shortBias1w = ctx.b1w
    color txt0 = shortBias0 == 1 ? THEME.COLOR_BULLISH : shortBias0 == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt15 = shortBias15 == 1 ? THEME.COLOR_BULLISH : shortBias15 == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt240 = shortBias240 == 1 ? THEME.COLOR_BULLISH : shortBias240 == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt1d = shortBias1d == 1 ? THEME.COLOR_BULLISH : shortBias1d == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt1w = shortBias1w == 1 ? THEME.COLOR_BULLISH : shortBias1w == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    string st0 = trend0 == 0 or shortBias0 == 0 ? "Neutral" : trend0 == shortBias0 ? "Continuation" : "Pullback"
    string st15 = ctx.dir15 == 0 or shortBias15 == 0 ? "Neutral" : ctx.dir15 == shortBias15 ? "Continuation" : "Pullback"
    string st240 = ctx.dir240 == 0 or shortBias240 == 0 ? "Neutral" : ctx.dir240 == shortBias240 ? "Continuation" : "Pullback"
    string st1d = ctx.dir1d == 0 or shortBias1d == 0 ? "Neutral" : ctx.dir1d == shortBias1d ? "Continuation" : "Pullback"
    string st1w = ctx.dir1w == 0 or shortBias1w == 0 ? "Neutral" : ctx.dir1w == shortBias1w ? "Continuation" : "Pullback"
    table.cell(t, 0, rowIdx, sourceName, bgcolor = color.new(THEME.COLOR_UI_BG, 55), text_color = color.white, text_size = size.tiny)
    int col = 1
    string tf0 = CORE.get_friendly_tf(timeframe.period)
    string tx0 = (str.length(tf0) > 2 ? str.substring(tf0, 0, 2) : tf0) + " " + UI.get_bias_symbol(shortBias0, CONST)
    table.cell(t, col, rowIdx, tx0, bgcolor = UI.get_bias_bg_from_trend(trend0, THEME), text_color = txt0, text_size = size.tiny, tooltip = "Trend: " + str.tostring(trend0) + " | BG:MSS Trend | Arrow:MSS TF Bias: " + str.tostring(shortBias0) + " | State: " + st0)
    col += 1
    if show15 and col <= 4
        string tf15 = CORE.get_friendly_tf("15")
        string tx15 = (str.length(tf15) > 2 ? str.substring(tf15, 0, 2) : tf15) + " " + UI.get_bias_symbol(shortBias15, CONST)
        table.cell(t, col, rowIdx, tx15, bgcolor = UI.get_bias_bg_from_trend(ctx.dir15, THEME), text_color = txt15, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir15) + " | BG:MSS Trend | Arrow:MSS TF Bias: " + str.tostring(shortBias15) + " | State: " + st15)
        col += 1
    if show240 and col <= 4
        string tf240 = CORE.get_friendly_tf("240")
        string tx240 = (str.length(tf240) > 2 ? str.substring(tf240, 0, 2) : tf240) + " " + UI.get_bias_symbol(shortBias240, CONST)
        table.cell(t, col, rowIdx, tx240, bgcolor = UI.get_bias_bg_from_trend(ctx.dir240, THEME), text_color = txt240, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir240) + " | BG:MSS Trend | Arrow:MSS TF Bias: " + str.tostring(shortBias240) + " | State: " + st240)
        col += 1
    if show1d and col <= 4
        string tf1d = CORE.get_friendly_tf("1D")
        string tx1d = (str.length(tf1d) > 2 ? str.substring(tf1d, 0, 2) : tf1d) + " " + UI.get_bias_symbol(shortBias1d, CONST)
        table.cell(t, col, rowIdx, tx1d, bgcolor = UI.get_bias_bg_from_trend(ctx.dir1d, THEME), text_color = txt1d, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir1d) + " | BG:MSS Trend | Arrow:MSS TF Bias: " + str.tostring(shortBias1d) + " | State: " + st1d)
        col += 1
    if show1w and col <= 4
        string tf1w = CORE.get_friendly_tf("1W")
        string tx1w = (str.length(tf1w) > 2 ? str.substring(tf1w, 0, 2) : tf1w) + " " + UI.get_bias_symbol(shortBias1w, CONST)
        table.cell(t, col, rowIdx, tx1w, bgcolor = UI.get_bias_bg_from_trend(ctx.dir1w, THEME), text_color = txt1w, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir1w) + " | BG:MSS Trend | Arrow:MSS TF Bias: " + str.tostring(shortBias1w) + " | State: " + st1w)
        col += 1
    if col <= 4
        for i = col to 4
            table.cell(t, i, rowIdx, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    bool(na)

draw_data_trades_dashboard() =>
    var array<CORE.Trade> dashboardTrades = array.new<CORE.Trade>()
    UI.collect_dashboard_trades(trades, dashboardTrades, chartCfg.showPending, chartCfg.showStart, chartCfg.showTp, chartCfg.showSl, perfLookbackBars, CONST)
    int dashCount = array.size(dashboardTrades)
    int maxTypes = math.max(1, dashCount)
    if dashCount > 0
        UI.render_entries_dashboard_from_entries(true, signalStatsTableBottomCenter, dashboardTrades, maxTypes, THEME, CONST, SIG_METRIC_COUNT)
    else
        table.clear(signalStatsTableBottomCenter, 0, 0, 4, 23)
    draw_data_bias_row_under_trades_local(signalStatsTableBottomCenter, 0, chartCtx, "MSS")
    bool(na)

draw_data_trade_debug_table() =>
    if not signalShowTradeDebug
        table.clear(tradeDebugTableTopCenter, 0, 0, 6, 7)
    else
        string shadowTip = "Shadow MS runtime ON (parity tooltip removed for token budget)"
        color bgHdr = color.new(THEME.COLOR_UI_BG, 10)
        color bgRow = color.new(THEME.COLOR_UI_BG, 75)
        table.cell(tradeDebugTableTopCenter, 0, 0, "Type", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny, tooltip = shadowTip)
        table.cell(tradeDebugTableTopCenter, 1, 0, "Dir", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(tradeDebugTableTopCenter, 2, 0, "State", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(tradeDebugTableTopCenter, 3, 0, "Entry", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(tradeDebugTableTopCenter, 4, 0, "SL", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(tradeDebugTableTopCenter, 5, 0, "TP", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(tradeDebugTableTopCenter, 6, 0, "Time", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        for r = 1 to 7
            int idx = array.size(trades) - r
            string c0 = ""
            string c1 = ""
            string c2 = ""
            string c3 = ""
            string c4 = ""
            string c5 = ""
            string c6 = ""
            if idx >= 0
                CORE.Trade t = array.get(trades, idx)
                c0 := t.type
                c1 := t.direction
                c2 := t.state
                c3 := str.tostring(t.entry, format.mintick)
                c4 := str.tostring(t.stoploss, format.mintick)
                c5 := str.tostring(t.takeprofit, format.mintick)
                c6 := str.tostring(t.barCreated) + (na(t.barClosed) ? "" : ">" + str.tostring(t.barClosed))
            table.cell(tradeDebugTableTopCenter, 0, r, c0, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
            table.cell(tradeDebugTableTopCenter, 1, r, c1, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
            table.cell(tradeDebugTableTopCenter, 2, r, c2, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
            table.cell(tradeDebugTableTopCenter, 3, r, c3, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
            table.cell(tradeDebugTableTopCenter, 4, r, c4, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
            table.cell(tradeDebugTableTopCenter, 5, r, c5, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
            table.cell(tradeDebugTableTopCenter, 6, r, c6, text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
    bool(na)

draw_data_sr_visual(CORE.PDArray z, int srRightIdx, int srLabelIdx, string tooltipText) =>
    CORE.PDArray out = z
    bool isResNow = SMC.is_sr_res_now(z, close)
    string txt = isResNow ? "R" : "S"
    color baseColor = CORE.get_tf_line_color(out.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
    color txtColor = color.new(baseColor, 0)
    string labelSize = get_data_label_size_for_source_tf(out.labelText)
    SR_VIS_CFG.lineStyle := CFG_SR.lineStyle
    SR_VIS_CFG.lineWidth := CFG_SR.lineWidth
    SR_VIS_CFG.labelSize := labelSize
    SR_VIS_CFG.showLabel := CFG_SR.showLabel
    out := UI.draw_price_zone(out, na(out.barEnd) ? bar_index : out.barEnd, srRightIdx, out.price, out.price, CFG_SR.lineColor, CFG_SR.lineColor, line.style_solid, txt, txtColor, tooltipText, srLabelIdx, out.price, ZONE_VIS_CFG, SR_VIS_CFG, false, true, out.price, CFG_SR.lineColor, "LINE", CFG_SR.showLabel)
    if not na(out.visualLine)
        string srStyle = CORE.lifecycle_line_style(out.lifeState, CONST.LIFE_TOUCHED, CONST.LIFE_BROKEN, CONST.LIFE_RECLAIMED, line.style_dotted, line.style_dotted, line.style_dashed, line.style_dotted)
        int srAlpha = CORE.lifecycle_alpha(out.lifeState, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED, CONST.LIFE_BROKEN, SETTINGS.SR_LINE_TRANSP, 72, 65, 55, 85)
        color srColor = color.new(baseColor, srAlpha)
        string srLineStyleSig = "SR_LINE|" + srStyle + "|" + str.tostring(srAlpha) + "|" + get_data_color_sig(baseColor)
        if out.visualLine.get_x2() != srRightIdx
            out.visualLine.set_x2(srRightIdx)
        if out.visLineStyleSig != srLineStyleSig
            out.visualLine.set_color(srColor)
            out.visualLine.set_style(srStyle)
            out.visLineStyleSig := srLineStyleSig
    if not na(out.visualLabel)
        string srLabelStyleSig = "SR_LABEL|" + labelSize + "|" + tooltipText
        if out.visualLabel.get_x() != srLabelIdx
            out.visualLabel.set_x(srLabelIdx)
        if out.visualLabel.get_y() != out.price
            out.visualLabel.set_y(out.price)
        if out.visLabelStyleSig != srLabelStyleSig
            out.visualLabel.set_size(labelSize)
            out.visualLabel.set_tooltip(tooltipText)
            out.visLabelStyleSig := srLabelStyleSig
    out

apply_removed_level_visuals(array<CORE.PDArray> removed) =>
    if array.size(removed) > 0
        for i = 0 to array.size(removed) - 1
            CORE.PDArray zDel = array.get(removed, i)
            UI.delete_line_label(zDel.visualLine, zDel.visualLabel)
    bool(na)

// Shared lifecycle engine for horizontal PDArray families (LIQ/SR).
process_data_horizontal_levels(int kind, array<CORE.PDArray> levels, float areaTop, float areaBottom, float srBand, float atrVal) =>
    int srRightIdx = na
    int srLabelIdx = na
    if array.size(levels) > 0
        for i = array.size(levels) - 1 to 0 by 1
            z = array.get(levels, i)
            z := SMC.normalize_pricezone_state(z, CONST)
            // EQH/EQL is retired and merged into sweep behavior; remove any stale EQ levels.
            if z.type == "eqh" or z.type == "eql"
                CORE.PDArray droppedEq = SMC.delete_level_at(levels, i)
                UI.delete_line_label(droppedEq.visualLine, droppedEq.visualLabel)
                continue
            if not SMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                continue
            if not na(z.visualBox)
                z.visualBox.delete()
                z.visualBox := na
            int srcIdx = na(z.barEnd) ? bar_index : z.barEnd
            if get_data_should_drop_level(z, srcIdx)
                CORE.PDArray dropped = SMC.delete_level_at(levels, i)
                UI.delete_line_label(dropped.visualLine, dropped.visualLabel)
                continue
            if kind == HL_KIND_LIQ
                bool isBearishLiq = z.isHigh
                bool liqPenetrated = SMC.check_break(isBearishLiq, z.price, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, atrVal, localCfg.detImpulseAtr, open, high, low, close, open[1], high[1], low[1], close[1])
                bool liqSwept = liqPenetrated
                bool isDollarLiq = z.labelText != timeframe.period
                if liqSwept and not get_data_is_liq_swept(z)
                    z.barEnd := bar_index
                    if isDollarLiq
                        UI.delete_line_label(z.visualLine, z.visualLabel)
                        z.visualLine := na
                        z.visualLabel := na
                    else
                        if not na(z.visualLine)
                            color liqMitigatedColor = color.new(CORE.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 50)
                            z.visualLine.set_color(liqMitigatedColor)
                            z.visualLine.set_style(line.style_dotted)
                        if na(z.visualLabel)
                            z.visualLabel := UI.draw_text_on_line(z.barStart, z.price, bar_index, z.price, xloc.bar_index, "xxx", color.new(CORE.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 0), get_data_label_size_for_source_tf(z.labelText), 0, 0, 0.5, 0, "", text.align_center, THEME)
                        else
                            if z.visualLabel.get_text() != "xxx"
                                z.visualLabel.set_text("xxx")
                            if not na(z.visualLine)
                                int midX = int(math.round((z.visualLine.get_x1() + z.visualLine.get_x2()) * 0.5))
                                if z.visualLabel.get_x() != midX
                                    z.visualLabel.set_x(midX)
                            if z.visualLabel.get_y() != z.price
                                z.visualLabel.set_y(z.price)
                    
                    // Emit SWEEP Event for LSR Phase A tracking
                    SMC.register_sweep_reclaim_event(chartCtx.events, isBearishLiq ? "Sell" : "Buy", z.price, bar_index, syminfo.mintick)

                bool liqTouched = SMC.check_touch(z.price, z.price, localCfg.detBasis, open, high, low, close)
                bool liqReclaimed = isBearishLiq ? close < z.price : close > z.price
                bool liqCooldownOk = na(z.barEnd) or (bar_index - z.barEnd >= localCfg.limSrTouchCountCooldownBars)
                int liqState = CORE.lifecycle_next_state(liqPenetrated and not liqReclaimed, liqTouched, false, liqSwept and liqReclaimed, liqCooldownOk, z.lifeState, CONST.LIFE_BROKEN, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED)
                [liqTouchCnt, _] = CORE.lifecycle_next_counts(z.touchCount, z.rejectCount, liqTouched, false, liqCooldownOk)
                if liqTouched and liqCooldownOk
                    z.barEnd := bar_index
                z.touchCount := liqTouchCnt
                z.lifeState := liqState
                z.broken := CORE.is_life_broken(liqState, CONST)
                if not na(z.visualLine)
                    int liqExt = CORE.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
                    int liqRightIdx = SMC.get_sr_x(bar_index, liqExt, false)
                    string liqStyle = CORE.lifecycle_line_style(liqState, CONST.LIFE_TOUCHED, CONST.LIFE_BROKEN, CONST.LIFE_RECLAIMED, line.style_solid, line.style_dotted, line.style_dashed, line.style_dotted)
                    int liqAlpha = CORE.lifecycle_alpha(liqState, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED, CONST.LIFE_BROKEN, 35, 45, 45, 50, 65)
                    color liqBaseColor = CORE.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
                    string liqLineStyleSig = "LIQ_LINE|" + liqStyle + "|" + str.tostring(liqAlpha) + "|" + get_data_color_sig(liqBaseColor)
                    if z.visLineStyleSig != liqLineStyleSig
                        z.visualLine.set_style(liqStyle)
                        z.visualLine.set_color(color.new(liqBaseColor, liqAlpha))
                        z.visLineStyleSig := liqLineStyleSig
                    if not get_data_is_liq_swept(z) and z.visualLine.get_x2() != liqRightIdx
                        z.visualLine.set_x2(liqRightIdx)
                if not na(z.visualLine)
                    string liqTxt = get_data_is_liq_swept(z) ? "xxx" : (z.labelText == timeframe.period ? "idm" : "$")
                    color tfTxtColor = color.new(CORE.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 0)
                    string tfTxtSize = SMC.ms_get_tf_text_size(z.labelText, htf1, htf2)
                    string liqAlign = get_data_liq_label_align(liqTxt)
                    float nextY = get_data_liq_label_y(liqTxt, z.price)
                    int nextX = get_data_liq_label_x(z.visualLine, liqTxt)
                    float overlapTol = math.max(commonAtr * math.max(localCfg.liqOverlapTolAtrMult, 0.005), syminfo.mintick * 8.0)
                    bool hideByPriority = localCfg.liqHideOverlapByTf and liqTxt == "$" and get_data_liq_has_stronger_overlap(levels, i, z, overlapTol)
                    string liqLabelStyleSig = "LIQ_LABEL|" + liqTxt + "|" + get_data_color_sig(tfTxtColor) + "|" + tfTxtSize + "|" + liqAlign + "|" + localCfg.liqDollarXPos + "|" + localCfg.liqDollarYPos + "|" + str.tostring(localCfg.liqDollarYOffsetTicks) + "|" + str.tostring(localCfg.liqOverlapTolAtrMult) + "|" + localCfg.liqOverlapScope + "|" + str.tostring(hideByPriority)
                    if hideByPriority
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                            z.visualLabel := na
                            z.visLabelStyleSig := ""
                    else
                        if na(z.visualLabel)
                            z.visualLabel := UI.draw_text_on_line(z.visualLine.get_x1(), z.price, z.visualLine.get_x2(), z.price, xloc.bar_index, liqTxt, tfTxtColor, tfTxtSize, 0, 0.0, 0.5, 0, "", liqAlign, THEME)
                        if z.visualLabel.get_text() != liqTxt
                            z.visualLabel.set_text(liqTxt)
                        if z.visualLabel.get_x() != nextX
                            z.visualLabel.set_x(nextX)
                        if z.visualLabel.get_y() != nextY
                            z.visualLabel.set_y(nextY)
                        if z.visLabelStyleSig != liqLabelStyleSig
                            z.visualLabel.set_textcolor(tfTxtColor)
                            z.visualLabel.set_size(tfTxtSize)
                            z.visualLabel.set_textalign(liqAlign)
                            z.visLabelStyleSig := liqLabelStyleSig
            else
                int srExt = CORE.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
                srRightIdx := SMC.get_sr_x(bar_index, srExt, false)
                srLabelIdx := SMC.get_sr_x(bar_index, srExt, false)
                int rejectN = math.max(z.rejectCount, 0)
                z.top := z.price + srBand
                z.bottom := z.price - srBand
                bool bodyCross = SMC.is_body_cross_level(z.price, open, close)
                bool touchedBand = SMC.is_level_wick_touch(z.price, srBand, open, high, low, close, syminfo.mintick)
                bool cooldownOk = na(z.barEnd) or (bar_index - z.barEnd >= localCfg.limSrTouchCountCooldownBars)
                bool sideRespected = z.isHigh ? close < z.price : close > z.price
                int state = CORE.lifecycle_next_state(bodyCross, touchedBand, sideRespected, sideRespected, cooldownOk, z.lifeState, CONST.LIFE_BROKEN, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED)
                [nextTouchCnt, nextRejectCnt] = CORE.lifecycle_next_counts(z.touchCount, rejectN, touchedBand, sideRespected, cooldownOk)
                if touchedBand and cooldownOk
                    z.qualityPct := math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                    z.barEnd := bar_index
                z.touchCount := nextTouchCnt
                z.rejectCount := nextRejectCnt
                z.lifeState := state
                z.broken := CORE.is_life_broken(state, CONST)
                z.touchCount := math.max(z.touchCount, int(math.max(nz(z.qualityPct, 1.0), 1.0)))
                string nextTip = SMC.get_data_sr_tooltip_text(nextRejectCnt, state, CONST)
                z := draw_data_sr_visual(z, srRightIdx, srLabelIdx, nextTip)
            array.set(levels, i, z)
    int kindCount = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            if SMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                kindCount += 1
    if kind == HL_KIND_LIQ
        while kindCount > 14
            int dropIdx = na
            for i = 0 to array.size(levels) - 1
                z = array.get(levels, i)
                if SMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                    dropIdx := i
                    break
            if na(dropIdx)
                break
            CORE.PDArray dropped = SMC.delete_level_at(levels, dropIdx)
            UI.delete_line_label(dropped.visualLine, dropped.visualLabel)
            kindCount -= 1
    else
        bool(na)
    bool(na)

get_data_level_latest_swing_high() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = CORE.market_structure_latest_hilo(ltfData.ms)
    latestHigh

get_data_level_latest_swing_low() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = CORE.market_structure_latest_hilo(ltfData.ms)
    latestLow

get_data_level_rank_score(CORE.PDArray z, float lastSwingHigh, float lastSwingLow) =>
    float p = z.price
    float tick = math.max(syminfo.mintick, 1e-10)
    float distTicks = math.abs(p - close) / tick
    float score = -distTicks
    if p > close and not na(lastSwingHigh)
        float swingTicks = math.abs(p - lastSwingHigh) / tick
        score += 1000.0 / (1.0 + swingTicks)
    if p < close and not na(lastSwingLow)
        float swingTicks = math.abs(p - lastSwingLow) / tick
        score += 1000.0 / (1.0 + swingTicks)
    score += float(math.max(int(nz(z.extendBars, 0)), 0)) * 8.0
    score += nz(z.qualityPct, 0.0) * 0.05
    score

process_data_prune_levels_by_relevance(array<CORE.PDArray> levels) =>
    int n = array.size(levels)
    if n <= 4
        bool(na)
    else
        float lastSwingHigh = get_data_level_latest_swing_high()
        float lastSwingLow = get_data_level_latest_swing_low()
        array<bool> keep = array.new_bool(n, false)
        int side = 0
        while side < 2
            int picked = 0
            while picked < 2
                int bestIdx = na
                float bestScore = na
                int i = 0
                while i < n
                    bool already = array.get(keep, i)
                    if not already
                        CORE.PDArray z = array.get(levels, i)
                        bool kindOk = z.type == "LIQ" or z.type == "SR"
                        bool active = kindOk and not get_data_is_liq_swept(z)
                        bool sideOk = side == 0 ? (z.price >= close) : (z.price <= close)
                        if active and sideOk
                            float s = get_data_level_rank_score(z, lastSwingHigh, lastSwingLow)
                            if na(bestIdx) or s > bestScore
                                bestIdx := i
                                bestScore := s
                    i += 1
                if na(bestIdx)
                    break
                array.set(keep, bestIdx, true)
                picked += 1
            side += 1
        int j = n - 1
        while j >= 0
            CORE.PDArray z = array.get(levels, j)
            bool kindOk = z.type == "LIQ" or z.type == "SR"
            bool active = kindOk and not get_data_is_liq_swept(z)
            bool selected = array.get(keep, j)
            if active and not selected
                UI.delete_line_label(z.visualLine, z.visualLabel)
                array.remove(levels, j)
            j -= 1
        bool(na)

process_data_register_sr_seed(array<CORE.PDArray> levels, float price, int pivotIdx, int pivotTime, bool isRes, float tol, float srBand, string sourceTf, int sourcePrio, float areaTop, float areaBottom) =>
    float vTop = price + srBand
    float vBtm = price - srBand
    bool inArea = na(areaTop) or na(areaBottom) or (price <= areaTop and price >= areaBottom)
    if not inArea or not is_in_working_zone_idx_for_source_tf(pivotIdx, sourceTf)
        bool(na)
    else
        if sourcePrio == SR_SOURCE_PRIO_LTF and SMC.get_data_has_keylevel_overlap_in_levels(levels, vTop, vBtm)
            bool(na)
        else
            int matchIdx = na
            if array.size(levels) > 0
                for mi = 0 to array.size(levels) - 1
                    mz = array.get(levels, mi)
                    if mz.type == "SR" and math.abs(mz.price - price) <= tol
                        matchIdx := mi
                        break
            if not na(matchIdx)
                z = array.get(levels, matchIdx)
                bool sameSeed = z.barStart == pivotTime and z.isHigh == isRes
                if not sameSeed
                    float touches = math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                    z.price := ((z.price * (touches - 1.0)) + price) / touches
                    z.qualityPct := touches
                    z.barEnd := na(z.barEnd) ? pivotIdx : math.min(z.barEnd, pivotIdx)
                int prevPrio = int(math.max(nz(z.extendBars, 0), 0))
                if sourcePrio >= prevPrio
                    z.labelText := sourceTf
                    z.isHigh := isRes
                z.extendBars := math.max(prevPrio, sourcePrio)
                z.top := z.price + srBand
                z.bottom := z.price - srBand
                z.touchCount := int(math.max(nz(z.qualityPct, 1.0), 1.0))
                array.set(levels, matchIdx, z)
            else
                CORE.PDArray z = CORE.PDArray.new()
                z.type := "SR"
                z.price := price
                z.top := vTop
                z.bottom := vBtm
                z.barStart := pivotTime
                z.barEnd := pivotIdx
                z.qualityPct := 1.0
                z.isHigh := isRes
                z.labelText := sourceTf
                z.extendBars := sourcePrio
                z.lifeState := CONST.LIFE_FORMED
                z.touchCount := 1
                z.rejectCount := 0
                array.push(levels, z)
            bool(na)

process_data_register_liquidity_seed(array<CORE.PDArray> levels, float price, int pivotIdx, int pivotTime, bool isHigh, float tol, string sourceTf, int sourcePrio, float areaTop, float areaBottom) =>
    bool inArea = na(areaTop) or na(areaBottom) or (price <= areaTop and price >= areaBottom)
    if not inArea or not is_in_working_zone_idx_for_source_tf(pivotIdx, sourceTf)
        bool(na)
    else
        int matchIdx = na
        if array.size(levels) > 0
            for mi = 0 to array.size(levels) - 1
                mz = array.get(levels, mi)
                if mz.type == "LIQ" and math.abs(mz.price - price) <= tol
                    matchIdx := mi
                    break
        if not na(matchIdx)
            z = array.get(levels, matchIdx)
            bool sameSeed = z.barStart == pivotTime and z.isHigh == isHigh
            if not sameSeed
                float touches = math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                z.price := ((z.price * (touches - 1.0)) + price) / touches
                z.qualityPct := touches
            int prevPrio = int(math.max(nz(z.extendBars, 0), 0))
            if sourcePrio >= prevPrio
                z.isHigh := isHigh
                z.labelText := sourceTf
            z.extendBars := math.max(prevPrio, sourcePrio)
            z.top := z.price
            z.bottom := z.price
            int liqExt = CORE.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
            int liqRightIdx = SMC.get_sr_x(bar_index, liqExt, false)
            if not get_data_is_liq_swept(z) and not na(z.visualLine) and z.visualLine.get_x2() != liqRightIdx
                z.visualLine.set_x2(liqRightIdx)
            array.set(levels, matchIdx, z)
        else
            CORE.PDArray z = CORE.PDArray.new()
            z.type := "LIQ"
            z.price := price
            z.top := price
            z.bottom := price
            z.barStart := pivotTime
            z.barEnd := pivotIdx
            z.isHigh := isHigh
            z.labelText := sourceTf
            z.extendBars := sourcePrio
            z.qualityPct := 1.0
            z.lifeState := CONST.LIFE_FORMED
            z.touchCount := 1
            z.rejectCount := 0
            color lvlColor = CORE.get_tf_line_color(sourceTf, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
            bool isLtfSeed = sourceTf == timeframe.period
            string liqTxt = isLtfSeed ? "idm" : "$"
            string liqTip = CORE.tt_side(not isHigh, isLtfSeed ? "Internal Dealing Range (IDM)" : "Liquidity")
            int liqExt = CORE.get_tf_line_ext_bars(sourceTf, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
            int liqRightIdx = SMC.get_sr_x(bar_index, liqExt, false)
            [liqLine, liqLabel] = UI.draw_line_with_text(pivotIdx, z.price, liqRightIdx, z.price, xloc.bar_index, color.new(lvlColor, 35), liqTxt, true, THEME.COLOR_NEUTRAL, liqTip, LIQ_LINE_VIS_CFG, THEME)
            z.visualLine := liqLine
            z.visualLabel := liqLabel
            array.push(levels, z)
    bool(na)

process_data_seed_from_ms_swings(bool isSrSeed, array<CORE.PDArray> levels, CORE.MarketStructure ms, bool isHigh, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom) =>
    int seeded = 0
    if not na(ms.swings) and array.size(ms.swings) > 0
        for i = array.size(ms.swings) - 1 to 0
            if seeded >= localCfg.limSrSeedSwingsPerTf
                break
            CORE.Swing s = array.get(ms.swings, i)
            if s.isSwingHigh == isHigh
                float p = s.price
                int t = s.time
                int idx = get_data_cached_bar_index_from_time(t)
                if is_in_working_zone_idx_for_source_tf(idx, sourceTf)
                    if isSrSeed
                        process_data_register_sr_seed(levels, p, idx, t, isHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    else
                        process_data_register_liquidity_seed(levels, p, idx, t, isHigh, tol, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded += 1
    bool(na)

// Fallback side-balancer: guarantee at least one swing seed above/below current price per TF.
process_data_seed_min_side_from_ms_swings(bool isSrSeed, array<CORE.PDArray> levels, CORE.MarketStructure ms, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, bool wantAbove) =>
    int relaxedFirstIdx = get_data_relaxed_first_idx_for_source_tf(sourceTf)
    bool seeded = false
    if not na(ms.swings) and array.size(ms.swings) > 0
        for i = array.size(ms.swings) - 1 to 0
            if seeded
                break
            CORE.Swing s = array.get(ms.swings, i)
            float p = s.price
            int t = s.time
            bool sideOk = not na(p) and (wantAbove ? p >= close : p <= close)
            if sideOk
                int idx = get_data_cached_bar_index_from_time(t)
                if not na(idx) and idx >= relaxedFirstIdx
                    if isSrSeed
                        process_data_register_sr_seed(levels, p, idx, t, s.isSwingHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    else
                        process_data_register_liquidity_seed(levels, p, idx, t, s.isSwingHigh, tol, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded := true
    bool(na)

get_data_sr_price_snapped_to_ms_swing(float srPrice, float tol, bool isRes) =>
    float out = srPrice
    float bestD = na
    if not na(ltfData.ms.swings) and array.size(ltfData.ms.swings) > 0
        for i = 0 to array.size(ltfData.ms.swings) - 1
            CORE.Swing s = array.get(ltfData.ms.swings, i)
            if s.isSwingHigh == isRes
                float d = math.abs(s.price - srPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    if not na(htf1Data.ms.swings) and array.size(htf1Data.ms.swings) > 0
        for i = 0 to array.size(htf1Data.ms.swings) - 1
            CORE.Swing s = array.get(htf1Data.ms.swings, i)
            if s.isSwingHigh == isRes
                float d = math.abs(s.price - srPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    if not na(htf2Data.ms.swings) and array.size(htf2Data.ms.swings) > 0
        for i = 0 to array.size(htf2Data.ms.swings) - 1
            CORE.Swing s = array.get(htf2Data.ms.swings, i)
            if s.isSwingHigh == isRes
                float d = math.abs(s.price - srPrice)
                if d <= tol and (na(bestD) or d < bestD)
                    out := s.price
                    bestD := d
    out

get_data_should_seed_refresh(int intervalBars) =>
    [ltfHiP, ltfHi, ltfLoP, ltfLo] = CORE.market_structure_latest_hilo(ltfData.ms)
    [h1HiP, h1Hi, h1LoP, h1Lo] = CORE.market_structure_latest_hilo(htf1Data.ms)
    [h2HiP, h2Hi, h2LoP, h2Lo] = CORE.market_structure_latest_hilo(htf2Data.ms)
    bool changed = na(array.get(seedPulseState, 0)) or ltfHi != array.get(seedPulseState, 0) or ltfLo != array.get(seedPulseState, 1) or h1Hi != array.get(seedPulseState, 2) or h1Lo != array.get(seedPulseState, 3) or h2Hi != array.get(seedPulseState, 4) or h2Lo != array.get(seedPulseState, 5)
    if changed
        array.set(seedPulseState, 0, ltfHi)
        array.set(seedPulseState, 1, ltfLo)
        array.set(seedPulseState, 2, h1Hi)
        array.set(seedPulseState, 3, h1Lo)
        array.set(seedPulseState, 4, h2Hi)
        array.set(seedPulseState, 5, h2Lo)
    bool periodic = intervalBars > 0 and (bar_index % intervalBars == 0)
    barstate.isfirst or changed or periodic

// process_data_liquidity: updates liquidity seeds + lifecycle.
process_data_liquidity(bool doSeed) =>
    if liquidityBool
        float areaTop = na
        float areaBottom = na
        float liqTol = commonAtr * localCfg.limSrTolAtrMult
        if doSeed
            if not na(htf2)
                process_data_seed_from_ms_swings(false, chartCtx.levels, htf2Data.ms, true, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_from_ms_swings(false, chartCtx.levels, htf2Data.ms, false, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_min_side_from_ms_swings(false, chartCtx.levels, htf2Data.ms, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom, true)
                process_data_seed_min_side_from_ms_swings(false, chartCtx.levels, htf2Data.ms, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom, false)
            if not na(htf1)
                process_data_seed_from_ms_swings(false, chartCtx.levels, htf1Data.ms, true, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_from_ms_swings(false, chartCtx.levels, htf1Data.ms, false, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_min_side_from_ms_swings(false, chartCtx.levels, htf1Data.ms, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom, true)
                process_data_seed_min_side_from_ms_swings(false, chartCtx.levels, htf1Data.ms, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom, false)
        process_data_horizontal_levels(HL_KIND_LIQ, chartCtx.levels, areaTop, areaBottom, 0.0, 0.0)

// process_data_sr: updates SR seeds + lifecycle.
process_data_sr(bool doSeed) =>
    if showSR
        float areaTop = na
        float areaBottom = na
        float srTol = commonAtr * localCfg.limSrTolAtrMult
        float srBand = math.max(commonAtr * localCfg.limSrTouchBandAtrMult, syminfo.mintick * localCfg.limSrTouchBandMinTicks)
        float srMinDist = math.max(commonAtr * localCfg.limZoneMinHeightAtr * localCfg.limSrNearbyMergeMult, syminfo.mintick * 30.0)
        int srLookbackBars = math.max(5, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)
        if doSeed
            int div = 50
            float _maxRange = ta.highest(high, srLookbackBars)
            float _minRange = ta.lowest(low, srLookbackBars)
            array<SMC.DensitySeed> dsL = SMC.get_density_seeds(ltfData, _maxRange, _minRange, timeframe.period, SR_SOURCE_PRIO_LTF, srLookbackBars, div, bar_index, close)
            for s in dsL
                float snapPrice = get_data_sr_price_snapped_to_ms_swing(s.lPrice, srTol, s.isRes)
                process_data_register_sr_seed(chartCtx.levels, snapPrice, bar_index, time, s.isRes, srTol, srBand, s.tfLbl, SR_SOURCE_PRIO_LTF, areaTop, areaBottom)
            if not na(htf2)
                array<SMC.DensitySeed> ds2 = SMC.get_density_seeds(htf2Data, _maxRange, _minRange, htf2, SR_SOURCE_PRIO_HTF2, srLookbackBars, div, bar_index, close)
                for s in ds2
                    float snapPrice = get_data_sr_price_snapped_to_ms_swing(s.lPrice, srTol, s.isRes)
                    process_data_register_sr_seed(chartCtx.levels, snapPrice, bar_index, time, s.isRes, srTol, srBand, s.tfLbl, SR_SOURCE_PRIO_HTF2, areaTop, areaBottom)
            if not na(htf1)
                array<SMC.DensitySeed> ds1 = SMC.get_density_seeds(htf1Data, _maxRange, _minRange, htf1, SR_SOURCE_PRIO_HTF1, srLookbackBars, div, bar_index, close)
                for s in ds1
                    float snapPrice = get_data_sr_price_snapped_to_ms_swing(s.lPrice, srTol, s.isRes)
                    process_data_register_sr_seed(chartCtx.levels, snapPrice, bar_index, time, s.isRes, srTol, srBand, s.tfLbl, SR_SOURCE_PRIO_HTF1, areaTop, areaBottom)
            
        apply_removed_level_visuals(SMC.prune_nearby_sr_levels(chartCtx.levels, srMinDist))
        // Bar-only mode: disable SR source/side caps.
        process_data_horizontal_levels(HL_KIND_SR, chartCtx.levels, areaTop, areaBottom, srBand, 0.0)
        SMC.draw_sr_rank_labels(chartCtx.levels, close)

if calcOnClosedBar
    int seedRefreshBars = timeframe.isintraday ? 5 : 3
    bool doSeedRefresh = get_data_should_seed_refresh(seedRefreshBars)
    process_data_liquidity(doSeedRefresh)
    process_data_sr(doSeedRefresh)
    process_data_prune_levels_by_relevance(chartCtx.levels)
    process_data_entries(canEmitSignals, entryEngineEnabled)

if barstate.islast
    bool showPd = showPDH_PDL and timeframe.isintraday
    int klRight = bar_index + 28
    color klColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorText, 50)
    string klStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
    bool showKlLabels = THEME.SIZE_SMALL != "None"
    [nextPdhLine, nextPdlLine, nextPdhLabel, nextPdlLabel] = UI.draw_pd_pw(pdhLine, pdlLine, pdhLabel, pdlLabel, showPd, klRight, klColor, klStyle, showKlLabels, chartCtx.pdh, chartCtx.pdl, chartCtx.pdTime, THEME)
    pdhLine := nextPdhLine
    pdlLine := nextPdlLine
    pdhLabel := nextPdhLabel
    pdlLabel := nextPdlLabel
    if entryEngineEnabled
        draw_data_trades_dashboard()
    draw_data_trade_debug_table()
// Divergence scan moved to bias/signals module.


// Market structure (MTF BOS/MSS + swings) runs above using HTF pair (TF1/TF2).
