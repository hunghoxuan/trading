modelSweepMssFvgType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m4", group = "2. Trade Models")
signalShowPending = input.bool(true, "Pending", inline = "v0", group = "4. Trade Display")
signalShowStart = input.bool(true, "Start", inline = "v0", group = "4. Trade Display")
signalShowTp = input.bool(true, "TP", inline = "v0", group = "4. Trade Display")
