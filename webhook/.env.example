# =========================
# Core server
# =========================
# REQUIRED
# Values: integer TCP port (example: 80, 3000)
# Meaning: HTTP port where webhook server listens
# Where to get: choose your server port (80/443 behind reverse proxy is common)
PORT=80

# OPTIONAL
# Values: true/false
# Meaning: enable native TLS/HTTPS listener in Node server
HTTPS_ENABLED=false

# OPTIONAL
# Values: integer TCP port
# Meaning: HTTPS port where TLS server listens when HTTPS_ENABLED=true
HTTPS_PORT=443

# OPTIONAL (REQUIRED when HTTPS_ENABLED=true)
# Values: filesystem path to TLS private key PEM
HTTPS_KEY_PATH=

# OPTIONAL (REQUIRED when HTTPS_ENABLED=true)
# Values: filesystem path to TLS certificate PEM
HTTPS_CERT_PATH=

# OPTIONAL
# Values: filesystem path to CA chain PEM
HTTPS_CA_PATH=

# OPTIONAL
# Values: true/false
# Meaning: keep HTTP listener on PORT and redirect all requests to HTTPS
HTTPS_REDIRECT_HTTP=true

# REQUIRED
# Values: long random string
# Meaning: shared secret for header auth (`x-api-key`) and fallback auth
# Where to get: generate yourself (example: `openssl rand -hex 32`)
SIGNAL_API_KEY=replace_with_long_random_key

# OPTIONAL
# Values: Telegram bot token format `123456789:xxxxxxxx...`
# Meaning: enable Telegram push notification when a signal arrives
# Where to get: Telegram @BotFather
TELEGRAM_BOT_TOKEN=

# OPTIONAL
# Values: numeric chat id (example: 123456789 or -100xxxxxxxxxx)
# Meaning: destination chat for Telegram push
# Where to get: Telegram `getUpdates` API after sending a message to your bot
TELEGRAM_CHAT_ID=

# OPTIONAL
# Values: comma-separated symbols in UPPERCASE, empty to allow all
# Meaning: allowlist for incoming trade symbols
# Where to get: define your own risk policy
ALLOW_SYMBOLS=

# OPTIONAL
# Values: numeric percent > 0, empty to disable
# Meaning: reject signal when entry->SL risk % exceeds this value
# Where to get: define your own risk policy
MAX_RISK_PCT=5

# =========================
# Binance executor
# =========================
# OPTIONAL (but REQUIRED to execute Binance)
# Values: `paper`, `live`, or empty
# Meaning: Binance execution mode; empty = Binance disabled
# Where to get: choose by environment (paper first, then live)
BINANCE_MODE=

# OPTIONAL
# Values: `spot` or `um_futures`
# Meaning: Binance market type
# Where to get: your Binance strategy/account product
BINANCE_PRODUCT=spot

# OPTIONAL (REQUIRED when BINANCE_MODE is set)
# Values: API key string
# Meaning: Binance API credential
# Where to get: Binance API Management
BINANCE_API_KEY=

# OPTIONAL (REQUIRED when BINANCE_MODE is set)
# Values: API secret string
# Meaning: Binance API secret
# Where to get: Binance API Management
BINANCE_API_SECRET=

# OPTIONAL
# Values: number > 0, empty allowed
# Meaning: fixed base quantity if signal qty is missing
# Where to get: your position sizing rule
BINANCE_DEFAULT_QTY=

# OPTIONAL
# Values: number > 0, empty allowed
# Meaning: quote amount for SPOT BUY (used if qty missing)
# Where to get: your position sizing rule
BINANCE_DEFAULT_QUOTE_QTY=50

# OPTIONAL
# Values: integer milliseconds
# Meaning: Binance recvWindow for signed requests
# Where to get: keep default unless needed
BINANCE_RECV_WINDOW=5000

# =========================
# cTrader executor bridge
# =========================
# OPTIONAL (but REQUIRED to execute cTrader)
# Values: `demo`, `live`, or empty
# Meaning: cTrader execution mode; empty = cTrader disabled
# Where to get: choose by environment
CTRADER_MODE=

# OPTIONAL (REQUIRED when CTRADER_MODE is set)
# Values: full URL (https://...)
# Meaning: your cTrader bridge endpoint that receives forwarded signal
# Where to get: your own cTrader executor service URL
CTRADER_EXECUTOR_URL=

# OPTIONAL
# Values: secret string or empty
# Meaning: API key sent as `x-api-key` to your cTrader bridge
# Where to get: your own cTrader bridge config
CTRADER_EXECUTOR_API_KEY=

# =========================
# MT5 bridge (same server.js)
# =========================
# OPTIONAL
# Values: true/false
# Meaning: enable MT5 queue + EA polling endpoints
# Where to get: set true if using MT5 EA bridge
MT5_ENABLED=true

# OPTIONAL
# Values: `sqlite`, `json`, `postgres`
# Meaning: storage backend for MT5 signal queue
# Where to get: choose based on your deployment (sqlite recommended default)
MT5_STORAGE=sqlite

# OPTIONAL
# Values: comma-separated keys, empty to reuse SIGNAL_API_KEY
# Meaning: API keys accepted by `/mt5/tv/webhook`
# Where to get: define your own keys (or leave empty to reuse SIGNAL_API_KEY)
MT5_TV_ALERT_API_KEYS=

# OPTIONAL
# Values: comma-separated random tokens, empty to reuse SIGNAL_API_KEY
# Meaning: token(s) accepted on tokenized webhook path:
#          `/signal/<token>` or `/mt5/tv/webhook/<token>`
# Where to get: generate your own token(s)
MT5_TV_WEBHOOK_TOKENS=

# OPTIONAL
# Values: comma-separated keys, empty to reuse SIGNAL_API_KEY
# Meaning: API keys accepted by `/mt5/ea/pull` and `/mt5/ea/ack`
# Where to get: define your own keys (or leave empty to reuse SIGNAL_API_KEY)
MT5_EA_API_KEYS=

# OPTIONAL
# Values: true/false
# Meaning: allow legacy payload key fields (`apiKey` / `api_key`) during migration
MT5_AUTH_ALLOW_LEGACY_PAYLOAD_KEY=true

# OPTIONAL
# Values: true/false
# Meaning: allow legacy query key fields (`apiKey` / `api_key`) during migration
MT5_AUTH_ALLOW_LEGACY_QUERY_KEY=true

# OPTIONAL
# Values: true/false
# Meaning: dual-write new v2 execution ledger tables (`sources/account_sources/trades/trade_events`)
#          on every newly ingested signal while keeping legacy flow active
MT5_V2_DUAL_WRITE_ENABLED=false

# OPTIONAL
# Values: true/false
# Meaning: enable v2 broker endpoints (`/v2/broker/pull`, `/v2/broker/ack`) with account API-key auth
MT5_V2_BROKER_API_ENABLED=false

# OPTIONAL
# Values: integer seconds (5..300)
# Meaning: lease TTL for v2 pulled trades
MT5_V2_LEASE_SECONDS=30

# OPTIONAL
# Values: number > 0
# Meaning: fallback lot size when signal does not provide quantity
# Where to get: your MT5 risk rule
MT5_DEFAULT_LOT=0.01

# OPTIONAL
# Values: text user id
# Meaning: default `user_id` applied when webhook payload has no user info
# Where to get: your own user naming convention
MT5_DEFAULT_USER_ID=default

# OPTIONAL
# Values: filesystem path
# Meaning: database file path for `sqlite` or `json` backend
# Where to get: choose local path (default works)
MT5_DB_PATH=./mt5-signals.db

# OPTIONAL
# Values: true/false
# Meaning: auto-prune old terminal MT5 trades
# Where to get: set true for production
MT5_PRUNE_ENABLED=true

# OPTIONAL
# Values: integer days (1..3650)
# Meaning: keep terminal records newer than this many days
# Where to get: your retention policy (14-30 typical)
MT5_PRUNE_DAYS=14

# OPTIONAL
# Values: integer minutes (1..1440)
# Meaning: scheduler interval for prune job
# Where to get: your ops preference (60 typical)
MT5_PRUNE_INTERVAL_MINUTES=60

# OPTIONAL (REQUIRED when MT5_STORAGE=postgres)
# Values: Postgres connection URI
# Meaning: remote Postgres DB for MT5 queue
# Where to get: your DB provider (Neon/Supabase/RDS/etc)
# Note: `MT5_POSTGRES_URL` takes priority; `POSTGRES_URL` and `POSTGRE_URL` are also accepted.
MT5_POSTGRES_URL=

# =========================
# Webhook UI auth
# =========================
# OPTIONAL
# Values: true/false
# Meaning: enable UI login (email/password + cookie session)
UI_AUTH_ENABLED=true

# OPTIONAL
# Values: email
# Meaning: bootstrap login email when auth state file does not exist yet
UI_BOOTSTRAP_EMAIL=hung.hoxuan@gmail.com

# OPTIONAL
# Values: password (min 8 chars)
# Meaning: bootstrap login password when auth state file does not exist yet
UI_BOOTSTRAP_PASSWORD=change_me_bootstrap_password

# OPTIONAL
# Values: integer seconds
# Meaning: cookie session max age
UI_SESSION_TTL_SECONDS=604800

# OPTIONAL
# Values: filesystem path
# Meaning: auth state file storing hashed password
UI_AUTH_STATE_PATH=./ui-auth.json
