// Shared series used across features (keep above any function references).
commonAtr = ta.atr(14)
    
UI_update_fib_line(line ln, int x1, int x2, float y, color lnColor) =>
    line out = ln
    if na(y) or na(x1) or na(x2)
        if not na(out)
            line.delete(out)
            out := na
    else
        if na(out)
            out := line.new(x1, y, x2, y, xloc = xloc.bar_index, extend = extend.none, color = lnColor, width = 1, style = line.style_dashed)
        else
            line.set_x1(out, x1)
            line.set_y1(out, y)
            line.set_x2(out, x2)
            line.set_y2(out, y)
            line.set_color(out, lnColor)
            line.set_width(out, 1)
            line.set_style(out, line.style_dashed)
    out

UI_update_fib_label(label lb, int x, float y, string txt, color txtColor, string txtSize) =>
    label out = lb
    if na(y) or na(x)
        if not na(out)
            label.delete(out)
            out := na
    else
        if na(out)
            out := label.new(x, y, txt, xloc = xloc.bar_index, style = label.style_none, color = color.new(color.white, 100), textcolor = txtColor, size = txtSize)
        else
            label.set_x(out, x)
            label.set_y(out, y)
            label.set_text(out, txt)
            label.set_textcolor(out, txtColor)
            label.set_size(out, txtSize)
    out

SMC_draw_tf_last_leg_fibs(KitSMC.TFData tfData, string sourceTf, color fibColor, line ln50, line ln60, line ln70, label lb50) =>
    [ok, startIdxRaw, endIdxRaw, startP, endP] = KitSMC.get_last_leg_from_swings(tfData)
    line out50 = ln50
    line out60 = ln60
    line out70 = ln70
    label outLb50 = lb50
    if not ok
        out50 := UI_update_fib_line(out50, na, na, na, fibColor)
        out60 := UI_update_fib_line(out60, na, na, na, fibColor)
        out70 := UI_update_fib_line(out70, na, na, na, fibColor)
        outLb50 := UI_update_fib_label(outLb50, na, na, "", fibColor, size.tiny)
    else
        int x1 = bar_index
        [tf1Local, tf2Local] = KitCore.get_htf_pair()
        int fibExt = KitCore.get_tf_line_ext_bars(sourceTf, tf1Local, tf2Local, uiCfg.ltfLineBarsExt, 17, 28)
        int x2 = KitCore.get_sr_x(bar_index, fibExt, false)
        float hi = math.max(startP, endP)
        float lo = math.min(startP, endP)
        float rng = hi - lo
        if rng <= syminfo.mintick
            out50 := UI_update_fib_line(out50, na, na, na, fibColor)
            out60 := UI_update_fib_line(out60, na, na, na, fibColor)
            out70 := UI_update_fib_line(out70, na, na, na, fibColor)
            outLb50 := UI_update_fib_label(outLb50, na, na, "", fibColor, size.tiny)
        else
            bool upLeg = endP >= startP
            float fib50 = upLeg ? (hi - (rng * 0.5)) : (lo + (rng * 0.5))
            float fib60 = upLeg ? (hi - (rng * 0.6)) : (lo + (rng * 0.6))
            float fib70 = upLeg ? (hi - (rng * 0.7)) : (lo + (rng * 0.7))
            color fib50Color = color.new(fibColor, 20)
            color fib60Color = color.new(fibColor, 45)
            color fib70Color = color.new(fibColor, 70)
            out50 := UI_update_fib_line(out50, x1, x2, fib50, fib50Color)
            out60 := UI_update_fib_line(out60, x1, x2, fib60, fib60Color)
            out70 := UI_update_fib_line(out70, x1, x2, fib70, fib70Color)
            string fibLabelSize = sourceTf == timeframe.period ? size.tiny : size.small
            outLb50 := UI_update_fib_label(outLb50, x2, fib50, "0.5", fibColor, fibLabelSize)
    [out50, out60, out70, outLb50]

process_data_reset_runtime_context_if_new_bar() =>
    int cachedBar = array.get(rtBarBox, 0)
    if na(cachedBar) or cachedBar != bar_index
        array.set(rtBarBox, 0, bar_index)
        array.clear(rtStrategyKeys)
        array.clear(rtStrategyEnabled)
        array.clear(rtStrategyScore)
        array.clear(rtStrategyShort)
        array.clear(rtStrategyTriggerType)
        array.clear(rtStrategyTriggerWhen)
        array.clear(rtTimeToIdxKeys)
        array.clear(rtTimeToIdxVals)
        array.clear(rtFvgScanKeys)
        array.clear(rtFvgScanTopVals)
        array.clear(rtFvgScanBtmVals)
        array.clear(rtFvgScanBarVals)
        array.clear(rtWorkIdxKeys)
        array.clear(rtWorkIdxVals)
        array.clear(rtWorkIdxRelaxKeys)
        array.clear(rtWorkIdxRelaxVals)
    bool(na)

get_data_working_first_time_for_source_tf(string sourceTf) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    KitSMC.get_working_first_time_for_source_tf(timeframe.period, sourceTf, tf1Local, tf2Local, localCfg.workingLookbackBars, htf1Data.mss, htf2Data.mss)

get_data_real_htf_swings(string tfName, int pivotLen) =>
    float sh = na
    int shT = na
    float sl = na
    int slT = na
    if not na(tfName) and tfName != ""
        [shRaw, slRaw, shTRaw, slTRaw] = request.security(syminfo.tickerid, tfName, [ta.pivothigh(high, pivotLen, pivotLen), ta.pivotlow(low, pivotLen, pivotLen), not na(ta.pivothigh(high, pivotLen, pivotLen)) ? time[pivotLen] : int(na), not na(ta.pivotlow(low, pivotLen, pivotLen)) ? time[pivotLen] : int(na)], lookahead = barmerge.lookahead_off)
        sh := shRaw
        sl := slRaw
        shT := int(shTRaw)
        slT := int(slTRaw)
    [sh, shT, sl, slT]

get_data_map_htf_swing_to_ltf_idx(int swingT) =>
    not na(swingT) ? KitUI.closest_bar_index_from_time(swingT) : na

get_data_working_first_idx_for_source_tf(string sourceTf) =>
    process_data_reset_runtime_context_if_new_bar()
    string key = na(sourceTf) or sourceTf == "" ? timeframe.period : sourceTf
    int idx = na
    if array.size(rtWorkIdxKeys) > 0
        for i = 0 to array.size(rtWorkIdxKeys) - 1
            if array.get(rtWorkIdxKeys, i) == key
                idx := array.get(rtWorkIdxVals, i)
                break
    if na(idx)
        int cutoffTime = get_data_working_first_time_for_source_tf(key)
        int cutoffIdx = KitUI.closest_bar_index_from_time(cutoffTime)
        idx := na(cutoffIdx) ? workingFirstBar : cutoffIdx
        array.push(rtWorkIdxKeys, key)
        array.push(rtWorkIdxVals, idx)
    idx

// Relaxed TF cutoff: ratio-window only (ignores structural anchor tightening).
get_data_relaxed_first_idx_for_source_tf(string sourceTf) =>
    if na(sourceTf) or sourceTf == "" or sourceTf == timeframe.period
        workingFirstBar
    else
        process_data_reset_runtime_context_if_new_bar()
        string key = sourceTf
        int idx = na
        if array.size(rtWorkIdxRelaxKeys) > 0
            for i = 0 to array.size(rtWorkIdxRelaxKeys) - 1
                if array.get(rtWorkIdxRelaxKeys, i) == key
                    idx := array.get(rtWorkIdxRelaxVals, i)
                    break
        if na(idx)
            int cutoffTime = KitSMC.get_working_first_time_for_tf(timeframe.period, key, localCfg.workingLookbackBars)
            int cutoffIdx = KitUI.closest_bar_index_from_time(cutoffTime)
            idx := na(cutoffIdx) ? workingFirstBar : cutoffIdx
            array.push(rtWorkIdxRelaxKeys, key)
            array.push(rtWorkIdxRelaxVals, idx)
        idx

is_in_working_zone_idx_for_source_tf(int idx, string sourceTf) =>
    not na(idx) and idx >= get_data_working_first_idx_for_source_tf(sourceTf)

get_data_level_anchor_idx(KitSMC.PDArray z) =>
    int idx = na
    if not na(z.barEnd)
        idx := z.barEnd
    else if not na(z.barStart)
        bool isTimestamp = z.barStart > 1000000000
        idx := isTimestamp ? na : z.barStart
    idx

process_data_prune_outside_working_zone_levels(array<KitSMC.PDArray> levels) =>
    if array.size(levels) > 0
        for i = array.size(levels) - 1 to 0 by 1
            KitSMC.PDArray z = array.get(levels, i)
            int anchorIdx = get_data_level_anchor_idx(z)
            string sourceTf = na(z.labelText) or z.labelText == "" ? timeframe.period : z.labelText
            int firstIdx = get_data_working_first_idx_for_source_tf(sourceTf)
            if not na(anchorIdx) and anchorIdx < firstIdx
                KitUI.delete_line_label(z.visualLine, z.visualLabel)
                array.remove(levels, i)
    bool(na)

// ==================== INPUT SETTINGS ====================

GROUP_UI_CONFIG = "1. UI Config"
GROUP_TRADE_MODELS = "2. Trade Models"
GROUP_TRADES_CONFIG = "3. Trade Config"

uiShowSrInput = input.bool(true, "S/R", inline = "ui0", group = GROUP_UI_CONFIG)
uiShowLiqInput = input.bool(true, "Swing Liq", inline = "ui0", group = GROUP_UI_CONFIG)
uiShowPdhPdlInput = input.bool(true, "PdH/L", inline = "ui0", group = GROUP_UI_CONFIG)
uiShowLtfInput = input.bool(false, "LTF", inline = "ui1", group = GROUP_UI_CONFIG)
uiShowTf1Input = input.bool(true, "TF1", inline = "ui1", group = GROUP_UI_CONFIG)
uiShowTf2Input = input.bool(true, "TF2", inline = "ui1", group = GROUP_UI_CONFIG)
uiShowBosMssInput = input.bool(true, "BOS/MSS", inline = "ui2", group = GROUP_UI_CONFIG)
uiShowZigzagInput = input.bool(true, "Zigzag", inline = "ui2", group = GROUP_UI_CONFIG)
uiShowSwingsInput = input.bool(true, "Swings", inline = "ui2", group = GROUP_UI_CONFIG)
uiDisplayCombo = input.string("Less", "Display", options = ["All", "Less", "Normal", "Extreme", "None"], inline = "ui_disp", group = GROUP_UI_CONFIG)
uiTimeRangeCombo = input.string("dynamic", "", options = ["dynamic", "Today", "Yesterday", "Day", "This Week", "Last Week", "Week", "This Month", "Last Month", "Month", "This Year", "Year"], inline = "ui_disp", group = GROUP_UI_CONFIG)

bool uiModeAll = uiDisplayCombo == "All"
bool uiModeLess = uiDisplayCombo == "Less"
bool uiModeExtreme = uiDisplayCombo == "Extreme"
bool uiModeNone = uiDisplayCombo == "None"
showSR = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? true : uiShowSrInput
liquidityBool = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? true : uiShowLiqInput
showPDH_PDL = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? true : uiShowPdhPdlInput
// Display mode must not affect MSS visual stack.
msShowLtf = uiShowLtfInput
msShowTf1 = uiShowTf1Input
msShowTf2 = uiShowTf2Input
msShowBosMss = uiShowBosMssInput
msShowZigzag = uiShowZigzagInput
msShowSwings = uiShowSwingsInput
modelMssTrade = input.bool(true, "MSS - MSS.", inline = "m0", group = GROUP_TRADE_MODELS)
modelMssRr = input.float(1.0, "RR", minval = 0.0, step = 0.25, inline = "m0rr", group = GROUP_TRADE_MODELS)
modelMssSlGap = input.float(0.1, "Gap", minval = 0.0, step = 0.05, inline = "m0rr", group = GROUP_TRADE_MODELS)
modelBosTrade = input.bool(false, "BOS - BOS.", inline = "m1", group = GROUP_TRADE_MODELS)
modelBosRr = input.float(1.0, "RR", minval = 0.0, step = 0.25, inline = "m1rr", group = GROUP_TRADE_MODELS)
modelBosSlGap = input.float(0.1, "Gap", minval = 0.0, step = 0.05, inline = "m1rr", group = GROUP_TRADE_MODELS)
modelSweep = false
modelSweepWhen = TRIGGER_WHEN_RETEST
modelSweepType = TRIGGER_TYPE_SIGNAL
modelSweepRr = 1.0
modelSweepMss = false
modelSweepMssWhen = TRIGGER_WHEN_TOUCH
modelSweepMssType = TRIGGER_TYPE_SIGNAL
modelSweepMssRr = 1.0
modelSweepMssFvg = false
modelSweepMssFvgWhen = TRIGGER_WHEN_TOUCH
modelSweepMssFvgType = TRIGGER_TYPE_SIGNAL
modelSweepMssFvgRr = 1.0

tradeEntriesInput = input.bool(true, "Trades", inline = "tc0", group = GROUP_TRADES_CONFIG)
strategyOrdersInput = input.bool(false, "Strategy", inline = "tc0", group = GROUP_TRADES_CONFIG)
propPreset = input.string("None", "Trade rules", options = ["None", "FTMO 2-Step", "FTMO 1-Step", "The5ers HS", "The5ers HG"], tooltip = "FTMO 2-Step: 2.5% daily cap, 0.5%/trade | FTMO 1-Step: 1.5%/2.5% | The5ers HS: 2.5%/0.5% | The5ers HG: 1.5%/0.5% | None: unlimited", inline="tc0", group = GROUP_TRADES_CONFIG)
tradeRiskValue = input.float(1.0, "1R", minval = 0.01, maxval = 100.0, step = 0.1, inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeRiskMode  = input.string("%", "", options = ["%", "$"], inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeSpreadTicks = input.float(0.0, "Spread", minval = 0.0, step = 0.5, inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeShowPending = input.bool(true, "Pending", inline = "tc2b", group = GROUP_TRADES_CONFIG)
tradeShowStart = input.bool(true, "Start -> Active", inline = "tc2b", group = GROUP_TRADES_CONFIG)
tradeShowTp = input.bool(false, "TP", inline = "tc2b", group = GROUP_TRADES_CONFIG)
tradeShowSl = input.bool(false, "SL", inline = "tc2b", group = GROUP_TRADES_CONFIG)
gateUsePreTouchTpCut = input.bool(false, "Pre-touch TP cut", inline = "tc3", group = GROUP_TRADES_CONFIG)
bool gateUseEntryDirection = false
bool gateUseRetestConfirm = false
bool gateUseRetestInvalidation = false
tradeEntriesEnabled = tradeEntriesInput
strategyOrdersEnabled = strategyOrdersInput
entryEngineEnabled = tradeEntriesEnabled or strategyOrdersEnabled
showTradesDashboard = true
gateUseMaxActive = false
GLOBAL_MAX_LOOKBACK_BARS := KitCore.get_dynamic_global_max_lookback_bars(uiTimeRangeCombo, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS, htf2MasterRangeBars)
GLOBAL_MAX_LOOKBACK_BARS := math.min(GLOBAL_MAX_LOOKBACK_BARS, get_data_effective_history_cap_bars(uiTimeRangeCombo))

// ==================== INIT / SETUP (ENTRY MODELS, PDARRAYs..) ====================
// barstate.isfirst
if barstate.isfirst
    localCfg := get_data_local_cfg(GLOBAL_MAX_LOOKBACK_BARS, uiDisplayCombo)
    workingFirstBar := KitCore.get_working_first_bar_from_lookback(localCfg.workingLookbackBars)
    [_wfLine0, _wfLabel0] = KitCore.update_working_first_bar_marker(workingFirstBarLine, workingFirstBarLabel, workingFirstBar, "MSS", color.new(uiCfg.ltfColor, 0), line.style_dotted, color.new(uiCfg.ltfColor, 0), THEME.SIZE_TINY)
    workingFirstBarLine := _wfLine0
    workingFirstBarLabel := _wfLabel0
    uiCfg := get_ui_cfg(THEME)
    ZONE_VIS_CFG.minWidthBars := uiCfg.zoneCurrMinWidthBars
float tradeRiskAmountUsd = tradeRiskMode == "%" ? (tradeRiskValue / 100.0 * math.max(strategy.equity, 0.0)) : tradeRiskValue
// removed minTradeSizeTicks
localCfg.minTradeRR := 0.0
localCfg.displayMode := uiDisplayCombo
localCfg.workingLookbackBars := KitCore.get_display_mode_working_lookback_bars(uiDisplayCombo, GLOBAL_MAX_LOOKBACK_BARS)
if SETTINGS.DYN_LOOKBACK_ENABLE and uiTimeRangeCombo == "dynamic"
    localCfg.workingLookbackBars := math.max(localCfg.workingLookbackBars, htf2MasterRangeBars)
localCfg.workingLookbackBars := math.min(localCfg.workingLookbackBars, get_data_effective_history_cap_bars(uiTimeRangeCombo))
localCfg.srSideCap := uiDisplayCombo == "All" ? 24 : uiDisplayCombo == "Less" ? 16 : uiDisplayCombo == "Normal" ? 10 : uiDisplayCombo == "Extreme" ? 6 : 0
localCfg.srSourceSideCap := uiDisplayCombo == "All" ? 12 : uiDisplayCombo == "Less" ? 8 : uiDisplayCombo == "Normal" ? 5 : uiDisplayCombo == "Extreme" ? 3 : 0
localCfg.srMinDistMult := uiDisplayCombo == "All" ? 0.85 : uiDisplayCombo == "Less" ? 1.00 : uiDisplayCombo == "Normal" ? 1.20 : uiDisplayCombo == "Extreme" ? 1.50 : 1.20
localCfg.srSeedLimit := uiDisplayCombo == "All" ? 20 : uiDisplayCombo == "Less" ? math.max(localCfg.limSrSeedSwingsPerTf * 4, localCfg.limSrSeedSwingsPerTf) : uiDisplayCombo == "Normal" ? localCfg.limSrSeedSwingsPerTf : uiDisplayCombo == "Extreme" ? math.max(1, localCfg.limSrSeedSwingsPerTf - 1) : localCfg.limSrSeedSwingsPerTf
localCfg.srSeedDiv := uiDisplayCombo == "All" ? 120 : uiDisplayCombo == "Less" ? 80 : uiDisplayCombo == "Normal" ? 50 : uiDisplayCombo == "Extreme" ? 30 : 50
if get_data_is_1m_chart()
    // 1m profile: tighter limits to avoid runtime timeout.
    localCfg.limSrSeedSwingsPerTf := 1
    localCfg.srSideCap := math.min(localCfg.srSideCap, 8)
    localCfg.srSourceSideCap := math.min(localCfg.srSourceSideCap, 3)
    localCfg.srSeedLimit := math.min(localCfg.srSeedLimit, 3)
    localCfg.srSeedDiv := math.min(localCfg.srSeedDiv, 40)
else if get_data_is_fast_chart()
    // <=5m profile: moderate throttles for stable runtime.
    localCfg.limSrSeedSwingsPerTf := math.min(localCfg.limSrSeedSwingsPerTf, 1)
    localCfg.srSideCap := math.min(localCfg.srSideCap, 10)
    localCfg.srSourceSideCap := math.min(localCfg.srSourceSideCap, 4)
    localCfg.srSeedLimit := math.min(localCfg.srSeedLimit, 4)
    localCfg.srSeedDiv := math.min(localCfg.srSeedDiv, 45)

// ==================== LOCAL HELPERS ====================

CORE_get_trade_order_qty(float entry, float stoploss, float riskPerRRUsd) =>
    if na(entry) or na(stoploss)
        float(na)
    else
        float riskPerUnitUsd = math.abs(entry - stoploss) * math.max(math.abs(syminfo.pointvalue), 1e-10)
        riskPerUnitUsd <= 0.0 ? float(na) : (math.max(riskPerRRUsd, 0.0) / riskPerUnitUsd)

CORE_track_trade_entry(array<KitCore.Trade> entriesRef, array<string> orderIdsRef, KitCore.Trade e, string orderId, bool shouldTrack) =>
    if shouldTrack and not na(e)
        array.push(entriesRef, e)
        array.push(orderIdsRef, orderId)
    bool(na)

CORE_submit_strategy_trade_order(string orderId, string direction, float orderQty, float entry, float stoploss, float takeprofit) =>
    if orderId != "" and not na(orderQty) and orderQty > 0.0
        strategy.entry(orderId, direction == "Buy" ? strategy.long : strategy.short, qty = orderQty, limit = entry, comment = "")
        strategy.exit(orderId + "_x", from_entry = orderId, stop = stoploss, limit = takeprofit, comment_profit = "", comment_loss = "")
    bool(na)

CORE_cancel_strategy_trade_order(string orderId) =>
    if orderId != ""
        strategy.cancel(orderId)
        strategy.cancel(orderId + "_x")
    bool(na)

// ==================== FEATURES ====================

get_data_color_sig(color c) =>
    str.tostring(color.r(c)) + ":" + str.tostring(color.g(c)) + ":" + str.tostring(color.b(c)) + ":" + str.tostring(color.t(c))

// LIQ-specific swept flag (separate semantics from generic lifecycle touched state).
get_data_is_liq_swept(KitSMC.PDArray z) =>
    KitCore.is_life_broken(z.lifeState, CONST) or KitCore.is_life_reclaimed(z.lifeState, CONST)

get_data_tf_priority(string tfLbl) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    tfLbl == tf2Local ? 3 : tfLbl == tf1Local ? 2 : tfLbl == timeframe.period ? 1 : 0

get_data_liq_label_align(string liqTxt) =>
    if liqTxt != "$"
        text.align_center
    else
        localCfg.liqDollarXPos == "Right" ? text.align_right : localCfg.liqDollarXPos == "Left" ? text.align_left : text.align_center

get_data_liq_label_y(string liqTxt, float basePrice) =>
    if liqTxt != "$"
        basePrice
    else
        float yPad = syminfo.mintick * math.max(localCfg.liqDollarYOffsetTicks, 0.0)
        localCfg.liqDollarYPos == "Above" ? (basePrice + yPad) : localCfg.liqDollarYPos == "Below" ? (basePrice - yPad) : basePrice

get_data_liq_label_x(line liqLine, string liqTxt) =>
    int x1 = liqLine.get_x1()
    int x2 = liqLine.get_x2()
    int midX = int(math.round((x1 + x2) * 0.5))
    if liqTxt != "$"
        midX
    else
        localCfg.liqDollarXPos == "Right" ? x2 : localCfg.liqDollarXPos == "Left" ? x1 : midX

get_data_liq_has_stronger_overlap(array<KitSMC.PDArray> levels, int selfIdx, KitSMC.PDArray self, float tolPrice) =>
    bool hasStronger = false
    int selfPrio = get_data_tf_priority(self.labelText)
    bool scopeDollarOnly = localCfg.liqOverlapScope == "Dollar Only"
    bool selfIsDollar = self.labelText != timeframe.period
    if array.size(levels) > 0
        for j = 0 to array.size(levels) - 1
            if j == selfIdx
                continue
            KitSMC.PDArray other = array.get(levels, j)
            bool sameFamily = other.type == "LIQ"
            bool otherIsDollar = other.labelText != timeframe.period
            bool scopeOk = scopeDollarOnly ? (selfIsDollar and otherIsDollar) : true
            bool near = math.abs(other.price - self.price) <= tolPrice
            bool active = not get_data_is_liq_swept(other)
            if sameFamily and scopeOk and near and active
                int otherPrio = get_data_tf_priority(other.labelText)
                if otherPrio > selfPrio
                    hasStronger := true
                    break
    hasStronger

process_data_init_strategy_defs() =>
    array.clear(strategyDefs)
    string mssType = modelMssTrade ? TRIGGER_TYPE_TRADE : TRIGGER_TYPE_SIGNAL
    string bosType = modelBosTrade ? TRIGGER_TYPE_TRADE : TRIGGER_TYPE_SIGNAL
    array.push(strategyDefs, KitCore.EntryModelDef.new("MSS", "MSS", 3, true, mssType, TRIGGER_WHEN_TOUCH, modelMssRr, "edge", 1, 1, 0, "", 100, "na", 2, true, modelMssSlGap, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, KitCore.EntryModelDef.new("BOS", "BOS", 2, true, bosType, TRIGGER_WHEN_TOUCH, modelBosRr, "edge", 1, 1, 0, "", 100, "na", 2, true, modelBosSlGap, ENTRY_MODE_AFTER_RETEST))
    bool(na)

get_data_strategy_defs_sig() =>
    int sig = 0
    sig += (modelMssTrade ? 1 : 0) * 100000 + int(math.round(modelMssRr * 10.0)) * 13 + int(math.round(modelMssSlGap * 100.0)) * 17
    sig += (modelBosTrade ? 1 : 0) * 100 + int(math.round(modelBosRr * 10.0)) * 29 + int(math.round(modelBosSlGap * 100.0)) * 31
    sig += (modelSweep ? 1 : 0) * 31 + KitCore.trigger_type_code(modelSweepType, TRIGGER_TYPE_SIGNAL) * 37 + KitCore.trigger_when_code(modelSweepWhen, TRIGGER_WHEN_TOUCH) * 41
    sig += (modelSweepMss ? 1 : 0) * 43 + KitCore.trigger_type_code(modelSweepMssType, TRIGGER_TYPE_SIGNAL) * 47 + KitCore.trigger_when_code(modelSweepMssWhen, TRIGGER_WHEN_TOUCH) * 53
    sig += (modelSweepMssFvg ? 1 : 0) * 59 + KitCore.trigger_type_code(modelSweepMssFvgType, TRIGGER_TYPE_SIGNAL) * 61 + KitCore.trigger_when_code(modelSweepMssFvgWhen, TRIGGER_WHEN_TOUCH) * 67
    sig

process_data_refresh_strategy_defs() =>
    int nextSig = get_data_strategy_defs_sig()
    int cachedSig = array.get(strategyDefsSigBox, 0)
    if na(cachedSig) or cachedSig != nextSig or array.size(strategyDefs) == 0
        process_data_init_strategy_defs()
        array.set(strategyDefsSigBox, 0, nextSig)
    bool(na)

get_data_strategy_meta_by_key(string key) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(key)
    process_data_reset_runtime_context_if_new_bar()
    int cachedIdx = na
    if array.size(rtStrategyKeys) > 0
        for i = 0 to array.size(rtStrategyKeys) - 1
            if array.get(rtStrategyKeys, i) == k
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtStrategyEnabled, cachedIdx), array.get(rtStrategyScore, cachedIdx), array.get(rtStrategyShort, cachedIdx), array.get(rtStrategyTriggerType, cachedIdx), array.get(rtStrategyTriggerWhen, cachedIdx)]
    else
        bool enabled = false
        int score = 0
        string shortName = ""
        string triggerType = TRIGGER_TYPE_TRADE
        string triggerWhen = TRIGGER_WHEN_RETEST
        for i = 0 to array.size(strategyDefs) - 1
            KitCore.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                enabled := s.enabled
                score := s.baseScore
                shortName := s.shortName
                triggerType := s.trigger_type
                triggerWhen := s.trigger_when
                break
        array.push(rtStrategyKeys, k)
        array.push(rtStrategyEnabled, enabled)
        array.push(rtStrategyScore, score)
        array.push(rtStrategyShort, shortName)
        array.push(rtStrategyTriggerType, triggerType)
        array.push(rtStrategyTriggerWhen, triggerWhen)
        [enabled, score, shortName, triggerType, triggerWhen]

get_data_cached_bar_index_from_time(int t) =>
    process_data_reset_runtime_context_if_new_bar()
    if na(t)
        na
    else
        int idx = na
        if array.size(rtTimeToIdxKeys) > 0
            for i = 0 to array.size(rtTimeToIdxKeys) - 1
                if array.get(rtTimeToIdxKeys, i) == t
                    idx := i
                    break
        if not na(idx)
            array.get(rtTimeToIdxVals, idx)
        else
            int v = KitUI.closest_bar_index_from_time(t)
            array.push(rtTimeToIdxKeys, t)
            array.push(rtTimeToIdxVals, v)
            v

get_data_ms_track_slot(string tfName) =>
    int slot = na
    if array.size(msTrackTf) > 0
        for i = 0 to array.size(msTrackTf) - 1
            if array.get(msTrackTf, i) == tfName
                slot := i
                break
    if na(slot)
        array.push(msTrackTf, tfName)
        array.push(msTrackLine, na)
        array.push(msTrackLabel, na)
        array.push(msTrackLevel, na)
        array.push(msTrackDir, 0)
        array.push(msTrackBar, na)
        array.push(msTrackActive, false)
        array.push(msTrackVisible, false)
        slot := array.size(msTrackTf) - 1
    slot

process_data_clear_ms_track_slot(int slot) =>
    line evtLine = array.get(msTrackLine, slot)
    label evtLabel = array.get(msTrackLabel, slot)
    KitUI.delete_line_label(evtLine, evtLabel)
    array.set(msTrackLine, slot, na)
    array.set(msTrackLabel, slot, na)
    array.set(msTrackLevel, slot, na)
    array.set(msTrackDir, slot, 0)
    array.set(msTrackBar, slot, na)
    array.set(msTrackActive, slot, false)
    array.set(msTrackVisible, slot, false)
    bool(na)

process_data_reset_ms_track(string tfName) =>
    int slot = get_data_ms_track_slot(tfName)
    line evtLine = array.get(msTrackLine, slot)
    label evtLabel = array.get(msTrackLabel, slot)
    KitUI.delete_line_label(evtLine, evtLabel)
    process_data_clear_ms_track_slot(slot)

get_data_ms_reclass_invalidated(int dir, float lvl) =>
    bool useWick = localCfg.msReclassBasis == "Wick"
    dir == 1 ? (useWick ? low < lvl : close < lvl) : (useWick ? high > lvl : close > lvl)

process_data_register_ms_track(string tfName, line evtLine, label evtLabel, float level, int direction, bool visible) =>
    int slot = get_data_ms_track_slot(tfName)
    line prevLine = array.get(msTrackLine, slot)
    label prevLabel = array.get(msTrackLabel, slot)
    KitUI.delete_line_label(prevLine, prevLabel)
    array.set(msTrackLine, slot, evtLine)
    array.set(msTrackLabel, slot, evtLabel)
    array.set(msTrackLevel, slot, level)
    array.set(msTrackDir, slot, direction)
    array.set(msTrackBar, slot, bar_index)
    array.set(msTrackActive, slot, true)
    array.set(msTrackVisible, slot, visible)
    bool(na)

process_data_prune_left_visual_orphans() =>
    array<label> allLabels = label.all
    if array.size(allLabels) > 0
        for i = array.size(allLabels) - 1 to 0
            label lb = array.get(allLabels, i)
            int x = lb.get_x()
            if not na(x) and x < workingFirstBar
                string t = str.lower(lb.get_text())
                bool isMssVisual = str.contains(t, "bos") or str.contains(t, "mss") or t == "·" or t == CONST.SYM_DOT or t == "x"
                if isMssVisual
                    lb.delete()
    array<line> allLines = line.all
    if array.size(allLines) > 0
        for i = array.size(allLines) - 1 to 0
            line ln = array.get(allLines, i)
            int x1 = ln.get_x1()
            int x2 = ln.get_x2()
            int rightX = math.max(x1, x2)
            if not na(rightX) and rightX < workingFirstBar
                ln.delete()
    bool(na)

process_data_update_ms_track(string tfName) =>
    int slot = get_data_ms_track_slot(tfName)
    bool active = array.get(msTrackActive, slot)
    if not active
        bool(na)
    else
        int bornBar = array.get(msTrackBar, slot)
        line liveLine = array.get(msTrackLine, slot)
        int lineLeft = not na(liveLine) ? liveLine.get_x1() : na
        if (not na(bornBar) and bornBar < workingFirstBar) or (not na(lineLeft) and lineLeft < workingFirstBar)
            process_data_clear_ms_track_slot(slot)
            bool(na)
        else
            int ageBars = na(bornBar) ? 1000000 : (bar_index - bornBar)
            if ageBars > localCfg.msReclassBars
                process_data_clear_ms_track_slot(slot)
            else
                float lvl = array.get(msTrackLevel, slot)
                int dir = array.get(msTrackDir, slot)
                bool invalidated = get_data_ms_reclass_invalidated(dir, lvl)
                if invalidated
                    line evtLine = array.get(msTrackLine, slot)
                    label evtLabel = array.get(msTrackLabel, slot)
                    if not na(evtLine)
                        evtLine.set_style(line.style_dotted)
                    if not na(evtLabel)
                        string oldTxt = evtLabel.get_text()
                        string cleanTxt = str.replace(oldTxt, " x", "")
                        if evtLabel.get_text() != cleanTxt
                            evtLabel.set_text(cleanTxt)
                    string invDir = dir == 1 ? "Sell" : "Buy"
                    string invTip = "BOS/MSS invalidated (reclaim through level)"
                    float invBand = math.max(commonAtr * 0.03, syminfo.mintick * 2.0)
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, "SWEEP", invDir, invTip, lvl + invBand, lvl - invBand, 100.0, 1, bar_index, syminfo.mintick, 80)
                    process_data_clear_ms_track_slot(slot)
    bool(na)

get_entry_model_dynamic_cfg(string modelKey) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(modelKey)
    float rrCfg = 2.0
    string entryPoint = "edge"
    int biasLtfMode = 1
    int biasHtf1Mode = 0
    int biasHtf2Mode = 0
    string requiredPrevEvents = ""
    int requiredWindowBars = 100
    string biasDirection = "na"
    int maxActiveCfg = 1
    bool dynamicTpCfg = true
    float riskZonePctCfg = 0.0
    string entryModeCfg = ENTRY_MODE_AFTER_RETEST
    if array.size(strategyDefs) > 0
        for i = 0 to array.size(strategyDefs) - 1
            KitCore.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                rrCfg := s.rr
                entryPoint := s.entry_point
                biasLtfMode := s.bias_ltf
                biasHtf1Mode := s.bias_htf1
                biasHtf2Mode := s.bias_htf2
                requiredPrevEvents := s.required_previous_events
                requiredWindowBars := s.required_window_bars
                biasDirection := s.bias_direction
                maxActiveCfg := s.max_active
                dynamicTpCfg := s.dynamic_tp_sl
                riskZonePctCfg := s.risk_zone_pct
                entryModeCfg := s.entry_mode
                break
    [rrCfg, entryPoint, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, maxActiveCfg, dynamicTpCfg, riskZonePctCfg, entryModeCfg]

get_data_model_long_name(string shortNameOrType) =>
    string k = str.upper(shortNameOrType)
    int dotPos = str.pos(k, ".")
    k := dotPos >= 0 ? str.substring(k, 0, dotPos) : k
    k == "MS" or k == "MSS" ? "Market Structure Shift" :
     k == "BO" or k == "BOS" ? "Break of Structure" :
     (k == "SW" or k == "SWEEP" or k == "SM" or k == "SF" or k == "SWP" or k == "SWM" or k == "SWF") ? "Sweep" : "Model"

get_data_model_short3(string shortNameOrType) =>
    string k = str.upper(shortNameOrType)
    int dotPos = str.pos(k, ".")
    k := dotPos >= 0 ? str.substring(k, 0, dotPos) : k
    k == "MS" or k == "MSS" ? "MSS" :
     k == "BO" or k == "BOS" ? "BOS" :
     (k == "SW" or k == "SWEEP" or k == "SWP") ? "SWP" :
     k == "SM" or k == "SWM" ? "SWM" :
     k == "SF" or k == "SWF" ? "SWF" :
     (str.length(k) > 3 ? str.substring(k, 0, 3) : k)

get_data_model_key_for_type(string shortNameOrType) =>
    string k = str.upper(shortNameOrType)
    int dotPos = str.pos(k, ".")
    k := dotPos >= 0 ? str.substring(k, 0, dotPos) : k
    k == "MS" or k == "MSS" ? "MSS" :
     k == "BO" or k == "BOS" ? "BOS" :
     (k == "SM" or k == "SWM") ? "SWEEP_MSS" :
     (k == "SF" or k == "SWF") ? "SWEEP_FVG" :
     (k == "SW" or k == "SWEEP" or k == "SWP" or k == "X") ? "SWEEP" : k

get_data_trade_tf_suffix(string sourceTf) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    string tfResolved = na(sourceTf) or sourceTf == "" ? timeframe.period : sourceTf
    tfResolved == timeframe.period ? KitUI.get_friendly_tf(timeframe.period) :
     tfResolved == tf1Local ? KitUI.get_friendly_tf(tf1Local) :
     tfResolved == tf2Local ? KitUI.get_friendly_tf(tf2Local) :
     KitUI.get_friendly_tf(tfResolved)

get_data_trade_type_for_source(string baseType, string sourceTf) =>
    baseType + "." + get_data_trade_tf_suffix(sourceTf)

process_data_add_entry(string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal, string sourceTf) =>
    bool isBuy = direction == "Buy"
    string modelKey = get_data_model_key_for_type(type)
    [rrCfg, entryPointCfg, _, _, _, _, _, _, _, _, riskZonePctCfg, _] = get_entry_model_dynamic_cfg(modelKey)
    bool passDynamic = true
    bool passEntryMode = true
    bool shouldTrackTrades = tradeEntriesEnabled or strategyOrdersEnabled
    bool passBatchCap = true
    bool propAllowed = true
    if passDynamic and passEntryMode and passBatchCap and propAllowed
        float tick = syminfo.mintick
        float zoneTop = math.max(levelTop, levelBtm)
        float zoneBtm = math.min(levelTop, levelBtm)
        float zoneHeight = math.max(zoneTop - zoneBtm, tick)
        float entry = entryPointCfg == "middle" ? ((zoneTop + zoneBtm) * 0.5) : entryPointCfg == "end" ? (isBuy ? zoneBtm : zoneTop) : (isBuy ? zoneTop : zoneBtm)
        float slRaw = isBuy ? zoneBtm : zoneTop
        KitCore.TradePlan plan = KitCore.build_trade_plan(direction, entry, slRaw, rrCfg, zoneHeight * math.max(riskZonePctCfg, 0.0))
        float stoploss = plan.stoploss
        float takeprofit = plan.takeprofit
        float rrUsed = plan.rrUsed
        float slGap = plan.slGap
        if not plan.valid or not KitCore.is_trade_plan_valid_with_limits(entry, stoploss, takeprofit, localCfg.minTradeSizeTicks, localCfg.minTradeRR)
            bool(na)
        else
            string tradeType = get_data_trade_type_for_source(type, sourceTf)
            string shortName = get_data_model_short3(type)
            string longName = get_data_model_long_name(shortName)
            string modelKeyTip = get_data_model_key_for_type(shortName)
            [_, _, _, _, _, requiredPrevEvents, requiredWindowBars, _, _, _, _, _] = get_entry_model_dynamic_cfg(modelKeyTip)
            int evLookback = math.max(requiredWindowBars, 40)
            string eventsLine = "events: " + KitSMC.get_trade_relevant_events_text(smcCtx.signalHist, direction, shortName, requiredPrevEvents, 5, evLookback, 28, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
            KitCore.TradeTooltipMeta tipMeta = KitCore.TradeTooltipMeta.new(shortName = shortName, longName = longName, reason = reason, pdarrayText = type, qualityPct = qualityPct, scoreVal = scoreVal)
            string reasonFinal = KitCore.format_trade_tooltip(chartCtx, tipMeta, direction, entry, takeprofit, stoploss, rrUsed, slGap, eventsLine, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
            float sameZoneTol = tick * 2.0
            int entryIdx = na
            if array.size(trades) > 0
                for k = array.size(trades) - 1 to 0
                    KitCore.Trade ex = array.get(trades, k)
                    bool sameZone = math.abs(ex.zoneTop - levelTop) <= sameZoneTol and math.abs(ex.zoneBtm - levelBtm) <= sameZoneTol
                    if ex.direction == direction and ex.type == tradeType and sameZone and ex.state == CONST.SIGNAL_STATE_PENDING
                        entryIdx := k
                        break
            if na(entryIdx)
                int orderSeq = shouldTrackTrades ? array.size(trades) : (strategy.opentrades + strategy.closedtrades)
                [e, orderId] = KitCore.build_trade_entry_payload(direction, tradeType, levelTop, levelBtm, entry, stoploss, takeprofit, rrUsed, bar_index, reasonFinal, scoreVal, tradeRiskAmountUsd, "MSS", tradeType, orderSeq, CONST, tick)
                float orderQty = not na(e) ? CORE_get_trade_order_qty(entry, stoploss, tradeRiskAmountUsd) : float(na)
                if not na(e)
                    CORE_track_trade_entry(trades, tradeOrderIds, e, orderId, shouldTrackTrades)
                    if tradeRiskMode == "%"
                        KitCore.prop_register_trade(propDayState, tradeRiskValue)
                    if strategyOrdersEnabled
                        CORE_submit_strategy_trade_order(orderId, direction, orderQty, entry, stoploss, takeprofit)
            else
                KitCore.Trade e = array.get(trades, entryIdx)
                e := KitCore.patch_pending_trade(e, tradeType, entry, stoploss, takeprofit, rrUsed, reasonFinal, scoreVal)
                array.set(trades, entryIdx, e)
                KitSMC.cache_signal_memory_event(smcCtx.signalHist, KitSMC.Event.new(type, direction, levelTop, levelBtm, na, bar_index, int(na), false, reasonFinal, sourceTf, qualityPct, scoreVal), tick, 80)
    bool(na)

get_data_model_entry_mode(string modelKey) =>
    string k = str.upper(modelKey)
    k == "MSS" or k == "BOS" ? "BOS/MSS" : "BOS/MSS"

get_data_model_rr_cfg(string modelKey) =>
    string k = str.upper(modelKey)
    k == "MSS" ? modelMssRr : k == "BOS" ? modelBosRr : 1.0

get_data_model_sl_gap_cfg(string modelKey) =>
    string k = str.upper(modelKey)
    k == "MSS" ? modelMssSlGap : k == "BOS" ? modelBosSlGap : 0.0

get_data_nearest_reward_swing(KitSMC.MSSContext msSource, bool isBuy, float entry) =>
    float out = na
    if not na(msSource.swings) and array.size(msSource.swings) > 0
        for i = 0 to array.size(msSource.swings) - 1
            KitSMC.Swing s = array.get(msSource.swings, i)
            bool okSide = isBuy ? (s.isSwingHigh and s.price > entry) : ((not s.isSwingHigh) and s.price < entry)
            if okSide
                if na(out)
                    out := s.price
                else
                    out := isBuy ? math.min(out, s.price) : math.max(out, s.price)
    out

get_data_mss_source_ctx(string sourceTf) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    na(sourceTf) or sourceTf == "" or sourceTf == timeframe.period ? ltfData.mss :
     sourceTf == tf1Local ? htf1Data.mss :
     sourceTf == tf2Local ? htf2Data.mss :
     ltfData.mss

get_data_first_pdarray_in_leg(bool isBuy, int legStartTime, int breakIdx, string sourceTf) =>
    float outTop = na
    float outBtm = na
    int legStartIdx = not na(legStartTime) ? get_data_cached_bar_index_from_time(legStartTime) : na
    int n = array.size(smcCtx.zones)
    int bestIdx = na
    int bestPri = na
    if n > 0
        for i = 0 to n - 1
            KitSMC.PDArray z = array.get(smcCtx.zones, i)
            int anchorIdx = get_data_level_anchor_idx(z)
            bool inLeg = not na(anchorIdx) and not na(breakIdx) and anchorIdx >= nz(legStartIdx, 0) and anchorIdx <= breakIdx
            bool typeOk = z.type == "SR" or z.type == "LIQ"
            bool tfOk = na(sourceTf) or sourceTf == "" ? true : z.labelText == sourceTf
            bool sideOk = z.type == "SR" ? (isBuy ? not z.isHigh : z.isHigh) : true
            int pri = z.type == "SR" ? 0 : 1
            if inLeg and typeOk and tfOk and sideOk
                bool better = na(bestIdx) or anchorIdx < bestIdx or (anchorIdx == bestIdx and (na(bestPri) or pri < bestPri))
                if better
                    bestIdx := anchorIdx
                    bestPri := pri
                    outTop := math.max(z.top, z.bottom)
                    outBtm := math.min(z.top, z.bottom)
    [outTop, outBtm]

process_data_add_entry_mss2_cfg(string type, string direction, string reason, float entryRaw, float stopRaw, float rrCfg, float slGapCfg, int scoreVal, KitSMC.MSSContext msSource, string sourceTf) =>
    bool isBuy = direction == "Buy"
    float tick = syminfo.mintick
    float baseRisk = math.max(math.abs(entryRaw - stopRaw), tick)
    float nearestOpp = rrCfg == 0.0 ? get_data_nearest_reward_swing(msSource, isBuy, entryRaw) : na
    KitCore.TradePlan plan = KitCore.build_trade_plan(direction, entryRaw, stopRaw, rrCfg, math.max(slGapCfg, 0.0) * baseRisk, nearestOpp, true)
    float entry = plan.entry
    float stoploss = plan.stoploss
    float takeprofit = plan.takeprofit
    float rrUsed = plan.rrUsed
    float buffer = plan.slGap
    bool shouldTrackTrades = tradeEntriesEnabled or strategyOrdersEnabled
    bool passBatchCap = true
    if na(takeprofit) or not plan.valid or not passBatchCap
        bool(na)
    else
        string tradeType = get_data_trade_type_for_source(type, sourceTf)
        string shortName = get_data_model_short3(type)
        string longName = get_data_model_long_name(shortName)
        string modelKeyTip = get_data_model_key_for_type(shortName)
        [_, _, _, _, _, requiredPrevEvents, requiredWindowBars, _, _, _, _, _] = get_entry_model_dynamic_cfg(modelKeyTip)
        int evLookback = math.max(requiredWindowBars, 40)
        string eventsLine = "events: " + KitSMC.get_trade_relevant_events_text(smcCtx.signalHist, direction, shortName, requiredPrevEvents, 5, evLookback, 28, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
        KitCore.TradeTooltipMeta tipMeta = KitCore.TradeTooltipMeta.new(shortName = shortName, longName = longName, reason = reason, pdarrayText = type, qualityPct = 100.0, scoreVal = scoreVal)
        string reasonFinal = KitCore.format_trade_tooltip(chartCtx, tipMeta, direction, entry, takeprofit, stoploss, rrUsed, buffer, eventsLine, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
        float sameZoneTol = tick * 2.0
        int entryIdx = na
        if array.size(trades) > 0
            for k = array.size(trades) - 1 to 0
                KitCore.Trade ex = array.get(trades, k)
                bool sameZone = math.abs(ex.zoneTop - entry) <= sameZoneTol and math.abs(ex.zoneBtm - entry) <= sameZoneTol
                if ex.direction == direction and ex.type == tradeType and sameZone and ex.state == CONST.SIGNAL_STATE_PENDING
                    entryIdx := k
                    break
        if na(entryIdx)
            int orderSeq = shouldTrackTrades ? array.size(trades) : (strategy.opentrades + strategy.closedtrades)
            [e, orderId] = KitCore.build_trade_entry_payload(direction, tradeType, entry, entry, entry, stoploss, takeprofit, rrUsed, bar_index, reasonFinal, scoreVal, tradeRiskAmountUsd, "MSS2", tradeType, orderSeq, CONST, tick)
            float orderQty = not na(e) ? CORE_get_trade_order_qty(entry, stoploss, tradeRiskAmountUsd) : float(na)
            if not na(e)
                CORE_track_trade_entry(trades, tradeOrderIds, e, orderId, shouldTrackTrades)
                if strategyOrdersEnabled
                    CORE_submit_strategy_trade_order(orderId, direction, orderQty, entry, stoploss, takeprofit)
        else
            KitCore.Trade e = array.get(trades, entryIdx)
            e := KitCore.patch_pending_trade(e, tradeType, entry, stoploss, takeprofit, rrUsed, reasonFinal, scoreVal)
            array.set(trades, entryIdx, e)
    bool(na)

get_data_nearest_swing_ref_before_break(KitSMC.MSSContext msSource, bool wantHigh, int breakIdx, int breakTime) =>
    float out = na
    int bestIdx = na
    int bestTime = na
    if not na(msSource.swings) and array.size(msSource.swings) > 0
        for i = 0 to array.size(msSource.swings) - 1
            KitSMC.Swing s = array.get(msSource.swings, i)
            if s.isSwingHigh == wantHigh
                bool passIdx = not na(s.barIndex) and not na(breakIdx) and s.barIndex < breakIdx
                bool passTime = na(s.barIndex) and not na(s.time) and not na(breakTime) and s.time < breakTime
                if passIdx or passTime
                    bool better = false
                    if passIdx
                        better := na(bestIdx) or s.barIndex > bestIdx
                    else
                        better := na(bestIdx) and (na(bestTime) or s.time > bestTime)
                    if better
                        out := s.price
                        bestIdx := s.barIndex
                        bestTime := s.time
    out

process_data_emit_structure_break(KitSMC.TFConfig cfg, string tfName, string htf1Name, string htf2Name, bool canEmitSignals, KitSMC.TFData tfData, int side, float pivotLevel, int pivotTime, int pivotIdx, int breakIdx, float oppositePivotLevel, int legStartTime, int prevBreakoutSeen, int msBiasSeen) =>
    int nextPrevBreakout = prevBreakoutSeen
    int nextMsBias = msBiasSeen
    int legEventTime = na
    string msVisualMode = localCfg.displayMode == "Less" ? "All" : localCfg.displayMode == "Normal" ? "Less" : localCfg.displayMode == "Extreme" ? "Normal" : localCfg.displayMode
    bool showBreakVisual = KitSMC.event_emit_allowed(msVisualMode, side, pivotLevel, open, high, low, close, syminfo.mintick, localCfg.msBreakExtremeMinRangeRatio)
    if KitSMC.ms_should_emit_structure_event(tfName, side, pivotTime, msEmitTf, msEmitSide, msEmitPivotTime)
        bool isMss = prevBreakoutSeen != 0 and prevBreakoutSeen != side
        string evtType = isMss ? "MSS" : "BOS"
        string direction = side == 1 ? "Buy" : "Sell"
        string reason = evtType + (side == 1 ? " up break" : " down break")
        string arrow = side == 1 ? CONST.SYM_ARR2_UP : CONST.SYM_ARR2_DN
        string eventTxt = (tfName == timeframe.period ? str.lower(evtType) : evtType) + " " + arrow
        int x1Raw = na(pivotIdx) ? bar_index : pivotIdx
        int x2Raw = na(breakIdx) ? bar_index : breakIdx
        int x1 = math.max(x1Raw, workingFirstBar)
        int x2 = math.max(x2Raw, x1)
        line evtLine = na
        label evtLabel = na
        if showBreakVisual
            float msLabelPadTicks = math.max(8.0, commonAtr * 0.08 / math.max(syminfo.mintick, 1e-10))
            evtCfg = KitUI.LineTextVisualCfg.new(lineStyle = cfg.zigzagStyle, lineWidth = math.max(cfg.zigzagWidth, 1), textSize = KitSMC.ms_get_tf_text_size(tfName, htf1Name, htf2Name), vPos = side == 1 ? 1 : -1, yPadTicks = msLabelPadTicks, xRatio = 0.5, xPadBars = 0, textAlign = text.align_center)
            [evtLine, evtLabel] = KitUI.draw_line_with_text(x1, pivotLevel, x2, pivotLevel, xloc.bar_index, color.new(cfg.zigzagColor, 55), eventTxt, true, color.new(cfg.zigzagColor, 0), "", evtCfg, UI_THEME)
        process_data_register_ms_track(tfName, evtLine, evtLabel, pivotLevel, side, showBreakVisual)
        float msBand = math.max(commonAtr * 0.06, syminfo.mintick * 2.0)
        [enabled, scoreVal, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(evtType)
        if canEmitSignals and enabled and showBreakVisual
            string entryMode = get_data_model_entry_mode(evtType)
            float rrCfg = get_data_model_rr_cfg(evtType)
            float slGapCfg = get_data_model_sl_gap_cfg(evtType)
            if triggerType == TRIGGER_TYPE_TRADE and triggerWhen == TRIGGER_WHEN_TOUCH
                float entryPx = pivotLevel
                float stopPx = na
                if entryMode == "PDArray"
                    [pdTop, pdBtm] = get_data_first_pdarray_in_leg(side == 1, legStartTime, x2, tfName)
                    entryPx := side == 1 ? (not na(pdTop) ? pdTop : entryPx) : (not na(pdBtm) ? pdBtm : entryPx)
                    stopPx := side == 1 ? (not na(pdBtm) ? pdBtm : na) : (not na(pdTop) ? pdTop : na)
                else
                    float slRef = oppositePivotLevel
                    stopPx := slRef
                stopPx := na(stopPx) ? (entryPx + (side == 1 ? -syminfo.mintick : syminfo.mintick)) : stopPx
                process_data_add_entry_mss2_cfg(evtType, direction, reason, entryPx, stopPx, rrCfg, slGapCfg, scoreVal, tfData.mss, tfName)
            else
                KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, evtType, direction, reason, pivotLevel + msBand, pivotLevel - msBand, 100.0, scoreVal, bar_index, syminfo.mintick, 80, tfName)
        nextPrevBreakout := side
        nextMsBias := side
        legEventTime := pivotTime
    [nextPrevBreakout, nextMsBias, legEventTime]

process_data_structure_from_ledger(KitSMC.TFData tfData, KitSMC.TFConfig cfg, string tfName, int recentTsCut, string htf1Name, string htf2Name, bool canEmitSignals) =>
    process_data_update_ms_track(tfName)
    int prevBreakoutNext = tfData.mss.prevBreakout
    int msBiasNext = tfData.mss.msBias
    [highBroken, lowBroken, highBreakIdx, lowBreakIdx, lastHigh, lastHighTime, lastHighIdx, lastLow, lastLowTime, lastLowIdx, highRecent, lowRecent, highArmedNext, lowArmedNext] = KitSMC.detect_tf_structure_breaks(tfData.mss, recentTsCut, high, low, bar_index)

    if msShowBosMss and highBroken and highRecent and bar_index >= workingFirstBar
        [prevBreakoutNext, msBiasNext, highLegEventTime] = process_data_emit_structure_break(cfg, tfName, htf1Name, htf2Name, canEmitSignals, tfData, 1, lastHigh, lastHighTime, lastHighIdx, highBreakIdx, lastLow, lastLowTime, prevBreakoutNext, msBiasNext)
        if not na(highLegEventTime)
            tfData.mss.legEventTime := highLegEventTime

    if msShowBosMss and lowBroken and lowRecent and bar_index >= workingFirstBar
        [prevBreakoutNext, msBiasNext, lowLegEventTime] = process_data_emit_structure_break(cfg, tfName, htf1Name, htf2Name, canEmitSignals, tfData, -1, lastLow, lastLowTime, lastLowIdx, lowBreakIdx, lastHigh, lastHighTime, prevBreakoutNext, msBiasNext)
        if not na(lowLegEventTime)
            tfData.mss.legEventTime := lowLegEventTime

    tfData.mss.highArmed := highArmedNext
    tfData.mss.lowArmed := lowArmedNext
    tfData.mss.prevBreakout := prevBreakoutNext
    tfData.mss.msBias := msBiasNext

process_data_market_structure_for_tf(KitSMC.TFData tfData, KitSMC.TFConfig cfg, bool enabled, string tfName, float sh, int shT, int shIdx, float sl, int slT, int slIdx, int structRecentTsCut, int structRecentIdxCut, string htf1Name, string htf2Name, bool canEmitSignals, string swingSymbol) =>
    KitSMC.process_tf_swing_markers(tfData, cfg, enabled, tfName, sh, shT, shIdx, sl, slT, slIdx, structRecentTsCut, swingSymbol)
    KitSMC.process_tf_zigzag_from_pivots(tfData, cfg, enabled, sh, shT, shIdx, sl, slT, slIdx, structRecentIdxCut)
    if enabled
        process_data_structure_from_ledger(tfData, cfg, tfName, structRecentTsCut, htf1Name, htf2Name, canEmitSignals)
    bool(na)

process_data_market_structure(string htf1NameRaw, string htf2NameRaw, int currPivotOffSafe, int structRecentTsCut, int structRecentIdxCut, float currSh, float currSl, float sh1Real, float sl1Real, int sh1RealT, int sl1RealT, int sh1RealIdx, int sl1RealIdx, float sh2Real, float sl2Real, int sh2RealT, int sl2RealT, int sh2RealIdx, int sl2RealIdx, bool canEmitSignals) =>
    msLtfCfg.showSwings := msShowLtf and msShowSwings
    msLtfCfg.showZigzag := msShowLtf and msShowZigzag
    msHtf1Cfg.showSwings := msShowTf1 and msShowSwings
    msHtf1Cfg.showZigzag := msShowTf1 and msShowZigzag
    msHtf2Cfg.showSwings := msShowTf2 and msShowSwings
    msHtf2Cfg.showZigzag := msShowTf2 and msShowZigzag

    string htf1Name = na(htf1NameRaw) ? "" : htf1NameRaw
    string htf2Name = na(htf2NameRaw) ? "" : htf2NameRaw
    if not msShowLtf
        process_data_reset_ms_track(timeframe.period)
    if not msShowTf1 and not na(htf1NameRaw)
        process_data_reset_ms_track(htf1NameRaw)
    if not msShowTf2 and not na(htf2NameRaw)
        process_data_reset_ms_track(htf2NameRaw)
    process_data_market_structure_for_tf(ltfData, msLtfCfg, msShowLtf, timeframe.period, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentTsCut, structRecentIdxCut, htf1Name, htf2Name, canEmitSignals, "·")
    process_data_market_structure_for_tf(htf1Data, msHtf1Cfg, msShowTf1 and not na(htf1NameRaw), htf1NameRaw, sh1Real, sh1RealT, sh1RealIdx, sl1Real, sl1RealT, sl1RealIdx, structRecentTsCut, structRecentIdxCut, htf1Name, htf2Name, canEmitSignals, CONST.SYM_DOT)
    process_data_market_structure_for_tf(htf2Data, msHtf2Cfg, msShowTf2 and not na(htf2NameRaw), htf2NameRaw, sh2Real, sh2RealT, sh2RealIdx, sl2Real, sl2RealT, sl2RealIdx, structRecentTsCut, structRecentIdxCut, htf1Name, htf2Name, canEmitSignals, CONST.SYM_DOT)
    bool(na)

get_data_label_size_for_source_tf(string sourceTf) =>
    [tf1, tf2] = KitCore.get_htf_pair()
    sourceTf == tf2 ? THEME.SIZE_SMALL : sourceTf == tf1 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL

[htf1, htf2] = KitCore.get_htf_pair()
localCfg.currPivotLenNormal := KitCore.get_pivot_len_for_tf(timeframe.period, timeframe.period, CONST.PIVOT_MODE_FIXED, "Normal", PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION)
localCfg.htf1PivotLenNormal := KitCore.get_pivot_len_for_tf(htf1, timeframe.period, CONST.PIVOT_MODE_FIXED, "Normal", PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION)
localCfg.htf2PivotLenNormal := KitCore.get_pivot_len_for_tf(htf2, timeframe.period, CONST.PIVOT_MODE_FIXED, "Normal", PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION)
process_data_chart_context() =>
    chartCfg.useBias := true
    chartCfg.allowLong := true
    chartCfg.allowShort := true
    ctxDataCfg.needBias := true
    ctxDataCfg.needMsTrendDirs := true
    ctxDataCfg.needPdPw := true
    ctxDataCfg.needPriceRange := true
    ctxDataCfg.needHtfCandles := false
    ctxDataCfg.initBiasFactorArrays := true
    ctxDataCfg.rangeLookbackBars := math.max(effectiveCurrLookbackBars, 50)
    KitSMC.sync_context_tf_data(smcCtx, ltfData, htf1Data, htf2Data)
    int dir0 = KitSMC.get_context_structure_dir(smcCtx)
    KitCore.ChartContext ctx = KitCore.get_data_context_for_dir(ctxDataCfg, SETTINGS, BIAS_TOG, dir0)
    KitCore.fill_trade_bias_trend_arrays(ctx, tradeBiasVals, tradeTrendVals)
    [memScore, memDir, bullCount, bearCount] = KitSMC.compute_signal_memory_bias(smcCtx.signalHist, 20)
    ctx.signalMemoryScore := memScore
    ctx.signalMemoryDir := memDir
    ctx.signalBullCount := bullCount
    ctx.signalBearCount := bearCount
    int effBias = ctx.activeBias
    if memDir != 0
        if effBias == 0
            effBias := memDir
        else if effBias != memDir
            effBias := 0
    ctx.biasVal := effBias
    process_data_reset_runtime_context_if_new_bar()
    array.set(rtBiasBox, 0, ctx.biasVal)
    array.set(rtAllowBuyBox, 0, KitCore.direction_allowed_raw("Buy", memDir) ? 1 : 0)
    array.set(rtAllowSellBox, 0, KitCore.direction_allowed_raw("Sell", memDir) ? 1 : 0)
    ctx

// Keep TF swing ledgers updated in ICT (data-only; no structure drawing here),
// because SR/LIQ/IDM/Sweep pipelines still seed from TFData swings.
runtimeCtx := KitCore.update_runtime_context(runtimeCtx)
bool canEmitSignals = entryEngineEnabled
bool calcOnClosedBar = barstate.ishistory or barstate.isconfirmed
workingFirstBar := KitCore.get_working_first_bar_from_lookback(localCfg.workingLookbackBars)
[_wfLine1, _wfLabel1] = KitCore.update_working_first_bar_marker(workingFirstBarLine, workingFirstBarLabel, workingFirstBar, "MSS", color.new(uiCfg.ltfColor, 0), line.style_dotted, color.new(uiCfg.ltfColor, 0), THEME.SIZE_TINY)
workingFirstBarLine := _wfLine1
workingFirstBarLabel := _wfLabel1
// Other logics
if calcOnClosedBar
    int currPivotLen = localCfg.currPivotLenNormal
    int htf1PivotLen = localCfg.htf1PivotLenNormal
    int htf2PivotLen = localCfg.htf2PivotLenNormal
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    [sh1Real, sh1RealT, sl1Real, sl1RealT] = get_data_real_htf_swings(htf1, htf1PivotLen)
    [sh2Real, sh2RealT, sl2Real, sl2RealT] = get_data_real_htf_swings(htf2, htf2PivotLen)
    KitSMC.ingest_real_swings(htf1Data, sh1Real, int(sh1RealT), sl1Real, int(sl1RealT), SETTINGS.SWING_HISTORY_MAX)
    KitSMC.ingest_real_swings(htf2Data, sh2Real, int(sh2RealT), sl2Real, int(sl2RealT), SETTINGS.SWING_HISTORY_MAX)
    int structRecentTsCut = KitCore.get_recent_time_cutoff(effectiveCurrLookbackBars)
    int structRecentIdxCut = workingFirstBar
    KitSMC.EngineCfg engineCfg = KitSMC.EngineCfg.new()
    engineCfg.runSwingCycle := true
    engineCfg.runStructureState := false
    engineCfg.runPDArray := false
    KitSMC.process_engine_base_cycle(
     smcCtx, engineCfg,
     htf1, htf2,
     currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na,
     sh1Real, int(sh1RealT), sl1Real, int(sl1RealT),
     sh2Real, int(sh2RealT), sl2Real, int(sl2RealT),
     SETTINGS.SWING_HISTORY_MAX,
     int(na), high, low, bar_index,
     float(na), float(na), commonAtr, syminfo.mintick, KitSMC.ZoneQualityCfg.new())
    int sh1RealIdx = get_data_map_htf_swing_to_ltf_idx(sh1RealT)
    int sl1RealIdx = get_data_map_htf_swing_to_ltf_idx(sl1RealT)
    int sh2RealIdx = get_data_map_htf_swing_to_ltf_idx(sh2RealT)
    int sl2RealIdx = get_data_map_htf_swing_to_ltf_idx(sl2RealT)
    process_data_market_structure(htf1, htf2, currPivotOffSafe, structRecentTsCut, structRecentIdxCut, currSh, currSl, sh1Real, sl1Real, sh1RealT, sl1RealT, sh1RealIdx, sl1RealIdx, sh2Real, sl2Real, sh2RealT, sl2RealT, sh2RealIdx, sl2RealIdx, canEmitSignals)
    [h2LastHi, h2LastHiT, h2LastLo, h2LastLoT] = KitSMC.market_structure_latest_hilo(htf2Data.mss)
    int htf2SwingAnchorTs = KitCore.get_latest_time4(h2LastHiT, h2LastLoT, int(na), int(na))
    bool recalcByHtf2 = not na(htf2) and ta.change(time(htf2)) != 0
    bool shouldDynRecalc = SETTINGS.DYN_LOOKBACK_ENABLE and (barstate.isfirst or recalcByHtf2) // Controls how often dynamic lookback/candle widths update.
    if shouldDynRecalc
        int dynHtf1Candles = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf1) ? KitCore.get_candles_to_anchor(htf1, htf2SwingAnchorTs, SETTINGS.DYN_HTF1_CANDLES_MIN, SETTINGS.DYN_HTF1_CANDLES_MAX, SETTINGS.HTF_CANDLES_BASE) : SETTINGS.HTF_CANDLES_BASE
        int htf1SecForDyn = not na(htf1) ? math.max(KitUI.get_tf_seconds(htf1), 1) : na
        int htf2SecForDyn = not na(htf2) ? math.max(KitUI.get_tf_seconds(htf2), 1) : na
        float htf2PerHtf1Dyn = not na(htf1SecForDyn) and not na(htf2SecForDyn) and htf2SecForDyn > htf1SecForDyn ? float(htf2SecForDyn) / float(htf1SecForDyn) : na
        // Keep HTF1/HTF2 panels on equivalent time span:
        // pass-1: derive HTF2 from HTF1 / ratio
        int dynHtf2Candles = not na(htf2PerHtf1Dyn) ? int(math.round(float(dynHtf1Candles) / htf2PerHtf1Dyn)) : SETTINGS.DYN_HTF2_CANDLES_FALLBACK
        dynHtf2Candles := math.max(SETTINGS.DYN_HTF2_CANDLES_MIN, math.min(dynHtf2Candles, SETTINGS.DYN_HTF2_CANDLES_MAX))
        // pass-2: back-project HTF1 from HTF2 * ratio and keep the larger (stability against rounding loss)
        int dynHtf1FromHtf2 = not na(htf2PerHtf1Dyn) ? int(math.ceil(float(dynHtf2Candles) * htf2PerHtf1Dyn)) : dynHtf1Candles
        dynHtf1Candles := math.max(dynHtf1Candles, dynHtf1FromHtf2)
        dynHtf1Candles := math.max(SETTINGS.DYN_HTF1_CANDLES_MIN, math.min(dynHtf1Candles, SETTINGS.DYN_HTF1_CANDLES_MAX))
        int dynCurrLookbackBars = KitCore.get_curr_lookback_from_htf2(htf2, dynHtf2Candles, SETTINGS.DYN_CURR_LOOKBACK_MIN_BARS, SETTINGS.DYN_CURR_LOOKBACK_MAX_BARS)
        dynCachedCurrLookbackBars := dynCurrLookbackBars
    effectiveCurrLookbackBars := SETTINGS.DYN_LOOKBACK_ENABLE ? dynCachedCurrLookbackBars : localCfg.workingLookbackBars // Master working lookback for pruning + keylevel lifecycle.
    effectiveCurrLookbackBars := math.max(bar_index - workingFirstBar + 1, 1)
    perfLookbackBars := effectiveCurrLookbackBars
    htfProjectionSpanBars := effectiveCurrLookbackBars
    int ltfOffSafe = math.max(0, math.min(math.min(bar_index - workingFirstBar, bar_index), 10000))
    int ltfFirstTime = int(time[ltfOffSafe])
    int htf1FirstTime = not na(htf1) ? get_data_working_first_time_for_source_tf(htf1) : na
    int htf2FirstTime = not na(htf2) ? get_data_working_first_time_for_source_tf(htf2) : na
    if not na(htf1FirstTime) and htf1FirstTime > ltfFirstTime
        htf1FirstTime := ltfFirstTime
    int htf2MaxTime = not na(htf1FirstTime) ? htf1FirstTime : ltfFirstTime
    if not na(htf2FirstTime) and htf2FirstTime > htf2MaxTime
        htf2FirstTime := htf2MaxTime
    process_data_prune_outside_working_zone_levels(smcCtx.zones)
    bool doOrphanSweep = barstate.isfirst or (bar_index % 200 == 0) or barstate.islastconfirmedhistory
    if doOrphanSweep
        process_data_prune_left_visual_orphans()
    chartCtx := process_data_chart_context()

get_data_should_drop_level(KitSMC.PDArray z, int srcIdx) =>
    bar_index - srcIdx > effectiveCurrLookbackBars

process_data_trades() =>
    if array.size(trades) > 0 and array.size(tradeOrderIds) == array.size(trades)
        for i = array.size(trades) - 1 to 0
            KitCore.Trade e = array.get(trades, i)
            if not KitCore.is_trade_plan_valid_with_limits(e.entry, e.stoploss, e.takeprofit, localCfg.minTradeSizeTicks, localCfg.minTradeRR)
                KitCore.remove_trade_entry(trades, tradeOrderIds, i, strategyOrdersEnabled)
                continue
            bool preTouchTpHit = e.state == CONST.SIGNAL_STATE_PENDING and not e.touched and
             ((e.direction == "Buy" and not na(e.takeprofit) and high >= e.takeprofit and low > e.entry) or
             (e.direction == "Sell" and not na(e.takeprofit) and low <= e.takeprofit and high < e.entry))
            if gateUsePreTouchTpCut and preTouchTpHit
                KitCore.remove_trade_entry(trades, tradeOrderIds, i, strategyOrdersEnabled)
                continue
            string orderId = array.get(tradeOrderIds, i)
            [eResolved, outcome] = KitCore.resolve_trade_state(e, high, low, bar_index, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
            e := eResolved
            if outcome == 2 and gateUsePreTouchTpCut
                KitCore.remove_trade_entry(trades, tradeOrderIds, i, strategyOrdersEnabled)
                continue
            if outcome == 1 or outcome == -1
                float exitPrice = outcome > 0 ? e.takeprofit : e.stoploss
                float denom = math.max(math.abs(e.entry - e.stoploss), syminfo.mintick)
                float realizedR = math.abs(exitPrice - e.entry) / denom
                float rrForStats = math.max(0.1, realizedR)
                e.rrValue := rrForStats
            string entryDisplayMode = (e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL) ? "RESULT_LINES" : "NORMAL"
            bool signalShowActive = e.state == CONST.SIGNAL_STATE_PENDING ? tradeShowPending : e.state == CONST.SIGNAL_STATE_START ? tradeShowStart : false
            if tradeEntriesEnabled
                e := KitCore.draw_trade_visual(e, CONST, THEME, ENTRY_VIS_CFG, true, signalShowActive, tradeShowTp, tradeShowSl, perfLookbackBars, 10, entryDisplayMode, "RESULT_LINES", 0)
            array.set(trades, i, e)
        bool(na)
    bool(na)

process_data_add_entry_from_event(string modelKey, string shortName, int modelScore, KitSMC.Event e) =>
    int finalScore = math.max(e.score, modelScore)
    if modelKey == "BOS" or modelKey == "MSS"
        bool isBuy = e.direction == "Buy"
        KitSMC.MSSContext sourceMss = get_data_mss_source_ctx(e.sourceTf)
        float breakLevel = (e.zoneTop + e.zoneBtm) * 0.5
        float rrCfg = get_data_model_rr_cfg(modelKey)
        float slGapCfg = get_data_model_sl_gap_cfg(modelKey)
        string entryMode = get_data_model_entry_mode(modelKey)
        float entryPx = breakLevel
        float stopPx = na
        if entryMode == "PDArray"
            int legStartT = sourceMss.legLastEventSeen
            [pdTop, pdBtm] = get_data_first_pdarray_in_leg(isBuy, legStartT, bar_index, e.sourceTf)
            entryPx := isBuy ? (not na(pdTop) ? pdTop : entryPx) : (not na(pdBtm) ? pdBtm : entryPx)
            stopPx := isBuy ? pdBtm : pdTop
        else
            [msHi, _, msLo, _] = KitSMC.market_structure_latest_hilo(sourceMss)
            stopPx := isBuy ? msLo : msHi
        stopPx := na(stopPx) ? (entryPx + (isBuy ? -syminfo.mintick : syminfo.mintick)) : stopPx
        process_data_add_entry_mss2_cfg(modelKey, e.direction, e.reason, entryPx, stopPx, rrCfg, slGapCfg, finalScore, sourceMss, e.sourceTf)
    else
        process_data_add_entry(modelKey, e.direction, e.reason, e.zoneTop, e.zoneBtm, e.quality, finalScore, e.sourceTf)
    bool(na)

process_data_events_queue(array<KitSMC.Event> events) =>
    if events.size() > 0
        for i = events.size() - 1 to 0
            KitSMC.Event e = events.get(i)
            bool isSweep = e.type == "SWEEP"
            bool isBos = e.type == "BOS"
            bool isMss = e.type == "MSS"
            if isSweep
                events.remove(i)
                continue
            string modelKey = isBos ? "BOS" : isMss ? "MSS" : str.upper(e.type)
            [enabledType, modelScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
            [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = get_entry_model_dynamic_cfg(modelKey)
            if not enabledType
                events.remove(i)
                continue
            bool validDirection = KitCore.direction_allowed_cached(e.direction, gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, chartCtx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
            if triggerType == TRIGGER_TYPE_SIGNAL
                events.remove(i)
                continue
            bool useTouchEntry = triggerWhen == TRIGGER_WHEN_TOUCH or modelEntryMode == ENTRY_MODE_LIMIT or not gateUseRetestConfirm
            if useTouchEntry
                if validDirection
                    process_data_add_entry_from_event(modelKey, shortName, modelScore, e)
                events.remove(i)
                continue
            bool confirm = e.direction == "Buy" ? close > e.zoneTop : close < e.zoneBtm
            bool invalid = e.direction == "Buy" ? close < e.zoneBtm : close > e.zoneTop
            if gateUseRetestInvalidation and invalid
                events.remove(i)
                continue
            bool passEntryMode = modelEntryMode != ENTRY_MODE_OFF
            bool passConfirm = not gateUseRetestConfirm or confirm
            if passEntryMode and passConfirm and validDirection
                process_data_add_entry_from_event(modelKey, shortName, modelScore, e)
                events.remove(i)
    bool(na)

process_data_entries(bool canEmitSignals) =>
    if not entryEngineEnabled
        if array.size(smcCtx.events) > 0
            array.clear(smcCtx.events)
        bool(na)
    else
        if canEmitSignals
            process_data_events_queue(smcCtx.events)
        else
            if array.size(smcCtx.events) > 0
                array.clear(smcCtx.events)
        process_data_trades()
    bool(na)

draw_data_trades_dashboard() =>
    var array<KitCore.Trade> dashboardTrades = array.new<KitCore.Trade>()
    int dashboardLookbackBars = math.max(localCfg.workingLookbackBars, 1)
    KitCore.collect_dashboard_stats_trades(trades, dashboardTrades, dashboardLookbackBars)
    int dashCount = array.size(dashboardTrades)
    int maxTypes = math.max(1, dashCount)
    if dashCount > 0
        KitCore.render_entries_dashboard_from_entries(true, signalStatsTableBottomCenter, dashboardTrades, maxTypes, THEME, CONST, CONST.SIG_METRIC_COUNT, tradeSpreadTicks, math.max(strategy.equity, 100000.0))
    else
        table.clear(signalStatsTableBottomCenter, 0, 0, 4, 23)
    KitCore.draw_bias_row_under_trades(signalStatsTableBottomCenter, 0, chartCtx, THEME, SETTINGS, CONST, "MSS")
    bool(na)

draw_data_sr_visual(KitSMC.PDArray z, int srRightIdx, int srLabelIdx, string tooltipText) =>
    KitSMC.PDArray out = z
    bool isResNow = KitSMC.is_sr_res_now(z, close)
    bool isUntouched = nz(out.touchCount, 0) <= 0
    string txt = isUntouched ? "$" : (isResNow ? "R" : "S")
    color baseColor = KitCore.get_tf_line_color(out.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
    color txtColor = color.new(baseColor, 0)
    string labelSize = get_data_label_size_for_source_tf(out.labelText)
    SR_VIS_CFG.lineStyle := CFG_SR.lineStyle
    SR_VIS_CFG.lineWidth := CFG_SR.lineWidth
    SR_VIS_CFG.labelSize := labelSize
    SR_VIS_CFG.showLabel := false
    out := KitSMC.draw_price_zone(out, na(out.barEnd) ? bar_index : out.barEnd, srRightIdx, out.price, out.price, CFG_SR.lineColor, CFG_SR.lineColor, line.style_solid, txt, txtColor, tooltipText, srLabelIdx, out.price, ZONE_VIS_CFG, SR_VIS_CFG, false, true, out.price, CFG_SR.lineColor, "LINE", false)
    if not out.visible
        if not na(out.visualLine)
            out.visualLine.set_color(color.new(CFG_SR.lineColor, 100))
        if not na(out.visualLabel)
            out.visualLabel.delete()
            out.visualLabel := na
            out.visLabelGeomSig := ""
            out.visLabelStyleSig := ""
        out
    else
        if not na(out.visualLine)
            string srStyle = KitCore.lifecycle_line_style(out.lifeState, CONST.LIFE_TOUCHED, CONST.LIFE_BROKEN, CONST.LIFE_RECLAIMED, line.style_dotted, line.style_dotted, line.style_dashed, line.style_dotted)
            int srAlpha = KitCore.lifecycle_alpha(out.lifeState, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED, CONST.LIFE_BROKEN, SETTINGS.SR_LINE_TRANSP, 72, 65, 55, 85)
            color srColor = color.new(baseColor, srAlpha)
            string srLineStyleSig = "SR_LINE|" + srStyle + "|" + str.tostring(srAlpha) + "|" + get_data_color_sig(baseColor)
            if out.visualLine.get_x2() != srRightIdx
                out.visualLine.set_x2(srRightIdx)
            if out.visLineStyleSig != srLineStyleSig
                out.visualLine.set_color(srColor)
                out.visualLine.set_style(srStyle)
                out.visLineStyleSig := srLineStyleSig
        if not na(out.visualLabel)
            string srLabelStyleSig = "SR_LABEL|" + labelSize + "|" + tooltipText
            if out.visualLabel.get_x() != srLabelIdx
                out.visualLabel.set_x(srLabelIdx)
            if out.visualLabel.get_y() != out.price
                out.visualLabel.set_y(out.price)
            if out.visLabelStyleSig != srLabelStyleSig
                out.visualLabel.set_size(labelSize)
                out.visualLabel.set_tooltip(tooltipText)
                out.visLabelStyleSig := srLabelStyleSig
    out

get_data_level_store_cap(int kind) =>
    bool is1m = get_data_is_1m_chart()
    bool isFast = get_data_is_fast_chart()
    kind == HL_KIND_LIQ ? (is1m ? 12 : isFast ? 16 : 24) :
     uiDisplayCombo == "All" ? (is1m ? 90 : isFast ? 120 : 240) :
     uiDisplayCombo == "Less" ? (is1m ? 60 : isFast ? 80 : 140) :
     uiDisplayCombo == "Normal" ? (is1m ? 40 : isFast ? 55 : 90) :
     uiDisplayCombo == "Extreme" ? (is1m ? 30 : isFast ? 40 : 60) : (is1m ? 40 : isFast ? 55 : 90)

process_data_cap_horizontal_levels_store(int kind, array<KitSMC.PDArray> levels) =>
    int cap = get_data_level_store_cap(kind)
    if cap <= 0
        bool(na)
    else
        int kindCount = 0
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                KitSMC.PDArray z = array.get(levels, i)
                if KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                    kindCount += 1
        while kindCount > cap
            int dropIdx = na
            int oldestAnchor = na
            if array.size(levels) > 0
                for i = 0 to array.size(levels) - 1
                    KitSMC.PDArray z = array.get(levels, i)
                    if KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                        int anchor = get_data_level_anchor_idx(z)
                        anchor := na(anchor) ? bar_index : anchor
                        if na(dropIdx) or anchor < oldestAnchor
                            dropIdx := i
                            oldestAnchor := anchor
            if na(dropIdx)
                break
            KitSMC.PDArray dropped = KitSMC.delete_level_at(levels, dropIdx)
            KitUI.delete_line_label(dropped.visualLine, dropped.visualLabel)
            kindCount -= 1
    bool(na)

// Shared lifecycle engine for horizontal PDArray families (LIQ/SR).
process_data_horizontal_levels(int kind, array<KitSMC.PDArray> levels, float areaTop, float areaBottom, float srBand, float atrVal) =>
    process_data_cap_horizontal_levels_store(kind, levels)
    int srRightIdx = na
    int srLabelIdx = na
    if array.size(levels) > 0
        for i = array.size(levels) - 1 to 0 by 1
            z = array.get(levels, i)
            z := KitSMC.normalize_pricezone_state(z, SMC_CONST)
            // EQH/EQL is retired and merged into sweep behavior; remove any stale EQ levels.
            if z.type == "eqh" or z.type == "eql"
                KitSMC.PDArray droppedEq = KitSMC.delete_level_at(levels, i)
                KitUI.delete_line_label(droppedEq.visualLine, droppedEq.visualLabel)
                continue
            if not KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                continue
            if not na(z.visualBox)
                z.visualBox.delete()
                z.visualBox := na
            int srcIdx = na(z.barEnd) ? bar_index : z.barEnd
            if get_data_should_drop_level(z, srcIdx)
                KitSMC.PDArray dropped = KitSMC.delete_level_at(levels, i)
                KitUI.delete_line_label(dropped.visualLine, dropped.visualLabel)
                continue
            if kind == HL_KIND_LIQ
                bool isBearishLiq = z.isHigh
                bool liqPenetrated = KitSMC.check_break(isBearishLiq, z.price, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, atrVal, localCfg.detImpulseAtr, open, high, low, close, open[1], high[1], low[1], close[1])
                bool liqSwept = liqPenetrated
                bool isDollarLiq = z.labelText != timeframe.period
                if liqSwept and not get_data_is_liq_swept(z)
                    z.barEnd := bar_index
                    if isDollarLiq
                        KitUI.delete_line_label(z.visualLine, z.visualLabel)
                        z.visualLine := na
                        z.visualLabel := na
                    else
                        if not na(z.visualLine)
                            color liqMitigatedColor = color.new(KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 50)
                            z.visualLine.set_color(liqMitigatedColor)
                            z.visualLine.set_style(line.style_dotted)
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                            z.visualLabel := na
                            z.visLabelStyleSig := ""
                    
                    // Emit SWEEP Event for LSR Phase A tracking
                    KitSMC.register_sweep_reclaim_event(smcCtx.events, isBearishLiq ? "Sell" : "Buy", z.price, bar_index, syminfo.mintick)

                bool liqTouched = KitSMC.check_touch(z.price, z.price, localCfg.detBasis, open, high, low, close)
                bool liqReclaimed = isBearishLiq ? close < z.price : close > z.price
                bool liqCooldownOk = na(z.barEnd) or (bar_index - z.barEnd >= localCfg.limSrTouchCountCooldownBars)
                int liqState = KitCore.lifecycle_next_state(liqPenetrated and not liqReclaimed, liqTouched, false, liqSwept and liqReclaimed, liqCooldownOk, z.lifeState, CONST.LIFE_BROKEN, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED)
                [liqTouchCnt, _] = KitCore.lifecycle_next_counts(z.touchCount, z.rejectCount, liqTouched, false, liqCooldownOk)
                if liqTouched and liqCooldownOk
                    z.barEnd := bar_index
                z.touchCount := liqTouchCnt
                z.lifeState := liqState
                z.broken := KitCore.is_life_broken(liqState, CONST)
                if not na(z.visualLine)
                    int liqExt = KitCore.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
                    int liqRightIdx = KitCore.get_sr_x(bar_index, liqExt, false)
                    string liqStyle = KitCore.lifecycle_line_style(liqState, CONST.LIFE_TOUCHED, CONST.LIFE_BROKEN, CONST.LIFE_RECLAIMED, line.style_solid, line.style_dotted, line.style_dashed, line.style_dotted)
                    int liqAlpha = KitCore.lifecycle_alpha(liqState, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED, CONST.LIFE_BROKEN, 35, 45, 45, 50, 65)
                    color liqBaseColor = KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
                    string liqLineStyleSig = "LIQ_LINE|" + liqStyle + "|" + str.tostring(liqAlpha) + "|" + get_data_color_sig(liqBaseColor)
                    if z.visLineStyleSig != liqLineStyleSig
                        z.visualLine.set_style(liqStyle)
                        z.visualLine.set_color(color.new(liqBaseColor, liqAlpha))
                        z.visLineStyleSig := liqLineStyleSig
                    if not get_data_is_liq_swept(z) and z.visualLine.get_x2() != liqRightIdx
                        z.visualLine.set_x2(liqRightIdx)
                if not na(z.visualLine)
                    string liqTxt = get_data_is_liq_swept(z) ? "" : (z.labelText == timeframe.period ? "idm" : "$")
                    color tfTxtColor = color.new(KitCore.get_tf_line_color(z.labelText, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor), 0)
                    string tfTxtSize = KitSMC.ms_get_tf_text_size(z.labelText, htf1, htf2)
                    string liqAlign = get_data_liq_label_align(liqTxt)
                    float nextY = get_data_liq_label_y(liqTxt, z.price)
                    int nextX = get_data_liq_label_x(z.visualLine, liqTxt)
                    float overlapTol = math.max(commonAtr * math.max(localCfg.liqOverlapTolAtrMult, 0.005), syminfo.mintick * 8.0)
                    bool hideByPriority = localCfg.liqHideOverlapByTf and liqTxt == "$" and get_data_liq_has_stronger_overlap(levels, i, z, overlapTol)
                    string liqLabelStyleSig = "LIQ_LABEL|" + liqTxt + "|" + get_data_color_sig(tfTxtColor) + "|" + tfTxtSize + "|" + liqAlign + "|" + localCfg.liqDollarXPos + "|" + localCfg.liqDollarYPos + "|" + str.tostring(localCfg.liqDollarYOffsetTicks) + "|" + str.tostring(localCfg.liqOverlapTolAtrMult) + "|" + localCfg.liqOverlapScope + "|" + str.tostring(hideByPriority)
                    bool hideLabel = hideByPriority or liqTxt == ""
                    if hideLabel
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                            z.visualLabel := na
                            z.visLabelStyleSig := ""
                    else
                        if na(z.visualLabel)
                            z.visualLabel := KitUI.draw_text_on_line(z.visualLine.get_x1(), z.price, z.visualLine.get_x2(), z.price, xloc.bar_index, liqTxt, tfTxtColor, tfTxtSize, 0, 0.0, 0.5, 0, "", liqAlign, UI_THEME)
                        if z.visualLabel.get_text() != liqTxt
                            z.visualLabel.set_text(liqTxt)
                        if z.visualLabel.get_x() != nextX
                            z.visualLabel.set_x(nextX)
                        if z.visualLabel.get_y() != nextY
                            z.visualLabel.set_y(nextY)
                        if z.visLabelStyleSig != liqLabelStyleSig
                            z.visualLabel.set_textcolor(tfTxtColor)
                            z.visualLabel.set_size(tfTxtSize)
                            z.visualLabel.set_textalign(liqAlign)
                            z.visLabelStyleSig := liqLabelStyleSig
            else
                int srExt = KitCore.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
                srRightIdx := KitCore.get_sr_x(bar_index, srExt, false)
                srLabelIdx := KitCore.get_sr_x(bar_index, srExt, false)
                int rejectN = math.max(z.rejectCount, 0)
                z.top := z.price + srBand
                z.bottom := z.price - srBand
                bool bodyCross = KitCore.is_body_cross_level(z.price, open, close)
                bool touchedBand = KitCore.is_level_wick_touch(z.price, srBand, open, high, low, close, syminfo.mintick)
                bool cooldownOk = na(z.barEnd) or (bar_index - z.barEnd >= localCfg.limSrTouchCountCooldownBars)
                bool sideRespected = z.isHigh ? close < z.price : close > z.price
                int state = KitCore.lifecycle_next_state(bodyCross, touchedBand, sideRespected, sideRespected, cooldownOk, z.lifeState, CONST.LIFE_BROKEN, CONST.LIFE_TOUCHED, CONST.LIFE_RESPECTED, CONST.LIFE_RECLAIMED)
                [nextTouchCnt, nextRejectCnt] = KitCore.lifecycle_next_counts(z.touchCount, rejectN, touchedBand, sideRespected, cooldownOk)
                if touchedBand and cooldownOk
                    z.qualityPct := math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                    z.barEnd := bar_index
                z.touchCount := nextTouchCnt
                z.rejectCount := nextRejectCnt
                z.lifeState := state
                z.broken := KitCore.is_life_broken(state, CONST)
                string nextTip = KitSMC.get_data_sr_tooltip_text(nextRejectCnt, state, SMC_CONST)
                z := draw_data_sr_visual(z, srRightIdx, srLabelIdx, nextTip)
            array.set(levels, i, z)
    int kindCount = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            if KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                kindCount += 1
    if kind == HL_KIND_LIQ
        while kindCount > 14
            int dropIdx = na
            for i = 0 to array.size(levels) - 1
                z = array.get(levels, i)
                if KitSMC.get_data_level_matches_kind(kind, z.type, HL_KIND_LIQ, -1, HL_KIND_SR)
                    dropIdx := i
                    break
            if na(dropIdx)
                break
            KitSMC.PDArray dropped = KitSMC.delete_level_at(levels, dropIdx)
            KitUI.delete_line_label(dropped.visualLine, dropped.visualLabel)
            kindCount -= 1
    else
        bool(na)
    bool(na)

get_data_level_rank_score(KitSMC.PDArray z, float lastSwingHigh, float lastSwingLow) =>
    float p = z.price
    float tick = math.max(syminfo.mintick, 1e-10)
    float distTicks = math.abs(p - close) / tick
    float score = -distTicks
    score += float(math.max(z.touchCount, 0)) * 30.0
    score += float(math.max(z.rejectCount, 0)) * 40.0
    if p > close and not na(lastSwingHigh)
        float swingTicks = math.abs(p - lastSwingHigh) / tick
        score += 1000.0 / (1.0 + swingTicks)
    if p < close and not na(lastSwingLow)
        float swingTicks = math.abs(p - lastSwingLow) / tick
        score += 1000.0 / (1.0 + swingTicks)
    score += float(math.max(int(nz(z.extendBars, 0)), 0)) * 8.0
    score += nz(z.qualityPct, 0.0) * 0.05
    score

process_data_prune_levels_by_relevance(array<KitSMC.PDArray> levels) =>
    int n = array.size(levels)
    float overlapDist = math.max(nz(commonAtr) * localCfg.limZoneMinHeightAtr * localCfg.limSrNearbyMergeMult * localCfg.srMinDistMult, syminfo.mintick * 8.0)
    int sideCap = uiDisplayCombo == "None" ? 0 : uiDisplayCombo == "All" ? 999 : uiDisplayCombo == "Less" ? 2 : 1
    if n > 0
        [lastSwingHigh, _, lastSwingLow, _] = KitSMC.market_structure_latest_hilo(ltfData.mss)
        array<string> typeFilters = array.from("SR")
        for i = 0 to n - 1
            KitSMC.PDArray z = array.get(levels, i)
            if z.type == "SR"
                z.volScore := get_data_level_rank_score(z, lastSwingHigh, lastSwingLow)
            array.set(levels, i, z)
        array<bool> keep = KitSMC.select_visible_pricezones(levels, close, typeFilters, sideCap, sideCap, false, overlapDist)
        int j = 0
        while j < n
            KitSMC.PDArray z = array.get(levels, j)
            if z.type == "SR"
                bool selected = array.get(keep, j)
                z.visible := selected
                if not selected
                    if not na(z.visualLine)
                        z.visualLine.set_color(color.new(CFG_SR.lineColor, 100))
                    if not na(z.visualLabel)
                        z.visualLabel.delete()
                        z.visualLabel := na
                        z.visLabelGeomSig := ""
                        z.visLabelStyleSig := ""
                array.set(levels, j, z)
            j += 1
        KitSMC.draw_sr_rank_labels(levels, close)
        bool(na)

process_data_register_sr_seed(array<KitSMC.PDArray> levels, float price, int pivotIdx, int pivotTime, bool isRes, float tol, float srBand, string sourceTf, int sourcePrio, float areaTop, float areaBottom) =>
    float vTop = price + srBand
    float vBtm = price - srBand
    bool inArea = na(areaTop) or na(areaBottom) or (price <= areaTop and price >= areaBottom)
    if not inArea or not is_in_working_zone_idx_for_source_tf(pivotIdx, sourceTf)
        bool(na)
    else
        if uiDisplayCombo != "All" and sourcePrio == SR_SOURCE_PRIO_LTF and KitSMC.get_data_has_keylevel_overlap_in_levels(levels, vTop, vBtm)
            bool(na)
        else
            int matchIdx = na
            if array.size(levels) > 0
                for mi = 0 to array.size(levels) - 1
                    mz = array.get(levels, mi)
                    if mz.type == "SR" and math.abs(mz.price - price) <= tol
                        matchIdx := mi
                        break
            if not na(matchIdx)
                z = array.get(levels, matchIdx)
                bool sameSeed = z.barStart == pivotTime and z.isHigh == isRes
                if not sameSeed
                    float touches = math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                    z.price := ((z.price * (touches - 1.0)) + price) / touches
                    z.qualityPct := touches
                    z.barEnd := na(z.barEnd) ? pivotIdx : math.min(z.barEnd, pivotIdx)
                int prevPrio = int(math.max(nz(z.extendBars, 0), 0))
                if sourcePrio >= prevPrio
                    z.labelText := sourceTf
                    z.isHigh := isRes
                z.extendBars := math.max(prevPrio, sourcePrio)
                z.top := z.price + srBand
                z.bottom := z.price - srBand
                array.set(levels, matchIdx, z)
            else
                KitSMC.PDArray z = KitSMC.PDArray.new()
                z.type := "SR"
                z.price := price
                z.top := vTop
                z.bottom := vBtm
                z.barStart := pivotTime
                z.barEnd := pivotIdx
                z.qualityPct := 1.0
                z.isHigh := isRes
                z.labelText := sourceTf
                z.extendBars := sourcePrio
                z.lifeState := CONST.LIFE_FORMED
                z.touchCount := 0
                z.rejectCount := 0
                array.push(levels, z)
            bool(na)

process_data_register_liquidity_seed(array<KitSMC.PDArray> levels, float price, int pivotIdx, int pivotTime, bool isHigh, float tol, string sourceTf, int sourcePrio, float areaTop, float areaBottom) =>
    bool inArea = na(areaTop) or na(areaBottom) or (price <= areaTop and price >= areaBottom)
    if not inArea or not is_in_working_zone_idx_for_source_tf(pivotIdx, sourceTf)
        bool(na)
    else
        int matchIdx = na
        if array.size(levels) > 0
            for mi = 0 to array.size(levels) - 1
                mz = array.get(levels, mi)
                if mz.type == "LIQ" and math.abs(mz.price - price) <= tol
                    matchIdx := mi
                    break
        if not na(matchIdx)
            z = array.get(levels, matchIdx)
            bool sameSeed = z.barStart == pivotTime and z.isHigh == isHigh
            if not sameSeed
                float touches = math.max(nz(z.qualityPct, 1.0), 1.0) + 1.0
                z.price := ((z.price * (touches - 1.0)) + price) / touches
                z.qualityPct := touches
            int prevPrio = int(math.max(nz(z.extendBars, 0), 0))
            if sourcePrio >= prevPrio
                z.isHigh := isHigh
                z.labelText := sourceTf
            z.extendBars := math.max(prevPrio, sourcePrio)
            z.top := z.price
            z.bottom := z.price
            int liqExt = KitCore.get_tf_line_ext_bars(z.labelText, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
            int liqRightIdx = KitCore.get_sr_x(bar_index, liqExt, false)
            if not get_data_is_liq_swept(z) and not na(z.visualLine) and z.visualLine.get_x2() != liqRightIdx
                z.visualLine.set_x2(liqRightIdx)
            array.set(levels, matchIdx, z)
        else
            KitSMC.PDArray z = KitSMC.PDArray.new()
            z.type := "LIQ"
            z.price := price
            z.top := price
            z.bottom := price
            z.barStart := pivotTime
            z.barEnd := pivotIdx
            z.isHigh := isHigh
            z.labelText := sourceTf
            z.extendBars := sourcePrio
            z.qualityPct := 1.0
            z.lifeState := CONST.LIFE_FORMED
            z.touchCount := 1
            z.rejectCount := 0
            color lvlColor = KitCore.get_tf_line_color(sourceTf, htf1, htf2, uiCfg.ltfColor, htf1Cfg.zigzagColor, htf2Cfg.zigzagColor)
            bool isLtfSeed = sourceTf == timeframe.period
            string liqTxt = isLtfSeed ? "idm" : "$"
            string liqTip = KitUI.tt_side(not isHigh, isLtfSeed ? "Internal Dealing Range (IDM)" : "Liquidity")
            int liqExt = KitCore.get_tf_line_ext_bars(sourceTf, htf1, htf2, uiCfg.ltfLineBarsExt, 17, 28)
            int liqRightIdx = KitCore.get_sr_x(bar_index, liqExt, false)
            [liqLine, liqLabel] = KitUI.draw_line_with_text(pivotIdx, z.price, liqRightIdx, z.price, xloc.bar_index, color.new(lvlColor, 35), liqTxt, true, THEME.COLOR_NEUTRAL, liqTip, LIQ_LINE_VIS_CFG, UI_THEME)
            z.visualLine := liqLine
            z.visualLabel := liqLabel
            array.push(levels, z)
    bool(na)

process_data_seed_from_ms_swings(bool isSrSeed, array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, bool isHigh, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom) =>
    int seeded = 0
    int firstIdx = get_data_working_first_idx_for_source_tf(sourceTf)
    int firstTime = get_data_working_first_time_for_source_tf(sourceTf)
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded >= localCfg.limSrSeedSwingsPerTf
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            if not na(firstTime) and not na(s.time) and s.time < firstTime
                break
            if s.isSwingHigh == isHigh
                float p = s.price
                int t = s.time
                int idx = get_data_cached_bar_index_from_time(t)
                if not na(idx) and idx < firstIdx
                    break
                if not na(idx) and idx >= firstIdx
                    if isSrSeed
                        process_data_register_sr_seed(levels, p, idx, t, isHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    else
                        process_data_register_liquidity_seed(levels, p, idx, t, isHigh, tol, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded += 1
    bool(na)

// Fallback side-balancer: guarantee at least one swing seed above/below current price per TF.
process_data_seed_min_side_from_ms_swings(bool isSrSeed, array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, bool wantAbove) =>
    int relaxedFirstIdx = get_data_relaxed_first_idx_for_source_tf(sourceTf)
    int firstTime = get_data_working_first_time_for_source_tf(sourceTf)
    bool seeded = false
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            if not na(firstTime) and not na(s.time) and s.time < firstTime
                break
            float p = s.price
            int t = s.time
            bool sideOk = not na(p) and (wantAbove ? p >= close : p <= close)
            if sideOk
                int idx = get_data_cached_bar_index_from_time(t)
                if not na(idx) and idx >= relaxedFirstIdx
                    if isSrSeed
                        process_data_register_sr_seed(levels, p, idx, t, s.isSwingHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    else
                        process_data_register_liquidity_seed(levels, p, idx, t, s.isSwingHigh, tol, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded := true
    bool(na)

process_data_seed_sr_from_ms_swings(array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, bool isHigh, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, float rangeTop, float rangeBottom, int div) =>
    int seeded = 0
    int seedLimit = localCfg.srSeedLimit
    int firstIdx = get_data_working_first_idx_for_source_tf(sourceTf)
    int firstTime = get_data_working_first_time_for_source_tf(sourceTf)
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded >= seedLimit
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            if not na(firstTime) and not na(s.time) and s.time < firstTime
                break
            if s.isSwingHigh == isHigh
                int t = s.time
                int idx = get_data_cached_bar_index_from_time(t)
                if not na(idx) and idx < firstIdx
                    break
                if not na(idx) and idx >= firstIdx
                    float p = KitCore.snap_to_density_grid(s.price, rangeTop, rangeBottom, div)
                    process_data_register_sr_seed(levels, p, idx, t, isHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded += 1
    bool(na)

process_data_seed_min_side_sr_from_ms_swings(array<KitSMC.PDArray> levels, KitSMC.MSSContext mss, string sourceTf, int sourcePrio, float tol, float srBand, float areaTop, float areaBottom, bool wantAbove, float rangeTop, float rangeBottom, int div) =>
    int relaxedFirstIdx = get_data_relaxed_first_idx_for_source_tf(sourceTf)
    int firstTime = get_data_working_first_time_for_source_tf(sourceTf)
    bool seeded = false
    if not na(mss.swings) and array.size(mss.swings) > 0
        for i = array.size(mss.swings) - 1 to 0
            if seeded
                break
            KitSMC.Swing s = array.get(mss.swings, i)
            if not na(firstTime) and not na(s.time) and s.time < firstTime
                break
            float snapped = KitCore.snap_to_density_grid(s.price, rangeTop, rangeBottom, div)
            bool sideOk = not na(snapped) and (wantAbove ? snapped >= close : snapped <= close)
            if sideOk
                int idx = get_data_cached_bar_index_from_time(s.time)
                if not na(idx) and idx >= relaxedFirstIdx
                    process_data_register_sr_seed(levels, snapped, idx, s.time, s.isSwingHigh, tol, srBand, sourceTf, sourcePrio, areaTop, areaBottom)
                    seeded := true
    bool(na)

get_data_should_seed_refresh(int intervalBars) =>
    [ltfHiP, ltfHi, ltfLoP, ltfLo] = KitSMC.market_structure_latest_hilo(ltfData.mss)
    [h1HiP, h1Hi, h1LoP, h1Lo] = KitSMC.market_structure_latest_hilo(htf1Data.mss)
    [h2HiP, h2Hi, h2LoP, h2Lo] = KitSMC.market_structure_latest_hilo(htf2Data.mss)
    bool changed = na(array.get(seedPulseState, 0)) or ltfHi != array.get(seedPulseState, 0) or ltfLo != array.get(seedPulseState, 1) or h1Hi != array.get(seedPulseState, 2) or h1Lo != array.get(seedPulseState, 3) or h2Hi != array.get(seedPulseState, 4) or h2Lo != array.get(seedPulseState, 5)
    if changed
        array.set(seedPulseState, 0, ltfHi)
        array.set(seedPulseState, 1, ltfLo)
        array.set(seedPulseState, 2, h1Hi)
        array.set(seedPulseState, 3, h1Lo)
        array.set(seedPulseState, 4, h2Hi)
        array.set(seedPulseState, 5, h2Lo)
    bool periodic = intervalBars > 0 and (bar_index % intervalBars == 0)
    barstate.isfirst or changed or periodic

// process_data_liquidity: updates liquidity seeds + lifecycle.
process_data_liquidity(bool doSeed) =>
    bool is1m = get_data_is_1m_chart()
    bool isFast = get_data_is_fast_chart()
    int cycleDiv = is1m ? 4 : isFast ? 3 : 1
    bool allowCycle = not isFast or doSeed or (bar_index % cycleDiv == 0)
    if liquidityBool and allowCycle
        float areaTop = na
        float areaBottom = na
        float liqTol = commonAtr * localCfg.limSrTolAtrMult
        if doSeed
            if not na(htf2)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf2Data.mss, true, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf2Data.mss, false, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom, true)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, liqTol, 0.0, areaTop, areaBottom, false)
            if not na(htf1)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf1Data.mss, true, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_from_ms_swings(false, smcCtx.zones, htf1Data.mss, false, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom, true)
                process_data_seed_min_side_from_ms_swings(false, smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, liqTol, 0.0, areaTop, areaBottom, false)
        process_data_horizontal_levels(HL_KIND_LIQ, smcCtx.zones, areaTop, areaBottom, 0.0, 0.0)

// process_data_sr: updates SR seeds + lifecycle.
process_data_sr(bool doSeed) =>
    bool is1m = get_data_is_1m_chart()
    bool isFast = get_data_is_fast_chart()
    int cycleDiv = is1m ? 4 : isFast ? 3 : 1
    bool allowCycle = not isFast or doSeed or (bar_index % cycleDiv == 0)
    if showSR and allowCycle
        float areaTop = na
        float areaBottom = na
        float srTol = uiDisplayCombo == "All" ? math.max(commonAtr * localCfg.limSrTolAtrMult * 0.35, syminfo.mintick * 2.0) : commonAtr * localCfg.limSrTolAtrMult
        float srBand = math.max(commonAtr * localCfg.limSrTouchBandAtrMult, syminfo.mintick * localCfg.limSrTouchBandMinTicks)
        int srLookbackBars = math.max(5, is1m ? math.min(GLOBAL_MAX_LOOKBACK_BARS, 1200) : isFast ? math.min(GLOBAL_MAX_LOOKBACK_BARS, 2200) : GLOBAL_MAX_LOOKBACK_BARS)
        int div = localCfg.srSeedDiv
        float _maxRange = ta.highest(high, srLookbackBars)
        float _minRange = ta.lowest(low, srLookbackBars)
        if doSeed
            process_data_seed_sr_from_ms_swings(smcCtx.zones, ltfData.mss, true, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
            process_data_seed_sr_from_ms_swings(smcCtx.zones, ltfData.mss, false, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
            process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, ltfData.mss, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, true, _maxRange, _minRange, div)
            process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, ltfData.mss, timeframe.period, SR_SOURCE_PRIO_LTF, srTol, srBand, areaTop, areaBottom, false, _maxRange, _minRange, div)
            if not na(htf2)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, true, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, false, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, true, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf2Data.mss, htf2, SR_SOURCE_PRIO_HTF2, srTol, srBand, areaTop, areaBottom, false, _maxRange, _minRange, div)
            if not na(htf1)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, true, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, false, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, true, _maxRange, _minRange, div)
                process_data_seed_min_side_sr_from_ms_swings(smcCtx.zones, htf1Data.mss, htf1, SR_SOURCE_PRIO_HTF1, srTol, srBand, areaTop, areaBottom, false, _maxRange, _minRange, div)
            
        process_data_horizontal_levels(HL_KIND_SR, smcCtx.zones, areaTop, areaBottom, srBand, 0.0)
        process_data_prune_levels_by_relevance(smcCtx.zones)

if not initialTradesSyncDone
    if tradeEntriesEnabled
        process_data_trades()
        draw_data_trades_dashboard()
    initialTradesSyncDone := true

if calcOnClosedBar
    bool is1m = get_data_is_1m_chart()
    bool isFast = get_data_is_fast_chart()
    int seedRefreshBars = is1m ? 24 : isFast ? 12 : timeframe.isintraday ? 5 : 3
    bool doSeedRefresh = get_data_should_seed_refresh(seedRefreshBars)
    if isFast and not barstate.isfirst and (bar_index % seedRefreshBars != 0)
        doSeedRefresh := false
    process_data_liquidity(doSeedRefresh)
    process_data_sr(doSeedRefresh)
    process_data_entries(canEmitSignals)
    htf2MasterRangeBars := KitSMC.get_master_range_lookback_bars(htf2Data, smcCtx.zones, 3, 2, high, low, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)
    GLOBAL_MAX_LOOKBACK_BARS := KitCore.get_dynamic_global_max_lookback_bars(uiTimeRangeCombo, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS, htf2MasterRangeBars)
    GLOBAL_MAX_LOOKBACK_BARS := math.min(GLOBAL_MAX_LOOKBACK_BARS, get_data_effective_history_cap_bars(uiTimeRangeCombo))
    localCfg.workingLookbackBars := KitCore.get_display_mode_working_lookback_bars(uiDisplayCombo, GLOBAL_MAX_LOOKBACK_BARS)
    if SETTINGS.DYN_LOOKBACK_ENABLE and uiTimeRangeCombo == "dynamic"
        localCfg.workingLookbackBars := math.max(localCfg.workingLookbackBars, htf2MasterRangeBars)
    localCfg.workingLookbackBars := math.min(localCfg.workingLookbackBars, get_data_effective_history_cap_bars(uiTimeRangeCombo))
    htfProjectionSpanBars := GLOBAL_MAX_LOOKBACK_BARS
    draw_data_trades_dashboard()
else
    // Realtime open bar: keep BOS/MSS entries + dashboard responsive on live ticks
    // using the already-built swing ledger from the last confirmed bar.
    int structRecentTsCutRt = KitCore.get_recent_time_cutoff(effectiveCurrLookbackBars)
    if msShowLtf
        process_data_structure_from_ledger(ltfData, msLtfCfg, timeframe.period, structRecentTsCutRt, htf1, htf2, canEmitSignals)
    if msShowTf1 and not na(htf1)
        process_data_structure_from_ledger(htf1Data, msHtf1Cfg, htf1, structRecentTsCutRt, htf1, htf2, canEmitSignals)
    if msShowTf2 and not na(htf2)
        process_data_structure_from_ledger(htf2Data, msHtf2Cfg, htf2, structRecentTsCutRt, htf1, htf2, canEmitSignals)
    chartCtx := process_data_chart_context()
    process_data_entries(canEmitSignals)
    draw_data_trades_dashboard()

// barstate.islast
if barstate.islast or barstate.islastconfirmedhistory
    [lnL50, lnL60, lnL70, lbL50] = SMC_draw_tf_last_leg_fibs(ltfData, timeframe.period, color.new(uiCfg.ltfColor, 0), fibLtf50, fibLtf60, fibLtf70, fibLtf50Label)
    fibLtf50 := lnL50
    fibLtf60 := lnL60
    fibLtf70 := lnL70
    fibLtf50Label := lbL50
    [lnH150, lnH160, lnH170, lbH150] = SMC_draw_tf_last_leg_fibs(htf1Data, htf1, color.new(htf1Cfg.zigzagColor, 0), fibHtf150, fibHtf160, fibHtf170, fibHtf150Label)
    fibHtf150 := lnH150
    fibHtf160 := lnH160
    fibHtf170 := lnH170
    fibHtf150Label := lbH150
    [lnH250, lnH260, lnH270, lbH250] = SMC_draw_tf_last_leg_fibs(htf2Data, htf2, color.new(htf2Cfg.zigzagColor, 0), fibHtf250, fibHtf260, fibHtf270, fibHtf250Label)
    fibHtf250 := lnH250
    fibHtf260 := lnH260
    fibHtf270 := lnH270
    fibHtf250Label := lbH250
    bool showPd = showPDH_PDL and timeframe.isintraday
    int klRight = bar_index + 28
    color klColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorText, 50)
    string klStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
    bool showKlLabels = THEME.SIZE_SMALL != "None"
    [nextPdhLine, nextPdlLine, nextPdhLabel, nextPdlLabel] = KitUI.draw_pd_pw(pdhLine, pdlLine, pdhLabel, pdlLabel, showPd, klRight, klColor, klStyle, showKlLabels, chartCtx.pdh, chartCtx.pdl, chartCtx.pdTime, UI_THEME)
    pdhLine := nextPdhLine
    pdlLine := nextPdlLine
    pdhLabel := nextPdhLabel
    pdlLabel := nextPdlLabel
// Divergence scan moved to bias/signals module.


// Market structure (MTF BOS/MSS + swings) runs above using HTF pair (TF1/TF2).
