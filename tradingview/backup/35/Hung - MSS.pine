// UI theme-derived colors (declared after THEME exists).
type LocalCfg
    // Detection
    int detMethod = 0 // 0 = state, 1 = cross.
    int detMethodCross = 1 // Cross method value.
    string detBasis = "Wick" // Wick/Close basis.
    bool detUseImpulse = false // Enable impulse filter.
    float detImpulseAtr = 0.5 // Impulse threshold in ATR.
    // Limitations
    float limZoneMinHeightAtr = 0.05 // Min zone height in ATR.
    float limSrTolAtrMult = 0.25 // SR merge/touch tolerance in ATR.
    float limSrNearbyMergeMult = 2.0 // SR min-distance multiplier for de-dup.
    float limSrTouchBandAtrMult = 0.10 // SR touch band in ATR.
    float limSrTouchBandMinTicks = 2.0 // SR touch band minimum ticks.
    int limSrTouchCountCooldownBars = 2 // Cooldown between SR touch increments.
    int limSrSeedSwingsPerTf = 2 // Number of latest swings used as SR seeds per TF.
    int srSideCap = 10 // Display-mode resolved side cap.
    int srSourceSideCap = 5 // Display-mode resolved per-source side cap.
    float srMinDistMult = 1.20 // Display-mode resolved SR min-distance multiplier.
    int srSeedLimit = 2 // Display-mode resolved seed limit per TF.
    int srSeedDiv = 50 // Display-mode resolved density-grid divisor.
    int currPivotLenNormal = 0 // Cached Normal-mode pivot length for current TF.
    int htf1PivotLenNormal = 0 // Cached Normal-mode pivot length for HTF1.
    int htf2PivotLenNormal = 0 // Cached Normal-mode pivot length for HTF2.
    // LIQ label behavior (non-UI configurable defaults).
    string liqDollarXPos = "Right" // Left/Middle/Right.
    string liqDollarYPos = "Center" // Above/Center/Below.
    bool liqHideOverlapByTf = true // Hide weaker overlapped HTF markers.
    float liqDollarYOffsetTicks = 4.0 // Y offset in ticks for $ label.
    float liqOverlapTolAtrMult = 0.03 // Overlap tolerance in ATR.
    string liqOverlapScope = "Dollar Only" // Dollar Only/All LIQ.
    // MSS reclass
    int msReclassBars = 3 // Mutable window in bars for BOS/MSS reclass.
    string msReclassBasis = "Close" // Reclass basis: Close/Wick.
    string msInvalidMarkerMode = "Marker" // Marker/Event output mode.
    string displayMode = "Normal" // All/Less/Normal/Extreme/None.
    int workingLookbackBars = 0 // Active working window resolved from display mode.
    float msBreakExtremeMinRangeRatio = 0.35 // Extreme mode continuation ratio beyond broken level.
    float minTradeSizeTicks = 0.0 // Minimum entry-stop size in ticks to allow trade creation.
    float minTradeRR = 0.0 // Minimum TP:SL ratio required for trade creation.

type UIConfig
    color colorText = color.white // Generic text color.
    color ltfColor = color.gray // Base-TF color.
    int ltfLineBarsExt = 8 // LTF line extension.
    bool msShowSwings = true // Show base-TF swings by default.
    bool msShowZigzag = true // Show base-TF zigzag by default.
    bool msHtf1SwingShow = true // Show HTF1 swings by default.
    bool msHtf1ZigzagShow = true // Show HTF1 zigzag by default.
    bool msHtf2SwingShow = true // Show HTF2 swings by default.
    bool msHtf2ZigzagShow = true // Show HTF2 zigzag by default.
    int zoneCurrMinWidthBars = 6 // Minimum zone width in bars.

get_data_local_cfg(int globalLookbackBars, string displayMode) =>
    LocalCfg cfg = LocalCfg.new()
    cfg.displayMode := displayMode
    cfg.workingLookbackBars := KitCore.get_display_mode_working_lookback_bars(displayMode, globalLookbackBars)
    cfg.srSideCap := displayMode == "All" ? 50 :
     displayMode == "Less" ? 16 :
     displayMode == "Normal" ? 10 :
     displayMode == "Extreme" ? 6 : 0
    cfg.srSourceSideCap := displayMode == "All" ? 50 :
     displayMode == "Less" ? 8 :
     displayMode == "Normal" ? 5 :
     displayMode == "Extreme" ? 3 : 0
    cfg.srMinDistMult := displayMode == "All" ? 0.85 :
     displayMode == "Less" ? 1.00 :
     displayMode == "Normal" ? 1.20 :
     displayMode == "Extreme" ? 1.50 : 1.20
    cfg.srSeedLimit := displayMode == "All" ? 50 :
     displayMode == "Less" ? math.max(cfg.limSrSeedSwingsPerTf * 4, cfg.limSrSeedSwingsPerTf) :
     displayMode == "Normal" ? cfg.limSrSeedSwingsPerTf :
     displayMode == "Extreme" ? math.max(1, cfg.limSrSeedSwingsPerTf - 1) : cfg.limSrSeedSwingsPerTf
    cfg.srSeedDiv := displayMode == "All" ? 120 :
     displayMode == "Less" ? 80 :
     displayMode == "Normal" ? 50 :
     displayMode == "Extreme" ? 30 : 50
    cfg

get_data_is_1m_chart() =>
    timeframe.in_seconds(timeframe.period) <= 60

get_data_is_fast_chart() =>
    timeframe.in_seconds(timeframe.period) <= 300

get_data_history_cap_bars_for_chart() =>
    int tfSec = timeframe.in_seconds(timeframe.period)
    tfSec <= 60 ? 1000 :
     tfSec <= 300 ? 1800 :
     tfSec <= 900 ? 2200 :
     tfSec <= 3600 ? 2400 :
     tfSec <= 14400 ? 1800 :
     tfSec <= 86400 ? 1600 : 1400

get_data_effective_history_cap_bars(string timeRange) =>
    str.lower(timeRange) == "dynamic" ? get_data_history_cap_bars_for_chart() : 10000

get_ui_cfg(KitCore.Theme th) =>
    UIConfig cfg = UIConfig.new()
    cfg.colorText := color.new(th.TEXT_COLOR, th.T_NORMAL)
    cfg.ltfColor := color.new(color.rgb(215, 215, 215), 0)
    cfg

