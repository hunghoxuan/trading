//@version=5
// @description: Candle Pattern Bias Detector
//   Imports CandlePatterns library and detects all candle patterns on each bar.
//   Displays:
//     • Plots bullish (▲) or bearish (▼) signals above/below bars
//     • Shows pattern name + bias as a label on detected bars
//     • Dashboard table summarising recent pattern count
//     • Bar colouring optional (faint tint on detected bars)
// @version: 1

indicator("Candle Pattern Bias Detector [HungBot]", shorttitle = "CPD", overlay = true, max_labels_count = 500)

import HungBot/CandlePatterns/1 as CP

// ─────────────────────────────────────────────────────────
//  SETTINGS
// ─────────────────────────────────────────────────────────
grpMain    = "Pattern Detection"
grpStyle   = "Display"
grpDash    = "Dashboard"

dojiPct         = input.float(0.10, "Doji body-to-range %",        minval=0.01, maxval=0.5,  step=0.01, group=grpMain,  tooltip="Max body/range ratio to qualify as doji.")
wickBodyMin     = input.float(2.0,  "Wick : body min ratio",       minval=0.5,  maxval=10.0, step=0.1,  group=grpMain,  tooltip="Minimum wick/body ratio for hammer/star patterns.")
engulfMin       = input.float(1.0,  "Engulf min body ratio",       minval=0.5,  maxval=3.0,  step=0.1,  group=grpMain,  tooltip="Engulfing body must be ≥ N × prior body.")
tweezerTolAtr   = input.float(0.05, "Tweezer tolerance (ATR×)",    minval=0.01, maxval=0.5,  step=0.01, group=grpMain)
marubozuMaxWick = input.float(0.05, "Marubozu max wick/body",      minval=0.01, maxval=0.5,  step=0.01, group=grpMain)
threeLineBody   = input.float(0.60, "3-candle min body %",         minval=0.1,  maxval=0.99, step=0.05, group=grpMain)
starBody        = input.float(0.33, "Star : prior body max ratio", minval=0.05, maxval=0.9,  step=0.05, group=grpMain)

showLabels     = input.bool(true,  "Show pattern labels",    group=grpStyle)
showArrows     = input.bool(true,  "Show arrows (▲/▼)",      group=grpStyle)
colorBars      = input.bool(false, "Colour bars on pattern", group=grpStyle)
showDashboard  = input.bool(true,  "Show dashboard table",   group=grpDash)
dashPos        = input.string("Bottom Right", "Dashboard position", options=["Top Right","Bottom Right","Top Left","Bottom Left"], group=grpDash)
lookbackBars   = input.int(50, "Dashboard lookback (bars)", minval=5, maxval=500, group=grpDash)

colBull = input.color(color.new(#00e5b0, 0),   "Bullish colour", group=grpStyle)
colBear = input.color(color.new(#ff3366, 0),   "Bearish colour", group=grpStyle)
colNone = input.color(color.new(#888888, 60),  "Neutral colour", group=grpStyle)

// ─────────────────────────────────────────────────────────
//  DETECTION
// ─────────────────────────────────────────────────────────
[patName, patBias, patStrength] = CP.detect_all(
     dojiPct,
     wickBodyMin,
     engulfMin,
     tweezerTolAtr,
     marubozuMaxWick,
     threeLineBody,
     starBody)

bool isBull    = patBias == 1
bool isBear    = patBias == -1
bool isPattern = patName != "None"

// ─────────────────────────────────────────────────────────
//  ARROWS (plotshape)
// ─────────────────────────────────────────────────────────
plotshape(showArrows and isBull  ? low  : na,
     id       = "bull_arrow",
     title    = "Bullish Signal",
     style    = shape.triangleup,
     location = location.belowbar,
     color    = colBull,
     size     = size.small)

plotshape(showArrows and isBear  ? high : na,
     id       = "bear_arrow",
     title    = "Bearish Signal",
     style    = shape.triangledown,
     location = location.abovebar,
     color    = colBear,
     size     = size.small)

// ─────────────────────────────────────────────────────────
//  LABEL with pattern name
// ─────────────────────────────────────────────────────────
float atr = ta.atr(14)

if showLabels and isPattern
    string emoji = isBull ? "▲ " : isBear ? "▼ " : "● "
    string lbl   = emoji + patName + (patStrength > 1 ? " ×" + str.tostring(patStrength) : "")
    color  lcol  = isBull ? colBull : isBear ? colBear : colNone
    float  yPos  = isBull ? low  - atr * 0.8 : high + atr * 0.8
    string lsty  = isBull ? label.style_label_up : label.style_label_down

    label.new(
         bar_index, yPos,
         text      = lbl,
         color     = color.new(lcol, 85),
         textcolor = lcol,
         style     = lsty,
         size      = size.small)

// ─────────────────────────────────────────────────────────
//  BAR COLOURING
// ─────────────────────────────────────────────────────────
barcolor(colorBars and isBull ? color.new(colBull, 75) :
         colorBars and isBear ? color.new(colBear, 75) : na)

// ─────────────────────────────────────────────────────────
//  DASHBOARD TABLE  (lookback stats)
// ─────────────────────────────────────────────────────────
// Accumulate trailing counts using persistent vars
var int   bullCount    = 0
var int   bearCount    = 0
var int   totalCount   = 0
var array<int> biasHist = array.new_int(0)

if barstate.isconfirmed
    array.push(biasHist, patBias)
    if array.size(biasHist) > lookbackBars
        array.shift(biasHist)

    // Recalculate from history
    bullCount  := 0
    bearCount  := 0
    totalCount := 0
    for i = 0 to array.size(biasHist) - 1
        int b = array.get(biasHist, i)
        if b == 1
            bullCount  += 1
            totalCount += 1
        else if b == -1
            bearCount  += 1
            totalCount += 1

int    netBias    = bullCount - bearCount
string biasText   = netBias > 0 ? "BULLISH" : netBias < 0 ? "BEARISH" : "NEUTRAL"
color  biasColor  = netBias > 0 ? colBull   : netBias < 0 ? colBear   : colNone

// Table position mapping
var table dashTable = na
if showDashboard and barstate.islast
    tPos = dashPos == "Top Right"    ? position.top_right    :
           dashPos == "Top Left"     ? position.top_left     :
           dashPos == "Bottom Left"  ? position.bottom_left  :
           position.bottom_right

    dashTable := table.new(tPos, 2, 7,
         bgcolor       = color.new(#0d0d0d, 10),
         border_color  = color.new(#333333, 0),
         border_width  = 1,
         frame_color   = color.new(#444444, 0),
         frame_width   = 1)

    // Helper: fill one row
    _hdr(col, txt, bgc, txc) =>
        table.cell(dashTable, col, 0, txt,
             bgcolor   = bgc,
             text_color = txc,
             text_size = size.small,
             text_halign = text.align_center)

    _row(row, label_, val_, valCol) =>
        table.cell(dashTable, 0, row, label_,
             bgcolor    = color.new(#1a1a2e, 0),
             text_color = color.new(#aaaaaa, 0),
             text_size  = size.tiny,
             text_halign = text.align_left)
        table.cell(dashTable, 1, row, val_,
             bgcolor    = color.new(#1a1a2e, 0),
             text_color = valCol,
             text_size  = size.tiny,
             text_halign = text.align_right)

    // Header
    table.cell(dashTable, 0, 0, "⬡  PATTERN BIAS",
         bgcolor     = color.new(#1e1e3f, 0),
         text_color  = color.new(#ddddff, 0),
         text_size   = size.small,
         text_halign = text.align_left)
    table.cell(dashTable, 1, 0, str.tostring(lookbackBars) + "b",
         bgcolor     = color.new(#1e1e3f, 0),
         text_color  = color.new(#888888, 0),
         text_size   = size.tiny,
         text_halign = text.align_right)

    _row(1, "Current Pattern",  patName   != "None" ? patName : "—",              isBull ? colBull : isBear ? colBear : colNone)
    _row(2, "Current Bias",     isBull ? "BULLISH" : isBear ? "BEARISH" : "NONE", isBull ? colBull : isBear ? colBear : colNone)
    _row(3, "Confluence",       patStrength > 0 ? str.tostring(patStrength) + " patterns" : "—", color.new(#cccccc, 0))
    _row(4, "▲ Bull patterns",  str.tostring(bullCount),  colBull)
    _row(5, "▼ Bear patterns",  str.tostring(bearCount),  colBear)
    _row(6, "Net Bias",         biasText + " (" + str.tostring(netBias) + ")", biasColor)

// ─────────────────────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────────────────────
alertcondition(isBull and isPattern, "Bullish Pattern", "Bullish candle pattern detected: {{patName}}")
alertcondition(isBear and isPattern, "Bearish Pattern", "Bearish candle pattern detected: {{patName}}")
alertcondition(isPattern,            "Any Pattern",     "Candle pattern detected: {{patName}}")
