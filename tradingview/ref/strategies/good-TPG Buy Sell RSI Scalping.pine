//@version=6
indicator('RSI Signals Tpg.invest', overlay=true, shorttitle='TPG Buy Sell RSI Scalping')

//Inputs
rsiL = input.int(title='RSI Length', defval=7)
rsiOBI = input.int(title='RSI Overbought', defval=85)
rsiOSI = input.int(title='RSI Oversold', defval=15)
fibLevel = input.float(title='Hammer Body Size', defval=0.333, step=0.01)
BullBearEngulf = input.bool(title='Bullish Bearish Engulfing', defval=true)
hammerShooting = input.bool(title='Hammer Shooting Bar', defval=false)
twoBullBearBar = input.bool(title='Two Bull Bear Bar', defval=false)

//RSI VALUE
myRsi = ta.rsi(close, rsiL)

//RSI OVERBOUGHT / OVERSOLD
rsiOB = myRsi >= rsiOBI
rsiOS = myRsi <= rsiOSI

///////////=Hammer & Shooting star=/////////////

bullFib = (low - high) * fibLevel + high
bearFib = (high - low) * fibLevel + low

bearCandle = close < open ? close : open
bullCandle = close > open ? close : open

hammer = bearCandle >= bullFib and rsiOS
shooting = bullCandle <= bearFib and rsiOB

twoGreenBars = close > open and close[1] > open[1] and rsiOS
twoRedBars = close < open and close[1] < open[1] and rsiOB

/////////////////////////////////////////////

bullE = close > open[1] and close[1] < open[1]
bearE = close < open[1] and close[1] > open[1]

TradeSignal = (rsiOS or rsiOS[1]) and bullE or (rsiOB or rsiOB[1]) and bearE

///////////////////////////////////////////
// PHẦN NÂNG CẤP HIỂN THỊ NHÃN (LABELS)
///////////////////////////////////////////

if TradeSignal and bearE and BullBearEngulf
    // Hiển thị Scalp.Sell + Giá đóng cửa, độ trong suốt 50%
    label.new(x=bar_index, y=na, text='Scalp.Sell\n' + str.tostring(close, "#.00"), yloc=yloc.abovebar, color=color.new(color.maroon, 50), textcolor=color.white, style=label.style_label_down, size=size.normal)
plotshape(TradeSignal and bearE and BullBearEngulf, title='Overbought', location=location.abovebar, color=color.new(color.orange, 0), style=shape.triangledown, size=size.auto, text='')

if TradeSignal and bullE and BullBearEngulf
    // Hiển thị Scalp.Buy + Giá đóng cửa, độ trong suốt 50%
    label.new(x=bar_index, y=na, text='Scalp.Buy\n' + str.tostring(close, "#.00"), yloc=yloc.belowbar, color=color.new(color.green, 50), textcolor=color.white, style=label.style_label_up, size=size.normal)
plotshape(TradeSignal and bullE and BullBearEngulf, title='Oversold', location=location.belowbar, color=color.new(color.lime, 0), style=shape.triangleup, size=size.auto, text='')

//////////////////////////////

if shooting and hammerShooting
    label.new(x=bar_index, y=na, text='SS\n' + str.tostring(close, "#.00"), yloc=yloc.abovebar, color=color.new(color.purple, 50), textcolor=color.white, style=label.style_label_down, size=size.normal)
plotshape(shooting and hammerShooting, title='Overbought + hammer/shooting', location=location.abovebar, color=color.new(color.purple, 0), style=shape.triangledown, size=size.auto, text='')

if hammer and hammerShooting
    label.new(x=bar_index, y=na, text='HMR\n' + str.tostring(close, "#.00"), yloc=yloc.belowbar, color=color.new(color.blue, 50), textcolor=color.white, style=label.style_label_up, size=size.normal)
plotshape(hammer and hammerShooting, title='Oversold + hammer/shooting', location=location.belowbar, color=color.new(color.lime, 0), style=shape.triangleup, size=size.auto, text='')

///////////////////////////

if twoGreenBars and twoBullBearBar
    label.new(x=bar_index, y=na, text='2Bull\n' + str.tostring(close, "#.00"), yloc=yloc.belowbar, color=color.new(color.olive, 50), textcolor=color.white, style=label.style_label_up, size=size.normal)
plotshape(twoGreenBars and twoBullBearBar, title='Oversold + 2bulls', location=location.belowbar, color=color.new(color.lime, 0), style=shape.triangleup, size=size.auto, text='')

if twoRedBars and twoBullBearBar
    label.new(x=bar_index, y=na, text='2Bear\n' + str.tostring(close, "#.00"), yloc=yloc.abovebar, color=color.new(color.red, 50), textcolor=color.white, style=label.style_label_down, size=size.normal)
plotshape(twoRedBars and twoBullBearBar, title='Overbought + 2bears', location=location.abovebar, color=color.new(color.blue, 0), style=shape.triangledown, size=size.auto, text='')

// Send Alert if Candle meets our condition
alertcondition(TradeSignal, title='RSI Scalp Entry', message='RSI Signal Detected for {{ticker}}')
