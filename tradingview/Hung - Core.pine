type UIConfig
    bool showEMA = true
    bool showSMA = false
    bool showVWAP = true
    bool showCandles = true
    bool showKillzones = true
    bool showHtfCandles = true
    bool showTradesDashboard = true
    int emaShort = 50
    int emaNormal = 100
    int emaLong = 200

get_data_ui_cfg(bool showEMA, bool showSMA, bool showVWAP, bool showCandles, bool showKillzones, bool showHtfCandles, bool showTradesDashboard, string tf) =>
    UIConfig cfg = UIConfig.new()
    cfg.showEMA := showEMA
    cfg.showSMA := showSMA
    cfg.showVWAP := showVWAP
    cfg.showCandles := showCandles
    cfg.showKillzones := showKillzones
    cfg.showHtfCandles := showHtfCandles
    cfg.showTradesDashboard := showTradesDashboard
    if tf == "1" or tf == "3" or tf == "5"
        cfg.emaShort := 5
        cfg.emaNormal := 13
        cfg.emaLong := 34
    else if tf == "15"
        cfg.emaShort := 9
        cfg.emaNormal := 21
        cfg.emaLong := 89
    else if tf == "60" or tf == "240"
        cfg.emaShort := 21
        cfg.emaNormal := 55
        cfg.emaLong := 200
    cfg

