get_data_local_technical_ctx(string tf) =>
    [atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down] = KitCore.get_data_technical(tf)
    KitCore.get_data_technical_ctx_from_tuple(atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down)

process_data_cache_ltf_bias_event(array<int> bars, array<float> vals, string dir, int scoreVal, int maxEvents) =>
    if dir == "Buy" or dir == "Sell"
        if array.size(bars) != array.size(vals)
            array.clear(bars)
            array.clear(vals)
        float baseScore = na(scoreVal) ? 1.0 : math.max(float(scoreVal), 1.0)
        float signedScore = (dir == "Buy" ? 1.0 : -1.0) * baseScore
        int n = array.size(bars)
        if n > 0
            int lastBar = array.get(bars, n - 1)
            if lastBar == bar_index
                array.set(vals, n - 1, array.get(vals, n - 1) + signedScore)
            else
                array.push(bars, bar_index)
                array.push(vals, signedScore)
        else
            array.push(bars, bar_index)
            array.push(vals, signedScore)
        while array.size(bars) > maxEvents and array.size(vals) > 0
            array.remove(bars, 0)
            array.remove(vals, 0)
    bool(na)

get_data_ltf_bias_memory_score(array<int> bars, array<float> vals, int windowBars) =>
    float out = 0.0
    int n = array.size(bars)
    int i = n - 1
    while i >= 0
        int age = bar_index - array.get(bars, i)
        if age > windowBars
            array.remove(bars, i)
            array.remove(vals, i)
        else
            float decay = 1.0 - (float(age) / float(math.max(windowBars, 1)))
            out += array.get(vals, i) * math.max(decay, 0.0)
        i -= 1
    out

