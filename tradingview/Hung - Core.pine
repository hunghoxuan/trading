// Helper (Strategy): True if strategy should be evaluated on current TF seconds.
get_data_is_strategy_applicable(KitCore.Strategy s, int tfSec) =>
    s.tfSecMin == STRAT_TF_ANY or (tfSec >= s.tfSecMin and tfSec <= s.tfSecMax)

// Helper (Strategy): Builds the strategy list based on docs/features/STRATEGIES.md.
process_data_init_strategies() =>
    array<KitCore.Strategy> out = array.new<KitCore.Strategy>()
    int tf1m = KitUI.get_tf_seconds("1")
    int tf5m = KitUI.get_tf_seconds("5")
    int tf15m = KitUI.get_tf_seconds("15")
    int tf1h = KitUI.get_tf_seconds("60")
    int tf4h = KitUI.get_tf_seconds("240")
    int tf1d = KitUI.get_tf_seconds("1D")
    int tf1w = KitUI.get_tf_seconds("1W")
    array.push(out, KitCore.Strategy.new(STRAT_ID_VWAP_EMA_CROSS, "VWAP bias + EMA momentum cross", "vwp", tf1m, tf1m, "Bias is price above/below VWAP; enter when EMA(9) crosses EMA(21) in the bias direction.", 9))
    array.push(out, KitCore.Strategy.new(STRAT_ID_EMA_STOCH_PULLBACK, "EMA trend + pullback mean reversion", "stc", tf5m, tf5m, "Bias from EMA(50) slope; enter on pullback to EMA(21) plus Stoch cross from oversold/overbought in bias direction.", 7))
    array.push(out, KitCore.Strategy.new(STRAT_ID_EMA200_BB_SQUEEZE, "EMA200 regime + volatility breakout", "bbs", tf15m, tf1h, "Bias is price vs EMA(200) and RSI vs 50; enter after BB squeeze then close outside bands in bias direction.", 7))
    array.push(out, KitCore.Strategy.new(STRAT_ID_ICHIMOKU_MACD_FLIP, "Ichimoku regime + MACD momentum flip", "ich", tf4h, tf4h, "Bias is price above/below Kumo; enter when MACD histogram flips while price is outside cloud.", 6))
    array.push(out, KitCore.Strategy.new(STRAT_ID_FIB_PULLBACK, "Macro trend + fib pullback", "fib", tf1d, tf1d, "Bias from 50/200 cross plus swing structure; enter on pullback to 0.618 after trend confirmation.", 5))
    array.push(out, KitCore.Strategy.new(STRAT_ID_SMA200_DIVERGENCE, "SMA200 macro anchor + divergence reversal", "smd", tf1w, tf1w, "Bias from SMA(200) slope; enter on RSI divergence at/near SMA(200) contact.", 6))
    array.push(out, KitCore.Strategy.new(STRAT_ID_ADX_EMA_CROSS, "ADX + EMA crossover trend system", "adx", STRAT_TF_ANY, STRAT_TF_ANY, "Enter when EMA(20) crosses EMA(50) and ADX crosses above 25; exit on reverse EMA cross or ADX falling below 25.", 6))
    array.push(out, KitCore.Strategy.new(STRAT_ID_SWEEP, "Swing sweep reclaim", "swp", STRAT_TF_ANY, STRAT_TF_ANY, "Wick sweeps nearest swing liquidity then closes back through level (reclaim).", 7))
    array.push(out, KitCore.Strategy.new(STRAT_ID_CANDLE_PATTERN, "Candle pattern bias alignment", "cpb", STRAT_TF_ANY, STRAT_TF_ANY, "Score-3+ candle pattern (Engulfing/Marubozu/Star/3-line) aligned with composite MTF bias. Volume confirmation boosts conviction.", 8))
    array.push(out, KitCore.Strategy.new(STRAT_ID_GOLDEN_DEATH_CROSS, "Golden/Death cross (macro alignment)", "gdc", tf1d, tf1w, "Use EMA(50)/EMA(200) cross as macro trend alignment; treat cross events as regime shift signals.", 5))
    array.push(out, KitCore.Strategy.new(STRAT_ID_STACK_BIAS, "MA+RSI+VWAP bias stack", "stk", STRAT_TF_ANY, STRAT_TF_ANY, "EMA/SMA stack + RSI + VWAP alignment. Fires only when local stack bias agrees with composite bias.", 6))
    array.push(out, KitCore.Strategy.new(STRAT_ID_TPG_RSI_SCALP, "TPG RSI Scalping", "tpg", STRAT_TF_ANY, STRAT_TF_ANY, "RSI OB/OS + engulfing/hammer/shooting/two-bars price-action trigger from TPG RSI scalping model.", 7))
    out

var array<KitCore.Strategy> STRATEGIES = process_data_init_strategies()

get_data_parse_rr_array(string rrText) =>
    array<float> out = array.new_float()
    string cleaned = str.replace_all(rrText, "[", "")
    cleaned := str.replace_all(cleaned, "]", "")
    cleaned := str.replace_all(cleaned, " ", "")
    array<string> parts = str.split(cleaned, ",")
    if array.size(parts) > 0
        for i = 0 to array.size(parts) - 1
            string token = array.get(parts, i)
            float v = str.tonumber(token)
            if not na(v) and v > 0
                bool exists = false
                if array.size(out) > 0
                    for j = 0 to array.size(out) - 1
                        if math.abs(array.get(out, j) - v) <= 0.000001
                            exists := true
                            break
                if not exists
                    array.push(out, v)
    if array.size(out) == 0
        array.push(out, 1.0)
    out

get_data_rr_text_for_strategy_key(string key) =>
    string k = str.upper(key)
    k == "CP" ? modelCpBiasRrs :
     k == "VWAP" ? modelVwapEmaRrs :
     k == "STOCH" ? modelEmaStochRrs :
     k == "BB" ? modelEmaBbRrs :
     k == "ICHI" ? modelIchMacdRrs :
     k == "FIB" ? modelFibRrs :
     k == "SMADIV" ? modelSmaDivRrs :
     k == "ADX" ? modelAdxEmaRrs :
     k == "SWEEP" ? modelSweepRrs :
     k == "GDC" ? modelGdCrossRrs :
     k == "TPG" ? modelTpgRsiRrs :
     k == "STACK" ? modelStackBiasRrs : "1"

get_data_rr_array_for_strategy_key(string key) =>
    get_data_parse_rr_array(get_data_rr_text_for_strategy_key(key))

get_data_first_rr_for_strategy_key(string key, float fallback) =>
    array<float> rrArr = get_data_rr_array_for_strategy_key(key)
    array.size(rrArr) > 0 ? array.get(rrArr, 0) : fallback

get_data_trade_tf_suffix(string sourceTf) =>
    KitUI.get_friendly_tf(na(sourceTf) or sourceTf == "" ? timeframe.period : sourceTf)

get_data_trade_source_label(string baseType) =>
    string k = str.upper(baseType)
    int dotPos = str.pos(k, ".")
    k := dotPos >= 0 ? str.substring(k, 0, dotPos) : k
    string fullName = k == "VEM" ? "VWAP+EMA [1m]" :
                      k == "EMS" ? "EMA+Stoch [5m]" :
                      k == "BBS" ? "BB Squeeze [15m-1h]" :
                      k == "ICH" ? "Ichimoku+MACD [4h]" :
                      k == "FIB" ? "Fib [1D]" :
                      k == "SMD" ? "SMA+Div [1W]" :
                      k == "GDC" ? "Golden/Death [1D-1W]" :
                      k == "CPB" ? "Candle Pattern" :
                      k == "SWP" ? "Sweep" :
                      k == "TPG" ? "TPG RSI" :
                      k == "ADX" ? "ADX+EMA" :
                      k == "STK" ? "MA+RSI+VWAP Bias" : "Model"
    k + " - " + fullName

get_data_trade_type_for_source_rr(string baseType, string sourceTf, float rrVal) =>
    string k = str.upper(baseType)
    int dotPos = str.pos(k, ".")
    k := dotPos >= 0 ? str.substring(k, 0, dotPos) : k
    string rrText = na(rrVal) ? "na" : str.tostring(rrVal)
    k + "." + get_data_trade_tf_suffix(sourceTf) + "." + rrText

