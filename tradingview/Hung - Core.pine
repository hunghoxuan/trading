type LocalCfg
    int pivotPeriodShort = 5 // Divergence pivot length (short).
    int pivotPeriodNormal = 9 // Divergence pivot length (normal).
    string displayMode = "Normal" // All/Less/Normal/Extreme/None.
    int workingLookbackBars = 0 // Active working window resolved from display mode.
    int currPivotLen = 0 // Cached display-mode pivot length for current TF.
    int htf1PivotLen = 0 // Cached display-mode pivot length for HTF1.
    int htf2PivotLen = 0 // Cached display-mode pivot length for HTF2.
    float slMinTicks = 0.5 // Lowered to prevent Plan Fail on tight scalps.
    float slMinAtr = 0.05 // Lowered to prevent Plan Fail.
    float slMaxAtr = 2.5 // Global maximum SL distance in ATR units.
    float slMaxPct = 0.02 // Global maximum SL distance as % of entry price (2%).
    float minTradeSizeTicks = 0.0 // Minimum total trade span in ticks.
    int ltfBiasMemWindowBars = 20 // LTF-only memory window (recent bars).
    int ltfBiasMemMaxEvents = 80 // Hard cap for cached LTF bias events.
    float ltfBiasMemWeight = 0.35 // Contribution of cached signal memory into LTF bias score.
    int signalContextBars = 20 // Dynamic short-term signal window by chart TF.

get_data_local_cfg(string tf, int globalLookbackBars, string displayMode) =>
    LocalCfg cfg = LocalCfg.new()
    int tfSec = KitUI.get_tf_seconds(tf)
    cfg.displayMode := displayMode
    cfg.workingLookbackBars := KitCore.get_display_mode_working_lookback_bars(displayMode, globalLookbackBars)
    cfg.signalContextBars := tfSec <= 60 ? 30 : tfSec <= 300 ? 20 : tfSec <= 900 ? 15 : 20
    cfg

get_data_history_cap_bars_for_chart() =>
    int tfSec = timeframe.in_seconds(timeframe.period)
    tfSec <= 60 ? 1000 :
     tfSec <= 300 ? 1800 :
     tfSec <= 900 ? 2200 :
     tfSec <= 3600 ? 2400 :
     tfSec <= 14400 ? 1800 :
     tfSec <= 86400 ? 1600 : 1400

get_data_effective_history_cap_bars(string timeRange) =>
    str.lower(timeRange) == "dynamic" ? get_data_history_cap_bars_for_chart() : 10000

