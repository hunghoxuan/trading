    array.clear(strategyDefs)
    array.push(strategyDefs, KitCore.EntryModelDef.new("CP", "CPB", 8, modelCpBias, TRIGGER_TYPE_TRADE, TRIGGER_WHEN_TOUCH, get_data_first_rr_for_strategy_key("CP", 1.0), "edge", 2, 0, 0, "", 120, "na", 1, true, modelCpBiasGap, "AFTER RETEST"))
