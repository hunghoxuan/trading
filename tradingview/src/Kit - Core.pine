Const CONST = Const.new()

get_tf_seconds(string tf_period) =>
    tf_period == "1" ? 60 :
     tf_period == "5" ? 300 :
     tf_period == "15" ? 900 :
     tf_period == "60" ? 3600 :
     tf_period == "240" ? 14400 :
     tf_period == "1D" or tf_period == "D" ? 86400 :
     tf_period == "1W" or tf_period == "W" ? 604800 :
     tf_period == "1M" or tf_period == "M" ? 2592000 :
     (not na(str.tonumber(tf_period)) ? int(str.tonumber(tf_period)) * 60 : timeframe.in_seconds(timeframe.period))

closest_bar_index_from_time_local(int t) =>
    int idx = na
    if not na(t) and bar_index > 0 and not na(time[1])
        int msPerBar = math.max(time - time[1], 1)
        int barsAgo = int(math.round((time - t) / msPerBar))
        int estOff = math.max(0, math.min(10000, barsAgo))
        int maxBack = math.min(10000, bar_index)
        int searchWin = timeframe.in_seconds(timeframe.period) <= 300 ? 160 : 512
        int leftOff = math.max(0, estOff - searchWin)
        int rightOff = math.min(maxBack, estOff + searchWin)
        int bestIdx = na
        int bestDt = na
        for i = leftOff to rightOff
            int tI = time[i]
            bool exact = tI == t
            bool bracket = false
            if i > 0
                int tPrev = time[i - 1]
                bracket := tI < t and tPrev > t
            if exact or bracket
                idx := bar_index - i
                break
            int dt = math.abs(tI - t)
            if na(bestDt) or dt < bestDt
                bestDt := dt
                bestIdx := bar_index - i
        if na(idx)
            idx := bestIdx
    idx

// Canonical pivot-length policy shared by all indicators.
export get_pivot_len_base_for_tf(string tfName, string chartTf, string pivotModeFixed, int pivotLenScalp, int pivotLenIntraday, int pivotLenMultiDay, int pivotLenSwing, int pivotLenPosition) =>
    string resolvedTf = na(tfName) or tfName == "" ? chartTf : tfName
    int tfSec = get_tf_seconds(resolvedTf)
    pivotModeFixed == "" ? 10 :
     tfSec <= 300 ? pivotLenScalp :
     tfSec <= 3600 ? pivotLenIntraday :
     tfSec <= 14400 ? pivotLenMultiDay :
     tfSec <= 86400 ? pivotLenSwing : pivotLenPosition

export get_pivot_len_for_tf(string tfName, string chartTf, string pivotModeFixed, string displayMode, int pivotLenScalp, int pivotLenIntraday, int pivotLenMultiDay, int pivotLenSwing, int pivotLenPosition) =>
    int baseLen = get_pivot_len_base_for_tf(tfName, chartTf, pivotModeFixed, pivotLenScalp, pivotLenIntraday, pivotLenMultiDay, pivotLenSwing, pivotLenPosition)
    displayMode == "All" ? baseLen :
     displayMode == "Less" ? baseLen :
     displayMode == "Normal" ? baseLen :
     displayMode == "Extreme" ? baseLen :
     displayMode == "None" ? baseLen : baseLen

// Encodes trigger type/timing into compact numeric signature bits.
export trigger_type_code(string v, string triggerSignal) =>
    v == triggerSignal ? 1 : 2

export trigger_when_code(string v, string triggerTouch) =>
    v == triggerTouch ? 1 : 2

export is_body_cross_level(float level, float openV, float closeV) =>
    (openV > level and closeV < level) or (openV < level and closeV > level)

export is_level_wick_touch(float level, float band, float openV, float highV, float lowV, float closeV, float mintick) =>
    float tol = math.max(band, mintick * 0.5)
    bool nearWick = (highV >= level - tol and lowV <= level + tol)
    bool bodyCross = is_body_cross_level(level, openV, closeV)
    nearWick and not bodyCross

export snap_to_density_grid(float price, float rangeMax, float rangeMin, int div) =>
    float out = price
    float span = rangeMax - rangeMin
    float rawStep = div > 0 ? span / div : na
    if not na(rawStep) and rawStep > 0
        float step = math.max(rawStep, syminfo.mintick)
        float slot = math.round((price - rangeMin) / step)
        float snapped = rangeMin + slot * step
        out := math.max(rangeMin, math.min(rangeMax, snapped))
    out

export get_sr_x(int barIndex, int extendBars, bool forLabel) =>
    barIndex + extendBars + (forLabel ? 1 : 0)

export get_current_pdarray_extend(string type, int extFvgIfvg, int extObFamily) =>
    type == "FVG" or type == "IFVG" ? extFvgIfvg : extObFamily

export get_htf_pdarray_extend(int tfSlot, int extHtf1, int extHtf2) =>
    tfSlot == 0 ? extHtf1 : extHtf2

get_friendly_tf(string simple_tf) =>
    simple_tf == "1" ? "1m" :
     simple_tf == "3" ? "3m" :
     simple_tf == "5" ? "5m" :
     simple_tf == "15" ? "15m" :
     simple_tf == "30" ? "30m" :
     simple_tf == "45" ? "45m" :
     simple_tf == "60" ? "1h" :
     simple_tf == "120" ? "2h" :
     simple_tf == "180" ? "3h" :
     simple_tf == "240" ? "4h" :
     simple_tf == "1D" or simple_tf == "D" ? "1D" :
     simple_tf == "1W" or simple_tf == "W" ? "1W" :
     simple_tf == "1M" or simple_tf == "M" ? "1M" :
     simple_tf

normalize_tf_code(string tf) =>
    tf == "D" ? "1D" :
     tf == "W" ? "1W" :
     tf == "M" ? "1M" :
     tf

get_bias_factor_slot_index(string tf) =>
    string normTf = normalize_tf_code(tf)
    string normCurr = normalize_tf_code(timeframe.period)
    normTf == normCurr ? 0 :
     normTf == "15" ? 1 :
     normTf == "60" ? 2 :
     normTf == "240" ? 3 :
     normTf == "1D" ? 4 :
     normTf == "1W" ? 5 : na

export get_next_higher_tf(string tf) =>
    string normTf = normalize_tf_code(tf)
    string[] baseTfs = array.from("15", "60", "240", "1D", "1W")
    string out = na
    int idx = array.indexof(baseTfs, normTf)
    if idx != -1 and idx + 1 < array.size(baseTfs)
        out := array.get(baseTfs, idx + 1)
    out
// Returns candidate higher timeframes (> current TF, max 2 from [15m,1h,4h,1D,1W]).
export get_htfs() =>
    string[] base_tfs = array.from("15", "60", "240", "1D", "1W")
    string[] valid_tfs = array.new_string(0)
    int current_tf_sec = timeframe.in_seconds(timeframe.period)
    for tf in base_tfs
        if timeframe.in_seconds(tf) > current_tf_sec
            array.push(valid_tfs, tf)
    string[] result_tfs = array.new_string(0)
    if array.size(valid_tfs) > 0
        array.push(result_tfs, array.get(valid_tfs, 0))
    if array.size(valid_tfs) > 1
        array.push(result_tfs, array.get(valid_tfs, 1))
    result_tfs

// Returns top-2 higher timeframes as a fixed pair [htf1, htf2].
export get_htf_pair() =>
    int currSec = get_tf_seconds(timeframe.period)
    string tf1 = na
    string tf2 = na
    // Override map:
    // 1m  -> 15m, 1h
    // 5m  -> 1h, 4h
    // 15m -> 4h, 1D
    // 1h  -> 1D, 1W
    if currSec <= 60
        tf1 := "15"
        tf2 := "60"
    else if currSec == 300
        tf1 := "60"
        tf2 := "240"
    else if currSec == 900
        tf1 := "240"
        tf2 := "1D"
    else if currSec == 3600
        tf1 := "1D"
        tf2 := "1W"
    else
        string[] tfs = get_htfs()
        tf1 := array.size(tfs) > 0 ? array.get(tfs, 0) : na
        tf2 := array.size(tfs) > 1 ? array.get(tfs, 1) : na
    [tf1, tf2]

export get_dashboard_tf_chain() =>
    [htf1, htf2] = get_htf_pair()
    string htf3 = get_next_higher_tf(htf2)
    [htf1, htf2, htf3]

draw_line_segment(int x1, float y1, int x2, float y2, string xLocation, color lnColor, string lnStyle, int lnWidth) =>
    line.new(x1, y1, x2, y2, xloc = xLocation, color = lnColor, style = lnStyle, width = lnWidth)

draw_dline(line ln, int x1, float y1, int x2, float y2, color lnColor, string lnStyle, int lnWidth) =>
    line out = ln
    int minSafeLeft = math.max(bar_index - 450, 0)
    int safeX1 = math.max(x1, minSafeLeft)
    int safeX2 = math.max(x2, minSafeLeft)
    if safeX2 < safeX1
        safeX2 := safeX1
    if na(out)
        out := line.new(safeX1, y1, safeX2, y2, xloc = xloc.bar_index, color = lnColor, style = lnStyle, width = lnWidth)
    else
        out.set_xy1(safeX1, y1)
        out.set_xy2(safeX2, y2)
        out.set_color(lnColor)
        out.set_style(lnStyle)
        out.set_width(lnWidth)
    out

delete_line_safe(line ln) =>
    if not na(ln)
        ln.delete()
    bool(na)

draw_line_label(label lb, int x, float y, string txt, color txtColor, string txtSize, string tipText) =>
    label out = lb
    if na(out)
        out := label.new(x, y, txt, xloc = xloc.bar_index, style = label.style_none, color = color.new(color.white, 100), textcolor = txtColor, size = txtSize, tooltip = tipText, textalign = text.align_left)
    else
        if out.get_x() != x
            out.set_x(x)
        if out.get_y() != y
            out.set_y(y)
        if out.get_text() != txt
            out.set_text(txt)
        out.set_textcolor(txtColor)
        out.set_size(txtSize)
        out.set_tooltip(tipText)
    out

export get_ctx_bias_for_tf(ChartContext ctx, string tf) =>
    string normTf = normalize_tf_code(tf)
    string normCurr = normalize_tf_code(timeframe.period)
    normTf == normCurr ? ctx.b0 :
     normTf == "15" ? ctx.b15 :
     normTf == "60" ? ctx.b60 :
     normTf == "240" ? ctx.b240 :
     normTf == "1D" ? ctx.b1d :
     normTf == "1W" ? ctx.b1w : 0

export get_ctx_bias_score_for_tf(ChartContext ctx, string tf) =>
    string normTf = normalize_tf_code(tf)
    string normCurr = normalize_tf_code(timeframe.period)
    normTf == normCurr ? ctx.s0 :
     normTf == "15" ? ctx.s15 :
     normTf == "60" ? ctx.s60 :
     normTf == "240" ? ctx.s240 :
     normTf == "1D" ? ctx.s1d :
     normTf == "1W" ? ctx.s1w : 0

export get_ctx_bias_max_for_tf(ChartContext ctx, string tf) =>
    string normTf = normalize_tf_code(tf)
    string normCurr = normalize_tf_code(timeframe.period)
    normTf == normCurr ? ctx.m0 :
     normTf == "15" ? ctx.m15 :
     normTf == "60" ? ctx.m60 :
     normTf == "240" ? ctx.m240 :
     normTf == "1D" ? ctx.m1d :
     normTf == "1W" ? ctx.m1w : 1

export get_ctx_trend_for_tf(ChartContext ctx, string tf) =>
    string normTf = normalize_tf_code(tf)
    string normCurr = normalize_tf_code(timeframe.period)
    normTf == normCurr ? ctx.dir0 :
     normTf == "15" ? ctx.dir15 :
     normTf == "60" ? ctx.dir60 :
     normTf == "240" ? ctx.dir240 :
     normTf == "1D" ? ctx.dir1d :
     normTf == "1W" ? ctx.dir1w : 0

// Fills the standard 3-slot trade bias/trend arrays from one chart context.
export fill_trade_bias_trend_arrays(ChartContext ctx, array<int> tradeBiasVals, array<int> tradeTrendVals) =>
    string h1Name = ctx.htf1Name
    string h2Name = ctx.htf2Name
    int h1Bias = get_ctx_bias_for_tf(ctx, h1Name)
    int h2Bias = get_ctx_bias_for_tf(ctx, h2Name)
    int h1Trend = get_ctx_trend_for_tf(ctx, h1Name)
    int h2Trend = get_ctx_trend_for_tf(ctx, h2Name)
    array.set(tradeBiasVals, 0, ctx.b0)
    array.set(tradeBiasVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.b0 : h1Bias)
    array.set(tradeBiasVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.b0 : h2Bias)
    array.set(tradeTrendVals, 0, ctx.dir0)
    array.set(tradeTrendVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.dir0 : h1Trend)
    array.set(tradeTrendVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.dir0 : h2Trend)
    bool(na)

get_bias_factor_slot_ui(array<string> arr, int slot) =>
    not na(arr) and slot >= 0 and slot < array.size(arr) ? array.get(arr, slot) : ""

// Helper (Bias): Select one effective indicator cluster by timeframe.
export get_bias_profile_id(string tf, Settings cfg) =>
    int sec = get_tf_seconds(tf)
    sec <= 300 ? cfg.BIAS_PROFILE_REACTIVE : sec <= 3600 ? cfg.BIAS_PROFILE_INTRADAY : sec <= 14400 ? cfg.BIAS_PROFILE_SWING : cfg.BIAS_PROFILE_MACRO

// Helper (Bias): Human-readable profile name for tooltip/debug.
export get_bias_profile_name(int profileId, Settings cfg) =>
    profileId == cfg.BIAS_PROFILE_REACTIVE ? "Reactive" : profileId == cfg.BIAS_PROFILE_INTRADAY ? "Intraday" : profileId == cfg.BIAS_PROFILE_SWING ? "Swing" : "Macro"

// Helper (Bias): Converts score strength into a 1..5 level for TradingKit colors.
export get_bias_strength_level(int absScore, int maxScore) =>
    float pct = maxScore > 0 ? (float(absScore) * 100.0 / float(maxScore)) : 0.0
    pct >= 80 ? 5 : pct >= 60 ? 4 : pct >= 40 ? 3 : pct >= 20 ? 2 : 1

export get_ctx_bias_factor_texts_for_tf(ChartContext ctx, string tf) =>
    int slotIdx = get_bias_factor_slot_index(tf)
    string bull = get_bias_factor_slot_ui(ctx.biasBullFactors, slotIdx)
    string bear = get_bias_factor_slot_ui(ctx.biasBearFactors, slotIdx)
    [bull, bear]

// Updates runtime state and computes "fresh chart" + scan gate.
export update_runtime_context(RuntimeContext rt) =>
    bool first = barstate.isfirst or rt.lastSymbol == "" or rt.lastTf == ""
    bool symChanged = not first and syminfo.tickerid != rt.lastSymbol
    bool tfChanged = not first and timeframe.period != rt.lastTf
    bool chartIsNew = first or symChanged or tfChanged
    int scanStart = rt.tradeScanStartBar
    if chartIsNew or na(scanStart)
        scanStart := last_bar_index
    bool canScan = bar_index >= scanStart
    rt.lastSymbol := syminfo.tickerid
    rt.lastTf := timeframe.period
    rt.tradeScanStartBar := scanStart
    rt.chartIsNew := chartIsNew
    rt.symbolChanged := symChanged
    rt.tfChanged := tfChanged
    rt.tradeScanEnabled := canScan
    rt

// Toggle pack for centralized context data loading.
export type DataCfg
    bool needBias = true
    bool needMsTrendDirs = true
    bool needPdPw = false
    bool needPriceRange = false
    bool needHtfCandles = false
    bool initBiasFactorArrays = false
    int rangeLookbackBars = 500

// Structure snapshot built by callers so Core stays independent from KitSMC.
export type StructureSnapshot
    int dir0 = 0

export structure_snapshot_new(int dir0) =>
    StructureSnapshot.new(dir0 = dir0)

// Shared runtime entry object for opened/resolved entry lifecycle.
export type Trade
    string direction
    string type
    float zoneTop
    float zoneBtm
    float entry
    float stoploss
    float takeprofit
    float rrValue
    int barCreated
    int barClosed = na
    string reason
    int score
    float riskUsd = 0.0
    string state = ""
    box tpBox = na
    box slBox = na
    line entryLine = na
    line tpLine = na
    line slLine = na
    label infoLabel = na
    bool touched = false
    string visualSig = ""

// Shared trade-plan math result before order/visual creation.
export type TradePlan
    float entry = na
    float stoploss = na
    float takeprofit = na
    float rrUsed = na
    float slGap = 0.0
    float risk = na
    bool valid = false

// Trade visual style config to allow per-indicator overrides without editing library code.
export type EntryVisualCfg
    int startTouchedBgAlpha = 88
    int startUntouchedBgAlpha = 95
    int resolvedWinnerBgAlpha = 72
    int resolvedLoserBgAlpha = 95
    int startTouchedBorderAlpha = 35
    int startUntouchedBorderAlpha = 55
    int resolvedWinnerBorderAlpha = 18
    int resolvedLoserBorderAlpha = 72
    int entryStartTouchedAlpha = 60
    int entryStartUntouchedAlpha = 35
    int entryResolvedWinnerAlpha = 18
    int entryResolvedLoserAlpha = 55
    int compactWinnerBgAlpha = 70
    int compactLoserBgAlpha = 92
    int compactWinnerBorderAlpha = 12
    int compactLoserBorderAlpha = 65

// Zone box+label visual configuration.
export type ZoneVisualCfg
    int minWidthBars = 1
    int borderWidth = 1
    string textSize = size.tiny
    color transparentColor = color.white
    string labelStyle = label.style_none
    string textHAlign = text.align_right
    string textVAlign = text.align_bottom

// PDArray line-render visual configuration.
export type PriceZoneLineVisualCfg
    string lineStyle = line.style_solid
    int lineWidth = 1
    string labelSize = size.tiny
    bool showLabel = true

// Shared strategy descriptor used by strategy engines.
export type Strategy
    int id
    string name
    string shortName
    int tfSecMin
    int tfSecMax
    string description
    int effectiveness

// Shared confluence adjustment result shape.
export type ConfluenceResult
    string reason
    int score

// Candle-pattern confluence config (pattern thresholds + volume gate + scoring weights).
export type CandlePatternCfg
    float dojiBodyMaxPct = 0.1
    float wickBodyMin = 2.0
    float wickDominanceMin = 2.0
    float oppositeWickMaxBody = 0.5
    float engulfMinPrevBody = 1.0
    float tweezerTolAtr = 0.05
    float marubozuMaxWickBody = 0.2
    float threeLineMinBodyPct = 0.6
    int volLen = 20
    float volMin = 1.5
    int scorePattern = 1
    int scoreVolume = 1

// Candle-pattern display config (visual toggles + color palette).
export type CandlePatternVisualCfg
    bool showCandles = true
    bool showHalo = true
    bool showMarkers = true
    color bull = #00e5b0
    color bear = #ff3366
    color neutral = #888888
    color normBull = #26a69a
    color normBear = #ef5350
    color markerBull = #00e5b0
    color markerBear = #ff3366
    color markerNeutral = #888888


// Returns a standard candle-pattern config built from shared Settings defaults.
// SMC helper
export get_candle_pattern_cfg(Settings s, int scorePattern, int scoreVolume) =>
    CandlePatternCfg.new(
     dojiBodyMaxPct = s.CP_DOJI_PCT,
     wickBodyMin = s.CP_WICK_BODY,
     wickDominanceMin = s.CP_WICK_DOMINANCE,
     oppositeWickMaxBody = s.CP_OPPOSITE_WICK_MAX_BODY,
     engulfMinPrevBody = s.CP_ENGULF_MIN,
     tweezerTolAtr = s.CP_TWEEZER_ATR,
     marubozuMaxWickBody = s.CP_MARUBOZU_WICK,
     threeLineMinBodyPct = s.CP_3LINE_BODY,
     volLen = s.CP_VOL_LEN,
     volMin = s.CP_VOL_MIN,
     scorePattern = scorePattern,
     scoreVolume = scoreVolume)

// Per-indicator toggle flags for each bias factor used in get_bias_data_for_tf().
// All flags default true so callers only need to override what they want to disable.
export type BiasToggles
    bool useStructure   = true  // Include market structure direction in scoring.
    bool useVwap        = true  // Include VWAP position in scoring.
    bool useEma         = true  // Include EMA-50/200 in scoring.
    bool useRsi         = true  // Include RSI midpoint in scoring.
    bool useAdx         = true  // Include ADX trend strength in scoring.
    bool useRsiImpulse  = true  // Include RSI impulse cross in scoring.
    bool useSupertrend  = true  // Include Supertrend direction in scoring.
    bool useDonchian    = true  // Include Donchian channel position in scoring.

// Builds a chart context directly from one canonical structure direction value.
// Returns strength background color by type and level (1..5).
export get_strength_color(string p_type, int s = 3) =>
    p_type == "bull" ? (s >= 5 ? #004D40 : s == 4 ? #00695C : s == 3 ? #00897B : s == 2 ? #26A69A : #80CBC4) : p_type == "bear" ? (s >= 5 ? #B71C1C : s == 4 ? #C62828 : s == 3 ? #D32F2F : s == 2 ? #EF5350 : #EF9A9A) : color.new(color.gray, 0)

// Returns dynamic confirmation window based on timeframe and event type.
export get_dynamic_confirmation_window_bars(string tfPeriod, bool isSweep, int sweepMinBars, int sweepMaxBars, int breakMinBars, int breakMaxBars) =>
    int tfSec = timeframe.in_seconds(tfPeriod)
    int raw = isSweep ? (tfSec <= 900 ? 6 : tfSec <= 3600 ? 8 : tfSec <= 14400 ? 6 : tfSec <= 86400 ? 4 : 3) : (tfSec <= 900 ? 20 : tfSec <= 3600 ? 24 : tfSec <= 14400 ? 18 : tfSec <= 86400 ? 12 : 8)
    int minBars = isSweep ? sweepMinBars : breakMinBars
    int maxBars = isSweep ? sweepMaxBars : breakMaxBars
    math.max(minBars, math.min(raw, maxBars))

// Returns flattened signal stats matrix index.
export get_signal_stat_idx(int typeIdx, int metricIdx, int metricCount) =>
    typeIdx * metricCount + metricIdx

color_sig(color c) =>
    str.tostring(color.r(c)) + ":" + str.tostring(color.g(c)) + ":" + str.tostring(color.b(c)) + ":" + str.tostring(color.t(c))

// Returns true when entry plan values are valid for direction and minimum tick distance.
export is_valid_trade_plan(string direction, float entry, float stoploss, float takeprofit, float tickSize) =>
    bool isBuy = direction == "Buy"
    bool finite = not na(entry) and not na(stoploss) and not na(takeprofit)
    bool sideOk = isBuy ? (stoploss < entry and takeprofit > entry) : (stoploss > entry and takeprofit < entry)
    bool distOk = math.abs(entry - stoploss) >= tickSize and math.abs(takeprofit - entry) >= tickSize
    finite and sideOk and distOk

// Returns true when the combined entry/SL/TP span satisfies the configured minimum size in ticks.
export is_trade_size_valid(float entry, float stoploss, float takeprofit, float minTradeSizeTicks) =>
    if na(entry) or na(stoploss) or na(takeprofit) or na(syminfo.mintick) or syminfo.mintick <= 0.0
        false
    else
        float minTicks = math.max(minTradeSizeTicks, 0.0)
        float sizeTicks = (math.abs(entry - stoploss) + math.abs(takeprofit - entry)) / math.max(syminfo.mintick, 1e-10)
        minTicks <= 0.0 or (not na(sizeTicks) and sizeTicks >= minTicks)

// Returns true when the plan reward:risk ratio meets the configured floor.
export is_trade_rr_valid(float entry, float stoploss, float takeprofit, float minTradeRR) =>
    if na(entry) or na(stoploss) or na(takeprofit)
        false
    else
        float risk = math.max(math.abs(entry - stoploss), syminfo.mintick)
        float reward = math.abs(takeprofit - entry)
        float rr = reward / risk
        rr >= math.max(minTradeRR, 0.1)

// Shared trade-plan validator with configurable min-size/min-RR gates.
export is_trade_plan_valid_with_limits(float entry, float stoploss, float takeprofit, float minTradeSizeTicks, float minTradeRR) =>
    is_trade_size_valid(entry, stoploss, takeprofit, minTradeSizeTicks) and is_trade_rr_valid(entry, stoploss, takeprofit, minTradeRR)

// Shared risk-based quantity calculator. Returns na when the price risk is invalid.
export get_trade_order_qty(float entry, float stoploss, float riskPerRRUsd) =>
    if na(entry) or na(stoploss)
        na
    else
        float riskPerUnitUsd = math.abs(entry - stoploss) * math.max(math.abs(syminfo.pointvalue), 1e-10)
        riskPerUnitUsd <= 0.0 ? na : (math.max(riskPerRRUsd, 0.0) / riskPerUnitUsd)

// Converts 1R value + mode ("%" or "$") to USD risk amount.
// WARNING: do NOT pass strategy.equity directly — Pine blocks strategy.* in imported lib call args.
// Inline this logic at indicator scope instead: tradeRiskMode == "%" ? (value / 100.0 * strategy.equity) : value
export get_trade_risk_usd(float value, string mode, float equity) =>
    mode == "%" ? math.max(value, 0.0) / 100.0 * math.max(equity, 0.0) : math.max(value, 0.0)

// Returns pre-filled PropRiskGuard for a named preset. "None" → limits disabled.
export get_prop_profile(string preset) =>
    PropRiskGuard p = PropRiskGuard.new(preset = preset)
    if preset == "FTMO 2-Step"
        p.dailyLimitPct := 2.5
        p.tradeCapPct   := 0.5
    else if preset == "FTMO 1-Step"
        p.dailyLimitPct := 1.5
        p.tradeCapPct   := 0.5
    else if preset == "The5ers HS"
        p.dailyLimitPct := 2.5
        p.tradeCapPct   := 0.5
    else if preset == "The5ers HG"
        p.dailyLimitPct := 1.5
        p.tradeCapPct   := 0.5
    p

// Returns NY-RTH trading day key (session anchored at 09:30 America/New_York).
get_ny_rth_day_key(int ts) =>
    string tz = "America/New_York"
    int nyMinutes = hour(ts, tz) * 60 + minute(ts, tz)
    int anchorTs = nyMinutes < 570 ? (ts - 24 * 60 * 60 * 1000) : ts
    int y = year(anchorTs, tz)
    int m = month(anchorTs, tz)
    int d = dayofmonth(anchorTs, tz)
    y * 10000 + m * 100 + d

// Resets daily risk cap if a new NY-RTH day has started.
export prop_check_new_day(array<float> propState) =>
    int dayKey = get_ny_rth_day_key(time)
    int lastDayKey = int(array.get(propState, 2))
    bool isNewDay = dayKey != lastDayKey
    if isNewDay
        array.set(propState, 1, 0.0)
        array.set(propState, 2, float(dayKey))
    isNewDay

// Returns true when a new trade is allowed under the prop risk guard rules.
export prop_entry_allowed(array<float> propState, PropRiskGuard cfg, float tradeRiskPct) =>
    bool tradeOk = cfg.tradeCapPct  <= 0.0 or tradeRiskPct <= cfg.tradeCapPct
    bool dailyOk = cfg.dailyLimitPct <= 0.0 or (array.get(propState, 1) + tradeRiskPct) <= cfg.dailyLimitPct
    tradeOk and dailyOk

// Adds tradeRiskPct to daily risk accumulator after a trade is confirmed.
export prop_register_trade(array<float> propState, float tradeRiskPct) =>
    array.set(propState, 1, array.get(propState, 1) + tradeRiskPct)
    bool(na)

// Deletes all visuals owned by one Trade.
export delete_trade_visuals(Trade e) =>
    if not na(e.tpBox)
        e.tpBox.delete()
    if not na(e.slBox)
        e.slBox.delete()
    if not na(e.entryLine)
        e.entryLine.delete()
    if not na(e.tpLine)
        e.tpLine.delete()
    if not na(e.slLine)
        e.slLine.delete()
    if not na(e.infoLabel)
        e.infoLabel.delete()
    bool(na)

// Shared policy: strategy orders are allowed only when Strategy toggle is enabled
// and quantity is valid. Visual trades are handled separately by callers.
export strategy_order_qty_ok(bool strategyOrdersEnabled, float orderQty) =>
    strategyOrdersEnabled and not na(orderQty) and orderQty > 0.0

// Shared working-lookback sizing from display mode.
export get_display_mode_working_lookback_bars(string displayMode, int baseLookbackBars) =>
    int baseBars = math.max(baseLookbackBars, 1)
    displayMode == "All" ? baseBars :
     displayMode == "Less" ? baseBars :
     displayMode == "Normal" ? baseBars :
     displayMode == "Extreme" ? baseBars :
     displayMode == "None" ? baseBars : baseBars

get_calendar_cutoff_lookback_bars(int cutoffTs, int fallbackBars) =>
    if na(cutoffTs)
        fallbackBars
    else
        int cutoffIdx = closest_bar_index_from_time_local(cutoffTs)
        na(cutoffIdx) ? fallbackBars : math.max(bar_index - cutoffIdx + 1, 1)

// Shared time-range lookback policy for all indicators.
export get_dynamic_global_max_lookback_bars(string timeRange, int fallbackBars, int structureBars) =>
    int baseFallback = math.max(fallbackBars, 1)
    string rawMode = str.lower(timeRange)
    int startOfToday = timestamp(year(time), month(time), dayofmonth(time), 0, 0)
    int dow = dayofweek(time)
    int dayOffset = dow == dayofweek.sunday ? 6 : dow - dayofweek.monday
    int startOfWeek = startOfToday - (dayOffset * 24 * 60 * 60 * 1000)
    int prevMonthYear = month(time) == 1 ? year(time) - 1 : year(time)
    int prevMonthNum = month(time) == 1 ? 12 : month(time) - 1
    int startOfMonth = timestamp(year(time), month(time), 1, 0, 0)
    int startOfPrevMonth = timestamp(prevMonthYear, prevMonthNum, 1, 0, 0)
    int startOfYear = timestamp(year(time), 1, 1, 0, 0)
    if rawMode == "dynamic"
        math.max(structureBars, 1)
    else if rawMode == "today"
        get_calendar_cutoff_lookback_bars(startOfToday, baseFallback)
    else if rawMode == "yesterday"
        get_calendar_cutoff_lookback_bars(startOfToday - (1 * 24 * 60 * 60 * 1000), baseFallback)
    else if rawMode == "day"
        int cutoffTs = time - (1 * 24 * 60 * 60 * 1000)
        get_calendar_cutoff_lookback_bars(cutoffTs, baseFallback)
    else if rawMode == "this week"
        get_calendar_cutoff_lookback_bars(startOfWeek, baseFallback)
    else if rawMode == "last week"
        get_calendar_cutoff_lookback_bars(startOfWeek - (7 * 24 * 60 * 60 * 1000), baseFallback)
    else if rawMode == "week"
        int cutoffTs = time - (7 * 24 * 60 * 60 * 1000)
        get_calendar_cutoff_lookback_bars(cutoffTs, baseFallback)
    else if rawMode == "this month"
        get_calendar_cutoff_lookback_bars(startOfMonth, baseFallback)
    else if rawMode == "last month"
        get_calendar_cutoff_lookback_bars(startOfPrevMonth, baseFallback)
    else if rawMode == "month"
        int cutoffTs = time - (30 * 24 * 60 * 60 * 1000)
        get_calendar_cutoff_lookback_bars(cutoffTs, baseFallback)
    else if rawMode == "this year"
        get_calendar_cutoff_lookback_bars(startOfYear, baseFallback)
    else if rawMode == "year"
        int cutoffTs = time - (365 * 24 * 60 * 60 * 1000)
        get_calendar_cutoff_lookback_bars(cutoffTs, baseFallback)
    else
        baseFallback

// Converts a current-chart range in bars into target-TF candle count for equivalent time span.
export get_tf_candle_count_from_range_bars(string targetTf, int rangeBars, int minCount, int maxCount, int fallbackCount) =>
    if na(targetTf) or targetTf == ""
        fallbackCount
    else
        int currSec = math.max(get_tf_seconds(timeframe.period), 1)
        int targetSec = math.max(get_tf_seconds(targetTf), currSec)
        int rawCount = int(math.ceil(float(math.max(rangeBars, 1) * currSec) / float(targetSec)))
        math.max(minCount, math.min(rawCount, maxCount))

// Shared trade-visual policy by display mode.
export get_display_mode_trade_visibility(string displayMode) =>
    bool showPending = displayMode == "All" or displayMode == "Normal"
    bool showStart = displayMode != "None"
    bool showTp = displayMode == "All" or displayMode == "Less"
    bool showSl = displayMode == "All" or displayMode == "Less"
    [showPending, showStart, showTp, showSl]

// Shared bar-index cutoff from a resolved working lookback size.
export get_working_first_bar_from_lookback(int workingLookbackBars) =>
    math.max(bar_index - math.max(workingLookbackBars, 1), 0)

// Shared working-window start marker update.
export update_working_first_bar_line(line currLine, int currFirst, color lnColor, string lnStyle) =>
    if not na(currLine)
        line.delete(currLine)
    int safeFirst = math.max(0, math.min(currFirst, bar_index))
    line.new(safeFirst, close, safeFirst, close + syminfo.mintick, xloc = xloc.bar_index, extend = extend.both, color = lnColor, width = 1, style = lnStyle)

// Shared working-window start marker update with indicator label.
export update_working_first_bar_marker(line currLine, label currLabel, int currFirst, string markerText, color lnColor, string lnStyle, color txtColor, string txtSize) =>
    if not na(currLine)
        line.delete(currLine)
    if not na(currLabel)
        label.delete(currLabel)
    int safeFirst = math.max(0, math.min(currFirst, bar_index))
    line nextLine = line.new(safeFirst, close, safeFirst, close + syminfo.mintick, xloc = xloc.bar_index, extend = extend.both, color = lnColor, width = 1, style = lnStyle)
    label nextLabel = label.new(safeFirst, na, markerText, xloc = xloc.bar_index, yloc = yloc.abovebar, color = color.new(color.white, 100), textcolor = txtColor, style = label.style_none, size = txtSize)
    [nextLine, nextLabel]

// Basic memory-direction allow check for Buy/Sell.
export direction_allowed_raw(string direction, int memDir) =>
    memDir == 0 or (direction == "Buy" and memDir == 1) or (direction == "Sell" and memDir == -1)

// Shared cached direction gate for indicators that keep per-bar allow flags.
export direction_allowed_cached(string direction, bool gateEnabled, int cachedBar, int cachedBias, int currentBarIndex, int queryBias, int allowBuyFlag, int allowSellFlag, int memDir) =>
    if not gateEnabled
        true
    else
        bool canUseCache = not na(cachedBar) and cachedBar == currentBarIndex and cachedBias == queryBias
        canUseCache ? (direction == "Buy" ? allowBuyFlag == 1 : allowSellFlag == 1) : direction_allowed_raw(direction, memDir)

// Shared trade-tooltip formatter using chart context plus preformatted event snapshot text.
export format_trade_tooltip(ChartContext ctx, TradeTooltipMeta meta, string direction, float entry, float takeprofit, float stoploss, float rrUsed, float slGap, string eventsLine, string upSym, string dnSym, string dashSym) =>
    string side = str.upper(direction)
    string shortName = str.upper(meta.shortName)
    string longName = meta.longName
    string titleName = str.upper(longName) == shortName ? shortName : (shortName + " - " + longName)
    int bLtf = ctx.b0
    int bH1 = na(ctx.htf1Name) ? 0 : get_ctx_bias_for_tf(ctx, ctx.htf1Name)
    int bH2 = na(ctx.htf2Name) ? 0 : get_ctx_bias_for_tf(ctx, ctx.htf2Name)
    string s0 = bLtf == 1 ? upSym : bLtf == -1 ? dnSym : dashSym
    string s1 = bH1 == 1 ? upSym : bH1 == -1 ? dnSym : dashSym
    string s2 = bH2 == 1 ? upSym : bH2 == -1 ? dnSym : dashSym
    string pdLine = "pdarray: " + meta.pdarrayText + " | score " + str.tostring(meta.scoreVal) + ", q " + str.tostring(nz(meta.qualityPct, 0.0), "#.0") + "%"
    float rsi14 = ta.rsi(close, 14)
    float vwapV = ta.vwap(hlc3)
    float ema20 = ta.ema(close, 20)
    float ema50 = ta.ema(close, 50)
    string techLine = "tech: rsi " + str.tostring(rsi14, "#.0") + ", vwap " + str.tostring(vwapV, format.mintick) + ", ema20 " + str.tostring(ema20, format.mintick) + ", ema50 " + str.tostring(ema50, format.mintick)
    side + ": " + titleName +
     "\ne: " + str.tostring(entry, format.mintick) + ", tp: " + str.tostring(takeprofit, format.mintick) + ", sl: " + str.tostring(stoploss, format.mintick) + ", rr: " + str.tostring(rrUsed, "#.##") + ", sl_gap: " + str.tostring(slGap, format.mintick) +
     "\nbias: ltf " + s0 + ", htf1 " + s1 + ", htf2 " + s2 +
     "\n" + eventsLine +
     "\n" + pdLine +
     "\n" + techLine +
     "\nreason: " + meta.reason

// Builds a shared Trade object only when the plan is valid; otherwise returns na.
export create_trade_if_valid(string direction, string type, float zoneTop, float zoneBtm, float entry, float stoploss, float takeprofit, float rrValue, int barCreated, string reason, int scoreVal, float riskUsd, Const c, float tickSize) =>
    Trade out = na
    if is_valid_trade_plan(direction, entry, stoploss, takeprofit, tickSize)
        out := Trade.new(direction, type, zoneTop, zoneBtm, entry, stoploss, takeprofit, rrValue, barCreated, int(na), reason, scoreVal, riskUsd, c.SIGNAL_STATE_PENDING, na, na, na, na, na)
    out

// Shared payload builder before callers push into arrays or submit strategy orders.
export build_trade_entry_payload(string direction, string type, float zoneTop, float zoneBtm, float entry, float stoploss, float takeprofit, float rrValue, int barCreated, string reason, int scoreVal, float riskUsd, string orderPrefix, string orderKey, int orderSeq, Const c, float tickSize) =>
    Trade e = create_trade_if_valid(direction, type, zoneTop, zoneBtm, entry, stoploss, takeprofit, rrValue, barCreated, reason, scoreVal, riskUsd, c, tickSize)
    string orderId = not na(e) ? (orderPrefix + "_" + orderKey + "_" + str.tostring(barCreated) + "_" + str.tostring(orderSeq)) : ""
    [e, orderId]

json_escape_for_webhook(string raw) =>
    string v0 = na(raw) ? "" : raw
    string v1 = str.replace_all(v0, "\\", "\\\\")
    string v2 = str.replace_all(v1, "\"", "\\\"")
    string v3 = str.replace_all(v2, "\n", " ")
    string v4 = str.replace_all(v3, "\r", " ")
    v4

format_tf_for_webhook(string tfRaw) =>
    string raw = na(tfRaw) or tfRaw == "" ? timeframe.period : tfRaw
    float asNum = str.tonumber(raw)
    not na(asNum) ? (str.tostring(int(math.round(asNum))) + "m") : str.lower(raw)

normalize_side_for_webhook(string direction) =>
    str.upper(direction) == "BUY" ? "BUY" : "SELL"

// Builds TradingView webhook JSON payload for one newly created trade signal.
export build_trade_webhook_payload(string strategyName, string symbolName, string direction, string sourceTf, float price, float sl, float tp, string note, string apiKey, string status = "PENDING", string tradeId = "", string provider = "ctrader", float rrValue = na, string modelType = "", float riskUsd = na, float riskPct = na, int barTime = na, string reasonText = "", string chartTf = "") =>
    string safeStrategy = json_escape_for_webhook(strategyName)
    string safeSymbol = json_escape_for_webhook(symbolName)
    string safeSide = normalize_side_for_webhook(direction)
    string safeTf = json_escape_for_webhook(format_tf_for_webhook(sourceTf))
    string safeNote = json_escape_for_webhook(note)
    string safeStatus = json_escape_for_webhook(status)
    string safeTradeId = json_escape_for_webhook(tradeId)
    string safeProvider = json_escape_for_webhook(str.lower(provider))
    string safeSourceTf = json_escape_for_webhook(sourceTf)
    string safeChartTf = json_escape_for_webhook(format_tf_for_webhook(na(chartTf) or chartTf == "" ? sourceTf : chartTf))
    string safeModelType = json_escape_for_webhook(modelType)
    string safeReason = json_escape_for_webhook(reasonText)
    float riskPctFinal = not na(riskPct) ? riskPct : (price > 0 ? math.abs(price - sl) / price * 100.0 : na)
    string msg = "{"
    msg += "\"strategy\":\"" + safeStrategy + "\""
    msg += ",\"symbol\":\"" + safeSymbol + "\""
    msg += ",\"side\":\"" + safeSide + "\""
    msg += ",\"timeframe\":\"" + safeTf + "\""
    msg += ",\"status\":\"" + safeStatus + "\""
    msg += ",\"id\":\"" + safeTradeId + "\""
    msg += ",\"provider\":\"" + safeProvider + "\""
    msg += ",\"sourceTf\":\"" + safeSourceTf + "\""
    msg += ",\"chartTf\":\"" + safeChartTf + "\""
    msg += ",\"model\":\"" + safeModelType + "\""
    msg += ",\"reason\":\"" + safeReason + "\""
    msg += ",\"barTime\":" + (na(barTime) ? "null" : str.tostring(barTime))
    msg += ",\"rr\":" + (na(rrValue) ? "null" : str.tostring(rrValue))
    msg += ",\"riskUsd\":" + (na(riskUsd) ? "null" : str.tostring(riskUsd))
    msg += ",\"riskPct\":" + (na(riskPctFinal) ? "null" : str.tostring(riskPctFinal))
    msg += ",\"price\":" + str.tostring(price)
    msg += ",\"sl\":" + str.tostring(sl)
    msg += ",\"tp\":" + str.tostring(tp)
    msg += ",\"note\":\"" + safeNote + "\""
    if str.length(apiKey) > 0
        msg += ",\"apiKey\":\"" + json_escape_for_webhook(apiKey) + "\""
    msg += "}"
    msg

// Emits one webhook-ready alert() call for each newly created trade entry.
export emit_trade_webhook_new_trade(bool enabled, bool realtimeOnly, string strategyName, string symbolName, string direction, string sourceTf, float price, float sl, float tp, string note, string apiKey, string tradeId = "", string provider = "ctrader", string status = "PENDING", float rrValue = na, string modelType = "", float riskUsd = na, float riskPct = na, int barTime = na, string reasonText = "", string chartTf = "") =>
    if enabled
        bool canEmit = (not realtimeOnly) or barstate.isrealtime
        if canEmit
            string payload = build_trade_webhook_payload(strategyName, symbolName, direction, sourceTf, price, sl, tp, note, apiKey, status, tradeId, provider, rrValue, modelType, riskUsd, riskPct, barTime, reasonText, chartTf)
            alert(payload, alert.freq_all)
    bool(na)

// Shared pending-trade mutator used by upsert flows.
export patch_pending_trade(Trade e, string type, float entry, float stoploss, float takeprofit, float rrValue, string reason, int scoreVal) =>
    e.type := type
    e.entry := entry
    e.stoploss := stoploss
    e.takeprofit := takeprofit
    e.rrValue := rrValue
    e.reason := reason
    e.score := scoreVal
    e

// Shared array tracker for newly created trade entries.
export track_trade_entry(array<Trade> entriesRef, array<string> orderIdsRef, Trade e, string orderId, bool shouldTrack) =>
    if shouldTrack and not na(e)
        array.push(entriesRef, e)
        array.push(orderIdsRef, orderId)
    bool(na)

// Shared strategy submission shell for one pending limit order and paired exit.
export submit_strategy_trade_order(string orderId, string direction, float orderQty, float entry, float stoploss, float takeprofit) =>
    if orderId != "" and not na(orderQty) and orderQty > 0.0
        strategy.entry(orderId, direction == "Buy" ? strategy.long : strategy.short, qty = orderQty, limit = entry, comment = "")
        strategy.exit(orderId + "_x", from_entry = orderId, stop = stoploss, limit = takeprofit, comment_profit = "", comment_loss = "")
    bool(na)

// Shared strategy cancellation shell for one pending limit order and paired exit.
export cancel_strategy_trade_order(string orderId) =>
    if orderId != ""
        strategy.cancel(orderId)
        strategy.cancel(orderId + "_x")
    bool(na)

// Shared trade cleanup shell before callers remove any side arrays aligned with trades.
export remove_trade_entry(array<Trade> entriesRef, array<string> orderIdsRef, int idx, bool strategyOrdersEnabled) =>
    if idx >= 0 and idx < array.size(entriesRef) and idx < array.size(orderIdsRef)
        Trade e = array.get(entriesRef, idx)
        string orderId = array.get(orderIdsRef, idx)
        if strategyOrdersEnabled
            cancel_strategy_trade_order(orderId)
        delete_trade_visuals(e)
        array.remove(entriesRef, idx)
        array.remove(orderIdsRef, idx)
    bool(na)

// Applies TP/SL/+R stats update from one outcome code: 1=TP, -1=SL, 0=none.
export apply_trade_outcome_stats(array<float> stats, int bucketIdx, int outcome, float rrValue, Const c, int metricCount) =>
    int idxSl = get_signal_stat_idx(bucketIdx, c.SIG_METRIC_SL, metricCount)
    int idxTp = get_signal_stat_idx(bucketIdx, c.SIG_METRIC_TP, metricCount)
    int idxGr = get_signal_stat_idx(bucketIdx, c.SIG_METRIC_GAIN_R, metricCount)
    if outcome < 0
        array.set(stats, idxSl, array.get(stats, idxSl) + 1)
        array.set(stats, idxGr, array.get(stats, idxGr) - 1)
    else if outcome > 0
        array.set(stats, idxTp, array.get(stats, idxTp) + 1)
        array.set(stats, idxGr, array.get(stats, idxGr) + rrValue)
    bool(na)

// Returns true if there is an active START entry for strategy+direction.
// Indicator helper
export has_active_trade_for_strategy(array<Trade> entriesRef, array<int> entryStrategyIds, int stratId, string direction, Const c) =>
    bool out = false
    if array.size(entriesRef) > 0 and array.size(entryStrategyIds) == array.size(entriesRef)
        for i = array.size(entriesRef) - 1 to 0
            Trade e = array.get(entriesRef, i)
            int sid = array.get(entryStrategyIds, i)
            if sid == stratId and e.direction == direction and e.state == c.SIGNAL_STATE_START
                out := true
                break
    out

// Returns true if there was a recent START entry for strategy+direction in the recentBars window.
// Indicator helper
export has_recent_active_trade_for_strategy(array<Trade> entriesRef, array<int> entryStrategyIds, int stratId, string direction, int recentBars, Const c) =>
    bool out = false
    if array.size(entriesRef) > 0 and array.size(entryStrategyIds) == array.size(entriesRef)
        for i = array.size(entriesRef) - 1 to 0
            Trade e = array.get(entriesRef, i)
            int sid = array.get(entryStrategyIds, i)
            bool same = sid == stratId and e.direction == direction and e.state == c.SIGNAL_STATE_START
            if same and (bar_index - e.barCreated <= recentBars)
                out := true
                break
    out

// Finds an existing active entry for same direction and approximately the same zone.
// SMC helper
export find_trade_idx(array<Trade> entriesRef, string direction, float top, float btm, float minTick, string activeState) =>
    int found = na
    if array.size(entriesRef) > 0
        for i = array.size(entriesRef) - 1 to 0
            Trade e = array.get(entriesRef, i)
            bool sameZone = math.abs(e.zoneTop - top) < minTick * 2 and math.abs(e.zoneBtm - btm) < minTick * 2
            bool sameDir = e.direction == direction
            bool active = e.state == activeState
            if sameZone and sameDir and active
                found := i
                break
    found

// Unified trade-gap calculator (supports Fixed/Risk/ATR/Hybrid with optional hard floors).
// `mode`: FIXED | RISK | RISK% | ATR | HYBRID (or any other => hybrid max).
export get_trade_gap_unified(float entry, float slRaw, float atrRef, string mode, float fixedTicks = 0.0, float riskPct = 0.0, float atrMult = 0.0, float floorTicks = 0.0, float floorAtrMult = 0.0) =>
    float safeAtr = math.max(atrRef, 0.0)
    float gapFixed = syminfo.mintick * math.max(fixedTicks, 0.0)
    float gapRisk = math.abs(entry - slRaw) * math.max(riskPct, 0.0)
    float gapAtr = safeAtr * math.max(atrMult, 0.0)
    string m = str.upper(mode)
    float baseGap = m == "FIXED" ? gapFixed :
     (m == "RISK" or m == "RISK%") ? gapRisk :
     m == "ATR" ? gapAtr :
     math.max(gapFixed, math.max(gapRisk, gapAtr))
    float minGap = math.max(syminfo.mintick * math.max(floorTicks, 0.0), safeAtr * math.max(floorAtrMult, 0.0))
    math.max(baseGap, minGap)

// Shared builder: raw entry/SL anchor + explicit SL-gap distance -> finalized trade plan.
export build_trade_plan(string direction, float entryRaw, float stopRaw, float rrCfg, float slGapDist = 0.0, float nearestOppTarget = na, bool moveEntryWithGap = false) =>
    TradePlan plan = TradePlan.new()
    bool isBuy = str.upper(direction) == "BUY"
    float tick = math.max(syminfo.mintick, 1e-10)
    float entry = entryRaw
    float stoploss = stopRaw
    float baseRisk = math.max(math.abs(entry - stoploss), tick)
    float rrUsed = rrCfg
    float takeprofit = na
    if rrCfg == 0.0
        if not na(nearestOppTarget)
            takeprofit := nearestOppTarget
            rrUsed := math.max(math.abs(takeprofit - entry) / baseRisk, 0.0)
        else
            rrUsed := 1.0
            takeprofit := isBuy ? (entry + baseRisk) : (entry - baseRisk)
    else
        rrUsed := math.max(rrCfg, 0.1)
        takeprofit := isBuy ? (entry + baseRisk * rrUsed) : (entry - baseRisk * rrUsed)
    float slGap = math.max(slGapDist, 0.0)
    if slGap > 0.0
        if moveEntryWithGap
            float shift = isBuy ? -slGap : slGap
            entry += shift
            stoploss += shift
            takeprofit := not na(takeprofit) ? (takeprofit + shift) : takeprofit
        else
            stoploss := isBuy ? (stoploss - slGap) : (stoploss + slGap)
    float finalRisk = math.max(math.abs(entry - stoploss), tick)
    if rrCfg == 0.0
        if na(takeprofit)
            takeprofit := isBuy ? (entry + finalRisk) : (entry - finalRisk)
            rrUsed := 1.0
        else
            rrUsed := math.max(math.abs(takeprofit - entry) / finalRisk, 0.0)
    else
        takeprofit := isBuy ? (entry + finalRisk * rrUsed) : (entry - finalRisk * rrUsed)
    plan.entry := entry
    plan.stoploss := stoploss
    plan.takeprofit := takeprofit
    plan.rrUsed := rrUsed
    plan.slGap := slGap
    plan.risk := finalRisk
    plan.valid := is_valid_trade_plan(direction, entry, stoploss, takeprofit, tick)
    plan

// Shared post-builder TP cap used by dynamic swing-target models.
export cap_trade_plan_target(TradePlan planIn, string direction, float cappedTarget, float minTarget) =>
    TradePlan plan = planIn
    bool isBuy = str.upper(direction) == "BUY"
    if not na(cappedTarget)
        plan.takeprofit := isBuy ? math.min(plan.takeprofit, cappedTarget) : math.max(plan.takeprofit, cappedTarget)
        plan.takeprofit := isBuy ? math.max(plan.takeprofit, minTarget) : math.min(plan.takeprofit, minTarget)
        plan.rrUsed := math.max(math.abs(plan.takeprofit - plan.entry) / math.max(plan.risk, math.max(syminfo.mintick, 1e-10)), 0.0)
        plan.valid := is_valid_trade_plan(direction, plan.entry, plan.stoploss, plan.takeprofit, math.max(syminfo.mintick, 1e-10))
    plan

// Counts active START trades.
// Shared helper
export count_start_trades(array<Trade> tradesRef, Const c) =>
    int cnt = 0
    if array.size(tradesRef) > 0
        for i = 0 to array.size(tradesRef) - 1
            Trade e = array.get(tradesRef, i)
            if e.state == c.SIGNAL_STATE_START
                cnt += 1
    cnt

// Renders generic strategy stats table using provided row names (bucket labels).
export render_strategy_stats_table(bool show, table t, array<float> statsMatrix, array<string> rowNames, Theme theme, int metricCount, float eq) =>
    if show and barstate.islast
        int rowCount = array.size(rowNames)
        bool showTotalRow = rowCount > 1
        int bodyOffset = showTotalRow ? 1 : 0
        table.clear(t, 0, 0, 4, rowCount + bodyOffset)
        color hdrBg = color.new(theme.COLOR_UI_BG, 60)
        color rowBg = color.new(theme.COLOR_UI_BG, 75)
        color totalBg = color.new(theme.COLOR_UI_BG, 60)
        table.cell(t, 0, 0, "", text_color = theme.COLOR_UI_FG, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 1, 0, "TP", text_color = theme.COLOR_BULLISH, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 2, 0, "SL", text_color = theme.COLOR_BEARISH, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 3, 0, "WR%", text_color = theme.COLOR_UI_FG, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 4, 0, "Gain", text_color = theme.COLOR_UI_ACCENT, bgcolor = hdrBg, text_size = size.tiny)
        float totalTp = 0.0
        float totalSl = 0.0
        float totalGr = 0.0
        float totalNetUsd = 0.0
        if rowCount > 0
            for b = 0 to rowCount - 1
                float tp = array.get(statsMatrix, get_signal_stat_idx(b, 0, metricCount))
                float sl = array.get(statsMatrix, get_signal_stat_idx(b, 1, metricCount))
                float gr = array.get(statsMatrix, get_signal_stat_idx(b, 2, metricCount))
                float netUsd = array.get(statsMatrix, get_signal_stat_idx(b, 3, metricCount))
                totalTp += tp
                totalSl += sl
                totalGr += gr
                totalNetUsd += netUsd
                float n = tp + sl
                float wr = n > 0 ? tp * 100.0 / n : 0.0
                float pct = eq > 0 ? (netUsd / eq * 100.0) : 0.0
                string cellText = str.tostring(math.abs(gr), "0.0") + "R (" + str.tostring(math.ceil(math.abs(pct))) + "%)"
                color cellColor = netUsd >= 0 ? theme.COLOR_BULLISH : theme.COLOR_BEARISH
                int rowY = b + 1 + bodyOffset
                table.cell(t, 0, rowY, array.get(rowNames, b), text_color = theme.COLOR_UI_FG, bgcolor = rowBg, text_size = size.tiny)
                table.cell(t, 1, rowY, str.tostring(int(math.round(tp))), text_color = theme.COLOR_BULLISH, bgcolor = rowBg, text_size = size.tiny)
                table.cell(t, 2, rowY, str.tostring(int(math.round(sl))), text_color = theme.COLOR_BEARISH, bgcolor = rowBg, text_size = size.tiny)
                table.cell(t, 3, rowY, str.tostring(int(math.round(wr))) + "%", text_color = color.new(theme.COLOR_UI_FG, 35), bgcolor = rowBg, text_size = size.tiny)
                table.cell(t, 4, rowY, cellText, text_color = cellColor, bgcolor = rowBg, text_size = size.tiny)
        float totalN = totalTp + totalSl
        float totalWr = totalN > 0 ? totalTp * 100.0 / totalN : 0.0
        float totalPct = eq > 0 ? (totalNetUsd / eq * 100.0) : 0.0
        string totalCellText = str.tostring(math.abs(totalGr), "0.0") + "R (" + str.tostring(math.ceil(math.abs(totalPct))) + "%)"
        color totalCellColor = totalNetUsd >= 0 ? theme.COLOR_BULLISH : theme.COLOR_BEARISH
        if showTotalRow
            table.cell(t, 0, 1, "Total", text_color = theme.COLOR_UI_FG, bgcolor = totalBg, text_size = size.tiny)
            table.cell(t, 1, 1, str.tostring(int(math.round(totalTp))), text_color = theme.COLOR_BULLISH, bgcolor = totalBg, text_size = size.tiny)
            table.cell(t, 2, 1, str.tostring(int(math.round(totalSl))), text_color = theme.COLOR_BEARISH, bgcolor = totalBg, text_size = size.tiny)
            table.cell(t, 3, 1, str.tostring(int(math.round(totalWr))) + "%", text_color = color.new(theme.COLOR_UI_FG, 35), bgcolor = totalBg, text_size = size.tiny)
            table.cell(t, 4, 1, totalCellText, text_color = totalCellColor, bgcolor = totalBg, text_size = size.tiny)
    else if not show and barstate.islast
        int rowCount = array.size(rowNames)
        bool showTotalRow = rowCount > 1
        int bodyOffset = showTotalRow ? 1 : 0
        table.clear(t, 0, 0, 4, rowCount + bodyOffset)
    bool(na)

// Dashboard name compare helper (case-insensitive, Pine v5-safe).
_dashboard_char_rank(string s, int pos) =>
    if pos >= str.length(s)
        -1
    else
        int r = str.pos("abcdefghijklmnopqrstuvwxyz0123456789._- ", str.substring(s, pos, pos + 1))
        r < 0 ? 99 : r

_dashboard_name_less(string a, string b) =>
    string la = str.lower(a)
    string lb = str.lower(b)
    bool done = false
    bool less = false
    for k = 0 to 47
        if not done
            int ra = _dashboard_char_rank(la, k)
            int rb = _dashboard_char_rank(lb, k)
            if ra == -1 or rb == -1
                done := true
                less := ra == -1 and rb != -1
            else if ra != rb
                done := true
                less := ra < rb
    less

// Builds dynamic setup rows from resolved entries and renders TP/SL/WR/+R table.
export render_entries_dashboard_from_entries(bool show, table t, array<Trade> entriesRef, int maxTypes, Theme theme, Const c, int metricCount, float spreadTicks, float eq) =>
    var array<string> rowNames = array.new_string()
    var array<float> statsMatrix = array.new_float()
    array.clear(rowNames)
    array.clear(statsMatrix)
    if array.size(entriesRef) > 0
        for i = 0 to array.size(entriesRef) - 1
            Trade e = array.get(entriesRef, i)
            bool resolved = e.state == c.SIGNAL_STATE_TP or e.state == c.SIGNAL_STATE_SL
            if resolved
                string setup = str.length(e.type) > 0 ? e.type : "N/A"
                int idx = array.indexof(rowNames, setup)
                if idx == -1 and array.size(rowNames) < maxTypes
                    array.push(rowNames, setup)
                    for _ = 0 to metricCount - 1
                        array.push(statsMatrix, 0.0)
                    idx := array.size(rowNames) - 1
                if idx >= 0
                    int base = idx * metricCount
                    float ticksRisked = math.max(1.0, math.abs(e.entry - e.stoploss) / syminfo.mintick)
                    float dollarPerTick = e.riskUsd / ticksRisked
                    float penaltyUsd = spreadTicks * dollarPerTick
                    if e.state == c.SIGNAL_STATE_TP
                        array.set(statsMatrix, base + c.SIG_METRIC_TP, array.get(statsMatrix, base + c.SIG_METRIC_TP) + 1)
                        array.set(statsMatrix, base + c.SIG_METRIC_GAIN_R, array.get(statsMatrix, base + c.SIG_METRIC_GAIN_R) + e.rrValue)
                        array.set(statsMatrix, base + c.SIG_METRIC_GAIN_USD, array.get(statsMatrix, base + c.SIG_METRIC_GAIN_USD) + (e.rrValue * e.riskUsd) - penaltyUsd)
                    else
                        array.set(statsMatrix, base + c.SIG_METRIC_SL, array.get(statsMatrix, base + c.SIG_METRIC_SL) + 1)
                        array.set(statsMatrix, base + c.SIG_METRIC_GAIN_R, array.get(statsMatrix, base + c.SIG_METRIC_GAIN_R) - 1.0)
                        array.set(statsMatrix, base + c.SIG_METRIC_GAIN_USD, array.get(statsMatrix, base + c.SIG_METRIC_GAIN_USD) - e.riskUsd - penaltyUsd)
    // Keep dashboard rows stable/readable by sorting setup names ascending.
    int rowCount = array.size(rowNames)
    if rowCount > 1
        for i = 0 to rowCount - 2
            int minIdx = i
            for j = i + 1 to rowCount - 1
                if _dashboard_name_less(array.get(rowNames, j), array.get(rowNames, minIdx))
                    minIdx := j
            if minIdx != i
                string nameI = array.get(rowNames, i)
                string nameMin = array.get(rowNames, minIdx)
                array.set(rowNames, i, nameMin)
                array.set(rowNames, minIdx, nameI)
                for m = 0 to metricCount - 1
                    int idxI = i * metricCount + m
                    int idxMin = minIdx * metricCount + m
                    float valI = array.get(statsMatrix, idxI)
                    float valMin = array.get(statsMatrix, idxMin)
                    array.set(statsMatrix, idxI, valMin)
                    array.set(statsMatrix, idxMin, valI)
    render_strategy_stats_table(show, t, statsMatrix, rowNames, theme, metricCount, eq)

// Shared dashboard helper: collect visible trades in lookback window.
export collect_dashboard_trades(array<Trade> src, array<Trade> out, bool showPending, bool showStart, bool showTp, bool showSl, int lookbackBars, Const c) =>
    array.clear(out)
    int lb = math.max(1, math.min(lookbackBars, 10000))
    int minX = math.max(last_bar_index - lb, 0)
    if array.size(src) > 0
        for i = 0 to array.size(src) - 1
            Trade e = array.get(src, i)
            bool isPending = e.state == c.SIGNAL_STATE_PENDING
            bool isStart = e.state == c.SIGNAL_STATE_START
            bool isTp = e.state == c.SIGNAL_STATE_TP
            bool isSl = e.state == c.SIGNAL_STATE_SL
            bool visibleState = isPending ? showPending : isStart ? showStart : isTp ? showTp : isSl ? showSl : false
            int anchorX = not na(e.barClosed) ? e.barClosed : e.barCreated
            if visibleState and anchorX >= minX
                array.push(out, e)
    bool(na)

// Shared dashboard stats source: collect all trades in lookback regardless of Display Mode.
export collect_dashboard_stats_trades(array<Trade> src, array<Trade> out, int lookbackBars) =>
    array.clear(out)
    int lb = math.max(1, math.min(lookbackBars, 10000))
    int minX = math.max(last_bar_index - lb, 0)
    if array.size(src) > 0
        for i = 0 to array.size(src) - 1
            Trade e = array.get(src, i)
            int anchorX = not na(e.barClosed) ? e.barClosed : e.barCreated
            if anchorX >= minX
                array.push(out, e)
    bool(na)

// Removes pending trades and their visuals; optionally keeps model-id array in sync.
export prune_pending_trades(array<Trade> tradesRef, Const c, array<int> tradeModelIds = na) =>
    bool hasModelIds = not na(tradeModelIds)
    if array.size(tradesRef) > 0
        for i = array.size(tradesRef) - 1 to 0
            Trade e = array.get(tradesRef, i)
            if e.state == c.SIGNAL_STATE_PENDING
                delete_trade_visuals(e)
                array.remove(tradesRef, i)
                if hasModelIds and array.size(tradeModelIds) > i
                    array.remove(tradeModelIds, i)
    bool(na)

// Draws one compact TP/SL box pair with a center entry line.
draw_signal_plan(int leftX, int rightX, float entry, float stop, float target, bool confirmed, color tpBgConfirmed, color tpBgPending, color slBgConfirmed, color slBgPending, string borderStyle, color entryColor) =>
    color tpBg = confirmed ? tpBgConfirmed : tpBgPending
    color slBg = confirmed ? slBgConfirmed : slBgPending
    float tpTop = math.max(entry, target)
    float tpBtm = math.min(entry, target)
    float slTop = math.max(entry, stop)
    float slBtm = math.min(entry, stop)
    box tpBox = box.new(leftX, tpTop, rightX, tpBtm, bgcolor = tpBg, border_color = tpBg, border_style = borderStyle, border_width = 1, xloc = xloc.bar_index)
    box slBox = box.new(leftX, slTop, rightX, slBtm, bgcolor = slBg, border_color = slBg, border_style = borderStyle, border_width = 1, xloc = xloc.bar_index)
    line entryLine = line.new(leftX, entry, rightX, entry, xloc = xloc.bar_index, color = entryColor, style = line.style_solid, width = 1)
    tpBox.set_text("")
    slBox.set_text("")
    entryLine.set_extend(extend.none)
    [tpBox, slBox, entryLine]

// Draw/update one entry visual by lifecycle state (START/TP/SL).
export draw_trade_visual(Trade e, Const c, Theme theme, EntryVisualCfg vcfg, bool planShow, bool showStart, bool showTp, bool showSl, int perfLookbackBars, int extendBars, string displayMode, string displayMark, int resolvedLineBars) =>
    bool isPending = e.state == c.SIGNAL_STATE_PENDING
    bool isStart = e.state == c.SIGNAL_STATE_START
    bool isTp = e.state == c.SIGNAL_STATE_TP
    bool isSl = e.state == c.SIGNAL_STATE_SL
    bool isLive = isPending or isStart
    bool visibleState = isLive ? showStart : isTp ? showTp : isSl ? showSl : false
    int VISUAL_BARINDEX_SAFE_MAX = 5000
    int lb = math.min(math.max(perfLookbackBars, 1), VISUAL_BARINDEX_SAFE_MAX)
    bool inLookback = bar_index >= math.max(last_bar_index - lb, 0)
    int minX = math.max(bar_index - lb, 0)
    int anchorX = not na(e.barClosed) ? e.barClosed : e.barCreated
    bool entryInsideWindow = anchorX >= minX
    if not planShow or not visibleState or not inLookback or not entryInsideWindow
        delete_trade_visuals(e)
        e.tpBox := na
        e.slBox := na
        e.entryLine := na
        e.tpLine := na
        e.slLine := na
        e.infoLabel := na
        e.visualSig := ""
    else
        int leftX = e.barCreated
        int rightX = not na(e.barClosed) ? e.barClosed : (bar_index + extendBars)
        int liveMinRightBars = 24
        if isLive
            rightX := math.max(rightX, bar_index + liveMinRightBars)
        int safeLeftX = math.max(leftX, minX)
        int safeRightX = math.max(rightX, safeLeftX)
        string sideTxt = str.upper(e.direction)
        bool isBuyEntry = str.upper(e.direction) == "BUY"
        string setupTxt = str.length(e.type) > 0 ? e.type : "N/A"
        string reasonTxt = str.length(e.reason) > 0 ? e.reason : "N/A"
        bool hasRichTooltip = str.contains(reasonTxt, "\ne: ") and str.contains(reasonTxt, "sl_gap:")
        string tt = hasRichTooltip ? reasonTxt : (sideTxt + " (" + setupTxt + ")" +
         "\nentry:" + str.tostring(e.entry, format.mintick) + ", tp:" + str.tostring(e.takeprofit, format.mintick) + ", sl:" + str.tostring(e.stoploss, format.mintick) + ", RR:" + str.tostring(e.rrValue, "#.##") +
         "\n" + reasonTxt)
        int RESOLVED_BG_FADE = 12
        int tpAlphaRaw = isLive ? (e.touched ? vcfg.startTouchedBgAlpha : vcfg.startUntouchedBgAlpha) : isTp ? vcfg.resolvedWinnerBgAlpha : vcfg.resolvedLoserBgAlpha
        int slAlphaRaw = isLive ? (e.touched ? vcfg.startTouchedBgAlpha : vcfg.startUntouchedBgAlpha) : isSl ? vcfg.resolvedWinnerBgAlpha : vcfg.resolvedLoserBgAlpha
        int tpAlpha = isLive ? tpAlphaRaw : math.min(tpAlphaRaw + RESOLVED_BG_FADE, 100)
        int slAlpha = isLive ? slAlphaRaw : math.min(slAlphaRaw + RESOLVED_BG_FADE, 100)
        color tpBg = color.new(theme.COLOR_BULLISH, tpAlpha)
        color slBg = color.new(theme.COLOR_BEARISH, slAlpha)
        color entryColor = isLive ? color.new(theme.COLOR_UI_FG, 0) : (isTp ? color.new(theme.COLOR_BULLISH, vcfg.entryResolvedWinnerAlpha) : isSl ? color.new(theme.COLOR_BEARISH, vcfg.entryResolvedWinnerAlpha) : color.new(theme.COLOR_UI_FG, vcfg.entryResolvedLoserAlpha))
        color tpBorder = isLive ? color.new(theme.COLOR_BULLISH, e.touched ? vcfg.startTouchedBorderAlpha : vcfg.startUntouchedBorderAlpha) : isTp ? color.new(theme.COLOR_BULLISH, vcfg.resolvedWinnerBorderAlpha) : color.new(theme.COLOR_BULLISH, vcfg.resolvedLoserBorderAlpha)
        color slBorder = isLive ? color.new(theme.COLOR_BEARISH, e.touched ? vcfg.startTouchedBorderAlpha : vcfg.startUntouchedBorderAlpha) : isSl ? color.new(theme.COLOR_BEARISH, vcfg.resolvedWinnerBorderAlpha) : color.new(theme.COLOR_BEARISH, vcfg.resolvedLoserBorderAlpha)
        string lineStyleByTouch = e.touched ? line.style_solid : line.style_dotted
        string markerTxt = (isTp or isSl) ? ((isTp ? c.SYM_CHECK : "✕") + " " + setupTxt) : setupTxt
        color markerTxtColor = isBuyEntry ? theme.COLOR_BULLISH : theme.COLOR_BEARISH
        float tpTop = math.max(e.entry, e.takeprofit)
        float tpBtm = math.min(e.entry, e.takeprofit)
        float slTop = math.max(e.entry, e.stoploss)
        float slBtm = math.min(e.entry, e.stoploss)
        float boxTop = math.max(tpTop, slTop)
        float boxBtm = math.min(tpBtm, slBtm)
        float resolvedLinePrice = isTp ? e.takeprofit : isSl ? e.stoploss : e.entry
        bool resolvedOnTopLine = resolvedLinePrice >= e.entry
        float labelPad = math.max(syminfo.mintick * 8.0, math.abs(boxTop - boxBtm) * 0.04)
        float resolvedTextPad = labelPad
        float resolvedTextY = resolvedOnTopLine ? (boxTop + resolvedTextPad) : (boxBtm - resolvedTextPad)
        int centerX = int(math.round((safeLeftX + safeRightX) * 0.5))
        bool useCompactResolved = (isTp or isSl) and displayMode == displayMark
        string visualSigNext = e.state + "|" + str.tostring(useCompactResolved) + "|" + str.tostring(safeLeftX) + "|" + str.tostring(safeRightX) + "|" +
         str.tostring(e.entry, format.mintick) + "|" + str.tostring(e.stoploss, format.mintick) + "|" + str.tostring(e.takeprofit, format.mintick) + "|" +
         color_sig(tpBg) + "|" + color_sig(slBg) + "|" + color_sig(tpBorder) + "|" + color_sig(slBorder) + "|" +
         color_sig(entryColor) + "|" + color_sig(markerTxtColor) + "|" + lineStyleByTouch + "|" + markerTxt + "|" + tt
        bool hasCompactObjs = not na(e.tpBox) and not na(e.slBox) and not na(e.entryLine) and not na(e.infoLabel)
        bool hasRegularObjs = not na(e.tpBox) and not na(e.slBox) and not na(e.entryLine) and not na(e.infoLabel)
        bool canSkip = e.visualSig == visualSigNext and ((useCompactResolved and hasCompactObjs) or ((not useCompactResolved) and hasRegularObjs))
        if not canSkip
            if useCompactResolved
                int tpResolvedAlphaRaw = isTp ? vcfg.compactWinnerBgAlpha : vcfg.compactLoserBgAlpha
                int slResolvedAlphaRaw = isSl ? vcfg.compactWinnerBgAlpha : vcfg.compactLoserBgAlpha
                int tpResolvedAlpha = math.min(tpResolvedAlphaRaw + RESOLVED_BG_FADE, 100)
                int slResolvedAlpha = math.min(slResolvedAlphaRaw + RESOLVED_BG_FADE, 100)
                color tpResolvedBg = color.new(theme.COLOR_BULLISH, tpResolvedAlpha)
                color slResolvedBg = color.new(theme.COLOR_BEARISH, slResolvedAlpha)
                color tpResolvedBorder = color.new(theme.COLOR_BULLISH, isTp ? vcfg.compactWinnerBorderAlpha : vcfg.compactLoserBorderAlpha)
                color slResolvedBorder = color.new(theme.COLOR_BEARISH, isSl ? vcfg.compactWinnerBorderAlpha : vcfg.compactLoserBorderAlpha)
                int markRight = math.max(safeRightX, safeRightX + math.min(resolvedLineBars, 0))
                color entryLineColor = isTp ? color.new(theme.COLOR_BULLISH, 20) : color.new(theme.COLOR_BEARISH, 20)
                if na(e.tpBox) or na(e.slBox)
                    [tpBox, slBox, _] = draw_signal_plan(safeLeftX, safeRightX, e.entry, e.stoploss, e.takeprofit, true, tpResolvedBg, tpResolvedBorder, slResolvedBg, slResolvedBorder, line.style_solid, entryLineColor)
                    e.tpBox := tpBox
                    e.slBox := slBox
                e.tpBox.set_lefttop(safeLeftX, tpTop)
                e.tpBox.set_rightbottom(safeRightX, tpBtm)
                e.tpBox.set_bgcolor(tpResolvedBg)
                e.tpBox.set_border_color(tpResolvedBorder)
                e.tpBox.set_border_style(line.style_dotted)
                e.tpBox.set_border_width(1)
                e.slBox.set_lefttop(safeLeftX, slTop)
                e.slBox.set_rightbottom(safeRightX, slBtm)
                e.slBox.set_bgcolor(slResolvedBg)
                e.slBox.set_border_color(slResolvedBorder)
                e.slBox.set_border_style(line.style_dotted)
                e.slBox.set_border_width(1)
                if not na(e.tpLine)
                    e.tpLine.delete()
                    e.tpLine := na
                if not na(e.slLine)
                    e.slLine.delete()
                    e.slLine := na
                if na(e.entryLine)
                    e.entryLine := line.new(safeLeftX, e.entry, markRight, e.entry, xloc = xloc.bar_index, color = entryLineColor, style = line.style_solid, width = 1)
                else
                    e.entryLine.set_xy1(safeLeftX, e.entry)
                    e.entryLine.set_xy2(markRight, e.entry)
                    e.entryLine.set_color(entryLineColor)
                    e.entryLine.set_style(line.style_solid)
                int tipX = (isTp or isSl) ? centerX : (safeRightX + 1)
                float tipY = (isTp or isSl) ? resolvedTextY : e.entry
                if na(e.infoLabel)
                    e.infoLabel := label.new(tipX, tipY, markerTxt, xloc = xloc.bar_index, style = label.style_none, color = color.new(theme.COLOR_TRANSPARENT, 100), textcolor = markerTxtColor, size = theme.SIZE_TINY, tooltip = tt)
                else
                    e.infoLabel.set_xy(tipX, tipY)
                    e.infoLabel.set_text(markerTxt)
                    e.infoLabel.set_style(label.style_none)
                    e.infoLabel.set_color(color.new(theme.COLOR_TRANSPARENT, 100))
                    e.infoLabel.set_textcolor(markerTxtColor)
                    e.infoLabel.set_tooltip(tt)
            else
                if not na(e.tpLine)
                    e.tpLine.delete()
                    e.tpLine := na
                if not na(e.slLine)
                    e.slLine.delete()
                    e.slLine := na
                if na(e.tpBox) or na(e.slBox) or na(e.entryLine)
                    [tpBox, slBox, entryLine] = draw_signal_plan(safeLeftX, safeRightX, e.entry, e.stoploss, e.takeprofit, true, tpBg, tpBorder, slBg, slBorder, lineStyleByTouch, entryColor)
                    e.tpBox := tpBox
                    e.slBox := slBox
                    e.entryLine := entryLine
                e.tpBox.set_lefttop(safeLeftX, tpTop)
                e.tpBox.set_rightbottom(safeRightX, tpBtm)
                e.tpBox.set_bgcolor(tpBg)
                e.tpBox.set_border_color(tpBorder)
                e.tpBox.set_border_style(lineStyleByTouch)
                e.tpBox.set_border_width(1)
                e.slBox.set_lefttop(safeLeftX, slTop)
                e.slBox.set_rightbottom(safeRightX, slBtm)
                e.slBox.set_bgcolor(slBg)
                e.slBox.set_border_color(slBorder)
                e.slBox.set_border_style(lineStyleByTouch)
                e.slBox.set_border_width(1)
                e.entryLine.set_xy1(safeLeftX, e.entry)
                e.entryLine.set_xy2(safeRightX, e.entry)
                e.entryLine.set_color(entryColor)
                e.entryLine.set_style(lineStyleByTouch)
                int tipX = (isTp or isSl) ? centerX : (safeRightX + 1)
                float tipY = (isTp or isSl) ? resolvedTextY : e.entry
                if na(e.infoLabel)
                    e.infoLabel := label.new(tipX, tipY, markerTxt, xloc = xloc.bar_index, style = label.style_none, color = color.new(theme.COLOR_TRANSPARENT, 100), textcolor = markerTxtColor, size = theme.SIZE_TINY, tooltip = tt)
                else
                    e.infoLabel.set_xy(tipX, tipY)
                    e.infoLabel.set_text(markerTxt)
                    e.infoLabel.set_style(label.style_none)
                    e.infoLabel.set_color(color.new(theme.COLOR_TRANSPARENT, 100))
                    e.infoLabel.set_textcolor(markerTxtColor)
                    e.infoLabel.set_tooltip(tt)
            e.visualSig := visualSigNext
    e

// Returns first non-na timestamp among 3 values.
export get_first_non_na3(int t1, int t2, int t3) =>
    not na(t1) ? t1 : not na(t2) ? t2 : t3

// Resolve dynamic anchor timestamp by priority mode.
export get_dynamic_anchor_ts(string mode, string srFirst, string swingFirst, int obTs, int srTs, int swingTs) =>
    mode == srFirst ? get_first_non_na3(srTs, obTs, swingTs) : mode == swingFirst ? get_first_non_na3(swingTs, obTs, srTs) : get_first_non_na3(obTs, srTs, swingTs)

build_bias_tt_ui(string tfCode, string tfLabel, int msDir, string bull, string bear, Settings cfg) =>
    int pid = get_bias_profile_id(tfCode, cfg)
    string pName = get_bias_profile_name(pid, cfg)
    string tr = msDir == 1 ? "Bullish" : msDir == -1 ? "Bearish" : "Neutral"
    tfLabel + " (" + pName + ") | Trend (MS): " + tr + " | Bias (factors):" +
     "\nBearish: " + (bear == "" ? "-" : bear) +
     "\nBullish: " + (bull == "" ? "-" : bull)

get_bias_cell_bg_color_ui(int biasDir, int absScore, int maxScore, int msDir, Theme theme) =>
    if biasDir != 0
        int lv = get_bias_strength_level(absScore, maxScore)
        get_strength_color(biasDir == 1 ? "bull" : "bear", lv)
    else
        msDir == 1 ? color.new(theme.COLOR_BULLISH, 80) : msDir == -1 ? color.new(theme.COLOR_BEARISH, 80) : color.new(theme.COLOR_NEUTRAL, 85)

export draw_bias_row_under_trades(table t, int rowIdx, ChartContext ctx, Theme theme, Settings cfg, Const c, string rowLabel = "BIAS") =>
    table.cell(t, 0, rowIdx, rowLabel, bgcolor = color.new(theme.COLOR_UI_BG, 55), text_color = color.white, text_size = size.tiny)
    string[] dashTfs = array.from(timeframe.period, ctx.htf1Name, ctx.htf2Name, get_next_higher_tf(ctx.htf2Name))
    for i = 0 to 3
        string tfName = array.get(dashTfs, i)
        int col = i + 1
        if not na(tfName)
            string tfLabel = get_friendly_tf(tfName)
            int biasVal = get_ctx_bias_for_tf(ctx, tfName)
            int scoreVal = get_ctx_bias_score_for_tf(ctx, tfName)
            int maxVal = get_ctx_bias_max_for_tf(ctx, tfName)
            int trendVal = get_ctx_trend_for_tf(ctx, tfName)
            string tx = (str.length(tfLabel) > 2 ? str.substring(tfLabel, 0, 2) : tfLabel) + " " + (trendVal == 1 ? c.SYM_ARR2_UP : trendVal == -1 ? c.SYM_ARR2_DN : c.SYM_DASH)
            [bullTf, bearTf] = get_ctx_bias_factor_texts_for_tf(ctx, tfName)
            string tt = build_bias_tt_ui(tfName, tfLabel, trendVal, bullTf, bearTf, cfg)
            table.cell(t, col, rowIdx, tx, bgcolor = get_bias_cell_bg_color_ui(biasVal, scoreVal, maxVal, trendVal, theme), text_color = color.white, text_size = size.tiny, tooltip = tt)
        else
            table.cell(t, col, rowIdx, "", bgcolor = color.new(theme.COLOR_TRANSPARENT, 100), text_color = color.new(theme.COLOR_UI_FG, 100), text_size = size.tiny)
    bool(na)


// Builds compact bull/bear factor texts from component scores.
export get_bias_factor_texts_from_scores(int sStructure, int sVwap, int sEma50, int sRsi, int sAdx, int sImpulse, int sSupertrend, int sDonchian) =>
    string bull = ""
    string bear = ""
    if sStructure > 0
        bull := bull == "" ? "Structure" : bull + ", Structure"
    else if sStructure < 0
        bear := bear == "" ? "Structure" : bear + ", Structure"
    if sVwap > 0
        bull := bull == "" ? "VWAP" : bull + ", VWAP"
    else if sVwap < 0
        bear := bear == "" ? "VWAP" : bear + ", VWAP"
    if sEma50 > 0
        bull := bull == "" ? "EMA" : bull + ", EMA"
    else if sEma50 < 0
        bear := bear == "" ? "EMA" : bear + ", EMA"
    if sRsi > 0
        bull := bull == "" ? "RSI" : bull + ", RSI"
    else if sRsi < 0
        bear := bear == "" ? "RSI" : bear + ", RSI"
    if sAdx > 0
        bull := bull == "" ? "ADX" : bull + ", ADX"
    else if sAdx < 0
        bear := bear == "" ? "ADX" : bear + ", ADX"
    if sImpulse > 0
        bull := bull == "" ? "Impulse" : bull + ", Impulse"
    else if sImpulse < 0
        bear := bear == "" ? "Impulse" : bear + ", Impulse"
    if sSupertrend > 0
        bull := bull == "" ? "Supertrend" : bull + ", Supertrend"
    else if sSupertrend < 0
        bear := bear == "" ? "Supertrend" : bear + ", Supertrend"
    if sDonchian > 0
        bull := bull == "" ? "Donchian" : bull + ", Donchian"
    else if sDonchian < 0
        bear := bear == "" ? "Donchian" : bear + ", Donchian"
    [bull, bear]

// Returns structure trend state from pivot breaks (-1 bear, 0 neutral, 1 bull).
// Local Helper
export get_trend_state(int len) =>
    float ph = ta.valuewhen(not na(ta.pivothigh(high, len, len)), ta.pivothigh(high, len, len), 0)
    float pl = ta.valuewhen(not na(ta.pivotlow(low, len, len)), ta.pivotlow(low, len, len), 0)
    int result = close > ph ? 1 : close < pl ? -1 : 0
    result

// Candle direction helpers (offset-based).
export is_bull_candle(int off) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    close[safeOff] > open[safeOff]

// Indicator helper
export is_bear_candle(int off) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    close[safeOff] < open[safeOff]

// Divergence helpers (ported from Hung - Indicators).
// Returns positive divergence length vs prior pivot lows.
export div_calc_pos_len(series float src, int cond, int prd, int maxbars, bool dontconfirm, array<int> pl_positions, array<float> pl_vals) =>
    int divlen = 0
    float prsc = close
    int maxSafeOff = 300
    if dontconfirm or src > src[1] or close > close[1]
        int startpoint = dontconfirm ? 0 : 1
        for x = 0 to 9
            int lenRaw = bar_index - array.get(pl_positions, x) + prd
            if array.get(pl_positions, x) == 0 or lenRaw > maxbars or lenRaw > maxSafeOff
                break
            int len = lenRaw
            if len > 5 and ((cond == 1 and src[startpoint] > src[len] and prsc[startpoint] < nz(array.get(pl_vals, x))) or (cond == 2 and src[startpoint] < src[len] and prsc[startpoint] > nz(array.get(pl_vals, x))))
                float slope1 = (src[startpoint] - src[len]) / (len - startpoint)
                float virtual_line1 = src[startpoint] - slope1
                float slope2 = (close[startpoint] - close[len]) / (len - startpoint)
                float virtual_line2 = close[startpoint] - slope2
                bool arrived = true
                for y = 1 + startpoint to len - 1
                    if y > maxSafeOff
                        arrived := false
                        break
                    if src[y] < virtual_line1 or nz(close[y]) < virtual_line2
                        arrived := false
                        break
                    virtual_line1 := virtual_line1 - slope1
                    virtual_line2 := virtual_line2 - slope2
                if arrived
                    divlen := len
                    break
    divlen

// Returns negative divergence length vs prior pivot highs.
// Local Helper
export div_calc_neg_len(series float src, int cond, int prd, int maxbars, bool dontconfirm, array<int> ph_positions, array<float> ph_vals) =>
    int divlen = 0
    float prsc = close
    int maxSafeOff = 300
    if dontconfirm or src < src[1] or close < close[1]
        int startpoint = dontconfirm ? 0 : 1
        for x = 0 to 9
            int lenRaw = bar_index - array.get(ph_positions, x) + prd
            if array.get(ph_positions, x) == 0 or lenRaw > maxbars or lenRaw > maxSafeOff
                break
            int len = lenRaw
            if len > 5 and ((cond == 1 and src[startpoint] < src[len] and prsc[startpoint] > nz(array.get(ph_vals, x))) or (cond == 2 and src[startpoint] > src[len] and prsc[startpoint] < nz(array.get(ph_vals, x))))
                float slope1 = (src[startpoint] - src[len]) / (len - startpoint)
                float virtual_line1 = src[startpoint] - slope1
                float slope2 = (close[startpoint] - nz(close[len])) / (len - startpoint)
                float virtual_line2 = close[startpoint] - slope2
                bool arrived = true
                for y = 1 + startpoint to len - 1
                    if y > maxSafeOff
                        arrived := false
                        break
                    if src[y] > virtual_line1 or nz(close[y]) > virtual_line2
                        arrived := false
                        break
                    virtual_line1 := virtual_line1 - slope1
                    virtual_line2 := virtual_line2 - slope2
                if arrived
                    divlen := len
                    break
    divlen

// Returns [divType, divLen] for a given source series and mode.
// divType: 0 none, 1 reg bull, 2 reg bear, 3 hidden bull, 4 hidden bear.
// Indicator helper
export div_check_all(series float src, string searchdiv, int prd, int maxbars, bool dontconfirm,
 array<int> ph_positions, array<int> pl_positions, array<float> ph_vals, array<float> pl_vals) =>
    int res = 0
    int len = 0
    if searchdiv == "Regular" or searchdiv == "Regular/Hidden"
        int l = div_calc_pos_len(src, 1, prd, maxbars, dontconfirm, pl_positions, pl_vals)
        if l > 0
            res := 1
            len := l
        else
            int l2 = div_calc_neg_len(src, 1, prd, maxbars, dontconfirm, ph_positions, ph_vals)
            if l2 > 0
                res := 2
                len := l2
    if (res == 0) and (searchdiv == "Hidden" or searchdiv == "Regular/Hidden")
        int l4 = div_calc_neg_len(src, 2, prd, maxbars, dontconfirm, ph_positions, ph_vals)
        if l4 > 0
            res := 3
            len := l4
        int l5 = div_calc_pos_len(src, 2, prd, maxbars, dontconfirm, pl_positions, pl_vals)
        if l5 > 0
            res := 4
            len := l5
    [res, len]


// Returns effective minimum bias percentage after profile override.
export get_effective_bias_min_pct(string profile, float customMinAbsPct) =>
    profile == "Scalp" ? 45.0 : profile == "Intraday" ? 35.0 : profile == "Swing" ? 30.0 : customMinAbsPct

// Returns raw factor values used by bias scoring.
export get_bias_factor_values(int len, int emaLen, int rsiLen, int adxLen, float stMult, int stAtrLen, int donchianLen) =>
    int msBias = get_trend_state(len)
    float ema50 = ta.ema(close, emaLen)
    float rsi = ta.rsi(close, rsiLen)
    [_, _, adx] = ta.dmi(adxLen, adxLen)
    float vwapVal = ta.vwap(hlc3)
    [stLine, _] = ta.supertrend(stMult, stAtrLen)
    float dUpper = ta.highest(high, donchianLen)
    float dLower = ta.lowest(low, donchianLen)
    float dMid = (dUpper + dLower) / 2.0
    [msBias, ema50, rsi, adx, vwapVal, stLine, dMid]

// Returns total/max/factor scores for bias confluence.
export get_bias_factor_scores(int msBias, float closeV, float ema50, float rsi, float adx, float vwapV, float stLine, float donchianMid,
 bool useStructure, bool useVwap, bool useEma50, bool useRsi, bool useAdx, bool useRsiImpulse, bool useSupertrend, bool useDonchian,
 int wStructure, int wVwap, int wEma50, int wRsi, int wAdx, int wRsiImpulse, int wSupertrend, int wDonchian,
 float rsiMidline, float rsiImpulseHigh, float rsiImpulseLow, float adxThreshold) =>
    int sStructure = 0
    int sEma50 = 0
    int sRsi = 0
    int sAdx = 0
    int sImpulse = 0
    int sVwap = 0
    int sSupertrend = 0
    int sDonchian = 0
    int maxScore = 0

    if useStructure
        maxScore += wStructure
        sStructure := msBias == 1 ? wStructure : msBias == -1 ? -wStructure : 0
    if useEma50
        maxScore += wEma50
        sEma50 := closeV > ema50 ? wEma50 : closeV < ema50 ? -wEma50 : 0
    if useRsi
        maxScore += wRsi
        sRsi := rsi > rsiMidline ? wRsi : rsi < rsiMidline ? -wRsi : 0
    if useAdx
        maxScore += wAdx
        if adx > adxThreshold
            int lead = sStructure + sEma50 + sRsi
            sAdx := lead > 0 ? wAdx : lead < 0 ? -wAdx : 0
    if useRsiImpulse
        maxScore += wRsiImpulse
        sImpulse := rsi > rsiImpulseHigh ? wRsiImpulse : rsi < rsiImpulseLow ? -wRsiImpulse : 0
    if useVwap
        maxScore += wVwap
        sVwap := closeV > vwapV ? wVwap : closeV < vwapV ? -wVwap : 0
    if useSupertrend
        maxScore += wSupertrend
        sSupertrend := closeV > stLine ? wSupertrend : closeV < stLine ? -wSupertrend : 0
    if useDonchian
        maxScore += wDonchian
        sDonchian := closeV > donchianMid ? wDonchian : closeV < donchianMid ? -wDonchian : 0

    int totalScore = sStructure + sVwap + sEma50 + sRsi + sAdx + sImpulse + sSupertrend + sDonchian
    [totalScore, maxScore, sStructure, sVwap, sEma50, sRsi, sAdx, sImpulse, sSupertrend, sDonchian]

// Returns final bias from confluence values.
export get_trend_data(int len, int emaLen, int rsiLen, int adxLen, float stMult, int stAtrLen, int donchianLen,
 bool useStructure, bool useVwap, bool useEma50, bool useRsi, bool useAdx, bool useRsiImpulse, bool useSupertrend, bool useDonchian,
 int wStructure, int wVwap, int wEma50, int wRsi, int wAdx, int wRsiImpulse, int wSupertrend, int wDonchian,
 float rsiMidline, float rsiImpulseHigh, float rsiImpulseLow, float adxThreshold,
 string profile, float customMinAbsPct) =>
    [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(len, emaLen, rsiLen, adxLen, stMult, stAtrLen, donchianLen)
    [totalScore, maxScore, _, _, _, _, _, _, _, _] = get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
     useStructure, useVwap, useEma50, useRsi, useAdx, useRsiImpulse, useSupertrend, useDonchian,
     wStructure, wVwap, wEma50, wRsi, wAdx, wRsiImpulse, wSupertrend, wDonchian,
     rsiMidline, rsiImpulseHigh, rsiImpulseLow, adxThreshold)
    int absScore = math.abs(totalScore)
    float effMinPct = get_effective_bias_min_pct(profile, customMinAbsPct)
    int minScoreRequired = math.max(1, int(math.ceil(maxScore * effMinPct / 100.0)))
    int bias = absScore >= minScoreRequired ? (totalScore > 0 ? 1 : totalScore < 0 ? -1 : 0) : 0
    [bias, absScore, maxScore, totalScore]

// Returns relative pivot length for target TF in current TF context.
// Higher TF-distance => higher returned pivot length.
export get_dynamic_pivot_length(string current_tf, string target_tf) =>
    int currSec = math.max(get_tf_seconds(current_tf), 1)
    int tgtSec = math.max(get_tf_seconds(target_tf), currSec)
    float ratio = float(tgtSec) / float(currSec)
    int currBase = currSec <= 900 ? 15 : currSec <= 3600 ? 10 : currSec <= 14400 ? 7 : currSec <= 86400 ? 5 : 3
    int raw = int(math.round(float(currBase) * math.sqrt(ratio)))
    int outLen = math.max(currBase + (ratio > 1.0 ? 1 : 0), math.min(raw, 300))
    outLen

// Records one swing point when enabled.
export record_swing_if(bool enabled, array<float> prices, array<int> times, float val, int ts, int maxHistory) =>
    bool added = false
    if enabled and not na(val) and not na(ts)
        bool shouldPush = true
        int n = array.size(times)
        if n > 0
            shouldPush := array.get(times, n - 1) != ts
        if shouldPush
            array.push(prices, val)
            array.push(times, ts)
            if array.size(prices) > maxHistory
                array.shift(prices)
                array.shift(times)
            added := true
    added

// Enforces alternating sequence H->L->H->L by collapsing consecutive same-side swings.
export sanitize_swing_ledgers(array<float> highPrices, array<int> highTimes, array<float> lowPrices, array<int> lowTimes, int maxHistory) =>
    int nH = array.size(highPrices)
    int nL = array.size(lowPrices)
    int nTot = nH + nL
    if nTot > 1
        array<int> mergedTimes = array.new_int()
        array<float> mergedPrices = array.new_float()
        array<bool> mergedIsHigh = array.new_bool()
        int iH = 0
        int iL = 0
        while iH < nH or iL < nL
            bool takeHigh = false
            if iL >= nL
                takeHigh := iH < nH
            else if iH >= nH
                takeHigh := false
            else
                int hT = array.get(highTimes, iH)
                int lT = array.get(lowTimes, iL)
                takeHigh := hT <= lT
            if takeHigh
                array.push(mergedTimes, array.get(highTimes, iH))
                array.push(mergedPrices, array.get(highPrices, iH))
                array.push(mergedIsHigh, true)
                iH += 1
            else
                array.push(mergedTimes, array.get(lowTimes, iL))
                array.push(mergedPrices, array.get(lowPrices, iL))
                array.push(mergedIsHigh, false)
                iL += 1

        array<int> cleanTimes = array.new_int()
        array<float> cleanPrices = array.new_float()
        array<bool> cleanIsHigh = array.new_bool()
        for i = 0 to array.size(mergedTimes) - 1
            int t = array.get(mergedTimes, i)
            float p = array.get(mergedPrices, i)
            bool isHigh = array.get(mergedIsHigh, i)
            int nClean = array.size(cleanTimes)
            if nClean == 0
                array.push(cleanTimes, t)
                array.push(cleanPrices, p)
                array.push(cleanIsHigh, isHigh)
            else
                int li = nClean - 1
                bool lastIsHigh = array.get(cleanIsHigh, li)
                if isHigh != lastIsHigh
                    array.push(cleanTimes, t)
                    array.push(cleanPrices, p)
                    array.push(cleanIsHigh, isHigh)
                else
                    float lastP = array.get(cleanPrices, li)
                    bool replace = isHigh ? p >= lastP : p <= lastP
                    if replace
                        array.set(cleanTimes, li, t)
                        array.set(cleanPrices, li, p)

        array.clear(highPrices)
        array.clear(highTimes)
        array.clear(lowPrices)
        array.clear(lowTimes)
        for i = 0 to array.size(cleanTimes) - 1
            int t = array.get(cleanTimes, i)
            float p = array.get(cleanPrices, i)
            bool isHigh = array.get(cleanIsHigh, i)
            if isHigh
                array.push(highTimes, t)
                array.push(highPrices, p)
            else
                array.push(lowTimes, t)
                array.push(lowPrices, p)
        while array.size(highPrices) > maxHistory
            array.remove(highPrices, 0)
            array.remove(highTimes, 0)
        while array.size(lowPrices) > maxHistory
            array.remove(lowPrices, 0)
            array.remove(lowTimes, 0)
    bool(na)

// Returns dynamic pivot length to mimic target TF swings from current TF bars.
export get_mimic_pivot_len(string currentTf, string targetTf, int pivotLenBase, int pivotLenScalp, int pivotLenIntraday, int pivotLenMultiDay, int pivotLenSwing, int pivotLenPosition) =>
    int currSec = math.max(get_tf_seconds(currentTf), 1)
    int tgtSec = math.max(get_tf_seconds(targetTf), currSec)
    int targetBase = tgtSec <= 300 ? pivotLenScalp :
     tgtSec <= 3600 ? pivotLenIntraday :
     tgtSec <= 14400 ? pivotLenMultiDay :
     tgtSec <= 86400 ? pivotLenSwing : pivotLenPosition
    float ratio = float(tgtSec) / float(currSec)
    int raw = int(math.round(float(targetBase) * math.pow(ratio, 0.55)))
    int outLen = math.max(pivotLenBase + 1, raw)
    outLen


// Core (Bias): TF-aware bias resolver. Routes to the correct get_trend_data() profile based on TF.
// Returns [biasDir, absScore, maxScore, totalScore] — same tuple as get_trend_data().
// Factors enabled per profile are overridden by the BiasToggles flags (AND logic).
// Call from indicator scope with request.security() for HTF data.
export get_bias_data_for_tf(string tf, Settings cfg, BiasToggles tog) =>
    int profileId = get_bias_profile_id(tf, cfg)
    int pivotLen  = get_dynamic_pivot_length(timeframe.period, tf)
    if profileId == cfg.BIAS_PROFILE_REACTIVE
        // Reactive (≤5m): VWAP + RSI + RSI impulse; EMA/ADX/ST/Donchian off.
        get_trend_data(pivotLen, 34, 14, 14, 2.0, 7, 20,
         tog.useStructure, tog.useVwap, false, tog.useRsi, false, tog.useRsiImpulse, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Scalp", 40.0)
    else if profileId == cfg.BIAS_PROFILE_INTRADAY
        // Intraday (≤1h): EMA200 + VWAP + RSI + ADX; impulse/ST/Donchian off.
        get_trend_data(pivotLen, 200, 14, 14, 2.5, 10, 20,
         tog.useStructure, tog.useVwap, tog.useEma, tog.useRsi, tog.useAdx, false, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Intraday", 35.0)
    else if profileId == cfg.BIAS_PROFILE_SWING
        // Swing (≤4h): Supertrend + Donchian + ADX + structure; VWAP/EMA/RSI/impulse off.
        get_trend_data(pivotLen, 200, 14, 14, 3.0, 10, 55,
         tog.useStructure, false, false, false, tog.useAdx, false, tog.useSupertrend, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Swing", 30.0)
    else
        // Macro (>4h): EMA200 + Donchian + structure; VWAP/RSI/ADX/impulse/ST off.
        get_trend_data(pivotLen, 200, 14, 14, 3.0, 10, 55,
         tog.useStructure, false, tog.useEma, false, false, false, false, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Macro", 30.0)

// Core (Bias): Full factor component breakdown for one TF.
// Returns: [total, max, sStructure, sVwap, sEma50, sRsi, sAdx, sImpulse, sSupertrend, sDonchian]
export get_bias_components_for_tf(string tf, Settings cfg, BiasToggles tog) =>
    int profileId = get_bias_profile_id(tf, cfg)
    int pivotLen  = get_dynamic_pivot_length(timeframe.period, tf)
    if profileId == cfg.BIAS_PROFILE_REACTIVE
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 34, 14, 14, 2.0, 7, 20)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, tog.useVwap, false, tog.useRsi, false, tog.useRsiImpulse, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)
    else if profileId == cfg.BIAS_PROFILE_INTRADAY
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 200, 14, 14, 2.5, 10, 20)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, tog.useVwap, tog.useEma, tog.useRsi, tog.useAdx, false, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)
    else if profileId == cfg.BIAS_PROFILE_SWING
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 200, 14, 14, 3.0, 10, 55)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, false, false, false, tog.useAdx, false, tog.useSupertrend, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)
    else
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 200, 14, 14, 3.0, 10, 55)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, false, tog.useEma, false, false, false, false, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)

// request.security-safe wrapper for exported callers.
// Pine disallows request expressions depending on exported function arguments.
get_bias_components_for_tf_default(string tf) =>
    Settings cfg0 = Settings.new()
    BiasToggles tog0 = BiasToggles.new()
    get_bias_components_for_tf(tf, cfg0, tog0)

// Fixed-TF market-structure trend source (independent from dynamic htf1/htf2 mapping).
// This is used to keep dashboard/context trend cells consistent across chart timeframe changes.
get_ms_trend_dir_fixed_expr() =>
    int piv = 5
    float lastHi = ta.valuewhen(not na(ta.pivothigh(high, piv, piv)), ta.pivothigh(high, piv, piv), 0)
    float lastLo = ta.valuewhen(not na(ta.pivotlow(low, piv, piv)), ta.pivotlow(low, piv, piv), 0)
    var int dir = 0
    bool breakUp = not na(lastHi) and close > lastHi
    bool breakDn = not na(lastLo) and close < lastLo
    if breakUp and not breakDn
        dir := 1
    else if breakDn and not breakUp
        dir := -1
    dir

get_ms_trend_dir_fixed_tf(string tfName) =>
    request.security(syminfo.tickerid, tfName, get_ms_trend_dir_fixed_expr(), gaps = barmerge.gaps_off)

get_ms_trend_dir_fixed_tf_cached(string tfName) =>
    var array<string> k = array.new_string()
    var array<int> v = array.new_int()
    int idx = na
    if array.size(k) > 0
        for i = 0 to array.size(k) - 1
            if array.get(k, i) == tfName
                idx := i
                break
    bool refresh = barstate.isfirst or ta.change(time(tfName)) != 0 or na(idx)
    if refresh
        int d = get_ms_trend_dir_fixed_tf(tfName)
        if na(idx)
            array.push(k, tfName)
            array.push(v, d)
            idx := array.size(v) - 1
        else
            array.set(v, idx, d)
    na(idx) ? 0 : array.get(v, idx)

get_bias_components_with_ms_dir_default(string tf) =>
    [tot, maxScore, sStructure, sVwap, sEma50, sRsi, sAdx, sImpulse, sSupertrend, sDonchian] = get_bias_components_for_tf_default(tf)
    int msDir = get_ms_trend_dir_fixed_expr()
    [tot, maxScore, sStructure, sVwap, sEma50, sRsi, sAdx, sImpulse, sSupertrend, sDonchian, msDir]

// Returns relative volume at offset (current volume / SMA volume).
export get_rel_volume(int off, int len) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    avgVol = ta.sma(volume, len)
    base = nz(avgVol[safeOff], volume[safeOff])
    base > 0 ? (volume[safeOff] / base) : 0.0

// Returns latest non-na timestamp among 4 candidates.
export get_latest_time4(int t1, int t2, int t3, int t4) =>
    int out = na
    if not na(t1)
        out := t1
    if not na(t2)
        out := na(out) ? t2 : math.max(out, t2)
    if not na(t3)
        out := na(out) ? t3 : math.max(out, t3)
    if not na(t4)
        out := na(out) ? t4 : math.max(out, t4)
    out

// Returns candle count in `tf` needed to include an anchor timestamp.
export get_candles_to_anchor(string tf, int anchorTs, int minCandles, int maxCandles, int fallbackCandles) =>
    if na(tf)
        fallbackCandles
    else
        int tfSec = math.max(get_tf_seconds(tf), 1)
        int barsRaw = na(anchorTs) ? fallbackCandles : int(math.ceil(math.max(float(time - anchorTs), 0.0) / float(tfSec * 1000))) + 2
        int lo = math.max(minCandles, 1)
        int hi = math.max(maxCandles, lo)
        math.max(lo, math.min(barsRaw, hi))

// Returns current-TF lookback bars derived from HTF2 candle span.
export get_curr_lookback_from_htf2(string htf2, int htf2Candles, int minBars, int maxBars) =>
    if na(htf2)
        math.max(minBars, 1)
    else
        int htf2Sec = math.max(get_tf_seconds(htf2), 1)
        int currSec = math.max(get_tf_seconds(timeframe.period), 1)
        int barsRaw = int(math.ceil(float(htf2Candles * htf2Sec) / float(currSec)))
        int lo = math.max(minBars, 1)
        int hi = math.max(maxBars, lo)
        math.max(lo, math.min(barsRaw, hi))

// Returns true when index is inside the last `lookbackBars` bars.
export is_in_draw_lookback_index(int idx, int lookbackBars) =>
    na(idx) ? false : idx >= math.max(last_bar_index - math.max(lookbackBars, 1), 0)

// Returns true when current bar is inside the last `lookbackBars` bars.
export is_in_draw_lookback_current(int lookbackBars) =>
    is_in_draw_lookback_index(bar_index, lookbackBars)

// Returns cutoff time for recent-window filtering from `lookbackBars`.
export get_recent_time_cutoff(int lookbackBars) =>
    int lb = math.max(lookbackBars, 1)
    bar_index > lb ? time[lb] : 0

// Computes retracement level on a leg.
export get_leg_retracement(float legStart, float legEnd, float ratio, bool isBullLeg) =>
    float rng = math.abs(legEnd - legStart)
    isBullLeg ? (legEnd - rng * ratio) : (legEnd + rng * ratio)

// Scans from start index to current bar and returns the extreme price+index.
export get_range_extreme_from_index(int startIdx, bool findLow, int maxScanBars) =>
    bool ok = false
    int outIdx = na
    float outPrice = na
    int dist = bar_index - startIdx
    if dist >= 0
        int safeMax = math.max(maxScanBars, 1)
        int scan = math.min(dist, safeMax)
        // Runtime-safe cap to avoid historical-buffer overrun in callers with long legs.
        int scanSafe = math.min(scan, 90)
        // Clamp scan start so first accessed offset never exceeds the safe cap.
        int safeStartIdx = math.max(startIdx, bar_index - scanSafe)
        int safeDist = bar_index - safeStartIdx
        float best = findLow ? 10e10 : -10e10
        for j = 0 to safeDist
            int idx = safeStartIdx + j
            int off = bar_index - idx
            float v = findLow ? low[off] : high[off]
            bool better = findLow ? (v <= best) : (v >= best)
            if better
                best := v
                outIdx := idx
                outPrice := v
                ok := true
    [ok, outIdx, outPrice]

// Sessions/time-event helper: selects displayed label text by mode.
export get_time_event_label(string mode, string modeTime, string shortTime, string shortName) =>
    mode == modeTime ? shortTime : shortName


// Resolves one entry state on current bar and returns [updatedEntry, outcomeCode].
// outcomeCode: 1 = TP hit, -1 = SL hit, 2 = invalidated before entry touch, 0 = unchanged.
export resolve_trade_state(Trade e, float hi, float lo, int barIdx, bool requireNextBar, bool slFirstOnDualHit, Const c) =>
    int outcome = 0
    if e.state == c.SIGNAL_STATE_PENDING or e.state == c.SIGNAL_STATE_START
        int age = barIdx - e.barCreated
        if age > 0 and not e.touched
            bool touchedNow = hi >= e.entry and lo <= e.entry
            if touchedNow
                e.touched := true
                e.state := c.SIGNAL_STATE_START
        if not requireNextBar or age > 0
            bool isBuy = e.direction == "Buy"
            bool hitTp = isBuy ? (hi >= e.takeprofit) : (lo <= e.takeprofit)
            bool hitSl = isBuy ? (lo <= e.stoploss) : (hi >= e.stoploss)
            if hitTp and hitSl
                if slFirstOnDualHit
                    hitTp := false
                else
                    hitSl := false
            // If TP/SL is reached before entry is ever touched, invalidate this setup.
            if (hitTp or hitSl) and not e.touched
                outcome := 2
            else if hitSl
                e.state := c.SIGNAL_STATE_SL
                e.barClosed := barIdx
                outcome := -1
            else if hitTp
                e.state := c.SIGNAL_STATE_TP
                e.barClosed := barIdx
                outcome := 1
    [e, outcome]

// ==================== GENERIC UTILITIES ====================

// Helper (Bias): Gate for directional entries against composite bias.
// Returns true when bias is neutral (0) or agrees with direction ("Buy"/"Sell").
export bias_allows_direction(int compositeBias, string direction) =>
    compositeBias == 0 ? true : direction == "Buy" ? compositeBias == 1 : direction == "Sell" ? compositeBias == -1 : false

CANDLE_NONE = 0 // Pattern enum id used by candle-pattern functions.
CANDLE_DOJI = 1 // Pattern enum id used by candle-pattern functions.
CANDLE_BULL_ENG = 2 // Pattern enum id used by candle-pattern functions.
CANDLE_BEAR_ENG = 3 // Pattern enum id used by candle-pattern functions.
CANDLE_HAMMER = 4 // Pattern enum id used by candle-pattern functions.
CANDLE_SHOOTING_STAR = 5 // Pattern enum id used by candle-pattern functions.
CANDLE_BULL_HARAMI = 6 // Pattern enum id used by candle-pattern functions.
CANDLE_BEAR_HARAMI = 7 // Pattern enum id used by candle-pattern functions.
CANDLE_DRAGONFLY_DOJI = 8 // Pattern enum id used by candle-pattern functions.
CANDLE_GRAVESTONE_DOJI = 9 // Pattern enum id used by candle-pattern functions.
CANDLE_PIERCING_LINE = 10 // Pattern enum id used by candle-pattern functions.
CANDLE_DARK_CLOUD = 11 // Pattern enum id used by candle-pattern functions.
CANDLE_TWEEZER_TOP = 12 // Pattern enum id used by candle-pattern functions.
CANDLE_TWEEZER_BOTTOM = 13 // Pattern enum id used by candle-pattern functions.
CANDLE_BULL_MARUBOZU = 14 // Pattern enum id used by candle-pattern functions.
CANDLE_BEAR_MARUBOZU = 15 // Pattern enum id used by candle-pattern functions.
CANDLE_3_WHITE_SOLDIERS = 16 // Pattern enum id used by candle-pattern functions.
CANDLE_3_BLACK_CROWS = 17 // Pattern enum id used by candle-pattern functions.
CANDLE_MORNING_STAR = 18 // Pattern enum id used by candle-pattern functions.
CANDLE_EVENING_STAR = 19 // Pattern enum id used by candle-pattern functions.

// Detects candle pattern enum id from OHLC structure.
export get_candle_pattern(float cpDojiBodyMaxPct, float cpWickBodyMin, float cpWickDominanceMin, float cpOppositeWickMaxBody, float cpEngulfMinPrevBody, float cpTweezerTolAtr, float cpMarubozuMaxWickBody, float cp3lineMinBodyPct) =>
    if not barstate.isconfirmed or bar_index < 2
        CANDLE_NONE
    else
        float body = math.abs(close - open)
        float rng = math.max(high - low, syminfo.mintick)
        float upperWick = high - math.max(open, close)
        float lowerWick = math.min(open, close) - low
        float safeBody = math.max(body, syminfo.mintick)
        float safeUpper = math.max(upperWick, syminfo.mintick)
        float safeLower = math.max(lowerWick, syminfo.mintick)
        // Keep pattern detection lightweight and buffer-safe in local scopes.
        float atrRef = ta.sma(math.max(high - low, syminfo.mintick), 3)
        float tweezerTol = math.max(atrRef * cpTweezerTolAtr, syminfo.mintick * 2)
        float bullWickBodyRatio = lowerWick / safeBody
        float bearWickBodyRatio = upperWick / safeBody
        float bullWickDominance = lowerWick / safeUpper
        float bearWickDominance = upperWick / safeLower
        float body1 = math.abs(close[1] - open[1])
        float body2 = math.abs(close[2] - open[2])
        float rng1 = math.max(high[1] - low[1], syminfo.mintick)
        float rng2 = math.max(high[2] - low[2], syminfo.mintick)
        float upW1 = high[1] - math.max(open[1], close[1])
        float dnW1 = math.min(open[1], close[1]) - low[1]
        float upW2 = high[2] - math.max(open[2], close[2])
        float dnW2 = math.min(open[2], close[2]) - low[2]
        bool doji = body <= rng * cpDojiBodyMaxPct
        bool dragonflyDoji = doji and bullWickBodyRatio >= cpWickBodyMin and bullWickDominance >= cpWickDominanceMin
        bool gravestoneDoji = doji and bearWickBodyRatio >= cpWickBodyMin and bearWickDominance >= cpWickDominanceMin
        bool bullEng = close > open and close[1] < open[1] and open <= close[1] and close >= open[1] and body > math.abs(close[1] - open[1]) * cpEngulfMinPrevBody
        bool bearEng = close < open and close[1] > open[1] and open >= close[1] and close <= open[1] and body > math.abs(close[1] - open[1]) * cpEngulfMinPrevBody
        bool hammer = not doji and bullWickBodyRatio >= cpWickBodyMin and bullWickDominance >= cpWickDominanceMin and upperWick <= body * cpOppositeWickMaxBody and close >= open
        bool shootingStar = not doji and bearWickBodyRatio >= cpWickBodyMin and bearWickDominance >= cpWickDominanceMin and lowerWick <= body * cpOppositeWickMaxBody and close <= open
        bool bullHarami = open[1] > close[1] and close > open and close <= open[1] and close[1] <= open
        bool bearHarami = close[1] > open[1] and open > close and open <= close[1] and open[1] <= close
        bool piercingLine = close[1] < open[1] and close > open and open < close[1] and close > (open[1] + close[1]) / 2
        bool darkCloudCover = close[1] > open[1] and close < open and open > close[1] and close < (open[1] + close[1]) / 2
        bool tweezerTop = close[1] > open[1] and close < open and math.abs(high - high[1]) <= tweezerTol
        bool tweezerBottom = close[1] < open[1] and close > open and math.abs(low - low[1]) <= tweezerTol
        bool bullMarubozu = close > open and (upperWick / safeBody) <= cpMarubozuMaxWickBody and (lowerWick / safeBody) <= cpMarubozuMaxWickBody and (body / rng) >= 0.7
        bool bearMarubozu = close < open and (upperWick / safeBody) <= cpMarubozuMaxWickBody and (lowerWick / safeBody) <= cpMarubozuMaxWickBody and (body / rng) >= 0.7
        bool threeWhiteSoldiers = close > open and close[1] > open[1] and close[2] > open[2] and close > close[1] and close[1] > close[2] and (body / rng) >= cp3lineMinBodyPct and (body1 / rng1) >= cp3lineMinBodyPct and (body2 / rng2) >= cp3lineMinBodyPct and upperWick <= body and upW1 <= body1 and upW2 <= body2 and open <= close[1] and open >= open[1] and open[1] <= close[2] and open[1] >= open[2]
        bool threeBlackCrows = close < open and close[1] < open[1] and close[2] < open[2] and close < close[1] and close[1] < close[2] and (body / rng) >= cp3lineMinBodyPct and (body1 / rng1) >= cp3lineMinBodyPct and (body2 / rng2) >= cp3lineMinBodyPct and lowerWick <= body and dnW1 <= body1 and dnW2 <= body2 and open >= close[1] and open <= open[1] and open[1] >= close[2] and open[1] <= open[2]
        bool morningStar = close[2] < open[2] and math.abs(close[1] - open[1]) <= (math.max(high[1] - low[1], syminfo.mintick) * cpDojiBodyMaxPct) and close > open and close > (open[2] + close[2]) / 2
        bool eveningStar = close[2] > open[2] and math.abs(close[1] - open[1]) <= (math.max(high[1] - low[1], syminfo.mintick) * cpDojiBodyMaxPct) and close < open and close < (open[2] + close[2]) / 2
        bullEng ? CANDLE_BULL_ENG : bearEng ? CANDLE_BEAR_ENG : hammer ? CANDLE_HAMMER : shootingStar ? CANDLE_SHOOTING_STAR : dragonflyDoji ? CANDLE_DRAGONFLY_DOJI : gravestoneDoji ? CANDLE_GRAVESTONE_DOJI : bullHarami ? CANDLE_BULL_HARAMI : bearHarami ? CANDLE_BEAR_HARAMI : piercingLine ? CANDLE_PIERCING_LINE : darkCloudCover ? CANDLE_DARK_CLOUD : tweezerTop ? CANDLE_TWEEZER_TOP : tweezerBottom ? CANDLE_TWEEZER_BOTTOM : bullMarubozu ? CANDLE_BULL_MARUBOZU : bearMarubozu ? CANDLE_BEAR_MARUBOZU : threeWhiteSoldiers ? CANDLE_3_WHITE_SOLDIERS : threeBlackCrows ? CANDLE_3_BLACK_CROWS : morningStar ? CANDLE_MORNING_STAR : eveningStar ? CANDLE_EVENING_STAR : doji ? CANDLE_DOJI : CANDLE_NONE

// Returns readable text for candle pattern enum id.
export get_candle_pattern_text(int p) =>
    p == CANDLE_BULL_ENG ? "Bull Engulfing (bullish reversal/continuation impulse)" :
     p == CANDLE_BEAR_ENG ? "Bear Engulfing (bearish reversal/continuation impulse)" :
     p == CANDLE_HAMMER ? "Hammer (bullish reversal/continuation impulse)" :
     p == CANDLE_SHOOTING_STAR ? "Shooting Star (bearish reversal/continuation impulse)" :
     p == CANDLE_DRAGONFLY_DOJI ? "Dragonfly Doji (bullish reversal/continuation impulse)" :
     p == CANDLE_GRAVESTONE_DOJI ? "Gravestone Doji (bearish reversal/continuation impulse)" :
     p == CANDLE_BULL_HARAMI ? "Bull Harami (bullish reversal/continuation impulse)" :
     p == CANDLE_BEAR_HARAMI ? "Bear Harami (bearish reversal/continuation impulse)" :
     p == CANDLE_PIERCING_LINE ? "Piercing Line (bullish reversal/continuation impulse)" :
     p == CANDLE_DARK_CLOUD ? "Dark Cloud (bearish reversal/continuation impulse)" :
     p == CANDLE_TWEEZER_TOP ? "Tweezer Top (bearish reversal/continuation impulse)" :
     p == CANDLE_TWEEZER_BOTTOM ? "Tweezer Bottom (bullish reversal/continuation impulse)" :
     p == CANDLE_BULL_MARUBOZU ? "Bull Marubozu (bullish reversal/continuation impulse)" :
     p == CANDLE_BEAR_MARUBOZU ? "Bear Marubozu (bearish reversal/continuation impulse)" :
     p == CANDLE_3_WHITE_SOLDIERS ? "3 White Soldiers (bullish reversal/continuation impulse)" :
     p == CANDLE_3_BLACK_CROWS ? "3 Black Crows (bearish reversal/continuation impulse)" :
     p == CANDLE_MORNING_STAR ? "Morning Star (bullish reversal/continuation impulse)" :
     p == CANDLE_EVENING_STAR ? "Evening Star (bearish reversal/continuation impulse)" :
     p == CANDLE_DOJI ? "Doji (neutral)" :
     ""

// Returns directional bias from candle pattern (-1/0/1).
export get_candle_pattern_bias(int p) =>
    p == CANDLE_BULL_ENG or p == CANDLE_HAMMER or p == CANDLE_DRAGONFLY_DOJI or p == CANDLE_BULL_HARAMI or p == CANDLE_PIERCING_LINE or p == CANDLE_TWEEZER_BOTTOM or p == CANDLE_BULL_MARUBOZU or p == CANDLE_3_WHITE_SOLDIERS or p == CANDLE_MORNING_STAR ? 1 :
     p == CANDLE_BEAR_ENG or p == CANDLE_SHOOTING_STAR or p == CANDLE_GRAVESTONE_DOJI or p == CANDLE_BEAR_HARAMI or p == CANDLE_DARK_CLOUD or p == CANDLE_TWEEZER_TOP or p == CANDLE_BEAR_MARUBOZU or p == CANDLE_3_BLACK_CROWS or p == CANDLE_EVENING_STAR ? -1 :
     0

// Applies candle-pattern + relative-volume confluence adjustments to a base signal score.
export apply_candle_pattern_confluence(string direction, string reason, int baseScore, CandlePatternCfg cfg) =>
    int p = get_candle_pattern(cfg.dojiBodyMaxPct, cfg.wickBodyMin, cfg.wickDominanceMin, cfg.oppositeWickMaxBody, cfg.engulfMinPrevBody, cfg.tweezerTolAtr, cfg.marubozuMaxWickBody, cfg.threeLineMinBodyPct)
    int pBias = get_candle_pattern_bias(p)
    bool aligned = (direction == "Buy" and pBias > 0) or (direction == "Sell" and pBias < 0)
    bool isConfluenceEvent = str.contains(reason, "Retest") or str.contains(reason, "Sweep") or str.contains(reason, "respected") or str.contains(reason, "reclaimed") or str.contains(reason, "rejected")
    float volBase = ta.sma(volume, cfg.volLen)
    float relVol = volBase > 0 ? (volume / volBase) : 0.0
    int bonus = (aligned and isConfluenceEvent ? cfg.scorePattern : 0) + (isConfluenceEvent and relVol >= cfg.volMin ? cfg.scoreVolume : 0)
    string pTxt = get_candle_pattern_text(p)
    string outReason = reason
    if bonus > 0 and pTxt != ""
        outReason += " + " + pTxt
    if isConfluenceEvent and relVol >= cfg.volMin
        outReason += " + Vol"
    ConfluenceResult.new(outReason, baseScore + bonus)

get_data_technical_local_tuple() =>
    float atr14 = ta.atr(14)
    float ema9 = ta.ema(close, 9)
    float ema20 = ta.ema(close, 20)
    float ema21 = ta.ema(close, 21)
    float ema50 = ta.ema(close, 50)
    float ema200 = ta.ema(close, 200)
    float sma20 = ta.sma(close, 20)
    float sma200 = ta.sma(close, 200)
    float rsi14 = ta.rsi(close, 14)
    [_, _, adx14] = ta.dmi(14, 14)
    float vwap = ta.vwap(hlc3)
    float stochK = ta.stoch(close, high, low, 14)
    float stochD = ta.sma(stochK, 3)
    float bbBasis = sma20
    float bbDev = 2.0 * ta.stdev(close, 20)
    float bbUpper = bbBasis + bbDev
    float bbLower = bbBasis - bbDev
    float bbBandwidth = bbBasis != 0 ? (bbUpper - bbLower) / bbBasis : 0.0
    float bbBandwidthAvg = ta.sma(bbBandwidth, 20)
    bool bbSqueeze = bbBandwidthAvg > 0 ? bbBandwidth <= bbBandwidthAvg * 0.8 : bbBandwidth < 0.04
    float ichiConv = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2.0
    float ichiBase = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2.0
    float ichiSpanA = (ichiConv + ichiBase) / 2.0
    float ichiSpanB = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2.0
    float ichiCloudTop = math.max(ichiSpanA[26], ichiSpanB[26])
    float ichiCloudBtm = math.min(ichiSpanA[26], ichiSpanB[26])
    bool ichiAboveCloud = close > ichiCloudTop
    bool ichiBelowCloud = close < ichiCloudBtm
    [_, _, macdHist] = ta.macd(close, 12, 26, 9)
    bool macdFlipUp = macdHist > 0 and macdHist[1] <= 0
    bool macdFlipDn = macdHist < 0 and macdHist[1] >= 0
    float fibHi55 = ta.highest(high, 55)
    float fibLo55 = ta.lowest(low, 55)
    float fibRange55 = math.max(fibHi55 - fibLo55, syminfo.mintick)
    float fib618Bull = fibHi55 - fibRange55 * 0.618
    float fib618Bear = fibLo55 + fibRange55 * 0.618
    float fibTolerance = fibRange55 * 0.03
    bool fibNearBull = low <= fib618Bull + fibTolerance and close >= fib618Bull - fibTolerance
    bool fibNearBear = high >= fib618Bear - fibTolerance and close <= fib618Bear + fibTolerance
    bool ema50Up = ema50 > ema50[1]
    bool ema50Down = ema50 < ema50[1]
    [atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down]

// Returns technical-analysis feature tuple for requested timeframe.
// tf="" or current timeframe returns local values, otherwise mapped via request.security.
export get_data_technical(string tf) =>
    bool useLocal = na(tf) or tf == "" or tf == timeframe.period
    if useLocal
        get_data_technical_local_tuple()
    else
        request.security(syminfo.tickerid, tf, get_data_technical_local_tuple())

export get_data_technical_ctx_from_tuple(float atr14, float ema9, float ema20, float ema21, float ema50, float ema200, float sma20, float sma200, float rsi14, float adx14, float vwap, float stochK, float stochD, float bbBasis, float bbDev, float bbUpper, float bbLower, float bbBandwidth, float bbBandwidthAvg, bool bbSqueeze, float ichiConv, float ichiBase, float ichiSpanA, float ichiSpanB, float ichiCloudTop, float ichiCloudBtm, bool ichiAboveCloud, bool ichiBelowCloud, float macdHist, bool macdFlipUp, bool macdFlipDn, float fibHi55, float fibLo55, float fibRange55, float fib618Bull, float fib618Bear, float fibTolerance, bool fibNearBull, bool fibNearBear, bool ema50Up, bool ema50Down) =>
    TechnicalContext out = TechnicalContext.new()
    out.atr14 := atr14
    out.ema9 := ema9
    out.ema20 := ema20
    out.ema21 := ema21
    out.ema50 := ema50
    out.ema200 := ema200
    out.sma20 := sma20
    out.sma200 := sma200
    out.rsi14 := rsi14
    out.adx14 := adx14
    out.vwap := vwap
    out.stochK := stochK
    out.stochD := stochD
    out.bbBasis := bbBasis
    out.bbDev := bbDev
    out.bbUpper := bbUpper
    out.bbLower := bbLower
    out.bbBandwidth := bbBandwidth
    out.bbBandwidthAvg := bbBandwidthAvg
    out.bbSqueeze := bbSqueeze
    out.ichiConv := ichiConv
    out.ichiBase := ichiBase
    out.ichiSpanA := ichiSpanA
    out.ichiSpanB := ichiSpanB
    out.ichiCloudTop := ichiCloudTop
    out.ichiCloudBtm := ichiCloudBtm
    out.ichiAboveCloud := ichiAboveCloud
    out.ichiBelowCloud := ichiBelowCloud
    out.macdHist := macdHist
    out.macdFlipUp := macdFlipUp
    out.macdFlipDn := macdFlipDn
    out.fibHi55 := fibHi55
    out.fibLo55 := fibLo55
    out.fibRange55 := fibRange55
    out.fib618Bull := fib618Bull
    out.fib618Bear := fib618Bear
    out.fibTolerance := fibTolerance
    out.fibNearBull := fibNearBull
    out.fibNearBear := fibNearBear
    out.ema50Up := ema50Up
    out.ema50Down := ema50Down
    out

// Returns technical context object for one timeframe key.
export get_data_technical_ctx(string tf) =>
    [atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down] = get_data_technical(tf)
    get_data_technical_ctx_from_tuple(atr14, ema9, ema20, ema21, ema50, ema200, sma20, sma200, rsi14, adx14, vwap, stochK, stochD, bbBasis, bbDev, bbUpper, bbLower, bbBandwidth, bbBandwidthAvg, bbSqueeze, ichiConv, ichiBase, ichiSpanA, ichiSpanB, ichiCloudTop, ichiCloudBtm, ichiAboveCloud, ichiBelowCloud, macdHist, macdFlipUp, macdFlipDn, fibHi55, fibLo55, fibRange55, fib618Bull, fib618Bear, fibTolerance, fibNearBull, fibNearBear, ema50Up, ema50Down)

// Returns OHLC + candle pattern stream for one HTF slot.
// Uses fixed pattern parameters because request.security expression in exported
// library functions cannot depend on function arguments.
export get_data_htf_candles(string tf) =>
    [o, h, l, c, pat] = if not na(tf)
        request.security(syminfo.tickerid, tf, [open, high, low, close, get_candle_pattern(0.10, 2.0, 2.0, 0.5, 1.0, 0.05, 0.05, 0.60)], gaps = barmerge.gaps_off)
    else
        [na, na, na, na, int(na)]
    [o, h, l, c, pat]

// Builds a centralized chart data context with optional data packs.
export get_data_context(DataCfg cfg, Settings s, BiasToggles tog, StructureSnapshot structure) =>
    ChartContext ctx = ChartContext.new()
    ctx.barIdx := bar_index
    ctx.closeV := close
    ctx.highV := high
    ctx.lowV := low
    ctx.atrV := ta.atr(14)
    [tf1, tf2] = get_htf_pair()
    ctx.htf1Name := tf1
    ctx.htf2Name := tf2

    if cfg.needBias
        [tot0, max0, sStructure0, sVwap0, sEma500, sRsi0, sAdx0, sImpulse0, sSupertrend0, sDonchian0] = get_bias_components_for_tf(timeframe.period, s, tog)
        [tot15, max15, sStructure15, sVwap15, sEma5015, sRsi15, sAdx15, sImpulse15, sSupertrend15, sDonchian15, dir15Remote] = request.security(syminfo.tickerid, "15", get_bias_components_with_ms_dir_default("15"))
        [tot60, max60, sStructure60, sVwap60, sEma5060, sRsi60, sAdx60, sImpulse60, sSupertrend60, sDonchian60, dir60Remote] = request.security(syminfo.tickerid, "60", get_bias_components_with_ms_dir_default("60"))
        [tot240, max240, sStructure240, sVwap240, sEma50240, sRsi240, sAdx240, sImpulse240, sSupertrend240, sDonchian240, dir240Remote] = request.security(syminfo.tickerid, "240", get_bias_components_with_ms_dir_default("240"))
        [tot1d, max1d, sStructure1d, sVwap1d, sEma501d, sRsi1d, sAdx1d, sImpulse1d, sSupertrend1d, sDonchian1d, dir1dRemote] = request.security(syminfo.tickerid, "1D", get_bias_components_with_ms_dir_default("1D"))
        [tot1w, max1w, sStructure1w, sVwap1w, sEma501w, sRsi1w, sAdx1w, sImpulse1w, sSupertrend1w, sDonchian1w, dir1wRemote] = request.security(syminfo.tickerid, "1W", get_bias_components_with_ms_dir_default("1W"))
        int b0 = tot0 > 0 ? 1 : tot0 < 0 ? -1 : 0
        int b15 = tot15 > 0 ? 1 : tot15 < 0 ? -1 : 0
        int b60 = tot60 > 0 ? 1 : tot60 < 0 ? -1 : 0
        int b240 = tot240 > 0 ? 1 : tot240 < 0 ? -1 : 0
        int b1d = tot1d > 0 ? 1 : tot1d < 0 ? -1 : 0
        int b1w = tot1w > 0 ? 1 : tot1w < 0 ? -1 : 0
        ctx.b0 := b0
        ctx.s0 := math.abs(tot0)
        ctx.m0 := math.max(max0, 1)
        ctx.t0 := tot0
        ctx.b15 := b15
        ctx.s15 := math.abs(tot15)
        ctx.m15 := math.max(max15, 1)
        ctx.t15 := tot15
        ctx.b60 := b60
        ctx.s60 := math.abs(tot60)
        ctx.m60 := math.max(max60, 1)
        ctx.t60 := tot60
        ctx.b240 := b240
        ctx.s240 := math.abs(tot240)
        ctx.m240 := math.max(max240, 1)
        ctx.t240 := tot240
        ctx.b1d := b1d
        ctx.s1d := math.abs(tot1d)
        ctx.m1d := math.max(max1d, 1)
        ctx.t1d := tot1d
        ctx.b1w := b1w
        ctx.s1w := math.abs(tot1w)
        ctx.m1w := math.max(max1w, 1)
        ctx.t1w := tot1w
        int currSec = get_tf_seconds(timeframe.period)
        bool use15 = get_tf_seconds("15") > currSec
        bool use60 = get_tf_seconds("60") > currSec
        bool use240 = get_tf_seconds("240") > currSec
        bool use1d = get_tf_seconds("1D") > currSec
        bool use1w = get_tf_seconds("1W") > currSec
        float power = (ctx.b0 * ctx.s0 * 1.0) + (use15 ? (ctx.b15 * ctx.s15 * 1.5) : 0.0) + (use60 ? (ctx.b60 * ctx.s60 * 2.0) : 0.0) + (use240 ? (ctx.b240 * ctx.s240 * 2.5) : 0.0) + (use1d ? (ctx.b1d * ctx.s1d * 3.0) : 0.0) + (use1w ? (ctx.b1w * ctx.s1w * 4.0) : 0.0)
        float powerMax = (ctx.m0 * 1.0) + (use15 ? (ctx.m15 * 1.5) : 0.0) + (use60 ? (ctx.m60 * 2.0) : 0.0) + (use240 ? (ctx.m240 * 2.5) : 0.0) + (use1d ? (ctx.m1d * 3.0) : 0.0) + (use1w ? (ctx.m1w * 4.0) : 0.0)
        float powerPct = powerMax > 0 ? math.min(math.max((power / powerMax) * 100.0, -100.0), 100.0) : 0.0
        ctx.compositeBias := powerPct > 20 ? 1 : powerPct < -20 ? -1 : 0
        ctx.activeBias := ctx.compositeBias != 0 ? ctx.compositeBias : ctx.b0
        ctx.biasVal := ctx.activeBias

        if cfg.initBiasFactorArrays
            ctx.biasBullFactors := array.new_string(6, "")
            ctx.biasBearFactors := array.new_string(6, "")
            [bull0, bear0] = get_bias_factor_texts_from_scores(sStructure0, sVwap0, sEma500, sRsi0, sAdx0, sImpulse0, sSupertrend0, sDonchian0)
            [bull15, bear15] = get_bias_factor_texts_from_scores(sStructure15, sVwap15, sEma5015, sRsi15, sAdx15, sImpulse15, sSupertrend15, sDonchian15)
            [bull60, bear60] = get_bias_factor_texts_from_scores(sStructure60, sVwap60, sEma5060, sRsi60, sAdx60, sImpulse60, sSupertrend60, sDonchian60)
            [bull240, bear240] = get_bias_factor_texts_from_scores(sStructure240, sVwap240, sEma50240, sRsi240, sAdx240, sImpulse240, sSupertrend240, sDonchian240)
            [bull1d, bear1d] = get_bias_factor_texts_from_scores(sStructure1d, sVwap1d, sEma501d, sRsi1d, sAdx1d, sImpulse1d, sSupertrend1d, sDonchian1d)
            [bull1w, bear1w] = get_bias_factor_texts_from_scores(sStructure1w, sVwap1w, sEma501w, sRsi1w, sAdx1w, sImpulse1w, sSupertrend1w, sDonchian1w)
            array.set(ctx.biasBullFactors, 0, bull0)
            array.set(ctx.biasBearFactors, 0, bear0)
            array.set(ctx.biasBullFactors, 1, bull15)
            array.set(ctx.biasBearFactors, 1, bear15)
            array.set(ctx.biasBullFactors, 2, bull60)
            array.set(ctx.biasBearFactors, 2, bear60)
            array.set(ctx.biasBullFactors, 3, bull240)
            array.set(ctx.biasBearFactors, 3, bear240)
            array.set(ctx.biasBullFactors, 4, bull1d)
            array.set(ctx.biasBearFactors, 4, bear1d)
            array.set(ctx.biasBullFactors, 5, bull1w)
            array.set(ctx.biasBearFactors, 5, bear1w)

        if cfg.needMsTrendDirs
            ctx.dir0 := structure.dir0
            ctx.dir15 := dir15Remote
            ctx.dir60 := dir60Remote
            ctx.dir240 := dir240Remote
            ctx.dir1d := dir1dRemote
            ctx.dir1w := dir1wRemote

    if cfg.needMsTrendDirs and not cfg.needBias
        ctx.dir0 := structure.dir0
        ctx.dir15 := get_ms_trend_dir_fixed_tf_cached("15")
        ctx.dir60 := get_ms_trend_dir_fixed_tf_cached("60")
        ctx.dir240 := get_ms_trend_dir_fixed_tf_cached("240")
        ctx.dir1d := get_ms_trend_dir_fixed_tf_cached("1D")
        ctx.dir1w := get_ms_trend_dir_fixed_tf_cached("1W")

    if cfg.needPdPw
        [d_h, d_l, d_t] = request.security(syminfo.tickerid, "D", [high[1], low[1], time[1]], lookahead = barmerge.lookahead_on)
        ctx.pdh := d_h
        ctx.pdl := d_l
        ctx.pdTime := d_t

    if cfg.needPriceRange
        int lb = math.max(cfg.rangeLookbackBars, 1)
        lb := math.min(lb, 15000)
        lb := math.min(lb, bar_index + 1)
        ctx.rangeHigh := ta.highest(high, lb)
        ctx.rangeLow := ta.lowest(low, lb)

    if cfg.needHtfCandles
        [o1, h1, l1, c1, p1] = get_data_htf_candles(tf1)
        [o2, h2, l2, c2, p2] = get_data_htf_candles(tf2)
        ctx.htf1Open := o1
        ctx.htf1High := h1
        ctx.htf1Low := l1
        ctx.htf1Close := c1
        ctx.htf1Pattern := p1
        ctx.htf2Open := o2
        ctx.htf2High := h2
        ctx.htf2Low := l2
        ctx.htf2Close := c2
        ctx.htf2Pattern := p2

    ctx

// Builds a chart context directly from one canonical structure direction value.
export get_data_context_for_dir(DataCfg cfg, Settings s, BiasToggles tog, int dir0) =>
    get_data_context(cfg, s, tog, structure_snapshot_new(dir0))

// ═══════════════════════════════════════════════════════════════════════════
//  CANDLE PATTERN DETECTION & SCORING
//  Reusable by any indicator. All logic centralised here.
// ═══════════════════════════════════════════════════════════════════════════

// ── private helpers ────────────────────────────────────────────────────────
_cp_body(o, c)      => math.abs(c - o)
_cp_rng(h, l)       => h - l
_cp_upWick(o, c, h) => h - math.max(o, c)
_cp_loWick(o, c, l) => math.min(o, c) - l
_cp_bull(o, c)      => c > o
_cp_bear(o, c)      => c < o

// Returns base reliability score (1-5) for a named pattern.
// 5 = 3-candle high conviction  4 = kicker  3 = engulf/marubozu
// 2 = single-bar moderate       1 = context-only (doji/inside/outside)
// Local Helper
export cp_base_score(string n) =>
    bool is5 = n == "Three White Soldiers" or n == "Three Black Crows" or n == "Morning Star" or n == "Evening Star"
    bool is4 = n == "Bullish Kicker" or n == "Bearish Kicker"
    bool is3 = n == "Bullish Engulfing" or n == "Bearish Engulfing" or n == "Bullish Marubozu" or n == "Bearish Marubozu" or n == "Piercing Line" or n == "Dark Cloud Cover"
    bool is2 = n == "Hammer" or n == "Hanging Man" or n == "Shooting Star" or n == "Inverted Hammer" or n == "Bullish Harami" or n == "Bearish Harami" or n == "Tweezer Bottom" or n == "Tweezer Top" or n == "Dragonfly Doji" or n == "Gravestone Doji"
    if is5
        5
    else if is4
        4
    else if is3
        3
    else if is2
        2
    else
        1

// Returns a star-rating string for the given score value.
export cp_score_stars(int score) =>
    if score >= 5
        "★★★★★"
    else if score == 4
        "★★★★☆"
    else if score == 3
        "★★★☆☆"
    else if score == 2
        "★★☆☆☆"
    else
        "★☆☆☆☆"

// Returns body bg color tinted by bias + score tier.
// Uses Theme transparency constants:
//   score 5 → T_NONE (0%) solid   4 → T_LOW (20%)   3 → T_MEDIUM (50%)
//   score 2 → 70%              1 → T_NORMAL (80%) — barely visible
export cp_score_color(int score, int bias, color bull, color bear, Theme th) =>
    if bias == 0
        na
    else
        color base  = bias == 1 ? bull : bear
        int   transp = score >= 5 ? th.T_NONE : score == 4 ? th.T_LOW : score == 3 ? th.T_MEDIUM : score == 2 ? 70 : th.T_NORMAL
        color.new(base, transp)

// Returns border color by conviction tier.
// score ≥5 + any vol  → bright white (top signal)
// score ≥4            → gold  #FFD700 (strong pattern)
// score = 3            → bias-tinted (moderate)
// score ≤2            → na (default thin border, no noise)
export cp_border_color(int score, int bias, color bull, color bear, Theme th) =>
    if score >= 5
        color.new(th.TEXT_COLOR, th.T_NONE)   // white – top conviction
    else if score >= 4
        color.new(#FFD700, th.T_NONE)          // gold – strong signal
    else if score == 3
        color base = bias == 1 ? bull : bear
        color.new(base, th.T_LOW)              // T_LOW = 20% transp (vivid tint)
    else
        na                                     // score ≤2: no border overlay

// Returns wick color based on volume ratio vs average.
// volRatio = volume / sma(volume, N)
//   ≥2.0 → extreme vol → bright white (institutional move)
//   ≥1.5 → high vol    → gold (#FFD700) — confirmed signal
//   ≥1.0 → normal vol  → bias color, T_LOW transp (clear but not loud)
//   < 1.0 → weak vol   → bias color, T_NORMAL transp (dim — caution: fake signal)
// When no pattern (bias==0): returns na so plotcandle uses default
export cp_wick_color(int score  , int bias, float volRatio, color bull, color bear, Theme th) =>
    if bias == 0 or score == 0
        na
    else
        color base = bias == 1 ? bull : bear
        if volRatio >= 2.0
            color.new(th.TEXT_COLOR, th.T_NONE)   // white — extreme volume
        else if volRatio >= 1.5
            color.new(#FFD700, th.T_NONE)          // gold — high volume
        else if volRatio >= 1.0
            color.new(base, th.T_LOW)              // tinted — average volume
        else
            color.new(base, th.T_NORMAL)           // dim — below-average (suspect)

// Runs all 25 pattern detectors using a CandlePatternCfg.
// Returns [patternName, bias, baseScore, confluenceVotes]
//   bias: +1 bullish | -1 bearish | 0 none
//   baseScore: 1-5 reliability of the dominant pattern
//   confluenceVotes: count of patterns voting in dominant direction
export cp_detect(CandlePatternCfg cfg) =>
    float dp  = cfg.dojiBodyMaxPct
    float wb  = cfg.wickBodyMin
    float ow  = cfg.oppositeWickMaxBody
    float em  = cfg.engulfMinPrevBody
    float ta  = cfg.tweezerTolAtr
    float mw  = cfg.marubozuMaxWickBody
    float tb  = cfg.threeLineMinBodyPct
    float sb  = 0.33   // star body max pct (fixed, sensible default)

    // ── 1. Doji ─────────────────────────────────────────────
    float _b0 = _cp_body(open, close)
    float _r0 = _cp_rng(high, low)
    bool d_doji = _r0 > 0 and (_b0 / _r0) <= dp

    // ── 2. Dragonfly Doji ───────────────────────────────────
    float _lo2 = _cp_loWick(open, close, low)
    float _up2 = _cp_upWick(open, close, high)
    bool d_dfly = _r0 > 0 and (_b0 / _r0) <= dp and _lo2 >= wb * math.max(_up2, syminfo.mintick)
    int   b_dfly = d_dfly ? 1 : 0

    // ── 3. Gravestone Doji ──────────────────────────────────
    bool d_grav = _r0 > 0 and (_b0 / _r0) <= dp and _up2 >= wb * math.max(_lo2, syminfo.mintick)
    int  b_grav = d_grav ? -1 : 0

    // ── 4. Hammer ───────────────────────────────────────────
    bool d_hammer = _b0 > 0 and _lo2 >= wb * _b0 and _up2 <= ow * _b0
    int  b_hammer = d_hammer ? 1 : 0

    // ── 5. Inverted Hammer ──────────────────────────────────
    bool d_iHam = _b0 > 0 and _up2 >= wb * _b0 and _lo2 <= ow * _b0
    int  b_iHam = d_iHam ? 1 : 0

    // ── 6. Hanging Man ──────────────────────────────────────
    bool d_hang = _b0 > 0 and _lo2 >= wb * _b0 and _up2 <= 0.3 * _b0
    int  b_hang = d_hang ? -1 : 0

    // ── 7. Shooting Star ────────────────────────────────────
    bool d_shoot = _b0 > 0 and _up2 >= wb * _b0 and _lo2 <= 0.3 * _b0
    int  b_shoot = d_shoot ? -1 : 0

    // ── 8. Bullish Marubozu ─────────────────────────────────
    bool d_mBull = _cp_bull(open, close) and _b0 > 0 and _up2 <= mw * _b0 and _lo2 <= mw * _b0
    int  b_mBull = d_mBull ? 1 : 0

    // ── 9. Bearish Marubozu ─────────────────────────────────
    bool d_mBear = _cp_bear(open, close) and _b0 > 0 and _up2 <= mw * _b0 and _lo2 <= mw * _b0
    int  b_mBear = d_mBear ? -1 : 0

    // ── 10. Bullish Engulfing ───────────────────────────────
    float _pb10 = _cp_body(open[1], close[1])
    bool d_bullEng = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and close >= open[1] and open <= close[1] and _b0 >= em * math.max(_pb10, syminfo.mintick)
    int  b_bullEng = d_bullEng ? 1 : 0

    // ── 11. Bearish Engulfing ───────────────────────────────
    bool d_bearEng = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and close <= open[1] and open >= close[1] and _b0 >= em * math.max(_pb10, syminfo.mintick)
    int  b_bearEng = d_bearEng ? -1 : 0

    // ── 12. Bullish Harami ──────────────────────────────────
    bool d_bullHar = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and high <= math.max(open[1], close[1]) and low >= math.min(open[1], close[1])
    int  b_bullHar = d_bullHar ? 1 : 0

    // ── 13. Bearish Harami ──────────────────────────────────
    bool d_bearHar = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and high <= math.max(open[1], close[1]) and low >= math.min(open[1], close[1])
    int  b_bearHar = d_bearHar ? -1 : 0

    // ── 14. Piercing Line ───────────────────────────────────
    float _mid14 = (open[1] + close[1]) / 2.0
    bool d_pierce = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and open <= close[1] and close > _mid14 and close < open[1]
    int  b_pierce = d_pierce ? 1 : 0

    // ── 15. Dark Cloud Cover ────────────────────────────────
    float _mid15 = (open[1] + close[1]) / 2.0
    bool d_dcc = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and open >= close[1] and close < _mid15 and close > open[1]
    int  b_dcc = d_dcc ? -1 : 0

    // ── 16. Morning Star ────────────────────────────────────
    float _c2b16 = _cp_body(open[2], close[2])
    float _c1b16 = _cp_body(open[1], close[1])
    bool d_morn = _cp_bear(open[2], close[2]) and _c1b16 <= sb * _c2b16 and _cp_bull(open, close) and close > (open[2] + close[2]) / 2.0
    int  b_morn = d_morn ? 1 : 0

    // ── 17. Evening Star ────────────────────────────────────
    float _c2b17 = _cp_body(open[2], close[2])
    float _c1b17 = _cp_body(open[1], close[1])
    bool d_even = _cp_bull(open[2], close[2]) and _c1b17 <= sb * _c2b17 and _cp_bear(open, close) and close < (open[2] + close[2]) / 2.0
    int  b_even = d_even ? -1 : 0

    // ── 18. Three White Soldiers ────────────────────────────
    float _r18a = _cp_rng(high, low)
    float _r18b = _cp_rng(high[1], low[1])
    float _r18c = _cp_rng(high[2], low[2])
    bool _3ws_c0 = _cp_bull(open, close)    and _cp_body(open, close)    >= tb * _r18a
    bool _3ws_c1 = _cp_bull(open[1], close[1]) and _cp_body(open[1], close[1]) >= tb * _r18b
    bool _3ws_c2 = _cp_bull(open[2], close[2]) and _cp_body(open[2], close[2]) >= tb * _r18c
    bool d_3ws = _3ws_c0 and _3ws_c1 and _3ws_c2 and close > close[1] and close[1] > close[2]
    int  b_3ws = d_3ws ? 1 : 0

    // ── 19. Three Black Crows ───────────────────────────────
    bool _3bc_c0 = _cp_bear(open, close)    and _cp_body(open, close)    >= tb * _r18a
    bool _3bc_c1 = _cp_bear(open[1], close[1]) and _cp_body(open[1], close[1]) >= tb * _r18b
    bool _3bc_c2 = _cp_bear(open[2], close[2]) and _cp_body(open[2], close[2]) >= tb * _r18c
    bool d_3bc = _3bc_c0 and _3bc_c1 and _3bc_c2 and close < close[1] and close[1] < close[2]
    int  b_3bc = d_3bc ? -1 : 0

    // ── 20. Bullish Kicker ──────────────────────────────────
    bool d_bKick = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and open >= open[1]
    int  b_bKick = d_bKick ? 1 : 0

    // ── 21. Bearish Kicker ──────────────────────────────────
    bool d_brKick = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and open <= open[1]
    int  b_brKick = d_brKick ? -1 : 0

    // ── 22. Tweezer Bottom ──────────────────────────────────
    float _atr22 = ta.atr(14)
    bool d_tBtm = math.abs(low - low[1]) <= _atr22 * ta and _cp_bear(open[1], close[1]) and _cp_bull(open, close)
    int  b_tBtm = d_tBtm ? 1 : 0

    // ── 23. Tweezer Top ─────────────────────────────────────
    bool d_tTop = math.abs(high - high[1]) <= _atr22 * ta and _cp_bull(open[1], close[1]) and _cp_bear(open, close)
    int  b_tTop = d_tTop ? -1 : 0

    // ── 24. Inside Bar ──────────────────────────────────────
    bool d_inside = high < high[1] and low > low[1]
    int  b_inside = d_inside ? (_cp_bull(open[1], close[1]) ? 1 : -1) : 0

    // ── 25. Outside Bar ─────────────────────────────────────
    bool d_outside = high > high[1] and low < low[1]
    int  b_outside = d_outside ? (_cp_bull(open, close) ? 1 : -1) : 0

    // ── Vote accumulation ───────────────────────────────────
    int bv = (b_dfly==1?1:0) + (b_hammer==1?1:0) + (b_iHam==1?1:0)  + (b_mBull==1?1:0)  + (b_bullEng==1?1:0) + (b_bullHar==1?1:0) + (b_pierce==1?1:0) + (b_morn==1?1:0) + (b_3ws==1?1:0) + (b_bKick==1?1:0) + (b_tBtm==1?1:0) + (b_inside==1?1:0) + (b_outside==1?1:0)
    int rv = (b_grav==-1?1:0) + (b_hang==-1?1:0) + (b_shoot==-1?1:0) + (b_mBear==-1?1:0) + (b_bearEng==-1?1:0) + (b_bearHar==-1?1:0) + (b_dcc==-1?1:0) + (b_even==-1?1:0) + (b_3bc==-1?1:0) + (b_brKick==-1?1:0) + (b_tTop==-1?1:0) + (b_inside==-1?1:0) + (b_outside==-1?1:0)

    int aggBias = bv > rv ? 1 : rv > bv ? -1 : 0
    int votes   = math.max(bv, rv)

    // ── Dominant pattern name (priority: 3-candle > kicker > 2-candle > 1-candle) ─
    string name = d_3ws     and aggBias ==  1 ? "Three White Soldiers" :
                  d_3bc     and aggBias == -1 ? "Three Black Crows"    :
                  d_bKick   and aggBias ==  1 ? "Bullish Kicker"       :
                  d_brKick  and aggBias == -1 ? "Bearish Kicker"       :
                  d_morn    and aggBias ==  1 ? "Morning Star"         :
                  d_even    and aggBias == -1 ? "Evening Star"         :
                  d_bullEng and aggBias ==  1 ? "Bullish Engulfing"    :
                  d_bearEng and aggBias == -1 ? "Bearish Engulfing"    :
                  d_pierce  and aggBias ==  1 ? "Piercing Line"        :
                  d_dcc     and aggBias == -1 ? "Dark Cloud Cover"     :
                  d_mBull   and aggBias ==  1 ? "Bullish Marubozu"     :
                  d_mBear   and aggBias == -1 ? "Bearish Marubozu"     :
                  d_hammer  and aggBias ==  1 ? "Hammer"               :
                  d_hang    and aggBias == -1 ? "Hanging Man"          :
                  d_dfly    and aggBias ==  1 ? "Dragonfly Doji"       :
                  d_grav    and aggBias == -1 ? "Gravestone Doji"      :
                  d_tBtm    and aggBias ==  1 ? "Tweezer Bottom"       :
                  d_tTop    and aggBias == -1 ? "Tweezer Top"          :
                  d_bullHar and aggBias ==  1 ? "Bullish Harami"       :
                  d_bearHar and aggBias == -1 ? "Bearish Harami"       :
                  d_iHam    and aggBias ==  1 ? "Inverted Hammer"      :
                  d_shoot   and aggBias == -1 ? "Shooting Star"        :
                  d_inside                    ? "Inside Bar"           :
                  d_outside                   ? "Outside Bar"          :
                  d_doji                      ? "Doji"                 :
                  "None"

    [name, aggBias, cp_base_score(name), votes]

// Returns line extension bars by source timeframe role.
export get_tf_line_ext_bars(string sourceTf, string tf1Name, string tf2Name, int ltfExt, int htf1Ext, int htf2Ext) =>
    sourceTf == tf2Name ? htf2Ext : sourceTf == tf1Name ? htf1Ext : ltfExt

// Returns line color by source timeframe role.
export get_tf_line_color(string sourceTf, string tf1Name, string tf2Name, color ltfColor, color htf1Color, color htf2Color) =>
    sourceTf == tf2Name ? htf2Color : sourceTf == tf1Name ? htf1Color : ltfColor

export is_life_formed(int state, Const c) =>
    state == c.LIFE_FORMED

export is_life_touched(int state, Const c) =>
    state == c.LIFE_TOUCHED

export is_life_respected(int state, Const c) =>
    state == c.LIFE_RESPECTED

export is_life_reclaimed(int state, Const c) =>
    state == c.LIFE_RECLAIMED

export is_life_broken(int state, Const c) =>
    state == c.LIFE_BROKEN

// Returns next lifecycle state from generic break/touch/respect/reclaim inputs.
export lifecycle_next_state(bool breakCond, bool touchCond, bool respectCond, bool reclaimCond, bool cooldownOk, int prevState, int broken, int touched, int respected, int reclaimed) =>
    int next = prevState
    if breakCond
        next := broken
    else if touchCond and cooldownOk
        next := respectCond ? (prevState == broken ? reclaimed : respected) : touched
    else if reclaimCond and prevState == broken
        next := reclaimed
    next

// Returns next [touchCount, rejectCount] from generic touch/respect flags.
export lifecycle_next_counts(int touchCount, int rejectCount, bool touchCond, bool respectCond, bool cooldownOk) =>
    int t = math.max(touchCount, 0)
    int r = math.max(rejectCount, 0)
    if touchCond and cooldownOk
        t += 1
        if respectCond
            r += 1
    [t, r]

// Returns lifecycle line style mapped from state.
export lifecycle_line_style(int state, int touched, int broken, int reclaimed, string formedStyle, string touchedStyle, string brokenStyle, string reclaimedStyle) =>
    state == broken ? brokenStyle : state == touched ? touchedStyle : state == reclaimed ? reclaimedStyle : formedStyle

// Returns lifecycle alpha mapped from state.
export lifecycle_alpha(int state, int touched, int respected, int reclaimed, int broken, int formedAlpha, int touchedAlpha, int respectedAlpha, int reclaimedAlpha, int brokenAlpha) =>
    state == broken ? brokenAlpha :
     state == reclaimed ? reclaimedAlpha :
     state == respected ? respectedAlpha :
     state == touched ? touchedAlpha :
     formedAlpha
