    int LIFE_INVALID = 5
    int LIFE_RESOLVED = 6

CONST = Const.new()

// Generic swing point payload.
export type Swing
    int id = 0
    string tfName = ""
    int tfIndex = 0
    int currentBarIndex = na
    float price
    int time
    int barIndex
    string tf
    bool isSwingHigh
    line swingLine = na
    bool mitigated = false

// High/low swing pair used by market-structure traversal.
export type SwingLeg
    int id = 0
    string tfName = ""
    int tfIndex = 0
    int highSwingId = na
    int lowSwingId = na
    int startBarIndex = na
    int endBarIndex = na
    int startTime = na
    int endTime = na
    float highPrice = na
    float lowPrice = na
    int dir = 0
    bool active = true
    string breakType = ""
    int breakTime = na
    float quality = na

