    bool useVolume = true
    float minRelVolume = 1.1
    bool useImpulse = false
    float minBodyAtr = 0.35
    float sizeStrongMult = 1.8
    float volStrong = 1.5
    float impStrong = 1.0
    float dispMin = 0.65
