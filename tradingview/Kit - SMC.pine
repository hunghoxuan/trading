    int scoreSizeStrong = 2
    int scoreSizeBase = 1
    int scoreVolStrong = 2
    int scoreVolBase = 1
    int scoreImpStrong = 2
    int scoreImpBase = 1
    int scoreDisp = 1

export type Const
    string OB_CLASS_ORIGIN = "O"
    string OB_CLASS_DECISIONAL = "D"
    string OB_CLASS_EXTREME = "X"
    string OB_CLASS_MITIGATION = "M"
