// Returns/updates swing references from source TF (high+low pivots merged by time).
// Output is persistent per sourceTf in current script instance.
export get_swingrefs_from_tf(string sourceTf, int maxCount) =>
    var string _srTf = ""
    var array<SwingRef> _srRefs = array.new<SwingRef>()
    var int _lastHighTs = na
    var int _lastLowTs = na
    string tf = sourceTf == "" ? timeframe.period : sourceTf
    int piv = 5
    int cap = math.max(maxCount, 1)
    if tf != _srTf
        _srTf := tf
        _lastHighTs := na
        _lastLowTs := na
        array.clear(_srRefs)

    float ph = request.security(syminfo.tickerid, tf, ta.pivothigh(high, piv, piv), gaps = barmerge.gaps_off)
    int phT = request.security(syminfo.tickerid, tf, not na(ta.pivothigh(high, piv, piv)) ? time[piv] : na, gaps = barmerge.gaps_off)
    float pl = request.security(syminfo.tickerid, tf, ta.pivotlow(low, piv, piv), gaps = barmerge.gaps_off)
    int plT = request.security(syminfo.tickerid, tf, not na(ta.pivotlow(low, piv, piv)) ? time[piv] : na, gaps = barmerge.gaps_off)

    if not na(ph) and not na(phT) and (na(_lastHighTs) or phT > _lastHighTs)
        int msPerBarH = math.max(time - time[1], 1)
        int barsAgoH = int(math.round((time - phT) / msPerBarH))
        int idxH = bar_index - barsAgoH
        idxH := idxH >= 0 and idxH <= bar_index + 500 ? idxH : na
        if not na(idxH)
            array.push(_srRefs, SwingRef.new(idxH, ph, true))
            _lastHighTs := phT
    if not na(pl) and not na(plT) and (na(_lastLowTs) or plT > _lastLowTs)
        int msPerBarL = math.max(time - time[1], 1)
        int barsAgoL = int(math.round((time - plT) / msPerBarL))
        int idxL = bar_index - barsAgoL
        idxL := idxL >= 0 and idxL <= bar_index + 500 ? idxL : na
        if not na(idxL)
            array.push(_srRefs, SwingRef.new(idxL, pl, false))
            _lastLowTs := plT

    while array.size(_srRefs) > cap
        array.shift(_srRefs)
    _srRefs

// Returns nearest swing top above currentPrice and nearest swing bottom below currentPrice from source TF.
export get_first_swingrefs_around_price(string sourceTf, int maxCount, float currentPrice) =>
    array<SwingRef> refs = get_swingrefs_from_tf(sourceTf, maxCount)
    SwingRef topRef = na
    SwingRef btmRef = na
    float topDist = na
    float btmDist = na
    if array.size(refs) > 0 and not na(currentPrice)
        for i = 0 to array.size(refs) - 1
            SwingRef s = array.get(refs, i)
            if s.isHigh and s.price > currentPrice
                float dTop = s.price - currentPrice
                if na(topDist) or dTop < topDist
                    topDist := dTop
                    topRef := s
            if (not s.isHigh) and s.price < currentPrice
                float dBtm = currentPrice - s.price
                if na(btmDist) or dBtm < btmDist
                    btmDist := dBtm
                    btmRef := s
    [topRef, btmRef]

// Returns a standard candle-pattern config built from shared Settings defaults.
// SMC helper
export get_candle_pattern_cfg(Settings s, int scorePattern, int scoreVolume) =>
    CandlePatternCfg.new(
     dojiBodyMaxPct = s.CP_DOJI_PCT,
     wickBodyMin = s.CP_WICK_BODY,
     wickDominanceMin = s.CP_WICK_DOMINANCE,
     oppositeWickMaxBody = s.CP_OPPOSITE_WICK_MAX_BODY,
     engulfMinPrevBody = s.CP_ENGULF_MIN,
     tweezerTolAtr = s.CP_TWEEZER_ATR,
     marubozuMaxWickBody = s.CP_MARUBOZU_WICK,
     threeLineMinBodyPct = s.CP_3LINE_BODY,
     volLen = s.CP_VOL_LEN,
     volMin = s.CP_VOL_MIN,
     scorePattern = scorePattern,
     scoreVolume = scoreVolume)

// Per-indicator toggle flags for each bias factor used in get_bias_data_for_tf().
// All flags default true so callers only need to override what they want to disable.
export type BiasToggles
    bool useStructure   = true  // Include market structure direction in scoring.
    bool useVwap        = true  // Include VWAP position in scoring.
    bool useEma         = true  // Include EMA-50/200 in scoring.
    bool useRsi         = true  // Include RSI midpoint in scoring.
    bool useAdx         = true  // Include ADX trend strength in scoring.
    bool useRsiImpulse  = true  // Include RSI impulse cross in scoring.
    bool useSupertrend  = true  // Include Supertrend direction in scoring.
    bool useDonchian    = true  // Include Donchian channel position in scoring.

// Returns strength background color by type and level (1..5).
export get_strength_color(string p_type, int s = 3) =>
    p_type == "bull" ? (s >= 5 ? #004D40 : s == 4 ? #00695C : s == 3 ? #00897B : s == 2 ? #26A69A : #80CBC4) : p_type == "bear" ? (s >= 5 ? #B71C1C : s == 4 ? #C62828 : s == 3 ? #D32F2F : s == 2 ? #EF5350 : #EF9A9A) : color.new(color.gray, 0)

// Returns side-prefixed text for buy/sell tooltip or label use.
export tt_side(bool isBuy, string reason) =>
    (isBuy ? "BUY • " : "SELL • ") + reason

// Returns dynamic confirmation window based on timeframe and event type.
export get_dynamic_confirmation_window_bars(string tfPeriod, bool isSweep, int sweepMinBars, int sweepMaxBars, int breakMinBars, int breakMaxBars) =>
    int tfSec = timeframe.in_seconds(tfPeriod)
    int raw = isSweep ? (tfSec <= 900 ? 6 : tfSec <= 3600 ? 8 : tfSec <= 14400 ? 6 : tfSec <= 86400 ? 4 : 3) : (tfSec <= 900 ? 20 : tfSec <= 3600 ? 24 : tfSec <= 14400 ? 18 : tfSec <= 86400 ? 12 : 8)
    int minBars = isSweep ? sweepMinBars : breakMinBars
    int maxBars = isSweep ? sweepMaxBars : breakMaxBars
    math.max(minBars, math.min(raw, maxBars))

// Returns flattened signal stats matrix index.
export get_signal_stat_idx(int typeIdx, int metricIdx, int metricCount) =>
    typeIdx * metricCount + metricIdx

// Returns true when entry plan values are valid for direction and minimum tick distance.
export is_valid_trade_plan(string direction, float entry, float stoploss, float takeprofit, float tickSize) =>
    bool isBuy = direction == "Buy"
    bool finite = not na(entry) and not na(stoploss) and not na(takeprofit)
    bool sideOk = isBuy ? (stoploss < entry and takeprofit > entry) : (stoploss > entry and takeprofit < entry)
    bool distOk = math.abs(entry - stoploss) >= tickSize and math.abs(takeprofit - entry) >= tickSize
    finite and sideOk and distOk

// Builds a shared Trade object only when the plan is valid; otherwise returns na.
export create_trade_if_valid(string direction, string type, float zoneTop, float zoneBtm, float entry, float stoploss, float takeprofit, float rrValue, int barCreated, string reason, int scoreVal, Const c, float tickSize) =>
    Trade out = na
    if is_valid_trade_plan(direction, entry, stoploss, takeprofit, tickSize)
        out := Trade.new(direction, type, zoneTop, zoneBtm, entry, stoploss, takeprofit, rrValue, barCreated, int(na), reason, scoreVal, c.SIGNAL_STATE_PENDING, na, na, na, na, na)
    out

// Applies TP/SL/+R stats update from one outcome code: 1=TP, -1=SL, 0=none.
export apply_trade_outcome_stats(array<float> stats, int bucketIdx, int outcome, float rrValue, Const c, int metricCount) =>
    int idxSl = get_signal_stat_idx(bucketIdx, c.SIG_METRIC_SL, metricCount)
    int idxTp = get_signal_stat_idx(bucketIdx, c.SIG_METRIC_TP, metricCount)
    int idxGr = get_signal_stat_idx(bucketIdx, c.SIG_METRIC_GAIN_R, metricCount)
    if outcome < 0
        array.set(stats, idxSl, array.get(stats, idxSl) + 1)
        array.set(stats, idxGr, array.get(stats, idxGr) - 1)
    else if outcome > 0
        array.set(stats, idxTp, array.get(stats, idxTp) + 1)
        array.set(stats, idxGr, array.get(stats, idxGr) + rrValue)
    bool(na)

// Returns true if there is an active START entry for strategy+direction.
// Indicator helper
export has_active_trade_for_strategy(array<Trade> entriesRef, array<int> entryStrategyIds, int stratId, string direction, Const c) =>
    bool out = false
    if array.size(entriesRef) > 0 and array.size(entryStrategyIds) == array.size(entriesRef)
        for i = array.size(entriesRef) - 1 to 0
            Trade e = array.get(entriesRef, i)
            int sid = array.get(entryStrategyIds, i)
            if sid == stratId and e.direction == direction and e.state == c.SIGNAL_STATE_START
                out := true
                break
    out

// Returns true if there was a recent START entry for strategy+direction in the recentBars window.
// Indicator helper
export has_recent_active_trade_for_strategy(array<Trade> entriesRef, array<int> entryStrategyIds, int stratId, string direction, int recentBars, Const c) =>
    bool out = false
    if array.size(entriesRef) > 0 and array.size(entryStrategyIds) == array.size(entriesRef)
        for i = array.size(entriesRef) - 1 to 0
            Trade e = array.get(entriesRef, i)
            int sid = array.get(entryStrategyIds, i)
            bool same = sid == stratId and e.direction == direction and e.state == c.SIGNAL_STATE_START
            if same and (bar_index - e.barCreated <= recentBars)
                out := true
                break
    out

// Finds an existing active entry for same direction and approximately the same zone.
// SMC helper
export find_trade_idx(array<Trade> entriesRef, string direction, float top, float btm, float minTick, string activeState) =>
    int found = na
    if array.size(entriesRef) > 0
        for i = array.size(entriesRef) - 1 to 0
            Trade e = array.get(entriesRef, i)
            bool sameZone = math.abs(e.zoneTop - top) < minTick * 2 and math.abs(e.zoneBtm - btm) < minTick * 2
            bool sameDir = e.direction == direction
            bool active = e.state == activeState
            if sameZone and sameDir and active
                found := i
                break
    found

// Unified trade-gap calculator (supports Fixed/Risk/ATR/Hybrid with optional hard floors).
// `mode`: FIXED | RISK | RISK% | ATR | HYBRID (or any other => hybrid max).
export get_trade_gap_unified(float entry, float slRaw, float atrRef, string mode, float fixedTicks = 0.0, float riskPct = 0.0, float atrMult = 0.0, float floorTicks = 0.0, float floorAtrMult = 0.0) =>
    float safeAtr = math.max(atrRef, 0.0)
    float gapFixed = syminfo.mintick * math.max(fixedTicks, 0.0)
    float gapRisk = math.abs(entry - slRaw) * math.max(riskPct, 0.0)
    float gapAtr = safeAtr * math.max(atrMult, 0.0)
    string m = str.upper(mode)
    float baseGap = m == "FIXED" ? gapFixed :
     (m == "RISK" or m == "RISK%") ? gapRisk :
     m == "ATR" ? gapAtr :
     math.max(gapFixed, math.max(gapRisk, gapAtr))
    float minGap = math.max(syminfo.mintick * math.max(floorTicks, 0.0), safeAtr * math.max(floorAtrMult, 0.0))
    math.max(baseGap, minGap)

// Counts active START trades.
// Shared helper
export count_start_trades(array<Trade> tradesRef, Const c) =>
    int cnt = 0
    if array.size(tradesRef) > 0
        for i = 0 to array.size(tradesRef) - 1
            Trade e = array.get(tradesRef, i)
            if e.state == c.SIGNAL_STATE_START
                cnt += 1
    cnt

// Finds nearest swing target above and below reference price across LTF/HTF stores.
// Shared helper
export get_nearest_swing_targets_from_tf_data(TFData ltfData, TFData htf1Data, TFData htf2Data, float refPrice) =>
    float above = na
    float below = na
    if array.size(ltfData.swingHighPrices) > 0
        for i = 0 to array.size(ltfData.swingHighPrices) - 1
            float p = array.get(ltfData.swingHighPrices, i)
            if p > refPrice and (na(above) or p < above)
                above := p
    if array.size(htf1Data.swingHighPrices) > 0
        for i = 0 to array.size(htf1Data.swingHighPrices) - 1
            float p = array.get(htf1Data.swingHighPrices, i)
            if p > refPrice and (na(above) or p < above)
                above := p
    if array.size(htf2Data.swingHighPrices) > 0
        for i = 0 to array.size(htf2Data.swingHighPrices) - 1
            float p = array.get(htf2Data.swingHighPrices, i)
            if p > refPrice and (na(above) or p < above)
                above := p
    if array.size(ltfData.swingLowPrices) > 0
        for i = 0 to array.size(ltfData.swingLowPrices) - 1
            float p = array.get(ltfData.swingLowPrices, i)
            if p < refPrice and (na(below) or p > below)
                below := p
    if array.size(htf1Data.swingLowPrices) > 0
        for i = 0 to array.size(htf1Data.swingLowPrices) - 1
            float p = array.get(htf1Data.swingLowPrices, i)
            if p < refPrice and (na(below) or p > below)
                below := p
    if array.size(htf2Data.swingLowPrices) > 0
        for i = 0 to array.size(htf2Data.swingLowPrices) - 1
            float p = array.get(htf2Data.swingLowPrices, i)
            if p < refPrice and (na(below) or p > below)
                below := p
    [above, below]


// Returns minimum right X for one zone after width clamping.
// UI Kit
export get_pdarray_min_right_idx(PDArray z, int desiredRight, int minWidthBars) =>
    math.max(desiredRight, z.barStart + minWidthBars)

// Returns first non-na timestamp among 3 values.
export get_first_non_na3(int t1, int t2, int t3) =>
    not na(t1) ? t1 : not na(t2) ? t2 : t3

// Resolve dynamic anchor timestamp by priority mode.
export get_dynamic_anchor_ts(string mode, string srFirst, string swingFirst, int obTs, int srTs, int swingTs) =>
    mode == srFirst ? get_first_non_na3(srTs, obTs, swingTs) : mode == swingFirst ? get_first_non_na3(swingTs, obTs, srTs) : get_first_non_na3(obTs, srTs, swingTs)

// Returns visible high/low range used by HTF mini-chart labels.
export get_htf_range(HTF_Data store) =>
    float rHi = na
    float rLo = na
    if store.hl.size() > 0
        for i = 0 to store.hl.size() - 1
            float v = store.hl.get(i)
            if not na(v)
                rHi := na(rHi) ? v : math.max(rHi, v)
                rLo := na(rLo) ? v : math.min(rLo, v)
    [rHi, rLo]

// Converts timeframe string to seconds.
export get_tf_seconds(string tf_period) =>
    tf_period == "1" ? 60 :
     tf_period == "5" ? 300 :
     tf_period == "15" ? 900 :
     tf_period == "60" ? 3600 :
     tf_period == "240" ? 14400 :
     tf_period == "1D" or tf_period == "D" ? 86400 :
     tf_period == "1W" or tf_period == "W" ? 604800 :
     tf_period == "1M" or tf_period == "M" ? 2592000 :
     (not na(str.tonumber(tf_period)) ? int(str.tonumber(tf_period)) * 60 : timeframe.in_seconds(timeframe.period))

// Returns candidate higher timeframes (> current TF, max 2 from [15m,4h,1D,1W]).
export get_htfs() =>
    string[] base_tfs = array.from("15", "240", "1D", "1W")
    string[] valid_tfs = array.new_string(0)
    int current_tf_sec = timeframe.in_seconds(timeframe.period)
    for tf in base_tfs
        if timeframe.in_seconds(tf) > current_tf_sec
            array.push(valid_tfs, tf)
    string[] result_tfs = array.new_string(0)
    if array.size(valid_tfs) > 0
        array.push(result_tfs, array.get(valid_tfs, 0))
    if array.size(valid_tfs) > 1
        array.push(result_tfs, array.get(valid_tfs, 1))
    result_tfs

// Returns top-2 higher timeframes as a fixed pair [htf1, htf2].
export get_htf_pair() =>
    int currSec = get_tf_seconds(timeframe.period)
    string tf1 = na
    string tf2 = na
    // Override map:
    // 1m  -> 5m, 15m
    // 1h  -> 1D, 1W
    if currSec <= 60
        tf1 := "5"
        tf2 := "15"
    else if currSec == 3600
        tf1 := "1D"
        tf2 := "1W"
    else
        string[] tfs = get_htfs()
        tf1 := array.size(tfs) > 0 ? array.get(tfs, 0) : na
        tf2 := array.size(tfs) > 1 ? array.get(tfs, 1) : na
    [tf1, tf2]

// Builds compact bull/bear factor texts from component scores.
export get_bias_factor_texts_from_scores(int sStructure, int sVwap, int sEma50, int sRsi, int sAdx, int sImpulse, int sSupertrend, int sDonchian) =>
    string bull = ""
    string bear = ""
    if sStructure > 0
        bull := bull == "" ? "Structure" : bull + ", Structure"
    else if sStructure < 0
        bear := bear == "" ? "Structure" : bear + ", Structure"
    if sVwap > 0
        bull := bull == "" ? "VWAP" : bull + ", VWAP"
    else if sVwap < 0
        bear := bear == "" ? "VWAP" : bear + ", VWAP"
    if sEma50 > 0
        bull := bull == "" ? "EMA" : bull + ", EMA"
    else if sEma50 < 0
        bear := bear == "" ? "EMA" : bear + ", EMA"
    if sRsi > 0
        bull := bull == "" ? "RSI" : bull + ", RSI"
    else if sRsi < 0
        bear := bear == "" ? "RSI" : bear + ", RSI"
    if sAdx > 0
        bull := bull == "" ? "ADX" : bull + ", ADX"
    else if sAdx < 0
        bear := bear == "" ? "ADX" : bear + ", ADX"
    if sImpulse > 0
        bull := bull == "" ? "Impulse" : bull + ", Impulse"
    else if sImpulse < 0
        bear := bear == "" ? "Impulse" : bear + ", Impulse"
    if sSupertrend > 0
        bull := bull == "" ? "Supertrend" : bull + ", Supertrend"
    else if sSupertrend < 0
        bear := bear == "" ? "Supertrend" : bear + ", Supertrend"
    if sDonchian > 0
        bull := bull == "" ? "Donchian" : bull + ", Donchian"
    else if sDonchian < 0
        bear := bear == "" ? "Donchian" : bear + ", Donchian"
    [bull, bear]

// Returns structure trend state from pivot breaks (-1 bear, 0 neutral, 1 bull).
// Local Helper
export get_trend_state(int len) =>
    float ph = ta.valuewhen(not na(ta.pivothigh(high, len, len)), ta.pivothigh(high, len, len), 0)
    float pl = ta.valuewhen(not na(ta.pivotlow(low, len, len)), ta.pivotlow(low, len, len), 0)
    int result = close > ph ? 1 : close < pl ? -1 : 0
    result

// Candle direction helpers (offset-based).
export is_bull_candle(int off) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    close[safeOff] > open[safeOff]

// Indicator helper
export is_bear_candle(int off) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    close[safeOff] < open[safeOff]

// Divergence helpers (ported from Hung - Indicators).
// Returns positive divergence length vs prior pivot lows.
export div_calc_pos_len(series float src, int cond, int prd, int maxbars, bool dontconfirm, array<int> pl_positions, array<float> pl_vals) =>
    int divlen = 0
    float prsc = close
    int maxSafeOff = 300
    if dontconfirm or src > src[1] or close > close[1]
        int startpoint = dontconfirm ? 0 : 1
        for x = 0 to 9
            int lenRaw = bar_index - array.get(pl_positions, x) + prd
            if array.get(pl_positions, x) == 0 or lenRaw > maxbars or lenRaw > maxSafeOff
                break
            int len = lenRaw
            if len > 5 and ((cond == 1 and src[startpoint] > src[len] and prsc[startpoint] < nz(array.get(pl_vals, x))) or (cond == 2 and src[startpoint] < src[len] and prsc[startpoint] > nz(array.get(pl_vals, x))))
                float slope1 = (src[startpoint] - src[len]) / (len - startpoint)
                float virtual_line1 = src[startpoint] - slope1
                float slope2 = (close[startpoint] - close[len]) / (len - startpoint)
                float virtual_line2 = close[startpoint] - slope2
                bool arrived = true
                for y = 1 + startpoint to len - 1
                    if y > maxSafeOff
                        arrived := false
                        break
                    if src[y] < virtual_line1 or nz(close[y]) < virtual_line2
                        arrived := false
                        break
                    virtual_line1 := virtual_line1 - slope1
                    virtual_line2 := virtual_line2 - slope2
                if arrived
                    divlen := len
                    break
    divlen

// Returns negative divergence length vs prior pivot highs.
// Local Helper
export div_calc_neg_len(series float src, int cond, int prd, int maxbars, bool dontconfirm, array<int> ph_positions, array<float> ph_vals) =>
    int divlen = 0
    float prsc = close
    int maxSafeOff = 300
    if dontconfirm or src < src[1] or close < close[1]
        int startpoint = dontconfirm ? 0 : 1
        for x = 0 to 9
            int lenRaw = bar_index - array.get(ph_positions, x) + prd
            if array.get(ph_positions, x) == 0 or lenRaw > maxbars or lenRaw > maxSafeOff
                break
            int len = lenRaw
            if len > 5 and ((cond == 1 and src[startpoint] < src[len] and prsc[startpoint] > nz(array.get(ph_vals, x))) or (cond == 2 and src[startpoint] > src[len] and prsc[startpoint] < nz(array.get(ph_vals, x))))
                float slope1 = (src[startpoint] - src[len]) / (len - startpoint)
                float virtual_line1 = src[startpoint] - slope1
                float slope2 = (close[startpoint] - nz(close[len])) / (len - startpoint)
                float virtual_line2 = close[startpoint] - slope2
                bool arrived = true
                for y = 1 + startpoint to len - 1
                    if y > maxSafeOff
                        arrived := false
                        break
                    if src[y] > virtual_line1 or nz(close[y]) > virtual_line2
                        arrived := false
                        break
                    virtual_line1 := virtual_line1 - slope1
                    virtual_line2 := virtual_line2 - slope2
                if arrived
                    divlen := len
                    break
    divlen

// Returns [divType, divLen] for a given source series and mode.
// divType: 0 none, 1 reg bull, 2 reg bear, 3 hidden bull, 4 hidden bear.
// Indicator helper
export div_check_all(series float src, string searchdiv, int prd, int maxbars, bool dontconfirm,
 array<int> ph_positions, array<int> pl_positions, array<float> ph_vals, array<float> pl_vals) =>
    int res = 0
    int len = 0
    if searchdiv == "Regular" or searchdiv == "Regular/Hidden"
        int l = div_calc_pos_len(src, 1, prd, maxbars, dontconfirm, pl_positions, pl_vals)
        if l > 0
            res := 1
            len := l
        else
            int l2 = div_calc_neg_len(src, 1, prd, maxbars, dontconfirm, ph_positions, ph_vals)
            if l2 > 0
                res := 2
                len := l2
    if (res == 0) and (searchdiv == "Hidden" or searchdiv == "Regular/Hidden")
        int l4 = div_calc_neg_len(src, 2, prd, maxbars, dontconfirm, ph_positions, ph_vals)
        if l4 > 0
            res := 3
            len := l4
        int l5 = div_calc_pos_len(src, 2, prd, maxbars, dontconfirm, pl_positions, pl_vals)
        if l5 > 0
            res := 4
            len := l5
    [res, len]


// Returns effective minimum bias percentage after profile override.
export get_effective_bias_min_pct(string profile, float customMinAbsPct) =>
    profile == "Scalp" ? 45.0 : profile == "Intraday" ? 35.0 : profile == "Swing" ? 30.0 : customMinAbsPct

// Returns raw factor values used by bias scoring.
export get_bias_factor_values(int len, int emaLen, int rsiLen, int adxLen, float stMult, int stAtrLen, int donchianLen) =>
    int msBias = get_trend_state(len)
    float ema50 = ta.ema(close, emaLen)
    float rsi = ta.rsi(close, rsiLen)
    [_, _, adx] = ta.dmi(adxLen, adxLen)
    float vwapVal = ta.vwap(hlc3)
    [stLine, _] = ta.supertrend(stMult, stAtrLen)
    float dUpper = ta.highest(high, donchianLen)
    float dLower = ta.lowest(low, donchianLen)
    float dMid = (dUpper + dLower) / 2.0
    [msBias, ema50, rsi, adx, vwapVal, stLine, dMid]

// Returns total/max/factor scores for bias confluence.
export get_bias_factor_scores(int msBias, float closeV, float ema50, float rsi, float adx, float vwapV, float stLine, float donchianMid,
 bool useStructure, bool useVwap, bool useEma50, bool useRsi, bool useAdx, bool useRsiImpulse, bool useSupertrend, bool useDonchian,
 int wStructure, int wVwap, int wEma50, int wRsi, int wAdx, int wRsiImpulse, int wSupertrend, int wDonchian,
 float rsiMidline, float rsiImpulseHigh, float rsiImpulseLow, float adxThreshold) =>
    int sStructure = 0
    int sEma50 = 0
    int sRsi = 0
    int sAdx = 0
    int sImpulse = 0
    int sVwap = 0
    int sSupertrend = 0
    int sDonchian = 0
    int maxScore = 0

    if useStructure
        maxScore += wStructure
        sStructure := msBias == 1 ? wStructure : msBias == -1 ? -wStructure : 0
    if useEma50
        maxScore += wEma50
        sEma50 := closeV > ema50 ? wEma50 : closeV < ema50 ? -wEma50 : 0
    if useRsi
        maxScore += wRsi
        sRsi := rsi > rsiMidline ? wRsi : rsi < rsiMidline ? -wRsi : 0
    if useAdx
        maxScore += wAdx
        if adx > adxThreshold
            int lead = sStructure + sEma50 + sRsi
            sAdx := lead > 0 ? wAdx : lead < 0 ? -wAdx : 0
    if useRsiImpulse
        maxScore += wRsiImpulse
        sImpulse := rsi > rsiImpulseHigh ? wRsiImpulse : rsi < rsiImpulseLow ? -wRsiImpulse : 0
    if useVwap
        maxScore += wVwap
        sVwap := closeV > vwapV ? wVwap : closeV < vwapV ? -wVwap : 0
    if useSupertrend
        maxScore += wSupertrend
        sSupertrend := closeV > stLine ? wSupertrend : closeV < stLine ? -wSupertrend : 0
    if useDonchian
        maxScore += wDonchian
        sDonchian := closeV > donchianMid ? wDonchian : closeV < donchianMid ? -wDonchian : 0

    int totalScore = sStructure + sVwap + sEma50 + sRsi + sAdx + sImpulse + sSupertrend + sDonchian
    [totalScore, maxScore, sStructure, sVwap, sEma50, sRsi, sAdx, sImpulse, sSupertrend, sDonchian]

// Returns final bias from confluence values.
export get_trend_data(int len, int emaLen, int rsiLen, int adxLen, float stMult, int stAtrLen, int donchianLen,
 bool useStructure, bool useVwap, bool useEma50, bool useRsi, bool useAdx, bool useRsiImpulse, bool useSupertrend, bool useDonchian,
 int wStructure, int wVwap, int wEma50, int wRsi, int wAdx, int wRsiImpulse, int wSupertrend, int wDonchian,
 float rsiMidline, float rsiImpulseHigh, float rsiImpulseLow, float adxThreshold,
 string profile, float customMinAbsPct) =>
    [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(len, emaLen, rsiLen, adxLen, stMult, stAtrLen, donchianLen)
    [totalScore, maxScore, _, _, _, _, _, _, _, _] = get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
     useStructure, useVwap, useEma50, useRsi, useAdx, useRsiImpulse, useSupertrend, useDonchian,
     wStructure, wVwap, wEma50, wRsi, wAdx, wRsiImpulse, wSupertrend, wDonchian,
     rsiMidline, rsiImpulseHigh, rsiImpulseLow, adxThreshold)
    int absScore = math.abs(totalScore)
    float effMinPct = get_effective_bias_min_pct(profile, customMinAbsPct)
    int minScoreRequired = math.max(1, int(math.ceil(maxScore * effMinPct / 100.0)))
    int bias = absScore >= minScoreRequired ? (totalScore > 0 ? 1 : totalScore < 0 ? -1 : 0) : 0
    [bias, absScore, maxScore, totalScore]

// Formats timeframe string to friendly label (e.g., 240 -> 4h).
export get_friendly_tf(string simple_tf) =>
    if simple_tf == "D" or simple_tf == "W" or simple_tf == "M"
        simple_tf
    else
        val = str.tonumber(simple_tf)
        if not na(val)
            if val >= 60 and val % 60 == 0
                str.tostring(val / 60) + "h"
            else
                simple_tf + "m"
        else
            simple_tf


// Returns relative pivot length for target TF in current TF context.
// Higher TF-distance => higher returned pivot length.
export get_dynamic_pivot_length(string current_tf, string target_tf) =>
    int currSec = math.max(get_tf_seconds(current_tf), 1)
    int tgtSec = math.max(get_tf_seconds(target_tf), currSec)
    float ratio = float(tgtSec) / float(currSec)
    int currBase = currSec <= 900 ? 15 : currSec <= 3600 ? 10 : currSec <= 14400 ? 7 : currSec <= 86400 ? 5 : 3
    int raw = int(math.round(float(currBase) * math.sqrt(ratio)))
    int outLen = math.max(currBase + (ratio > 1.0 ? 1 : 0), math.min(raw, 300))
    outLen

// Records one swing point when enabled.
export record_swing_if(bool enabled, array<float> prices, array<int> times, float val, int ts, int maxHistory) =>
    bool added = false
    if enabled and not na(val) and not na(ts)
        bool shouldPush = true
        int n = array.size(times)
        if n > 0
            shouldPush := array.get(times, n - 1) != ts
        if shouldPush
            array.push(prices, val)
            array.push(times, ts)
            if array.size(prices) > maxHistory
                array.shift(prices)
                array.shift(times)
            added := true
    added

// Enforces alternating sequence H->L->H->L by collapsing consecutive same-side swings.
export sanitize_swing_ledgers(array<float> highPrices, array<int> highTimes, array<float> lowPrices, array<int> lowTimes, int maxHistory) =>
    int nH = array.size(highPrices)
    int nL = array.size(lowPrices)
    int nTot = nH + nL
    if nTot > 1
        array<int> mergedTimes = array.new_int()
        array<float> mergedPrices = array.new_float()
        array<bool> mergedIsHigh = array.new_bool()
        int iH = 0
        int iL = 0
        while iH < nH or iL < nL
            bool takeHigh = false
            if iL >= nL
                takeHigh := iH < nH
            else if iH >= nH
                takeHigh := false
            else
                int hT = array.get(highTimes, iH)
                int lT = array.get(lowTimes, iL)
                takeHigh := hT <= lT
            if takeHigh
                array.push(mergedTimes, array.get(highTimes, iH))
                array.push(mergedPrices, array.get(highPrices, iH))
                array.push(mergedIsHigh, true)
                iH += 1
            else
                array.push(mergedTimes, array.get(lowTimes, iL))
                array.push(mergedPrices, array.get(lowPrices, iL))
                array.push(mergedIsHigh, false)
                iL += 1

        array<int> cleanTimes = array.new_int()
        array<float> cleanPrices = array.new_float()
        array<bool> cleanIsHigh = array.new_bool()
        for i = 0 to array.size(mergedTimes) - 1
            int t = array.get(mergedTimes, i)
            float p = array.get(mergedPrices, i)
            bool isHigh = array.get(mergedIsHigh, i)
            int nClean = array.size(cleanTimes)
            if nClean == 0
                array.push(cleanTimes, t)
                array.push(cleanPrices, p)
                array.push(cleanIsHigh, isHigh)
            else
                int li = nClean - 1
                bool lastIsHigh = array.get(cleanIsHigh, li)
                if isHigh != lastIsHigh
                    array.push(cleanTimes, t)
                    array.push(cleanPrices, p)
                    array.push(cleanIsHigh, isHigh)
                else
                    float lastP = array.get(cleanPrices, li)
                    bool replace = isHigh ? p >= lastP : p <= lastP
                    if replace
                        array.set(cleanTimes, li, t)
                        array.set(cleanPrices, li, p)

        array.clear(highPrices)
        array.clear(highTimes)
        array.clear(lowPrices)
        array.clear(lowTimes)
        for i = 0 to array.size(cleanTimes) - 1
            int t = array.get(cleanTimes, i)
            float p = array.get(cleanPrices, i)
            bool isHigh = array.get(cleanIsHigh, i)
            if isHigh
                array.push(highTimes, t)
                array.push(highPrices, p)
            else
                array.push(lowTimes, t)
                array.push(lowPrices, p)
        while array.size(highPrices) > maxHistory
            array.remove(highPrices, 0)
            array.remove(highTimes, 0)
        while array.size(lowPrices) > maxHistory
            array.remove(lowPrices, 0)
            array.remove(lowTimes, 0)
    bool(na)

// TF pipeline mutator: arm candidate swings from raw pivots.
export process_tf_armed_state(TFData tfData, bool enabled, float swingHigh, int swingHighT, float swingLow, int swingLowT, int maxHistory) =>
    if enabled
        bool nextHighArmed = record_swing_if(enabled, tfData.swingHighPrices, tfData.swingHighTimes, swingHigh, swingHighT, maxHistory) ? true : tfData.highArmed
        bool nextLowArmed = record_swing_if(enabled, tfData.swingLowPrices, tfData.swingLowTimes, swingLow, swingLowT, maxHistory) ? true : tfData.lowArmed
        sanitize_swing_ledgers(tfData.swingHighPrices, tfData.swingHighTimes, tfData.swingLowPrices, tfData.swingLowTimes, maxHistory)
        tfData.highArmed := nextHighArmed
        tfData.lowArmed := nextLowArmed
    bool(na)

// Returns dynamic pivot length to mimic target TF swings from current TF bars.
export get_mimic_pivot_len(string currentTf, string targetTf, int pivotLenBase, int pivotLenScalp, int pivotLenIntraday, int pivotLenMultiDay, int pivotLenSwing, int pivotLenPosition) =>
    int currSec = math.max(get_tf_seconds(currentTf), 1)
    int tgtSec = math.max(get_tf_seconds(targetTf), currSec)
    int targetBase = tgtSec <= 300 ? pivotLenScalp :
     tgtSec <= 3600 ? pivotLenIntraday :
     tgtSec <= 14400 ? pivotLenMultiDay :
     tgtSec <= 86400 ? pivotLenSwing : pivotLenPosition
    float ratio = float(tgtSec) / float(currSec)
    int raw = int(math.round(float(targetBase) * math.pow(ratio, 0.55)))
    int outLen = math.max(pivotLenBase + 1, raw)
    outLen


// Helper (Bias): Select one effective indicator cluster by timeframe.
export get_bias_profile_id(string tf, Settings cfg) =>
    int sec = get_tf_seconds(tf)
    sec <= 300 ? cfg.BIAS_PROFILE_REACTIVE : sec <= 3600 ? cfg.BIAS_PROFILE_INTRADAY : sec <= 14400 ? cfg.BIAS_PROFILE_SWING : cfg.BIAS_PROFILE_MACRO

// Helper (Bias): Human-readable profile name for tooltip/debug.
// Local Helper
export get_bias_profile_name(int profileId, Settings cfg) =>
    profileId == cfg.BIAS_PROFILE_REACTIVE ? "Reactive" : profileId == cfg.BIAS_PROFILE_INTRADAY ? "Intraday" : profileId == cfg.BIAS_PROFILE_SWING ? "Swing" : "Macro"

// Helper (Bias): Converts score strength into a 1..5 level for TradingKit colors.
export get_bias_strength_level(int absScore, int maxScore) =>
    float pct = maxScore > 0 ? (float(absScore) * 100.0 / float(maxScore)) : 0.0
    pct >= 80 ? 5 : pct >= 60 ? 4 : pct >= 40 ? 3 : pct >= 20 ? 2 : 1

// Core (Bias): TF-aware bias resolver. Routes to the correct get_trend_data() profile based on TF.
// Returns [biasDir, absScore, maxScore, totalScore] — same tuple as get_trend_data().
// Factors enabled per profile are overridden by the BiasToggles flags (AND logic).
// Call from indicator scope with request.security() for HTF data.
export get_bias_data_for_tf(string tf, Settings cfg, BiasToggles tog) =>
    int profileId = get_bias_profile_id(tf, cfg)
    int pivotLen  = get_dynamic_pivot_length(timeframe.period, tf)
    if profileId == cfg.BIAS_PROFILE_REACTIVE
        // Reactive (≤5m): VWAP + RSI + RSI impulse; EMA/ADX/ST/Donchian off.
        get_trend_data(pivotLen, 34, 14, 14, 2.0, 7, 20,
         tog.useStructure, tog.useVwap, false, tog.useRsi, false, tog.useRsiImpulse, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Scalp", 40.0)
    else if profileId == cfg.BIAS_PROFILE_INTRADAY
        // Intraday (≤1h): EMA200 + VWAP + RSI + ADX; impulse/ST/Donchian off.
        get_trend_data(pivotLen, 200, 14, 14, 2.5, 10, 20,
         tog.useStructure, tog.useVwap, tog.useEma, tog.useRsi, tog.useAdx, false, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Intraday", 35.0)
    else if profileId == cfg.BIAS_PROFILE_SWING
        // Swing (≤4h): Supertrend + Donchian + ADX + structure; VWAP/EMA/RSI/impulse off.
        get_trend_data(pivotLen, 200, 14, 14, 3.0, 10, 55,
         tog.useStructure, false, false, false, tog.useAdx, false, tog.useSupertrend, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Swing", 30.0)
    else
        // Macro (>4h): EMA200 + Donchian + structure; VWAP/RSI/ADX/impulse/ST off.
        get_trend_data(pivotLen, 200, 14, 14, 3.0, 10, 55,
         tog.useStructure, false, tog.useEma, false, false, false, false, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0, "Macro", 30.0)

// Core (Bias): Full factor component breakdown for one TF.
// Returns: [total, max, sStructure, sVwap, sEma50, sRsi, sAdx, sImpulse, sSupertrend, sDonchian]
export get_bias_components_for_tf(string tf, Settings cfg, BiasToggles tog) =>
    int profileId = get_bias_profile_id(tf, cfg)
    int pivotLen  = get_dynamic_pivot_length(timeframe.period, tf)
    if profileId == cfg.BIAS_PROFILE_REACTIVE
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 34, 14, 14, 2.0, 7, 20)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, tog.useVwap, false, tog.useRsi, false, tog.useRsiImpulse, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)
    else if profileId == cfg.BIAS_PROFILE_INTRADAY
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 200, 14, 14, 2.5, 10, 20)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, tog.useVwap, tog.useEma, tog.useRsi, tog.useAdx, false, false, false,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)
    else if profileId == cfg.BIAS_PROFILE_SWING
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 200, 14, 14, 3.0, 10, 55)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, false, false, false, tog.useAdx, false, tog.useSupertrend, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)
    else
        [msBias, ema50, rsi, adx, vwapVal, stLine, dMid] = get_bias_factor_values(pivotLen, 200, 14, 14, 3.0, 10, 55)
        get_bias_factor_scores(msBias, close, ema50, rsi, adx, vwapVal, stLine, dMid,
         tog.useStructure, false, tog.useEma, false, false, false, false, tog.useDonchian,
         cfg.W_BIAS_STRUCTURE, cfg.W_BIAS_VWAP, cfg.W_BIAS_EMA50, cfg.W_BIAS_RSI, cfg.W_BIAS_ADX, cfg.W_BIAS_RSI_IMPULSE, cfg.W_BIAS_SUPERTREND, cfg.W_BIAS_DONCHIAN,
         50.0, 60.0, 40.0, 20.0)

// request.security-safe wrapper for exported callers.
// Pine disallows request expressions depending on exported function arguments.
get_bias_components_for_tf_default(string tf) =>
    Settings cfg0 = Settings.new()
    BiasToggles tog0 = BiasToggles.new()
    get_bias_components_for_tf(tf, cfg0, tog0)

// Market-structure trend dir helper from TFData.
// Indicator helper
export get_ms_trend_dir(TFData tfData) =>
    tfData.msBias != 0 ? tfData.msBias : tfData.prevBreakout

// Slot trend resolver from three TFData ledgers.
export get_ms_trend_dir_for_slot(string tfName, string currentTf, string htf1Name, string htf2Name, TFData ltfDataX, TFData htf1DataX, TFData htf2DataX) =>
    int out = 0
    if tfName == currentTf
        out := get_ms_trend_dir(ltfDataX)
    else if tfName == htf1Name
        out := get_ms_trend_dir(htf1DataX)
    else if tfName == htf2Name
        out := get_ms_trend_dir(htf2DataX)
    out

// Returns relative volume at offset (current volume / SMA volume).
export get_rel_volume(int off, int len) =>
    int maxSafeOff = 300
    int safeOff = math.max(0, math.min(off, maxSafeOff))
    avgVol = ta.sma(volume, len)
    base = nz(avgVol[safeOff], volume[safeOff])
    base > 0 ? (volume[safeOff] / base) : 0.0

// Maps timestamp to closest current-chart bar_index.
export closest_bar_index_from_time(int t) =>
    int msPerBar = math.max(time - time[1], 1)
    int barsAgo = int(math.round((time - t) / msPerBar))
    int idx = bar_index - barsAgo
    idx >= 0 and idx <= bar_index + 500 ? idx : na

// Returns rendered span in bars for one HTF mini-chart slot.
export get_htf_chart_span(int count) =>
    (count - 1) * (2 + 1) + 2

// Returns latest non-na timestamp among 4 candidates.
export get_latest_time4(int t1, int t2, int t3, int t4) =>
    int out = na
    if not na(t1)
        out := t1
    if not na(t2)
        out := na(out) ? t2 : math.max(out, t2)
    if not na(t3)
        out := na(out) ? t3 : math.max(out, t3)
    if not na(t4)
        out := na(out) ? t4 : math.max(out, t4)
    out

// Returns candle count in `tf` needed to include an anchor timestamp.
export get_candles_to_anchor(string tf, int anchorTs, int minCandles, int maxCandles, int fallbackCandles) =>
    if na(tf)
        fallbackCandles
    else
        int tfSec = math.max(get_tf_seconds(tf), 1)
        int barsRaw = na(anchorTs) ? fallbackCandles : int(math.ceil(math.max(float(time - anchorTs), 0.0) / float(tfSec * 1000))) + 2
        int lo = math.max(minCandles, 1)
        int hi = math.max(maxCandles, lo)
        math.max(lo, math.min(barsRaw, hi))

// Returns current-TF lookback bars derived from HTF2 candle span.
export get_curr_lookback_from_htf2(string htf2, int htf2Candles, int minBars, int maxBars) =>
    if na(htf2)
        math.max(minBars, 1)
    else
        int htf2Sec = math.max(get_tf_seconds(htf2), 1)
        int currSec = math.max(get_tf_seconds(timeframe.period), 1)
        int barsRaw = int(math.ceil(float(htf2Candles * htf2Sec) / float(currSec)))
        int lo = math.max(minBars, 1)
        int hi = math.max(maxBars, lo)
        math.max(lo, math.min(barsRaw, hi))

// Returns true when index is inside the last `lookbackBars` bars.
export is_in_draw_lookback_index(int idx, int lookbackBars) =>
    na(idx) ? false : idx >= math.max(last_bar_index - math.max(lookbackBars, 1), 0)

// Returns true when current bar is inside the last `lookbackBars` bars.
export is_in_draw_lookback_current(int lookbackBars) =>
    is_in_draw_lookback_index(bar_index, lookbackBars)

// Returns cutoff time for recent-window filtering from `lookbackBars`.
export get_recent_time_cutoff(int lookbackBars) =>
    int lb = math.max(lookbackBars, 1)
    bar_index > lb ? time[lb] : 0

// Computes retracement level on a leg.
export get_leg_retracement(float legStart, float legEnd, float ratio, bool isBullLeg) =>
    float rng = math.abs(legEnd - legStart)
    isBullLeg ? (legEnd - rng * ratio) : (legEnd + rng * ratio)

// Scans from start index to current bar and returns the extreme price+index.
export get_range_extreme_from_index(int startIdx, bool findLow, int maxScanBars) =>
    bool ok = false
    int outIdx = na
    float outPrice = na
    int dist = bar_index - startIdx
    if dist >= 0
        int safeMax = math.max(maxScanBars, 1)
        int scan = math.min(dist, safeMax)
        // Runtime-safe cap to avoid historical-buffer overrun in callers with long legs.
        int scanSafe = math.min(scan, 90)
        // Clamp scan start so first accessed offset never exceeds the safe cap.
        int safeStartIdx = math.max(startIdx, bar_index - scanSafe)
        int safeDist = bar_index - safeStartIdx
        float best = findLow ? 10e10 : -10e10
        for j = 0 to safeDist
            int idx = safeStartIdx + j
            int off = bar_index - idx
            float v = findLow ? low[off] : high[off]
            bool better = findLow ? (v <= best) : (v >= best)
            if better
                best := v
                outIdx := idx
                outPrice := v
                ok := true
    [ok, outIdx, outPrice]

// Sessions/time-event helper: selects displayed label text by mode.
export get_time_event_label(string mode, string modeTime, string shortTime, string shortName) =>
    mode == modeTime ? shortTime : shortName


// Resolves one entry state on current bar and returns [updatedEntry, outcomeCode].
// outcomeCode: 1 = TP hit, -1 = SL hit, 2 = invalidated before entry touch, 0 = unchanged.
export resolve_trade_state(Trade e, float hi, float lo, int barIdx, bool requireNextBar, bool slFirstOnDualHit, Const c) =>
    int outcome = 0
    if e.state == c.SIGNAL_STATE_PENDING or e.state == c.SIGNAL_STATE_START
        int age = barIdx - e.barCreated
        if age > 0 and not e.touched
            bool touchedNow = hi >= e.entry and lo <= e.entry
            if touchedNow
                e.touched := true
                e.state := c.SIGNAL_STATE_START
        if not requireNextBar or age > 0
            bool isBuy = e.direction == "Buy"
            bool hitTp = isBuy ? (hi >= e.takeprofit) : (lo <= e.takeprofit)
            bool hitSl = isBuy ? (lo <= e.stoploss) : (hi >= e.stoploss)
            if hitTp and hitSl
                if slFirstOnDualHit
                    hitTp := false
                else
                    hitSl := false
            // If TP/SL is reached before entry is ever touched, invalidate this setup.
            if (hitTp or hitSl) and not e.touched
                outcome := 2
            else if hitSl
                e.state := c.SIGNAL_STATE_SL
                e.barClosed := barIdx
                outcome := -1
            else if hitTp
                e.state := c.SIGNAL_STATE_TP
                e.barClosed := barIdx
                outcome := 1
    [e, outcome]

// ==================== GENERIC UTILITIES ====================

// Helper (Bias): Gate for directional entries against composite bias.
// Returns true when bias is neutral (0) or agrees with direction ("Buy"/"Sell").
export bias_allows_direction(int compositeBias, string direction) =>
    compositeBias == 0 ? true : direction == "Buy" ? compositeBias == 1 : direction == "Sell" ? compositeBias == -1 : false

CANDLE_NONE = 0 // Pattern enum id used by candle-pattern functions.
CANDLE_DOJI = 1 // Pattern enum id used by candle-pattern functions.
CANDLE_BULL_ENG = 2 // Pattern enum id used by candle-pattern functions.
CANDLE_BEAR_ENG = 3 // Pattern enum id used by candle-pattern functions.
CANDLE_HAMMER = 4 // Pattern enum id used by candle-pattern functions.
CANDLE_SHOOTING_STAR = 5 // Pattern enum id used by candle-pattern functions.
CANDLE_BULL_HARAMI = 6 // Pattern enum id used by candle-pattern functions.
CANDLE_BEAR_HARAMI = 7 // Pattern enum id used by candle-pattern functions.
CANDLE_DRAGONFLY_DOJI = 8 // Pattern enum id used by candle-pattern functions.
CANDLE_GRAVESTONE_DOJI = 9 // Pattern enum id used by candle-pattern functions.
CANDLE_PIERCING_LINE = 10 // Pattern enum id used by candle-pattern functions.
CANDLE_DARK_CLOUD = 11 // Pattern enum id used by candle-pattern functions.
CANDLE_TWEEZER_TOP = 12 // Pattern enum id used by candle-pattern functions.
CANDLE_TWEEZER_BOTTOM = 13 // Pattern enum id used by candle-pattern functions.
CANDLE_BULL_MARUBOZU = 14 // Pattern enum id used by candle-pattern functions.
CANDLE_BEAR_MARUBOZU = 15 // Pattern enum id used by candle-pattern functions.
CANDLE_3_WHITE_SOLDIERS = 16 // Pattern enum id used by candle-pattern functions.
CANDLE_3_BLACK_CROWS = 17 // Pattern enum id used by candle-pattern functions.
CANDLE_MORNING_STAR = 18 // Pattern enum id used by candle-pattern functions.
CANDLE_EVENING_STAR = 19 // Pattern enum id used by candle-pattern functions.

// Detects candle pattern enum id from OHLC structure.
export get_candle_pattern(float cpDojiBodyMaxPct, float cpWickBodyMin, float cpWickDominanceMin, float cpOppositeWickMaxBody, float cpEngulfMinPrevBody, float cpTweezerTolAtr, float cpMarubozuMaxWickBody, float cp3lineMinBodyPct) =>
    if not barstate.isconfirmed or bar_index < 2
        CANDLE_NONE
    else
        float body = math.abs(close - open)
        float rng = math.max(high - low, syminfo.mintick)
        float upperWick = high - math.max(open, close)
        float lowerWick = math.min(open, close) - low
        float safeBody = math.max(body, syminfo.mintick)
        float safeUpper = math.max(upperWick, syminfo.mintick)
        float safeLower = math.max(lowerWick, syminfo.mintick)
        // Keep pattern detection lightweight and buffer-safe in local scopes.
        float atrRef = ta.sma(math.max(high - low, syminfo.mintick), 3)
        float tweezerTol = math.max(atrRef * cpTweezerTolAtr, syminfo.mintick * 2)
        float bullWickBodyRatio = lowerWick / safeBody
        float bearWickBodyRatio = upperWick / safeBody
        float bullWickDominance = lowerWick / safeUpper
        float bearWickDominance = upperWick / safeLower
        float body1 = math.abs(close[1] - open[1])
        float body2 = math.abs(close[2] - open[2])
        float rng1 = math.max(high[1] - low[1], syminfo.mintick)
        float rng2 = math.max(high[2] - low[2], syminfo.mintick)
        float upW1 = high[1] - math.max(open[1], close[1])
        float dnW1 = math.min(open[1], close[1]) - low[1]
        float upW2 = high[2] - math.max(open[2], close[2])
        float dnW2 = math.min(open[2], close[2]) - low[2]
        bool doji = body <= rng * cpDojiBodyMaxPct
        bool dragonflyDoji = doji and bullWickBodyRatio >= cpWickBodyMin and bullWickDominance >= cpWickDominanceMin
        bool gravestoneDoji = doji and bearWickBodyRatio >= cpWickBodyMin and bearWickDominance >= cpWickDominanceMin
        bool bullEng = close > open and close[1] < open[1] and open <= close[1] and close >= open[1] and body > math.abs(close[1] - open[1]) * cpEngulfMinPrevBody
        bool bearEng = close < open and close[1] > open[1] and open >= close[1] and close <= open[1] and body > math.abs(close[1] - open[1]) * cpEngulfMinPrevBody
        bool hammer = not doji and bullWickBodyRatio >= cpWickBodyMin and bullWickDominance >= cpWickDominanceMin and upperWick <= body * cpOppositeWickMaxBody and close >= open
        bool shootingStar = not doji and bearWickBodyRatio >= cpWickBodyMin and bearWickDominance >= cpWickDominanceMin and lowerWick <= body * cpOppositeWickMaxBody and close <= open
        bool bullHarami = open[1] > close[1] and close > open and close <= open[1] and close[1] <= open
        bool bearHarami = close[1] > open[1] and open > close and open <= close[1] and open[1] <= close
        bool piercingLine = close[1] < open[1] and close > open and open < close[1] and close > (open[1] + close[1]) / 2
        bool darkCloudCover = close[1] > open[1] and close < open and open > close[1] and close < (open[1] + close[1]) / 2
        bool tweezerTop = close[1] > open[1] and close < open and math.abs(high - high[1]) <= tweezerTol
        bool tweezerBottom = close[1] < open[1] and close > open and math.abs(low - low[1]) <= tweezerTol
        bool bullMarubozu = close > open and (upperWick / safeBody) <= cpMarubozuMaxWickBody and (lowerWick / safeBody) <= cpMarubozuMaxWickBody and (body / rng) >= 0.7
        bool bearMarubozu = close < open and (upperWick / safeBody) <= cpMarubozuMaxWickBody and (lowerWick / safeBody) <= cpMarubozuMaxWickBody and (body / rng) >= 0.7
        bool threeWhiteSoldiers = close > open and close[1] > open[1] and close[2] > open[2] and close > close[1] and close[1] > close[2] and (body / rng) >= cp3lineMinBodyPct and (body1 / rng1) >= cp3lineMinBodyPct and (body2 / rng2) >= cp3lineMinBodyPct and upperWick <= body and upW1 <= body1 and upW2 <= body2 and open <= close[1] and open >= open[1] and open[1] <= close[2] and open[1] >= open[2]
        bool threeBlackCrows = close < open and close[1] < open[1] and close[2] < open[2] and close < close[1] and close[1] < close[2] and (body / rng) >= cp3lineMinBodyPct and (body1 / rng1) >= cp3lineMinBodyPct and (body2 / rng2) >= cp3lineMinBodyPct and lowerWick <= body and dnW1 <= body1 and dnW2 <= body2 and open >= close[1] and open <= open[1] and open[1] >= close[2] and open[1] <= open[2]
        bool morningStar = close[2] < open[2] and math.abs(close[1] - open[1]) <= (math.max(high[1] - low[1], syminfo.mintick) * cpDojiBodyMaxPct) and close > open and close > (open[2] + close[2]) / 2
        bool eveningStar = close[2] > open[2] and math.abs(close[1] - open[1]) <= (math.max(high[1] - low[1], syminfo.mintick) * cpDojiBodyMaxPct) and close < open and close < (open[2] + close[2]) / 2
        bullEng ? CANDLE_BULL_ENG : bearEng ? CANDLE_BEAR_ENG : hammer ? CANDLE_HAMMER : shootingStar ? CANDLE_SHOOTING_STAR : dragonflyDoji ? CANDLE_DRAGONFLY_DOJI : gravestoneDoji ? CANDLE_GRAVESTONE_DOJI : bullHarami ? CANDLE_BULL_HARAMI : bearHarami ? CANDLE_BEAR_HARAMI : piercingLine ? CANDLE_PIERCING_LINE : darkCloudCover ? CANDLE_DARK_CLOUD : tweezerTop ? CANDLE_TWEEZER_TOP : tweezerBottom ? CANDLE_TWEEZER_BOTTOM : bullMarubozu ? CANDLE_BULL_MARUBOZU : bearMarubozu ? CANDLE_BEAR_MARUBOZU : threeWhiteSoldiers ? CANDLE_3_WHITE_SOLDIERS : threeBlackCrows ? CANDLE_3_BLACK_CROWS : morningStar ? CANDLE_MORNING_STAR : eveningStar ? CANDLE_EVENING_STAR : doji ? CANDLE_DOJI : CANDLE_NONE

// Returns readable text for candle pattern enum id.
export get_candle_pattern_text(int p) =>
    p == CANDLE_BULL_ENG ? "Bull Engulfing (bullish reversal/continuation impulse)" :
     p == CANDLE_BEAR_ENG ? "Bear Engulfing (bearish reversal/continuation impulse)" :
     p == CANDLE_HAMMER ? "Hammer (bullish reversal/continuation impulse)" :
     p == CANDLE_SHOOTING_STAR ? "Shooting Star (bearish reversal/continuation impulse)" :
     p == CANDLE_DRAGONFLY_DOJI ? "Dragonfly Doji (bullish reversal/continuation impulse)" :
     p == CANDLE_GRAVESTONE_DOJI ? "Gravestone Doji (bearish reversal/continuation impulse)" :
     p == CANDLE_BULL_HARAMI ? "Bull Harami (bullish reversal/continuation impulse)" :
     p == CANDLE_BEAR_HARAMI ? "Bear Harami (bearish reversal/continuation impulse)" :
     p == CANDLE_PIERCING_LINE ? "Piercing Line (bullish reversal/continuation impulse)" :
     p == CANDLE_DARK_CLOUD ? "Dark Cloud (bearish reversal/continuation impulse)" :
     p == CANDLE_TWEEZER_TOP ? "Tweezer Top (bearish reversal/continuation impulse)" :
     p == CANDLE_TWEEZER_BOTTOM ? "Tweezer Bottom (bullish reversal/continuation impulse)" :
     p == CANDLE_BULL_MARUBOZU ? "Bull Marubozu (bullish reversal/continuation impulse)" :
     p == CANDLE_BEAR_MARUBOZU ? "Bear Marubozu (bearish reversal/continuation impulse)" :
     p == CANDLE_3_WHITE_SOLDIERS ? "3 White Soldiers (bullish reversal/continuation impulse)" :
     p == CANDLE_3_BLACK_CROWS ? "3 Black Crows (bearish reversal/continuation impulse)" :
     p == CANDLE_MORNING_STAR ? "Morning Star (bullish reversal/continuation impulse)" :
     p == CANDLE_EVENING_STAR ? "Evening Star (bearish reversal/continuation impulse)" :
     p == CANDLE_DOJI ? "Doji (neutral)" :
     ""

// Returns directional bias from candle pattern (-1/0/1).
export get_candle_pattern_bias(int p) =>
    p == CANDLE_BULL_ENG or p == CANDLE_HAMMER or p == CANDLE_DRAGONFLY_DOJI or p == CANDLE_BULL_HARAMI or p == CANDLE_PIERCING_LINE or p == CANDLE_TWEEZER_BOTTOM or p == CANDLE_BULL_MARUBOZU or p == CANDLE_3_WHITE_SOLDIERS or p == CANDLE_MORNING_STAR ? 1 :
     p == CANDLE_BEAR_ENG or p == CANDLE_SHOOTING_STAR or p == CANDLE_GRAVESTONE_DOJI or p == CANDLE_BEAR_HARAMI or p == CANDLE_DARK_CLOUD or p == CANDLE_TWEEZER_TOP or p == CANDLE_BEAR_MARUBOZU or p == CANDLE_3_BLACK_CROWS or p == CANDLE_EVENING_STAR ? -1 :
     0

// Applies candle-pattern + relative-volume confluence adjustments to a base signal score.
export apply_candle_pattern_confluence(string direction, string reason, int baseScore, CandlePatternCfg cfg) =>
    int p = get_candle_pattern(cfg.dojiBodyMaxPct, cfg.wickBodyMin, cfg.wickDominanceMin, cfg.oppositeWickMaxBody, cfg.engulfMinPrevBody, cfg.tweezerTolAtr, cfg.marubozuMaxWickBody, cfg.threeLineMinBodyPct)
    int pBias = get_candle_pattern_bias(p)
    bool aligned = (direction == "Buy" and pBias > 0) or (direction == "Sell" and pBias < 0)
    bool isConfluenceEvent = str.contains(reason, "Retest") or str.contains(reason, "Sweep") or str.contains(reason, "respected") or str.contains(reason, "reclaimed") or str.contains(reason, "rejected")
    float volBase = ta.sma(volume, cfg.volLen)
    float relVol = volBase > 0 ? (volume / volBase) : 0.0
    int bonus = (aligned and isConfluenceEvent ? cfg.scorePattern : 0) + (isConfluenceEvent and relVol >= cfg.volMin ? cfg.scoreVolume : 0)
    string pTxt = get_candle_pattern_text(p)
    string outReason = reason
    if bonus > 0 and pTxt != ""
        outReason += " + " + pTxt
    if isConfluenceEvent and relVol >= cfg.volMin
        outReason += " + Vol"
    ConfluenceResult.new(outReason, baseScore + bonus)

// Returns OHLC + candle pattern stream for one HTF slot.
// Uses fixed pattern parameters because request.security expression in exported
// library functions cannot depend on function arguments.
export get_data_htf_candles(string tf) =>
    [o, h, l, c] = if not na(tf)
        request.security(syminfo.tickerid, tf, [open, high, low, close], gaps = barmerge.gaps_off)
    else
        [na, na, na, na]
    int pat = if not na(tf)
        request.security(syminfo.tickerid, tf, get_candle_pattern(0.10, 2.0, 2.0, 0.5, 1.0, 0.05, 0.05, 0.60))
    else
        na
    [o, h, l, c, pat]

// Builds a centralized chart data context with optional data packs.
export get_data_context(DataContextCfg cfg, Settings s, BiasToggles tog, array<PDArray> zonesRef, array<PDArray> levelsRef, array<Event> eventsRef, array<Event> signalHistRef, TFData ltfData, TFData htf1Data, TFData htf2Data) =>
    ChartContext ctx = ChartContext.new()
    ctx.barIdx := bar_index
    ctx.closeV := close
    ctx.highV := high
    ctx.lowV := low
    ctx.atrV := ta.atr(14)
    ctx.zones := zonesRef
    ctx.levels := levelsRef
    ctx.events := eventsRef
    ctx.signalHist := signalHistRef
    [tf1, tf2] = get_htf_pair()
    ctx.htf1Name := tf1
    ctx.htf2Name := tf2

    if cfg.needBias
        [tot0, max0, sStructure0, sVwap0, sEma500, sRsi0, sAdx0, sImpulse0, sSupertrend0, sDonchian0] = get_bias_components_for_tf(timeframe.period, s, tog)
        [tot15, max15, sStructure15, sVwap15, sEma5015, sRsi15, sAdx15, sImpulse15, sSupertrend15, sDonchian15] = request.security(syminfo.tickerid, "15", get_bias_components_for_tf_default("15"))
        [tot240, max240, sStructure240, sVwap240, sEma50240, sRsi240, sAdx240, sImpulse240, sSupertrend240, sDonchian240] = request.security(syminfo.tickerid, "240", get_bias_components_for_tf_default("240"))
        [tot1d, max1d, sStructure1d, sVwap1d, sEma501d, sRsi1d, sAdx1d, sImpulse1d, sSupertrend1d, sDonchian1d] = request.security(syminfo.tickerid, "1D", get_bias_components_for_tf_default("1D"))
        [tot1w, max1w, sStructure1w, sVwap1w, sEma501w, sRsi1w, sAdx1w, sImpulse1w, sSupertrend1w, sDonchian1w] = request.security(syminfo.tickerid, "1W", get_bias_components_for_tf_default("1W"))
        int b0 = tot0 > 0 ? 1 : tot0 < 0 ? -1 : 0
        int b15 = tot15 > 0 ? 1 : tot15 < 0 ? -1 : 0
        int b240 = tot240 > 0 ? 1 : tot240 < 0 ? -1 : 0
        int b1d = tot1d > 0 ? 1 : tot1d < 0 ? -1 : 0
        int b1w = tot1w > 0 ? 1 : tot1w < 0 ? -1 : 0
        ctx.b0 := b0
        ctx.s0 := math.abs(tot0)
        ctx.m0 := math.max(max0, 1)
        ctx.t0 := tot0
        ctx.b15 := b15
        ctx.s15 := math.abs(tot15)
        ctx.m15 := math.max(max15, 1)
        ctx.t15 := tot15
        ctx.b240 := b240
        ctx.s240 := math.abs(tot240)
        ctx.m240 := math.max(max240, 1)
        ctx.t240 := tot240
        ctx.b1d := b1d
        ctx.s1d := math.abs(tot1d)
        ctx.m1d := math.max(max1d, 1)
        ctx.t1d := tot1d
        ctx.b1w := b1w
        ctx.s1w := math.abs(tot1w)
        ctx.m1w := math.max(max1w, 1)
        ctx.t1w := tot1w
        int currSec = get_tf_seconds(timeframe.period)
        bool use15 = get_tf_seconds("15") > currSec
        bool use240 = get_tf_seconds("240") > currSec
        bool use1d = get_tf_seconds("1D") > currSec
        bool use1w = get_tf_seconds("1W") > currSec
        float power = (ctx.b0 * ctx.s0 * 1.0) + (use15 ? (ctx.b15 * ctx.s15 * 1.5) : 0.0) + (use240 ? (ctx.b240 * ctx.s240 * 2.0) : 0.0) + (use1d ? (ctx.b1d * ctx.s1d * 3.0) : 0.0) + (use1w ? (ctx.b1w * ctx.s1w * 4.0) : 0.0)
        float powerMax = (ctx.m0 * 1.0) + (use15 ? (ctx.m15 * 1.5) : 0.0) + (use240 ? (ctx.m240 * 2.0) : 0.0) + (use1d ? (ctx.m1d * 3.0) : 0.0) + (use1w ? (ctx.m1w * 4.0) : 0.0)
        float powerPct = powerMax > 0 ? math.min(math.max((power / powerMax) * 100.0, -100.0), 100.0) : 0.0
        ctx.compositeBias := powerPct > 20 ? 1 : powerPct < -20 ? -1 : 0
        ctx.activeBias := ctx.compositeBias != 0 ? ctx.compositeBias : ctx.b0
        ctx.biasVal := ctx.activeBias

        if cfg.initBiasFactorArrays
            ctx.biasBullFactors := array.new_string(5, "")
            ctx.biasBearFactors := array.new_string(5, "")
            [bull0, bear0] = get_bias_factor_texts_from_scores(sStructure0, sVwap0, sEma500, sRsi0, sAdx0, sImpulse0, sSupertrend0, sDonchian0)
            [bull15, bear15] = get_bias_factor_texts_from_scores(sStructure15, sVwap15, sEma5015, sRsi15, sAdx15, sImpulse15, sSupertrend15, sDonchian15)
            [bull240, bear240] = get_bias_factor_texts_from_scores(sStructure240, sVwap240, sEma50240, sRsi240, sAdx240, sImpulse240, sSupertrend240, sDonchian240)
            [bull1d, bear1d] = get_bias_factor_texts_from_scores(sStructure1d, sVwap1d, sEma501d, sRsi1d, sAdx1d, sImpulse1d, sSupertrend1d, sDonchian1d)
            [bull1w, bear1w] = get_bias_factor_texts_from_scores(sStructure1w, sVwap1w, sEma501w, sRsi1w, sAdx1w, sImpulse1w, sSupertrend1w, sDonchian1w)
            array.set(ctx.biasBullFactors, 0, bull0)
            array.set(ctx.biasBearFactors, 0, bear0)
            array.set(ctx.biasBullFactors, 1, bull15)
            array.set(ctx.biasBearFactors, 1, bear15)
            array.set(ctx.biasBullFactors, 2, bull240)
            array.set(ctx.biasBearFactors, 2, bear240)
            array.set(ctx.biasBullFactors, 3, bull1d)
            array.set(ctx.biasBearFactors, 3, bear1d)
            array.set(ctx.biasBullFactors, 4, bull1w)
            array.set(ctx.biasBearFactors, 4, bear1w)

    if cfg.needMsTrendDirs
        ctx.dir0 := get_ms_trend_dir_for_slot(timeframe.period, timeframe.period, tf1, tf2, ltfData, htf1Data, htf2Data)
        ctx.dir15 := get_ms_trend_dir_for_slot("15", timeframe.period, tf1, tf2, ltfData, htf1Data, htf2Data)
        ctx.dir240 := get_ms_trend_dir_for_slot("240", timeframe.period, tf1, tf2, ltfData, htf1Data, htf2Data)
        ctx.dir1d := get_ms_trend_dir_for_slot("1D", timeframe.period, tf1, tf2, ltfData, htf1Data, htf2Data)
        ctx.dir1w := get_ms_trend_dir_for_slot("1W", timeframe.period, tf1, tf2, ltfData, htf1Data, htf2Data)

    if cfg.needPdPw
        [d_h, d_l, d_t] = request.security(syminfo.tickerid, "D", [high[1], low[1], time[1]], lookahead = barmerge.lookahead_on)
        ctx.pdh := d_h
        ctx.pdl := d_l
        ctx.pdTime := d_t

    if cfg.needPriceRange
        int lb = math.max(cfg.rangeLookbackBars, 1)
        ctx.rangeHigh := ta.highest(high, lb)
        ctx.rangeLow := ta.lowest(low, lb)

    if cfg.needHtfCandles
        [o1, h1, l1, c1, p1] = get_data_htf_candles(tf1)
        [o2, h2, l2, c2, p2] = get_data_htf_candles(tf2)
        ctx.htf1Open := o1
        ctx.htf1High := h1
        ctx.htf1Low := l1
        ctx.htf1Close := c1
        ctx.htf1Pattern := p1
        ctx.htf2Open := o2
        ctx.htf2High := h2
        ctx.htf2Low := l2
        ctx.htf2Close := c2
        ctx.htf2Pattern := p2

    if cfg.needMsSwingArrays
        ctx.ltfSwingHighPrices := ltfData.swingHighPrices
        ctx.ltfSwingHighTimes := ltfData.swingHighTimes
        ctx.ltfSwingLowPrices := ltfData.swingLowPrices
        ctx.ltfSwingLowTimes := ltfData.swingLowTimes
        ctx.htf1SwingHighPrices := htf1Data.swingHighPrices
        ctx.htf1SwingHighTimes := htf1Data.swingHighTimes
        ctx.htf1SwingLowPrices := htf1Data.swingLowPrices
        ctx.htf1SwingLowTimes := htf1Data.swingLowTimes
        ctx.htf2SwingHighPrices := htf2Data.swingHighPrices
        ctx.htf2SwingHighTimes := htf2Data.swingHighTimes
        ctx.htf2SwingLowPrices := htf2Data.swingLowPrices
        ctx.htf2SwingLowTimes := htf2Data.swingLowTimes

    ctx

// Applies candle-pattern border emphasis to a rendered HTF slot.
export apply_htf_candle_pattern_marks(HTF_Data store, bool show, int patSeries, int count, color tfColor, color bullColor, color bearColor, HTFCandleVisualCfg cfg) =>
    if not show
        if array.size(store.boxes) > 0
            for i = 0 to array.size(store.boxes) - 1
                box bx = array.get(store.boxes, i)
                bx.set_border_width(cfg.clearBorderWidth)
    else
        for i = 0 to count - 1
            int currD = i * 3
            int p = patSeries[currD]
            bool hasPattern = not na(p) and p > 0
            if i < array.size(store.boxes)
                box bx = array.get(store.boxes, i)
                if hasPattern
                    int pb = get_candle_pattern_bias(p)
                    color borderClr = pb > 0 ? bullColor : pb < 0 ? bearColor : tfColor
                    bx.set_border_color(color.new(borderClr, 0))
                    bx.set_border_width(cfg.patternBorderWidth)
                else
                    bx.set_border_width(cfg.clearBorderWidth)
    bool(na)

// ═══════════════════════════════════════════════════════════════════════════
//  CANDLE PATTERN DETECTION & SCORING
//  Reusable by any indicator. All logic centralised here.
// ═══════════════════════════════════════════════════════════════════════════

// ── private helpers ────────────────────────────────────────────────────────
_cp_body(o, c)      => math.abs(c - o)
_cp_rng(h, l)       => h - l
_cp_upWick(o, c, h) => h - math.max(o, c)
_cp_loWick(o, c, l) => math.min(o, c) - l
_cp_bull(o, c)      => c > o
_cp_bear(o, c)      => c < o

// Returns base reliability score (1-5) for a named pattern.
// 5 = 3-candle high conviction  4 = kicker  3 = engulf/marubozu
// 2 = single-bar moderate       1 = context-only (doji/inside/outside)
// Local Helper
export cp_base_score(string n) =>
    bool is5 = n == "Three White Soldiers" or n == "Three Black Crows" or n == "Morning Star" or n == "Evening Star"
    bool is4 = n == "Bullish Kicker" or n == "Bearish Kicker"
    bool is3 = n == "Bullish Engulfing" or n == "Bearish Engulfing" or n == "Bullish Marubozu" or n == "Bearish Marubozu" or n == "Piercing Line" or n == "Dark Cloud Cover"
    bool is2 = n == "Hammer" or n == "Hanging Man" or n == "Shooting Star" or n == "Inverted Hammer" or n == "Bullish Harami" or n == "Bearish Harami" or n == "Tweezer Bottom" or n == "Tweezer Top" or n == "Dragonfly Doji" or n == "Gravestone Doji"
    if is5
        5
    else if is4
        4
    else if is3
        3
    else if is2
        2
    else
        1

// Returns a star-rating string for the given score value.
export cp_score_stars(int score) =>
    if score >= 5
        "★★★★★"
    else if score == 4
        "★★★★☆"
    else if score == 3
        "★★★☆☆"
    else if score == 2
        "★★☆☆☆"
    else
        "★☆☆☆☆"

// Returns body bg color tinted by bias + score tier.
// Uses Theme transparency constants:
//   score 5 → T_NONE (0%) solid   4 → T_LOW (20%)   3 → T_MEDIUM (50%)
//   score 2 → 70%              1 → T_NORMAL (80%) — barely visible
export cp_score_color(int score, int bias, color bull, color bear, Theme th) =>
    if bias == 0
        na
    else
        color base  = bias == 1 ? bull : bear
        int   transp = score >= 5 ? th.T_NONE : score == 4 ? th.T_LOW : score == 3 ? th.T_MEDIUM : score == 2 ? 70 : th.T_NORMAL
        color.new(base, transp)

// Returns border color by conviction tier.
// score ≥5 + any vol  → bright white (top signal)
// score ≥4            → gold  #FFD700 (strong pattern)
// score = 3            → bias-tinted (moderate)
// score ≤2            → na (default thin border, no noise)
export cp_border_color(int score, int bias, color bull, color bear, Theme th) =>
    if score >= 5
        color.new(th.TEXT_COLOR, th.T_NONE)   // white – top conviction
    else if score >= 4
        color.new(#FFD700, th.T_NONE)          // gold – strong signal
    else if score == 3
        color base = bias == 1 ? bull : bear
        color.new(base, th.T_LOW)              // T_LOW = 20% transp (vivid tint)
    else
        na                                     // score ≤2: no border overlay

// Returns wick color based on volume ratio vs average.
// volRatio = volume / sma(volume, N)
//   ≥2.0 → extreme vol → bright white (institutional move)
//   ≥1.5 → high vol    → gold (#FFD700) — confirmed signal
//   ≥1.0 → normal vol  → bias color, T_LOW transp (clear but not loud)
//   < 1.0 → weak vol   → bias color, T_NORMAL transp (dim — caution: fake signal)
// When no pattern (bias==0): returns na so plotcandle uses default
export cp_wick_color(int score  , int bias, float volRatio, color bull, color bear, Theme th) =>
    if bias == 0 or score == 0
        na
    else
        color base = bias == 1 ? bull : bear
        if volRatio >= 2.0
            color.new(th.TEXT_COLOR, th.T_NONE)   // white — extreme volume
        else if volRatio >= 1.5
            color.new(#FFD700, th.T_NONE)          // gold — high volume
        else if volRatio >= 1.0
            color.new(base, th.T_LOW)              // tinted — average volume
        else
            color.new(base, th.T_NORMAL)           // dim — below-average (suspect)

// Runs all 25 pattern detectors using a CandlePatternCfg.
// Returns [patternName, bias, baseScore, confluenceVotes]
//   bias: +1 bullish | -1 bearish | 0 none
//   baseScore: 1-5 reliability of the dominant pattern
//   confluenceVotes: count of patterns voting in dominant direction
export cp_detect(CandlePatternCfg cfg) =>
    float dp  = cfg.dojiBodyMaxPct
    float wb  = cfg.wickBodyMin
    float ow  = cfg.oppositeWickMaxBody
    float em  = cfg.engulfMinPrevBody
    float ta  = cfg.tweezerTolAtr
    float mw  = cfg.marubozuMaxWickBody
    float tb  = cfg.threeLineMinBodyPct
    float sb  = 0.33   // star body max pct (fixed, sensible default)

    // ── 1. Doji ─────────────────────────────────────────────
    float _b0 = _cp_body(open, close)
    float _r0 = _cp_rng(high, low)
    bool d_doji = _r0 > 0 and (_b0 / _r0) <= dp

    // ── 2. Dragonfly Doji ───────────────────────────────────
    float _lo2 = _cp_loWick(open, close, low)
    float _up2 = _cp_upWick(open, close, high)
    bool d_dfly = _r0 > 0 and (_b0 / _r0) <= dp and _lo2 >= wb * math.max(_up2, syminfo.mintick)
    int   b_dfly = d_dfly ? 1 : 0

    // ── 3. Gravestone Doji ──────────────────────────────────
    bool d_grav = _r0 > 0 and (_b0 / _r0) <= dp and _up2 >= wb * math.max(_lo2, syminfo.mintick)
    int  b_grav = d_grav ? -1 : 0

    // ── 4. Hammer ───────────────────────────────────────────
    bool d_hammer = _b0 > 0 and _lo2 >= wb * _b0 and _up2 <= ow * _b0
    int  b_hammer = d_hammer ? 1 : 0

    // ── 5. Inverted Hammer ──────────────────────────────────
    bool d_iHam = _b0 > 0 and _up2 >= wb * _b0 and _lo2 <= ow * _b0
    int  b_iHam = d_iHam ? 1 : 0

    // ── 6. Hanging Man ──────────────────────────────────────
    bool d_hang = _b0 > 0 and _lo2 >= wb * _b0 and _up2 <= 0.3 * _b0
    int  b_hang = d_hang ? -1 : 0

    // ── 7. Shooting Star ────────────────────────────────────
    bool d_shoot = _b0 > 0 and _up2 >= wb * _b0 and _lo2 <= 0.3 * _b0
    int  b_shoot = d_shoot ? -1 : 0

    // ── 8. Bullish Marubozu ─────────────────────────────────
    bool d_mBull = _cp_bull(open, close) and _b0 > 0 and _up2 <= mw * _b0 and _lo2 <= mw * _b0
    int  b_mBull = d_mBull ? 1 : 0

    // ── 9. Bearish Marubozu ─────────────────────────────────
    bool d_mBear = _cp_bear(open, close) and _b0 > 0 and _up2 <= mw * _b0 and _lo2 <= mw * _b0
    int  b_mBear = d_mBear ? -1 : 0

    // ── 10. Bullish Engulfing ───────────────────────────────
    float _pb10 = _cp_body(open[1], close[1])
    bool d_bullEng = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and close >= open[1] and open <= close[1] and _b0 >= em * math.max(_pb10, syminfo.mintick)
    int  b_bullEng = d_bullEng ? 1 : 0

    // ── 11. Bearish Engulfing ───────────────────────────────
    bool d_bearEng = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and close <= open[1] and open >= close[1] and _b0 >= em * math.max(_pb10, syminfo.mintick)
    int  b_bearEng = d_bearEng ? -1 : 0

    // ── 12. Bullish Harami ──────────────────────────────────
    bool d_bullHar = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and high <= math.max(open[1], close[1]) and low >= math.min(open[1], close[1])
    int  b_bullHar = d_bullHar ? 1 : 0

    // ── 13. Bearish Harami ──────────────────────────────────
    bool d_bearHar = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and high <= math.max(open[1], close[1]) and low >= math.min(open[1], close[1])
    int  b_bearHar = d_bearHar ? -1 : 0

    // ── 14. Piercing Line ───────────────────────────────────
    float _mid14 = (open[1] + close[1]) / 2.0
    bool d_pierce = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and open <= close[1] and close > _mid14 and close < open[1]
    int  b_pierce = d_pierce ? 1 : 0

    // ── 15. Dark Cloud Cover ────────────────────────────────
    float _mid15 = (open[1] + close[1]) / 2.0
    bool d_dcc = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and open >= close[1] and close < _mid15 and close > open[1]
    int  b_dcc = d_dcc ? -1 : 0

    // ── 16. Morning Star ────────────────────────────────────
    float _c2b16 = _cp_body(open[2], close[2])
    float _c1b16 = _cp_body(open[1], close[1])
    bool d_morn = _cp_bear(open[2], close[2]) and _c1b16 <= sb * _c2b16 and _cp_bull(open, close) and close > (open[2] + close[2]) / 2.0
    int  b_morn = d_morn ? 1 : 0

    // ── 17. Evening Star ────────────────────────────────────
    float _c2b17 = _cp_body(open[2], close[2])
    float _c1b17 = _cp_body(open[1], close[1])
    bool d_even = _cp_bull(open[2], close[2]) and _c1b17 <= sb * _c2b17 and _cp_bear(open, close) and close < (open[2] + close[2]) / 2.0
    int  b_even = d_even ? -1 : 0

    // ── 18. Three White Soldiers ────────────────────────────
    float _r18a = _cp_rng(high, low)
    float _r18b = _cp_rng(high[1], low[1])
    float _r18c = _cp_rng(high[2], low[2])
    bool _3ws_c0 = _cp_bull(open, close)    and _cp_body(open, close)    >= tb * _r18a
    bool _3ws_c1 = _cp_bull(open[1], close[1]) and _cp_body(open[1], close[1]) >= tb * _r18b
    bool _3ws_c2 = _cp_bull(open[2], close[2]) and _cp_body(open[2], close[2]) >= tb * _r18c
    bool d_3ws = _3ws_c0 and _3ws_c1 and _3ws_c2 and close > close[1] and close[1] > close[2]
    int  b_3ws = d_3ws ? 1 : 0

    // ── 19. Three Black Crows ───────────────────────────────
    bool _3bc_c0 = _cp_bear(open, close)    and _cp_body(open, close)    >= tb * _r18a
    bool _3bc_c1 = _cp_bear(open[1], close[1]) and _cp_body(open[1], close[1]) >= tb * _r18b
    bool _3bc_c2 = _cp_bear(open[2], close[2]) and _cp_body(open[2], close[2]) >= tb * _r18c
    bool d_3bc = _3bc_c0 and _3bc_c1 and _3bc_c2 and close < close[1] and close[1] < close[2]
    int  b_3bc = d_3bc ? -1 : 0

    // ── 20. Bullish Kicker ──────────────────────────────────
    bool d_bKick = _cp_bear(open[1], close[1]) and _cp_bull(open, close) and open >= open[1]
    int  b_bKick = d_bKick ? 1 : 0

    // ── 21. Bearish Kicker ──────────────────────────────────
    bool d_brKick = _cp_bull(open[1], close[1]) and _cp_bear(open, close) and open <= open[1]
    int  b_brKick = d_brKick ? -1 : 0

    // ── 22. Tweezer Bottom ──────────────────────────────────
    float _atr22 = ta.atr(14)
    bool d_tBtm = math.abs(low - low[1]) <= _atr22 * ta and _cp_bear(open[1], close[1]) and _cp_bull(open, close)
    int  b_tBtm = d_tBtm ? 1 : 0

    // ── 23. Tweezer Top ─────────────────────────────────────
    bool d_tTop = math.abs(high - high[1]) <= _atr22 * ta and _cp_bull(open[1], close[1]) and _cp_bear(open, close)
    int  b_tTop = d_tTop ? -1 : 0

    // ── 24. Inside Bar ──────────────────────────────────────
    bool d_inside = high < high[1] and low > low[1]
    int  b_inside = d_inside ? (_cp_bull(open[1], close[1]) ? 1 : -1) : 0

    // ── 25. Outside Bar ─────────────────────────────────────
    bool d_outside = high > high[1] and low < low[1]
    int  b_outside = d_outside ? (_cp_bull(open, close) ? 1 : -1) : 0

    // ── Vote accumulation ───────────────────────────────────
    int bv = (b_dfly==1?1:0) + (b_hammer==1?1:0) + (b_iHam==1?1:0)  + (b_mBull==1?1:0)  + (b_bullEng==1?1:0) + (b_bullHar==1?1:0) + (b_pierce==1?1:0) + (b_morn==1?1:0) + (b_3ws==1?1:0) + (b_bKick==1?1:0) + (b_tBtm==1?1:0) + (b_inside==1?1:0) + (b_outside==1?1:0)
    int rv = (b_grav==-1?1:0) + (b_hang==-1?1:0) + (b_shoot==-1?1:0) + (b_mBear==-1?1:0) + (b_bearEng==-1?1:0) + (b_bearHar==-1?1:0) + (b_dcc==-1?1:0) + (b_even==-1?1:0) + (b_3bc==-1?1:0) + (b_brKick==-1?1:0) + (b_tTop==-1?1:0) + (b_inside==-1?1:0) + (b_outside==-1?1:0)

    int aggBias = bv > rv ? 1 : rv > bv ? -1 : 0
    int votes   = math.max(bv, rv)

    // ── Dominant pattern name (priority: 3-candle > kicker > 2-candle > 1-candle) ─
    string name = d_3ws     and aggBias ==  1 ? "Three White Soldiers" :
                  d_3bc     and aggBias == -1 ? "Three Black Crows"    :
                  d_bKick   and aggBias ==  1 ? "Bullish Kicker"       :
                  d_brKick  and aggBias == -1 ? "Bearish Kicker"       :
                  d_morn    and aggBias ==  1 ? "Morning Star"         :
                  d_even    and aggBias == -1 ? "Evening Star"         :
                  d_bullEng and aggBias ==  1 ? "Bullish Engulfing"    :
                  d_bearEng and aggBias == -1 ? "Bearish Engulfing"    :
                  d_pierce  and aggBias ==  1 ? "Piercing Line"        :
                  d_dcc     and aggBias == -1 ? "Dark Cloud Cover"     :
                  d_mBull   and aggBias ==  1 ? "Bullish Marubozu"     :
                  d_mBear   and aggBias == -1 ? "Bearish Marubozu"     :
                  d_hammer  and aggBias ==  1 ? "Hammer"               :
                  d_hang    and aggBias == -1 ? "Hanging Man"          :
                  d_dfly    and aggBias ==  1 ? "Dragonfly Doji"       :
                  d_grav    and aggBias == -1 ? "Gravestone Doji"      :
                  d_tBtm    and aggBias ==  1 ? "Tweezer Bottom"       :
                  d_tTop    and aggBias == -1 ? "Tweezer Top"          :
                  d_bullHar and aggBias ==  1 ? "Bullish Harami"       :
                  d_bearHar and aggBias == -1 ? "Bearish Harami"       :
                  d_iHam    and aggBias ==  1 ? "Inverted Hammer"      :
                  d_shoot   and aggBias == -1 ? "Shooting Star"        :
                  d_inside                    ? "Inside Bar"           :
                  d_outside                   ? "Outside Bar"          :
                  d_doji                      ? "Doji"                 :
                  "None"

    [name, aggBias, cp_base_score(name), votes]

// Returns line extension bars by source timeframe role.
export get_tf_line_ext_bars(string sourceTf, string tf1Name, string tf2Name, int ltfExt, int htf1Ext, int htf2Ext) =>
    sourceTf == tf2Name ? htf2Ext : sourceTf == tf1Name ? htf1Ext : ltfExt

// Returns line color by source timeframe role.
export get_tf_line_color(string sourceTf, string tf1Name, string tf2Name, color ltfColor, color htf1Color, color htf2Color) =>
    sourceTf == tf2Name ? htf2Color : sourceTf == tf1Name ? htf1Color : ltfColor

// Human-readable lifecycle name.
export get_lifecycle_name(int state, int formed, int touched, int respected, int reclaimed) =>
    state == formed ? "FORMED" :
     state == touched ? "TOUCHED" :
     state == respected ? "RESPECTED" :
     state == reclaimed ? "RECLAIMED" :
     "BROKEN"

// Merge lifecycle states with BROKEN precedence.
export merge_lifecycle_state(int a, int b, int brokenState) =>
    a == brokenState or b == brokenState ? brokenState : math.max(a, b)

// Builds SR tooltip from counters + lifecycle state.
export build_sr_tooltip(string touchesPrefix, int touchCount, int rejectCount, int state, int formed, int touched, int respected, int reclaimed) =>
    string touchLabel = touchesPrefix == "" ? "Touches" : touchesPrefix
    touchLabel + ": " + str.tostring(math.max(touchCount, 0)) + "\nRejects: " + str.tostring(math.max(rejectCount, 0)) + "\nState: " + get_lifecycle_name(state, formed, touched, respected, reclaimed)

// Returns next lifecycle state from generic break/touch/respect/reclaim inputs.
export lifecycle_next_state(bool breakCond, bool touchCond, bool respectCond, bool reclaimCond, bool cooldownOk, int prevState, int broken, int touched, int respected, int reclaimed) =>
    int next = prevState
    if breakCond
        next := broken
    else if touchCond and cooldownOk
        next := respectCond ? (prevState == broken ? reclaimed : respected) : touched
    else if reclaimCond and prevState == broken
        next := reclaimed
    next

// Returns next [touchCount, rejectCount] from generic touch/respect flags.
export lifecycle_next_counts(int touchCount, int rejectCount, bool touchCond, bool respectCond, bool cooldownOk) =>
    int t = math.max(touchCount, 0)
    int r = math.max(rejectCount, 0)
    if touchCond and cooldownOk
        t += 1
        if respectCond
            r += 1
    [t, r]

// Returns lifecycle line style mapped from state.
export lifecycle_line_style(int state, int touched, int broken, int reclaimed, string formedStyle, string touchedStyle, string brokenStyle, string reclaimedStyle) =>
    state == broken ? brokenStyle : state == touched ? touchedStyle : state == reclaimed ? reclaimedStyle : formedStyle

// Returns lifecycle alpha mapped from state.
export lifecycle_alpha(int state, int touched, int respected, int reclaimed, int broken, int formedAlpha, int touchedAlpha, int respectedAlpha, int reclaimedAlpha, int brokenAlpha) =>
    state == broken ? brokenAlpha :
     state == reclaimed ? reclaimedAlpha :
     state == respected ? respectedAlpha :
     state == touched ? touchedAlpha :
     formedAlpha
