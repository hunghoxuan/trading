// Shared baseline settings for duplicated cross-indicator constants.
export type Settings
    int GLOBAL_MAX_LOOKBACK_BARS = 500 // Global default lookback bars for lifecycle/render gating.
    int HTF_CANDLES_BASE = 16 // Base count for HTF1 projected candles/panel.
    int HTF_CANDLES_BIAS1 = 12 // Base count for HTF2 projected candles/panel.
    bool DYN_LOOKBACK_ENABLE = true // Enables dynamic HTF-derived lookback recalculation.
    string DYN_RECALC_MODE_ON_HTF2 = "ON_HTF2_CLOSE" // Recalculate when HTF2 closes.
    string DYN_RECALC_MODE_EVERY_N = "EVERY_N_BARS" // Recalculate every N bars.
    int DYN_RECALC_EVERY_BARS = 10 // N-bars interval when using EVERY_N_BARS mode.
    int DYN_HTF2_CANDLES_MIN = 3 // Min dynamic candle count for HTF2 panel.
    int DYN_HTF2_CANDLES_MAX = 12 // Max dynamic candle count for HTF2 panel.
    int DYN_HTF2_CANDLES_FALLBACK = 12 // Fallback HTF2 candle count when no anchor exists.
    int DYN_HTF1_CANDLES_MIN = 3 // Min derived candle count for HTF1 panel.
    int DYN_HTF1_CANDLES_MAX = 16 // Max derived candle count for HTF1 panel.
    int DYN_CURR_LOOKBACK_MIN_BARS = 50 // Min derived current-TF lookback bars.
    int DYN_CURR_LOOKBACK_MAX_BARS = 3000 // Max derived current-TF lookback bars.
    float MS_CURR_SWING_X_SHIFT_FRAC = 1.0 // Current-TF swing marker X offset factor.
    float MS_CURR_SWING_Y_SHIFT_TICKS = 0.0 // Current-TF swing marker Y offset in ticks.
    int MS_HTF1_SWING_Y_SHIFT_TICKS = 0 // HTF1 swing marker Y offset in ticks.
    int MS_HTF2_SWING_Y_SHIFT_TICKS = 0 // HTF2 swing marker Y offset in ticks.
    //int HTF_RIGHT_OFFSET = 20 // Right-side bars offset for HTF candle panels.
    int SWING_HISTORY_MAX = 120 // Max stored swing points in per-TF arrays.
    int SR_LINE_TRANSP = 72 // Support/Resistance line transparency.
    int W_BIAS_STRUCTURE = 3
    int W_BIAS_VWAP = 2
    int W_BIAS_EMA50 = 2
    int W_BIAS_RSI = 1
    int W_BIAS_ADX = 1
    int W_BIAS_RSI_IMPULSE = 1
    int W_BIAS_SUPERTREND = 2
    int W_BIAS_DONCHIAN = 2
    int BIAS_PROFILE_REACTIVE = 0 // TF profile: 1m-5m.
    int BIAS_PROFILE_INTRADAY = 1 // TF profile: 15m-1h.
    int BIAS_PROFILE_SWING = 2 // TF profile: 4h.
    int BIAS_PROFILE_MACRO = 3 // TF profile: 1D-1W.
    float SIGNAL_RR_DEFAULT = 1.0 // Default reward:risk target multiple for signal trade plans.
    float SIGNAL_STOPLOSS = 0.0 // 0=auto zone-edge stop, >0=fixed ATR-multiple stop distance from entry.
    bool ENTRY_REQUIRE_NEXT_BAR = true // If true, TP/SL checks start after entry candle closes.
    bool ENTRY_SL_FIRST_ON_DUAL_HIT = true // If TP+SL touched on same bar, prioritize SL.
    int ENTRY_RECENT_DUP_BARS = 2 // Default anti-duplicate window for recent active entries.
    string TOOLTIP_REASON_PREFIX = "\nReason: " // Shared tooltip prefix for reason text.
    string TOOLTIP_TOUCHES_PREFIX = "Touches: " // Shared tooltip prefix for touch-count labels.
    int CP_MIN_CONV = 2 // Min confluence score required to show candle-pattern emphasis.
    int CP_VOL_LEN = 20 // Candle-pattern relative-volume moving-average length.
    float CP_VOL_HIGH = 1.5 // Relative-volume threshold for high-volume bonus.
    float CP_VOL_EXTREME = 2.0 // Relative-volume threshold for extreme-volume bonus.
    float CP_DOJI_PCT = 0.10 // Max body/range ratio to classify doji-like candles.
    float CP_WICK_BODY = 2.0 // Min wick/body ratio for long-wick rejection families.
    float CP_WICK_DOMINANCE = 2.0 // Min dominant-wick factor vs opposite wick.
    float CP_OPPOSITE_WICK_MAX_BODY = 0.5 // Opposite wick cap (in body units).
    float CP_ENGULF_MIN = 1.0 // Min previous-body multiplier for engulfing validation.
    float CP_TWEEZER_ATR = 0.05 // Max ATR-distance between tweezer highs/lows.
    float CP_MARUBOZU_WICK = 0.05 // Max wick/body ratio for marubozu classification.
    float CP_3LINE_BODY = 0.60 // Min body/range ratio for 3-line momentum candles.
    float CP_VOL_MIN = 1.5 // Min relative volume for candle-pattern confluence bonus.
    

