emSweep = input.bool(true, "SW - Sweep.", inline="em4", group = GROUP_TRADE_MODELS)
emSweepWhen = TRIGGER_WHEN_RETEST
emSweepType = TRIGGER_TYPE_TRADE
emSweepRr = input.float(2.0, "RR", minval = 0.1, step = 0.1, inline="em4", group = GROUP_TRADE_MODELS)

