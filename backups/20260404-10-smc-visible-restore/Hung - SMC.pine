tradeMinSizeTicks = input.float(0.0, "Min size", minval = 0.0, step = 1.0, inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeMaxActive = input.int(1, "Trades", minval = 0, inline = "tc1", group = GROUP_TRADES_CONFIG)
gateUseEntryDirection = input.bool(false, "Dir gate", inline="tc3", group = GROUP_TRADES_CONFIG)
gateUseDynamicBiasModes = input.bool(false, "Dyn bias", inline="tc3", group = GROUP_TRADES_CONFIG)
gateUseRetestConfirm = input.bool(true, "Retest confirm", inline="tc5", group = GROUP_TRADES_CONFIG)
gateUseRetestInvalidation = input.bool(true, "Retest invalid", inline="tc6", group = GROUP_TRADES_CONFIG)
gateUsePretouchCancel = input.bool(false, "Pre-touch cancel", inline="tc6", group = GROUP_TRADES_CONFIG)
tradeEntriesEnabled = tradeEntriesInput and not uiModeNone
strategyOrdersEnabled = strategyOrdersInput and not uiModeNone
entryEngineEnabled = tradeEntriesEnabled or strategyOrdersEnabled
showTradesDashboard = true
gateUseMaxActive = tradeMaxActive > 0


// ==================== INIT / SETUP (ENTRY MODELS, PDARRAYs..) ====================
// barstate.isfirst
if barstate.isfirst
    localCfg := get_data_local_cfg(SETTINGS.GLOBAL_MAX_LOOKBACK_BARS, pdDisplayMode)
    workingFirstBar := KitCore.get_working_first_bar_from_lookback(localCfg.workingLookbackBars)
    uiCfg := get_ui_cfg(THEME)
    zqCfg.minHeightAtr := localCfg.zoneMinHeightAtr
    ZONE_VIS_CFG.minWidthBars := uiCfg.zoneCurrMinWidthBars
    cfgOB.extendBarsCurr := uiCfg.ltfBarsExt
    cfgFVG.extendBarsCurr := uiCfg.ltfBarsExt - 4
    cfgRJB.extendBarsCurr := uiCfg.ltfBarsExt
    cfgSD.extendBarsCurr := uiCfg.ltfBarsExt
    cfgBB.extendBarsCurr := uiCfg.ltfBarsExt
    cfgIFVG.extendBarsCurr := uiCfg.ltfBarsExt - 4
    uiCfg.htfShowProjectedZones := showProjectedZones

localCfg.riskPerRRUsd := tradeRiskPerRRUsd
localCfg.minTradeSizeTicks := tradeMinSizeTicks
localCfg.minTradeRR := 0.0
localCfg.displayMode := pdDisplayMode
localCfg.workingLookbackBars := KitCore.get_display_mode_working_lookback_bars(pdDisplayMode, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)
localCfg.displayZonePerTypeSideCap := pdDisplayMode == "Less" ? 2 : pdDisplayMode == "Normal" ? 1 : 999
localCfg.displayZoneSideTotalCap := pdDisplayMode == "Extreme" ? 1 : 999
localCfg.htfZoneLookbackBars := localCfg.workingLookbackBars
uiCfg.htfShowProjectedZones := showProjectedZones

// ==================== LOCAL HELPERS ====================
get_data_htf_detection_cutoff_time(int tfSlot, string tfName) =>
    int ratioTime = not na(tfName) ? KitSMC.get_working_first_time_for_tf(timeframe.period, tfName, localCfg.workingLookbackBars) : 0
    int structTime = KitSMC.get_tf_struct_pair_start_time(tfSlot, htf1Data.mss, htf2Data.mss)
    na(structTime) ? ratioTime : math.max(ratioTime, structTime)

get_data_working_first_idx_for_tf_name(string tfName) =>
    if na(tfName) or tfName == "" or tfName == timeframe.period
        workingFirstBar
    else
        [tf1Local, tf2Local] = KitCore.get_htf_pair()
        int tfSlot = tfName == tf1Local ? 0 : tfName == tf2Local ? 1 : 0
        int cutoffTime = get_data_htf_detection_cutoff_time(tfSlot, tfName)
        int cutoffIdx = KitUI.closest_bar_index_from_time(cutoffTime)
        na(cutoffIdx) ? workingFirstBar : cutoffIdx

get_data_real_htf_swings(string tfName, int pivotLen) =>
    float sh = na
    int shT = na
    float sl = na
    int slT = na
    if not na(tfName) and tfName != ""
        [shRaw, slRaw, shTRaw, slTRaw] = request.security(syminfo.tickerid, tfName, [ta.pivothigh(high, pivotLen, pivotLen), ta.pivotlow(low, pivotLen, pivotLen), not na(ta.pivothigh(high, pivotLen, pivotLen)) ? time[pivotLen] : int(na), not na(ta.pivotlow(low, pivotLen, pivotLen)) ? time[pivotLen] : int(na)], lookahead = barmerge.lookahead_off)
        sh := shRaw
        sl := slRaw
        shT := int(shTRaw)
        slT := int(slTRaw)
    [sh, shT, sl, slT]

process_data_prune_outside_working_zone(array<KitSMC.PDArray> zones) =>
    if array.size(zones) > 0
        for i = array.size(zones) - 1 to 0 by 1
            KitSMC.PDArray z = array.get(zones, i)
            int anchorIdx = na(z.barStart) ? na : z.barStart
            string sourceTf = na(z.sourceTf) or z.sourceTf == "" ? timeframe.period : z.sourceTf
            int firstIdx = get_data_working_first_idx_for_tf_name(sourceTf)
            if not na(anchorIdx) and anchorIdx < firstIdx
                KitSMC.delete_pd_array_drawings(z)
                array.remove(zones, i)
    bool(na)

get_pdarray_cfg(string zoneType) =>
    zoneType == "OB" ? cfgOB :
     zoneType == "FVG" ? cfgFVG :
     zoneType == "RJB" ? cfgRJB :
     zoneType == "SD" ? cfgSD :
     zoneType == "BB" ? cfgBB :
     zoneType == "IFVG" ? cfgIFVG :
     KitSMC.ZoneTypeConfig.new(0, "", "", "", "", 0, 0.0, 0, line.style_solid, false, false, "")

process_data_init_strategy_defs() =>
    array.clear(strategyDefs)
    array.push(strategyDefs, KitCore.EntryModelDef.new("BREAK_OUT", "BO", 6, emBreakout, emBreakoutType, emBreakoutWhen, emBreakoutRr, "edge", 1, 1, 0, "", 80, "na", 1, true, 0.0, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, KitCore.EntryModelDef.new("REJECTION", "RJ", 5, emRejection, emRejectionType, emRejectionWhen, emRejectionRr, "edge", 2, 0, 0, "", 120, "na", 1, true, 0.0, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, KitCore.EntryModelDef.new("SWEEP", "SW", 6, emSweep, emSweepType, emSweepWhen, emSweepRr, "edge", 1, 0, 0, "", 80, "na", 1, true, 0.0, ENTRY_MODE_LIMIT))
    bool(na)

process_data_reset_runtime_context_if_new_bar() =>
    int cachedBar = array.get(rtBarBox, 0)
    if na(cachedBar) or cachedBar != bar_index
        array.set(rtBarBox, 0, bar_index)
        array.clear(rtStrategyKeys)
        array.clear(rtStrategyEnabled)
        array.clear(rtStrategyScore)
        array.clear(rtStrategyShort)
        array.clear(rtStrategyTriggerType)
        array.clear(rtStrategyTriggerWhen)
        array.clear(rtPdMetaKeys)
        array.clear(rtPdMetaRank)
        array.clear(rtPdMetaLegId)
        array.clear(rtPdMetaLegDir)
        array.clear(rtPdMetaLegSeq)
        array.clear(rtMinRightKeys)
        array.clear(rtMinRightVals)
        array.clear(rtTimeToIdxKeys)
        array.clear(rtTimeToIdxVals)
    bool(na)

get_data_strategy_meta_by_key(string key) =>
    process_data_init_strategy_defs()
    string k = str.upper(key)
    process_data_reset_runtime_context_if_new_bar()
    int cachedIdx = na
    if array.size(rtStrategyKeys) > 0
        for i = 0 to array.size(rtStrategyKeys) - 1
            if array.get(rtStrategyKeys, i) == k
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtStrategyEnabled, cachedIdx), array.get(rtStrategyScore, cachedIdx), array.get(rtStrategyShort, cachedIdx), array.get(rtStrategyTriggerType, cachedIdx), array.get(rtStrategyTriggerWhen, cachedIdx)]
    else
        bool enabled = false
        int score = 0
        string shortName = ""
        string triggerType = TRIGGER_TYPE_TRADE
        string triggerWhen = TRIGGER_WHEN_RETEST
        if array.size(strategyDefs) > 0
            for i = 0 to array.size(strategyDefs) - 1
                KitCore.EntryModelDef s = array.get(strategyDefs, i)
                if s.key == k
                    enabled := s.enabled
                    score := s.baseScore
                    shortName := s.shortName
                    triggerType := s.trigger_type
                    triggerWhen := s.trigger_when
                    break
        array.push(rtStrategyKeys, k)
        array.push(rtStrategyEnabled, enabled)
        array.push(rtStrategyScore, score)
        array.push(rtStrategyShort, shortName)
        array.push(rtStrategyTriggerType, triggerType)
        array.push(rtStrategyTriggerWhen, triggerWhen)
        [enabled, score, shortName, triggerType, triggerWhen]

get_data_cached_bar_index_from_time(int t) =>
    process_data_reset_runtime_context_if_new_bar()
    if na(t)
        na
    else
        int idx = na
        if array.size(rtTimeToIdxKeys) > 0
            for i = 0 to array.size(rtTimeToIdxKeys) - 1
                if array.get(rtTimeToIdxKeys, i) == t
                    idx := i
                    break
        if not na(idx)
            array.get(rtTimeToIdxVals, idx)
        else
            int v = KitUI.closest_bar_index_from_time(t)
            array.push(rtTimeToIdxKeys, t)
            array.push(rtTimeToIdxVals, v)
            v

BIAS_TOG = KitCore.BiasToggles.new(true, true, true, true, true, true, true, true)

prune_post_touch_pdarrays(array<KitSMC.PDArray> zones, int keepMax, float ageDecay) =>
    int cnt = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            KitSMC.PDArray z = array.get(zones, i)
            bool isCurrentTf = z.sourceTfRank <= 1
            if isCurrentTf and KitSMC.is_pdarray_post_touch(z) and not z.broken
                cnt += 1
    while cnt > keepMax
        int weakestIdx = na
        float weakestScore = 10e10
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                KitSMC.PDArray z = array.get(zones, i)
                bool isCurrentTf = z.sourceTfRank <= 1
                if isCurrentTf and KitSMC.is_pdarray_post_touch(z) and not z.broken
                    float s = nz(z.qualityPct, 0.0) - (math.max(bar_index - z.barStart, 0) * ageDecay)
                    if na(weakestIdx) or s < weakestScore
                        weakestScore := s
                        weakestIdx := i
        if not na(weakestIdx)
            KitSMC.PDArray zDel = array.get(zones, weakestIdx)
            KitSMC.delete_pd_array_drawings(zDel)
            array.remove(zones, weakestIdx)
            cnt -= 1
        else
            cnt := keepMax
    bool(na)

apply_removed_pdarray_visuals(array<KitSMC.PDArray> removed) =>
    if array.size(removed) > 0
        for i = 0 to array.size(removed) - 1
            KitSMC.PDArray zDel = array.get(removed, i)
            KitSMC.delete_pd_array_drawings(zDel)
    bool(na)

add_primary_zone(array<KitSMC.PDArray> zones, string type, bool isBull, float top, float btm, int leftIdx, int ext, string labelText, int labelX, float labelY, color labelColor, color borderColor, string borderStyle, float qualityPct, int tfSlot) =>
    bool merged = false
    if na(leftIdx) or leftIdx < workingFirstBar
        bool(na)
    else if merged
        bool(na)
    else
        string labelSize = tfSlot == 1 ? THEME.SIZE_SMALL : tfSlot == 0 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL
        bool showLabel = labelSize != "None"
        color resolvedLabelColor = na(labelColor) ? uiCfg.ltfColor : labelColor
        color resolvedBorderColor = borderColor
        if tfSlot < 0 and not na(resolvedBorderColor)
            resolvedBorderColor := color.new(uiCfg.ltfColor, 85)
        if tfSlot < 0
            resolvedLabelColor := uiCfg.ltfColor
        color areaFillColor = uiCfg.colorBg
        bool strong = not na(qualityPct) and qualityPct >= 70.0
        if strong
            resolvedLabelColor := color.new(resolvedLabelColor, 0)
        KitSMC.ZoneVisualCfg zoneCfg = ZONE_VIS_CFG
        zoneCfg.textSize := labelSize
        SR_VIS_CFG.lineStyle := CFG_SR.lineStyle
        SR_VIS_CFG.lineWidth := CFG_SR.lineWidth
        SR_VIS_CFG.labelSize := labelSize
        SR_VIS_CFG.showLabel := CFG_SR.showLabel
        KitSMC.PDArray z = KitSMC.PDArray.new()
        z.type := type
        z.top := top
        z.bottom := btm
        z.barStart := leftIdx
        z.isBullish := isBull
        z.labelText := labelText
        z.extendBars := ext
        z.qualityPct := qualityPct
        z := KitSMC.draw_price_zone(z, leftIdx, bar_index + ext, top, btm, areaFillColor, resolvedBorderColor, borderStyle, labelText, resolvedLabelColor, "", labelX, labelY, zoneCfg, SR_VIS_CFG, true, false, (top + btm) / 2.0, CFG_SR.lineColor, "AREA", showLabel)
        z.lifeState := CONST.LIFE_FORMED
        z.touchCount := 0
        array<KitSMC.PDArray> removed = KitSMC.add_active_zone(zones, z, localCfg.zoneCapPerType, localCfg.zoneCapTotal, localCfg.zoneCurrMaxPerTypeSide, effectiveCurrLookbackBars, last_bar_index, close, bar_index, localCfg.zonePriorityAgeDecay)
        apply_removed_pdarray_visuals(removed)
    bool(na)

process_data_add_ltf_candidate(KitSMC.PDArrayCandidate cand) =>
    string zoneType = cand.type
    bool isBull = cand.isBullish
    float top = cand.top
    float btm = cand.bottom
    int leftIdx = cand.leftIdx
    float qPct = cand.qualityPct
    string labelText = cand.labelText
    if zoneType == "OB"
        KitSMC.ZoneTypeConfig obCfg = get_pdarray_cfg("OB")
        int ext = obCfg.extendBarsCurr > 0 ? obCfg.extendBarsCurr : KitCore.get_current_pdarray_extend("OB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        string borderStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
        color labelColor = isBull ? uiCfg.colorBullish : color.new(uiCfg.colorBearish, 20)
        color borderColor = isBull ? (THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBullish, 55)) : color.new(uiCfg.colorBearish, 55)
        float labelY = isBull ? top : btm
        add_primary_zone(smcCtx.zones, zoneType, isBull, top, btm, leftIdx, ext, labelText, bar_index + 3, labelY, labelColor, borderColor, borderStyle, qPct, -1)
    else if zoneType == "RJB"
        KitSMC.ZoneTypeConfig rjbCfg = get_pdarray_cfg("RJB")
        int ext = rjbCfg.extendBarsCurr > 0 ? rjbCfg.extendBarsCurr : KitCore.get_current_pdarray_extend("RJB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        string borderStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
        color labelColor = isBull ? uiCfg.colorBullish : color.new(uiCfg.colorBearish, THEME.T_LOW)
        color borderColor = THEME.STYLE_STRONG == "None" ? na : (isBull ? color.new(uiCfg.colorBullish, 55) : color.new(uiCfg.colorBearish, 55))
        float labelY = isBull ? top : btm
        add_primary_zone(smcCtx.zones, zoneType, isBull, top, btm, leftIdx, ext, labelText, bar_index + 11, labelY, labelColor, borderColor, borderStyle, qPct, -1)
    else if zoneType == "FVG"
        KitSMC.ZoneTypeConfig fvgCfg = get_pdarray_cfg("FVG")
        int ext = fvgCfg.extendBarsCurr > 0 ? fvgCfg.extendBarsCurr : KitCore.get_current_pdarray_extend("FVG", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        color labelColor = isBull ? uiCfg.colorBullish : color.new(uiCfg.colorBearish, THEME.T_LOW)
        add_primary_zone(smcCtx.zones, zoneType, isBull, top, btm, leftIdx, ext, labelText, bar_index + 7, (top + btm) / 2.0, labelColor, na, line.style_solid, qPct, -1)
    bool(na)

process_data_detect_ltf_pdarrays() =>
    if array.size(smcCtx.ltfCandidates) > 0
        for i = 0 to array.size(smcCtx.ltfCandidates) - 1
            process_data_add_ltf_candidate(array.get(smcCtx.ltfCandidates, i))
    bool(na)

spawn_derived_zone(array<KitSMC.PDArray> zones, string newType, bool isBull, float top, float btm, float qualityPct) =>
    KitSMC.ZoneTypeConfig cfg = get_pdarray_cfg(newType)
    float q = nz(qualityPct, 0.0)
    int ext = cfg.extendBarsCurr > 0 ? cfg.extendBarsCurr : KitCore.get_current_pdarray_extend(newType, uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
    color txtColor = uiCfg.ltfColor
    borderStyle = cfg.borderStyle
    color borderColor = cfg.noBorder ? na : color.new(uiCfg.ltfColor, 85)
    string lbl = cfg.shortName != "" ? cfg.shortName : (newType == "BB" ? "BB" : "iFVG")
    KitSMC.PDArray z = KitSMC.PDArray.new()
    z.type := newType
    z.top := top
    z.bottom := btm
    z.barStart := bar_index
    z.isBullish := isBull
    z.labelText := lbl
    z.extendBars := ext
    z.qualityPct := q
    z := KitSMC.draw_price_zone(z, bar_index, bar_index + ext, top, btm, uiCfg.colorBg, borderColor, borderStyle, lbl, txtColor, "", bar_index + ext, (top + btm) / 2.0, ZONE_VIS_CFG, SR_VIS_CFG, true, false, na, borderColor, "AREA", true)
    z.lifeState := CONST.LIFE_FORMED
    z.touchCount := 0
    z.rejectCount := 0
    array<KitSMC.PDArray> removed = KitSMC.add_active_zone(zones, z, localCfg.zoneCapPerType, localCfg.zoneCapTotal, localCfg.zoneCurrMaxPerTypeSide, effectiveCurrLookbackBars, last_bar_index, close, bar_index, localCfg.zonePriorityAgeDecay)
    apply_removed_pdarray_visuals(removed)

annotate_new_pricezones(array<KitSMC.PDArray> zones, int startIdx, string sourceTf, int sourceTfRank, KitSMC.TFData tfData) =>
    int zoneCount = array.size(zones)
    if startIdx < zoneCount
        for i = startIdx to zoneCount - 1
            KitSMC.PDArray z = array.get(zones, i)
            if z.sourceTf == ""
                tfData.mss.legSeqAll += 1
                int seqType = 0
                if z.type == "OB" or z.type == "BB"
                    tfData.mss.legSeqOb += 1
                    seqType := tfData.mss.legSeqOb
                else if z.type == "FVG" or z.type == "IFVG"
                    tfData.mss.legSeqFvg += 1
                    seqType := tfData.mss.legSeqFvg
                else if z.type == "RJB"
                    tfData.mss.legSeqRjb += 1
                    seqType := tfData.mss.legSeqRjb
                else
                    tfData.mss.legSeqLevel += 1
                    seqType := tfData.mss.legSeqLevel
                z.sourceTf := sourceTf
                z.sourceTfRank := sourceTfRank
                z.legId := tfData.mss.legId
                z.legDir := tfData.mss.legDir
                z.legSeqAll := tfData.mss.legSeqAll
                z.legSeqType := seqType
                array.set(zones, i, z)

is_pdarray_trade_type(string type) =>
    string t = str.upper(type)
    str.contains(t, "OB") or str.contains(t, "BB") or str.contains(t, "FVG") or str.contains(t, "IFVG") or str.contains(t, "RJB") or str.contains(t, "SD")

get_trade_pdarray_meta(string type, float zoneTop, float zoneBtm) =>
    process_data_reset_runtime_context_if_new_bar()
    string metaKey = type + "|" + str.tostring(zoneTop, "#.#####") + "|" + str.tostring(zoneBtm, "#.#####")
    int cachedIdx = na
    if array.size(rtPdMetaKeys) > 0
        for i = 0 to array.size(rtPdMetaKeys) - 1
            if array.get(rtPdMetaKeys, i) == metaKey
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtPdMetaRank, cachedIdx), array.get(rtPdMetaLegId, cachedIdx), array.get(rtPdMetaLegDir, cachedIdx), array.get(rtPdMetaLegSeq, cachedIdx)]
    else
        int outRank = 0
        int outLegId = -1
        int outLegDir = 0
        int outLegSeq = -1
        float tol = syminfo.mintick * 2.0
        if array.size(smcCtx.zones) > 0
            for i = array.size(smcCtx.zones) - 1 to 0
                KitSMC.PDArray z = array.get(smcCtx.zones, i)
                bool sameType = z.type == type
                bool nearTop = math.abs(z.top - zoneTop) <= tol
                bool nearBtm = math.abs(z.bottom - zoneBtm) <= tol
                if sameType and nearTop and nearBtm
                    outRank := z.sourceTfRank
                    outLegId := z.legId
                    outLegDir := z.legDir
                    outLegSeq := z.legSeqAll
                    break
        array.push(rtPdMetaKeys, metaKey)
        array.push(rtPdMetaRank, outRank)
        array.push(rtPdMetaLegId, outLegId)
        array.push(rtPdMetaLegDir, outLegDir)
        array.push(rtPdMetaLegSeq, outLegSeq)
        [outRank, outLegId, outLegDir, outLegSeq]

passes_pdarray_trade_filter(string type, float qualityPct, float zoneTop, float zoneBtm, string direction) =>
    bool pass = true
    if localCfg.entryZoneFilterEnable and is_pdarray_trade_type(type)
        [srcRank, legId, legDir, legSeq] = get_trade_pdarray_meta(type, zoneTop, zoneBtm)
        float q = nz(qualityPct, 0.0)
        if pass and q < localCfg.entryZoneMinQualityPct
            pass := false
        if pass and localCfg.entryFilterNearLegEnable
            bool known = legId >= 0 and legSeq > 0
            bool seqOk = known and legSeq <= localCfg.entryFilterNearLegMaxSeq
            bool dirOk = true
            if localCfg.entryFilterNearLegRequireDirMatch and known
                bool isBuy = str.upper(direction) == "BUY"
                dirOk := (isBuy and legDir >= 0) or ((not isBuy) and legDir <= 0)
            pass := known ? (seqOk and dirOk) : localCfg.entryFilterNearLegAllowUnknown
    pass

add_htf_pdarray_core(array<KitSMC.PDArray> zones, int tfSlot, string zoneType, bool isBull, float top, float btm, int startTs, float qPct) =>
    int ext = KitCore.get_htf_pdarray_extend(tfSlot, HTF1_EXT_BASE + HTF_EXT_PAD, HTF2_EXT_BASE + HTF_EXT_PAD)
    string lbl = zoneType == "SD" ? (isBull ? "D" : "S") : str.upper(zoneType)
    bool hasDupSameSlot = false
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            KitSMC.PDArray z = array.get(zones, i)
            bool sameTypeSide = z.type == zoneType and z.isBullish == isBull
            bool sameSlot = z.extendBars == ext
            if sameTypeSide and sameSlot and KitSMC.pd_arrays_overlap(top, btm, z.top, z.bottom)
                hasDupSameSlot := true
                break
    if not hasDupSameSlot
        int leftIdxRaw = get_data_cached_bar_index_from_time(startTs)
        int leftIdx = na(leftIdxRaw) ? bar_index : leftIdxRaw
        KitSMC.ZoneTypeConfig cfg = get_pdarray_cfg(zoneType)
        color lineClr = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 0) : color.new(htf2Cfg.zigzagColor, 0)
        color tfBorder = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 85) : color.new(htf2Cfg.zigzagColor, 85)
        color borderClr = cfg.noBorder ? na : tfBorder
        string borderStyle = cfg.borderStyle
        float y = (top + btm) * 0.5
        int labelX = bar_index + 5
        add_primary_zone(zones, zoneType, isBull, top, btm, leftIdx, ext, lbl, labelX, y, lineClr, borderClr, borderStyle, qPct, tfSlot)
    bool(na)

add_htf_pdarray_if_valid(array<KitSMC.PDArray> zones, string tfLabel, int tfSlot, bool showTf, bool showType, string zoneType, bool isBull, float top, float btm, int startTs, float qPct) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    string tfName = tfSlot == 0 ? tf1Local : tf2Local
    int recentTsCut = get_data_htf_detection_cutoff_time(tfSlot, tfName)
    bool recent = not na(startTs) and startTs >= recentTsCut
    bool sdRelax = pdDisplayMode == "Less" and zoneType == "SD"
    bool recencyOk = sdRelax ? not na(startTs) : recent
    bool qualityOk = sdRelax ? true : nz(qPct, 0) >= localCfg.htfProjectionMinQualityPct
    bool unmitigated = zoneType == "SD" ? true : (isBull ? (low > top) : (high < btm))
    bool valid = showTf and showType and recencyOk and not na(startTs) and not na(top) and not na(btm) and top > btm and qualityOk and unmitigated
    if valid
        add_htf_pdarray_core(zones, tfSlot, zoneType, isBull, top, btm, startTs, qPct)
    bool(na)

process_data_add_htf_side_fallback(array<KitSMC.PDArray> zones, int startIdx, int tfSlot, bool showTf, bool wantAbove,
 bool showType0, string type0, bool bull0, float top0, float btm0, int st0, float q0,
 bool showType1, string type1, bool bull1, float top1, float btm1, int st1, float q1,
 bool showType2, string type2, bool bull2, float top2, float btm2, int st2, float q2,
 bool showType3, string type3, bool bull3, float top3, float btm3, int st3, float q3) =>
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    string tfName = tfSlot == 0 ? tf1Local : tf2Local
    int recentTsCut = get_data_htf_detection_cutoff_time(tfSlot, tfName)
    [hasChoice, zType, isBull, top, btm, st, q] = KitSMC.pick_htf_side_fallback(zones, startIdx, showTf, wantAbove, close, recentTsCut, localCfg.htfProjectionMinQualityPct, low, high, syminfo.mintick,
     showType0, type0, bull0, top0, btm0, st0, q0,
     showType1, type1, bull1, top1, btm1, st1, q1,
     showType2, type2, bull2, top2, btm2, st2, q2,
     showType3, type3, bull3, top3, btm3, st3, q3)
    if hasChoice
        add_htf_pdarray_core(zones, tfSlot, zType, isBull, top, btm, st, q)
    bool(na)

process_data_add_htf_side_fallback_both(array<KitSMC.PDArray> zones, int startIdx, int tfSlot, bool showTf,
 bool showType0, string type0, bool bull0, float top0, float btm0, int st0, float q0,
 bool showType1, string type1, bool bull1, float top1, float btm1, int st1, float q1,
 bool showType2, string type2, bool bull2, float top2, float btm2, int st2, float q2,
 bool showType3, string type3, bool bull3, float top3, float btm3, int st3, float q3) =>
    process_data_add_htf_side_fallback(zones, startIdx, tfSlot, showTf, true,
     showType0, type0, bull0, top0, btm0, st0, q0,
     showType1, type1, bull1, top1, btm1, st1, q1,
     showType2, type2, bull2, top2, btm2, st2, q2,
     showType3, type3, bull3, top3, btm3, st3, q3)
    process_data_add_htf_side_fallback(zones, startIdx, tfSlot, showTf, false,
     showType0, type0, bull0, top0, btm0, st0, q0,
     showType1, type1, bull1, top1, btm1, st1, q1,
     showType2, type2, bull2, top2, btm2, st2, q2,
     showType3, type3, bull3, top3, btm3, st3, q3)
    bool(na)

process_data_attach_htf_pdarrays_for_tf(array<KitSMC.PDArray> zones, string tfName, int tfSlot, bool showTf,
 bool obEnabled, float obUpTop, float obUpBtm, int obUpStart, float obUpQ,
 float obDnTop, float obDnBtm, int obDnStart, float obDnQ,
 bool fvgEnabled, float fvgUpTop, float fvgUpBtm, int fvgUpStart, float fvgUpQ,
 float fvgDnTop, float fvgDnBtm, int fvgDnStart, float fvgDnQ,
 bool sdEnabled, float sdSupTop, float sdSupBtm, int sdSupStart,
 float sdDemTop, float sdDemBtm, int sdDemStart,
 KitSMC.TFData tfData, int sourceTfRank) =>
    string tfLabel = showTf ? KitUI.get_friendly_tf(tfName) : ""
    int zoneStartIdx = array.size(zones)
    add_htf_pdarray_if_valid(zones, tfLabel, tfSlot, showTf, obEnabled, "OB", true, obUpTop, obUpBtm, obUpStart, obUpQ)
    add_htf_pdarray_if_valid(zones, tfLabel, tfSlot, showTf, obEnabled, "OB", false, obDnTop, obDnBtm, obDnStart, obDnQ)
    add_htf_pdarray_if_valid(zones, tfLabel, tfSlot, showTf, fvgEnabled, "FVG", true, fvgUpTop, fvgUpBtm, fvgUpStart, fvgUpQ)
    add_htf_pdarray_if_valid(zones, tfLabel, tfSlot, showTf, fvgEnabled, "FVG", false, fvgDnTop, fvgDnBtm, fvgDnStart, fvgDnQ)
    process_data_add_htf_side_fallback_both(zones, zoneStartIdx, tfSlot, showTf,
     obEnabled, "OB", true, obUpTop, obUpBtm, obUpStart, obUpQ,
     obEnabled, "OB", false, obDnTop, obDnBtm, obDnStart, obDnQ,
     fvgEnabled, "FVG", true, fvgUpTop, fvgUpBtm, fvgUpStart, fvgUpQ,
     fvgEnabled, "FVG", false, fvgDnTop, fvgDnBtm, fvgDnStart, fvgDnQ)
    add_htf_pdarray_if_valid(zones, tfLabel, tfSlot, showTf, sdEnabled, "SD", false, sdSupTop, sdSupBtm, sdSupStart, 100.0)
    add_htf_pdarray_if_valid(zones, tfLabel, tfSlot, showTf, sdEnabled, "SD", true, sdDemTop, sdDemBtm, sdDemStart, 100.0)
    annotate_new_pricezones(zones, zoneStartIdx, tfName, sourceTfRank, tfData)
    bool(na)

get_data_htf_sd_snapshot(float thresholdPct, int divBins, int lookbackBars) =>
    int lb = math.max(5, lookbackBars)
    float hi = ta.highest(high, lb)
    float lo = ta.lowest(low, lb)
    float csum = math.sum(volume, lb)
    float bin = (hi - lo) / divBins
    int safeOff = math.max(0, math.min(math.min(lb - 1, bar_index), 10000))
    int st = int(time[safeOff])
    float sTop = na
    float sBtm = na
    float dTop = na
    float dBtm = na
    if csum > 0 and bin > 0
        float sAcc = 0.0
        float dAcc = 0.0
        for i = 0 to divBins - 1
            float sLvl = hi - (i + 1) * bin
            float sPrev = hi - i * bin
            float dLvl = lo + (i + 1) * bin
            float dPrev = lo + i * bin
            float sVol = 0.0
            float dVol = 0.0
            for j = 0 to lb - 1
                if high[j] > sLvl and high[j] <= sPrev
                    sVol += volume[j]
                if low[j] >= dPrev and low[j] < dLvl
                    dVol += volume[j]
            sAcc += sVol
            dAcc += dVol
            if na(sBtm) and sAcc / csum * 100 > thresholdPct
                sTop := hi
                sBtm := sLvl
            if na(dTop) and dAcc / csum * 100 > thresholdPct
                dTop := dLvl
                dBtm := lo
            if not na(sBtm) and not na(dTop)
                break
    [sTop, sBtm, st, dTop, dBtm, st]

get_data_entry_model_dynamic_cfg(string modelKey) =>
    process_data_init_strategy_defs()
    string k = str.upper(modelKey)
    float rrCfg = 2.0
    string entryPoint = "edge"
    int biasLtfMode = 1
    int biasHtf1Mode = 0
    int biasHtf2Mode = 0
    string requiredPrevEvents = ""
    int requiredWindowBars = 80
    string biasDirection = "na"
    int maxActiveCfg = 1
    bool dynamicTpCfg = true
    float riskZonePctCfg = 0.0
    string entryModeCfg = ENTRY_MODE_AFTER_RETEST
    if array.size(strategyDefs) > 0
        for i = 0 to array.size(strategyDefs) - 1
            KitCore.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                rrCfg := s.rr
                entryPoint := s.entry_point
                biasLtfMode := s.bias_ltf
                biasHtf1Mode := s.bias_htf1
                biasHtf2Mode := s.bias_htf2
                requiredPrevEvents := s.required_previous_events
                requiredWindowBars := s.required_window_bars
                biasDirection := s.bias_direction
                maxActiveCfg := s.max_active
                dynamicTpCfg := s.dynamic_tp_sl
                riskZonePctCfg := s.risk_zone_pct
                entryModeCfg := s.entry_mode
                break
    [rrCfg, entryPoint, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, maxActiveCfg, dynamicTpCfg, riskZonePctCfg, entryModeCfg]

get_cached_pdarray_min_right(KitSMC.PDArray z, int desiredRight, int minWidthBars) =>
    process_data_reset_runtime_context_if_new_bar()
    string key = z.type + "|" + str.tostring(z.barStart) + "|" + str.tostring(desiredRight) + "|" + str.tostring(minWidthBars)
    int idx = na
    if array.size(rtMinRightKeys) > 0
        for i = 0 to array.size(rtMinRightKeys) - 1
            if array.get(rtMinRightKeys, i) == key
                idx := i
                break
    if not na(idx)
        array.get(rtMinRightVals, idx)
    else
        int v = KitSMC.get_pdarray_min_right_idx(z, desiredRight, minWidthBars)
        array.push(rtMinRightKeys, key)
        array.push(rtMinRightVals, v)
        v

get_model_key_for_type(string t) =>
    string u = str.upper(t)
    (u == "OB" or u == "FVG" or u == "SD" or u == "BB" or u == "IFVG" or u == "RJB" or u == "BO" or u == "BREAK_OUT" or u == "BOS" or u == "MSS" or u == "MS") ? "BREAK_OUT" :
     ((u == "RJ" or u == "REJECTION") ? "REJECTION" :
     ((u == "SW" or u == "SWEEP") ? "SWEEP" : u))

is_pdarray_type_enabled(string t) =>
    string u = str.upper(t)
    (u == "OB" and plotOB) or (u == "FVG" and plotFVG) or (u == "SD" and plotSD) or (u == "BB" and useBB) or (u == "IFVG" and useIFVG) or (u == "RJB") or (u == "SWEEP")

process_data_add_entry(string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal, string pdarrayType) =>
    bool isBuy = direction == "Buy"
    float zoneTop = math.max(levelTop, levelBtm)
    float zoneBtm = math.min(levelTop, levelBtm)
    string modelKey = get_model_key_for_type(type)
    [rrCfg, entryPointCfg, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, maxActiveCfg, _, riskPctCfg, _] = get_data_entry_model_dynamic_cfg(modelKey)
    int effBiasLtfMode = gateUseDynamicBiasModes ? biasLtfMode : 0
    int effBiasHtf1Mode = gateUseDynamicBiasModes ? biasHtf1Mode : 0
    int effBiasHtf2Mode = gateUseDynamicBiasModes ? biasHtf2Mode : 0
    bool passDynamic = KitSMC.check_entry_model_dynamic(tradeBiasVals, tradeTrendVals, smcCtx.signalHist, direction, 0, effBiasLtfMode, effBiasHtf1Mode, effBiasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, bar_index)
    bool passSide = true
    bool allowEntry = passes_pdarray_trade_filter(type, qualityPct, zoneTop, zoneBtm, direction) and passSide and passDynamic
    int maxEntries = gateUseMaxActive ? math.max(tradeMaxActive, 1) : math.max(maxActiveCfg, 1)
    int activeCount = tradeEntriesEnabled ? KitCore.count_start_trades(trades, CONST) : strategy.opentrades
    bool passBatchCap = not gateUseMaxActive or activeCount < maxEntries
    if allowEntry and passBatchCap
        KitSMC.cache_signal_memory_event(smcCtx.signalHist, KitSMC.Event.new(type, direction, levelTop, levelBtm, na, bar_index, int(na), false, reason, qualityPct, scoreVal), syminfo.mintick, 80)
        float tick = syminfo.mintick
        float sameZoneTol = tick * 2.0
        float zoneHeight = math.max(zoneTop - zoneBtm, syminfo.mintick)
        float slRaw = isBuy ? zoneBtm : zoneTop
        float riskPct = math.max(riskPctCfg, 0.0)

        int mode = entryPointCfg == "middle" ? 1 : entryPointCfg == "end" ? 2 : 0
        float entry = mode == 0 ? (isBuy ? zoneTop : zoneBtm) : mode == 1 ? ((zoneTop + zoneBtm) * 0.5) : slRaw
        float slGap = zoneHeight * riskPct
        float stoploss = isBuy ? (slRaw - slGap) : (slRaw + slGap)
        float riskBase = math.max(math.abs(entry - slRaw), syminfo.mintick)
        float rrUsed = math.max(rrCfg, 0.1)
        float takeprofit = isBuy ? (entry + riskBase * rrUsed) : (entry - riskBase * rrUsed)

        float orderQty = KitCore.get_trade_order_qty(entry, stoploss, localCfg.riskPerRRUsd)
        if KitCore.is_trade_plan_valid_with_limits(entry, stoploss, takeprofit, localCfg.minTradeSizeTicks, localCfg.minTradeRR)
            string modeTag = mode == 0 ? ".E" : mode == 1 ? ".M" : ".N"
            string tradeType = type + modeTag
            string sh = str.upper(type)
            int p = str.pos(sh, ".")
            sh := p >= 0 ? str.substring(sh, 0, p) : sh
            string longName = sh == "RJ" or sh == "REJECTION" ? "Rejection" : sh == "SW" or sh == "SWEEP" ? "Sweep" : (sh == "BO" or sh == "BREAK_OUT" or sh == "BOS" or sh == "MSS" or sh == "MS") ? "Breakout" : "Model"
            [_, _, _, _, _, requiredPrevEvents, _, _, _, _, _, _] = get_data_entry_model_dynamic_cfg(get_model_key_for_type(type))
            string pdU = str.upper(pdarrayType)
            string pdType = (pdU == "OB" or pdU == "FVG" or pdU == "SD" or pdU == "BB" or pdU == "IFVG" or pdU == "RJB") ? pdU : "na"
            string eventsLine = "events: " + KitSMC.get_trade_relevant_events_text(smcCtx.signalHist, direction, type, requiredPrevEvents, 5, 40, 28, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
            KitCore.TradeTooltipMeta tipMeta = KitCore.TradeTooltipMeta.new(shortName = sh, longName = longName, reason = reason + " [" + modeTag + "]", pdarrayText = pdType, qualityPct = qualityPct, scoreVal = scoreVal)
            string reasonFinal = KitCore.format_trade_tooltip(chartCtx, tipMeta, direction, entry, takeprofit, stoploss, rrUsed, slGap, eventsLine, CONST.SYM_ARR2_UP, CONST.SYM_ARR2_DN, CONST.SYM_DASH)
            int entryIdx = na
            if array.size(trades) > 0
                for k = array.size(trades) - 1 to 0
                    KitCore.Trade ex = array.get(trades, k)
                    bool sameZone = math.abs(ex.zoneTop - levelTop) <= sameZoneTol and math.abs(ex.zoneBtm - levelBtm) <= sameZoneTol
                    if ex.direction == direction and ex.type == tradeType and sameZone and ex.state == CONST.SIGNAL_STATE_PENDING
                        entryIdx := k
                        break
            if na(entryIdx)
                KitCore.Trade e = KitCore.create_trade_if_valid(direction, tradeType, levelTop, levelBtm, entry, stoploss, takeprofit, rrUsed, bar_index, reasonFinal, scoreVal, CONST, tick)
                if not na(e)
                    int orderSeq = tradeEntriesEnabled ? array.size(trades) : (strategy.opentrades + strategy.closedtrades)
                    string orderId = "SMC_" + tradeType + "_" + str.tostring(bar_index) + "_" + str.tostring(orderSeq)
                    if tradeEntriesEnabled
                        array.push(trades, e)
                        array.push(tradeOrderIds, orderId)
                    if strategyOrdersEnabled and not na(orderQty) and orderQty > 0.0
                        strategy.entry(orderId, direction == "Buy" ? strategy.long : strategy.short, qty = orderQty, limit = entry, comment = "")
                        strategy.exit(orderId + "_x", from_entry = orderId, stop = stoploss, limit = takeprofit, comment_profit = "", comment_loss = "")
            else
                KitCore.Trade e = array.get(trades, entryIdx)
                string orderId = array.get(tradeOrderIds, entryIdx)
                e.type := tradeType
                e.entry := entry
                e.stoploss := stoploss
                e.takeprofit := takeprofit
                e.rrValue := rrUsed
                e.reason := reasonFinal
                e.score := scoreVal
                array.set(trades, entryIdx, e)
                if strategyOrdersEnabled and not na(orderQty) and orderQty > 0.0
                    strategy.entry(orderId, direction == "Buy" ? strategy.long : strategy.short, qty = orderQty, limit = entry, comment = "")
                    strategy.exit(orderId + "_x", from_entry = orderId, stop = stoploss, limit = takeprofit, comment_profit = "", comment_loss = "")
    bool(na)

process_data_chart_context() =>
    chartCfg.useBias := true
    chartCfg.allowLong := true
    chartCfg.allowShort := true

    ctxDataCfg.needBias := true
    ctxDataCfg.needMsTrendDirs := true
    ctxDataCfg.needPdPw := true
    ctxDataCfg.needPriceRange := true
    ctxDataCfg.needHtfCandles := false
    ctxDataCfg.initBiasFactorArrays := true
    ctxDataCfg.rangeLookbackBars := math.max(effectiveCurrLookbackBars, 50)
    KitSMC.sync_context_tf_data(smcCtx, ltfData, htf1Data, htf2Data)
    int dir0 = KitSMC.get_context_structure_dir(smcCtx)
    KitCore.ChartContext ctx = KitCore.get_data_context_for_dir(ctxDataCfg, SETTINGS, BIAS_TOG, dir0)

    KitCore.fill_trade_bias_trend_arrays(ctx, tradeBiasVals, tradeTrendVals)
    [memScore, memDir, bullCount, bearCount] = KitSMC.compute_signal_memory_bias(smcCtx.signalHist, 20)
    ctx.signalMemoryScore := memScore
    ctx.signalMemoryDir := memDir
    ctx.signalBullCount := bullCount
    ctx.signalBearCount := bearCount
    int effBias = ctx.activeBias
    if memDir != 0
        if effBias == 0
            effBias := memDir
        else if effBias != memDir
            effBias := 0
    ctx.biasVal := effBias
    process_data_reset_runtime_context_if_new_bar()
    array.set(rtBiasBox, 0, ctx.biasVal)
    array.set(rtAllowBuyBox, 0, KitCore.direction_allowed_raw("Buy", memDir) ? 1 : 0)
    array.set(rtAllowSellBox, 0, KitCore.direction_allowed_raw("Sell", memDir) ? 1 : 0)
    ctx

process_data_barrier_touch_setup(KitCore.ChartContext ctx) =>
    [btEnabled, btScore, shortName, btType, btWhen] = get_data_strategy_meta_by_key("REJECTION")
    [_, _, _, _, _, _, _, _, _, _, _, btEntryMode] = get_data_entry_model_dynamic_cfg("REJECTION")
    if not btEnabled or btEntryMode == ENTRY_MODE_OFF
        bool(na)
    else
        [aboveBarrier, belowBarrier, aboveH, belowH] = KitSMC.get_nearest_barriers(smcCtx.zones, close, syminfo.mintick)
        bool hasRes = not na(aboveBarrier) and not na(aboveH)
        bool hasSup = not na(belowBarrier) and not na(belowH)
        if hasRes
            bool touchedRes = KitSMC.check_touch(aboveBarrier + aboveH, aboveBarrier, localCfg.detBasis, open, high, low, close)
            bool validSell = KitCore.direction_allowed_cached("Sell", gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, ctx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
            int scoreSell = btScore + (chartCfg.useBias and validSell ? localCfg.scoreHtf : 0)
            string reasonSell = "Barrier Touch (resistance touch)"
            if touchedRes and validSell
                if btWhen == TRIGGER_WHEN_TOUCH and btType == TRIGGER_TYPE_TRADE
                    process_data_add_entry(shortName, "Sell", reasonSell, aboveBarrier + aboveH, aboveBarrier, na, scoreSell, "")
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, shortName, "Sell", reasonSell, aboveBarrier + aboveH, aboveBarrier, float(na), scoreSell, bar_index, syminfo.mintick, 80)
        if hasSup
            bool touchedSup = KitSMC.check_touch(belowBarrier, belowBarrier - belowH, localCfg.detBasis, open, high, low, close)
            bool validBuy = KitCore.direction_allowed_cached("Buy", gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, ctx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
            int scoreBuy = btScore + (chartCfg.useBias and validBuy ? localCfg.scoreHtf : 0)
            string reasonBuy = "Barrier Touch (support touch)"
            if touchedSup and validBuy
                if btWhen == TRIGGER_WHEN_TOUCH and btType == TRIGGER_TYPE_TRADE
                    process_data_add_entry(shortName, "Buy", reasonBuy, belowBarrier, belowBarrier - belowH, na, scoreBuy, "")
                else
                    KitSMC.add_signal(smcCtx.events, smcCtx.signalHist, shortName, "Buy", reasonBuy, belowBarrier, belowBarrier - belowH, float(na), scoreBuy, bar_index, syminfo.mintick, 80)
        bool(na)

process_data_trades() =>
    bool doResolve = true
    float rHi = high
    float rLo = low
    int rBar = bar_index
    if doResolve and array.size(trades) > 0 and array.size(tradeOrderIds) == array.size(trades)
        for i = array.size(trades) - 1 to 0
            KitCore.Trade e = array.get(trades, i)
            string orderId = array.get(tradeOrderIds, i)
            if not KitCore.is_trade_plan_valid_with_limits(e.entry, e.stoploss, e.takeprofit, localCfg.minTradeSizeTicks, localCfg.minTradeRR)
                if strategyOrdersEnabled
                    strategy.cancel(orderId)
                    strategy.cancel(orderId + "_x")
                if tradeEntriesEnabled
                    KitCore.delete_trade_visuals(e)
                array.remove(trades, i)
                array.remove(tradeOrderIds, i)
                continue
            [eResolved, outcome] = KitCore.resolve_trade_state(e, rHi, rLo, rBar, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
            e := eResolved
            if outcome == 2 and gateUsePretouchCancel
                if strategyOrdersEnabled
                    strategy.cancel(orderId)
                    strategy.cancel(orderId + "_x")
                if tradeEntriesEnabled
                    KitCore.delete_trade_visuals(e)
                array.remove(trades, i)
                array.remove(tradeOrderIds, i)
                continue
            if outcome == 1 or outcome == -1
                float exitPrice = outcome > 0 ? e.takeprofit : e.stoploss
                float denom = math.max(math.abs(e.entry - e.stoploss), syminfo.mintick)
                float realizedR = math.abs(exitPrice - e.entry) / denom
                float rrForStats = math.max(0.1, realizedR)
                e.rrValue := rrForStats
            string entryDisplayMode = (e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL) ? "RESULT_LINES" : "NORMAL"
            [showPendingEntries, showStartEntries, showTpEntries, showSlEntries] = KitCore.get_display_mode_trade_visibility(localCfg.displayMode)
            bool signalShowActive = e.state == CONST.SIGNAL_STATE_PENDING ? showPendingEntries : e.state == CONST.SIGNAL_STATE_START ? showStartEntries : false
            if tradeEntriesEnabled
                e := KitCore.draw_trade_visual(e, CONST, THEME, ENTRY_VIS_CFG, true, signalShowActive, showTpEntries, showSlEntries, perfLookbackBars, 0, entryDisplayMode, "RESULT_LINES", 0)
            array.set(trades, i, e)
    bool(na)

process_data_events_queue(array<KitSMC.Event> events, KitCore.ChartContext ctx, int breakRetestWindowBars) =>
    if events.size() > 0
        for i = events.size() - 1 to 0
            e = events.get(i)
            bool isBreakRetestEvent = not na(e.barBreak)
            bool isSignalEvent = not isBreakRetestEvent
            if isSignalEvent
                if e.type == "SWEEP"
                    continue
                string signalModelKey = get_model_key_for_type(e.type)
                [sigEnabled, _, _, sigTriggerType, sigTriggerWhen] = get_data_strategy_meta_by_key(signalModelKey)
                [_, _, _, _, _, _, _, _, _, _, _, sigEntryMode] = get_data_entry_model_dynamic_cfg(signalModelKey)
                if not sigEnabled
                    events.remove(i)
                    continue
                if sigTriggerType != TRIGGER_TYPE_TRADE
                    events.remove(i)
                    continue
                bool validSignalDirection = KitCore.direction_allowed_cached(e.direction, gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, ctx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
                bool passSignalEntryMode = sigEntryMode != ENTRY_MODE_OFF
                if not gateUseRetestConfirm
                    if passSignalEntryMode and validSignalDirection
                        process_data_add_entry(e.type, e.direction, e.reason, e.zoneTop, e.zoneBtm, e.quality, e.score, e.type)
                    events.remove(i)
                    continue
                if e.direction == "Buy" and close > e.zoneTop
                    bool validBuy = KitCore.direction_allowed_cached("Buy", gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, ctx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
                    if sigEntryMode == ENTRY_MODE_AFTER_RETEST and sigTriggerWhen == TRIGGER_WHEN_RETEST and validBuy
                        process_data_add_entry(e.type, "Buy", e.reason + " (close reclaimed zone top)", e.zoneTop, e.zoneBtm, e.quality, e.score + localCfg.scoreConfirm, e.type)
                    events.remove(i)
                    continue
                else if e.direction == "Sell" and close < e.zoneBtm
                    bool validSell = KitCore.direction_allowed_cached("Sell", gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, ctx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
                    if sigEntryMode == ENTRY_MODE_AFTER_RETEST and sigTriggerWhen == TRIGGER_WHEN_RETEST and validSell
                        process_data_add_entry(e.type, "Sell", e.reason + " (close rejected below zone bottom)", e.zoneTop, e.zoneBtm, e.quality, e.score + localCfg.scoreConfirm, e.type)
                    events.remove(i)
                    continue
            else
                int age = bar_index - e.barBreak
                if age > breakRetestWindowBars
                    events.remove(i)
                    continue
                bool isBuy = e.direction == "Buy"
                string modelKey = get_model_key_for_type(e.type)
                [stratEnabled, stratScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
                [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = get_data_entry_model_dynamic_cfg(modelKey)
                bool allowedPdArray = is_pdarray_type_enabled(e.type)
                bool validType = stratEnabled and allowedPdArray
                bool validDirection = KitCore.direction_allowed_cached(e.direction, gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, ctx.biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
                bool touched = KitSMC.check_touch(e.zoneTop, e.zoneBtm, localCfg.detBasis, open, high, low, close)
                if touched
                    e.retestSeen := true
                    events.set(i, e)
                bool confirmed = e.retestSeen and (isBuy ? (close > e.zoneTop) : (close < e.zoneBtm))
                bool invalidated = isBuy ? (close < e.zoneBtm) : (close > e.zoneTop)
                if gateUseRetestInvalidation and invalidated
                    events.remove(i)
                    continue
                bool passEntryMode = modelEntryMode != ENTRY_MODE_OFF
                bool passTriggerWhen = not gateUseRetestConfirm or triggerWhen == TRIGGER_WHEN_RETEST
                bool passConfirm = not gateUseRetestConfirm or confirmed
                bool tradeCandidate = validType and validDirection and passEntryMode and passTriggerWhen and triggerType == TRIGGER_TYPE_TRADE
                if passConfirm and tradeCandidate
                    int baseScore = stratScore + localCfg.scoreConfirm + (chartCfg.useBias and validDirection ? localCfg.scoreHtf : 0)
                    string reason = gateUseRetestConfirm ? e.type + " Break-Retest confirmed" : e.type + " Break-Retest gate bypass"
                    process_data_add_entry(shortName, e.direction, reason, e.zoneTop, e.zoneBtm, e.quality, baseScore, e.type)
                    events.remove(i)
                    continue
                if confirmed
                    events.remove(i)
                    continue
    bool(na)

process_data_register_pdarray_retest_signal(array<KitSMC.Event> _triggersQueue, KitSMC.PDArray z, int biasVal, string reasonOverride, string setupOverride) =>
    string type = z.type
    string modelKey = get_model_key_for_type(type)
    [stratEnabled, stratScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
    [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = get_data_entry_model_dynamic_cfg(modelKey)
    bool allowedPdArray = is_pdarray_type_enabled(type)
    bool enabledType = stratEnabled and allowedPdArray
    string direction = z.isBullish ? "Buy" : "Sell"
    bool validBias = KitCore.direction_allowed_cached(direction, gateUseEntryDirection, array.get(rtBarBox, 0), array.get(rtBiasBox, 0), bar_index, biasVal, array.get(rtAllowBuyBox, 0), array.get(rtAllowSellBox, 0), chartCtx.signalMemoryDir)
    int baseScore = stratScore
    int biasScore = chartCfg.useBias and validBias ? localCfg.scoreHtf : 0
    int totalScore = baseScore + biasScore
    string reason = reasonOverride == "" ? KitSMC.signal_reason_text(type, z.isBullish) : reasonOverride
    reason := reason + (chartCfg.useBias ? " (HTF Bias Confirmed)" : "")
    string setup = setupOverride == "" ? shortName : setupOverride
    bool passEntryMode = modelEntryMode != ENTRY_MODE_OFF
    if enabledType and validBias and passEntryMode and not KitSMC.has_pending_trade_signal(_triggersQueue, setup, direction, z.top, z.bottom, syminfo.mintick)
        bool directEntry = triggerType == TRIGGER_TYPE_TRADE and ((triggerWhen == TRIGGER_WHEN_TOUCH and modelEntryMode == ENTRY_MODE_LIMIT) or not gateUseRetestConfirm)
        if directEntry
            process_data_add_entry(setup, direction, reason, z.top, z.bottom, z.qualityPct, totalScore, z.type)
        else if triggerType == TRIGGER_TYPE_SIGNAL or (gateUseRetestConfirm and (triggerWhen == TRIGGER_WHEN_RETEST or modelEntryMode == ENTRY_MODE_AFTER_RETEST))
            KitSMC.add_signal(_triggersQueue, smcCtx.signalHist, setup, direction, reason, z.top, z.bottom, z.qualityPct, totalScore, bar_index, syminfo.mintick, 80)
    bool(na)

var array<int> lsrBarState = array.new<int>(2, na)

process_data_lsr_model(KitCore.ChartContext ctx) =>
    [lsrEnabled, lsrScore, shortName, _, _] = get_data_strategy_meta_by_key("SWEEP")
    if lsrEnabled
        int bearBar = array.get(lsrBarState, 0)
        int bullBar = array.get(lsrBarState, 1)
        int evSize = array.size(smcCtx.events)
        if evSize > 0
            for i = evSize - 1 to 0
                KitSMC.Event e = array.get(smcCtx.events, i)
                if e.type == "SWEEP"
                    if e.direction == "Sell"
                        bearBar := e.barDetected
                        array.set(lsrBarState, 0, bearBar)
                    else if e.direction == "Buy"
                        bullBar := e.barDetected
                        array.set(lsrBarState, 1, bullBar)
                    array.remove(smcCtx.events, i)
                    
        int chochBarsLimit = 50
        bool bearSweepValid = not na(bearBar) and (bar_index - bearBar) <= chochBarsLimit
        int lastLtfLegBar = get_data_cached_bar_index_from_time(ltfData.mss.legEventTime)
        bool bearChoch = bearSweepValid and ltfData.mss.msBias == -1 and lastLtfLegBar > bearBar
        if bearSweepValid and bearChoch
            KitSMC.PDArray extremeOrigin = na
            float highestTop = -999999.0
            if array.size(smcCtx.zones) > 0
                for i = 0 to array.size(smcCtx.zones) - 1
                    KitSMC.PDArray z = array.get(smcCtx.zones, i)
                    bool isTrendZone = z.type == "OB" or z.type == "FVG" or z.type == "SD"
                    if isTrendZone and not z.isBullish
                        if z.barStart >= bearBar - 2 and z.barStart <= lastLtfLegBar + 2
                            if z.top > highestTop
                                extremeOrigin := z
                                highestTop := z.top
            if not na(extremeOrigin)
                process_data_register_pdarray_retest_signal(smcCtx.events, extremeOrigin, ctx.biasVal, "LSR Swept: Bearish Origin RTO", shortName)
                array.set(lsrBarState, 0, na)
                
        bool bullSweepValid = not na(bullBar) and (bar_index - bullBar) <= chochBarsLimit
        bool bullChoch = bullSweepValid and ltfData.mss.msBias == 1 and lastLtfLegBar > bullBar
        if bullSweepValid and bullChoch
            KitSMC.PDArray extremeOrigin = na
            float lowestBtm = 999999.0
            if array.size(smcCtx.zones) > 0
                for i = 0 to array.size(smcCtx.zones) - 1
                    KitSMC.PDArray z = array.get(smcCtx.zones, i)
                    bool isTrendZone = z.type == "OB" or z.type == "FVG" or z.type == "SD"
                    if isTrendZone and z.isBullish
                        if z.barStart >= bullBar - 2 and z.barStart <= lastLtfLegBar + 2
                            if z.bottom < lowestBtm
                                extremeOrigin := z
                                lowestBtm := z.bottom
            if not na(extremeOrigin)
                process_data_register_pdarray_retest_signal(smcCtx.events, extremeOrigin, ctx.biasVal, "LSR Swept: Bullish Origin RTO", shortName)
                array.set(lsrBarState, 1, na)

    bool(na)

update_pdarray_box_label(KitSMC.PDArray z, float boxHigh, float boxLow) =>
    if not na(z.visualLabel)
        float zoneH = math.max(boxHigh - boxLow, syminfo.mintick)
        float labelY = ((boxHigh + boxLow) * 0.5) - (zoneH * 0.12)
        int labelXRaw = box.get_right(z.visualBox) - math.max(1, 1)
        int minLabelX = math.max(bar_index - 4000, 0)
        int maxLabelX = bar_index + 500
        int labelX = math.min(math.max(labelXRaw, minLabelX), maxLabelX)
        if z.visualLabel.get_x() != labelX
            z.visualLabel.set_x(labelX)
        if z.visualLabel.get_y() != labelY
            z.visualLabel.set_y(labelY)
        string lblAlignSig = "SMC_LABEL_ALIGN|RIGHT"
        if z.visLabelStyleSig != lblAlignSig
            z.visualLabel.set_textalign(text.align_right)
            z.visLabelStyleSig := lblAlignSig
        if z.visualLabel.get_text() != z.labelText
            z.visualLabel.set_text(z.labelText)
    if not na(z.visualBox)
        string nextBorderStyle = KitSMC.get_pdarray_border_style(z.type, z.labelText, line.style_solid, SMC_CONST)
        string boxBorderSig = "SMC_BOX_BORDER|" + nextBorderStyle
        if z.visAreaStyleSig != boxBorderSig
            z.visualBox.set_border_style(nextBorderStyle)
            z.visAreaStyleSig := boxBorderSig
    z

mark_pdarray_mitigated_visual(KitSMC.PDArray z) =>
    bool isHtfZone = z.sourceTfRank >= 2
    color mitClr = isHtfZone ? (z.sourceTfRank >= 3 ? color.new(htf2Cfg.zigzagColor, 0) : color.new(htf1Cfg.zigzagColor, 0)) : THEME.COLOR_NEUTRAL
    if not na(z.visualBox)
        z.visualBox.set_bgcolor(color.new(mitClr, 90))
        z.visualBox.set_border_color(z.type == "IFVG" ? na : color.new(mitClr, 85))
    if z.type == "OB"
        z.labelText := "ob"
    if not na(z.visualLabel)
        z.visualLabel.set_textcolor(color.new(mitClr, 40))
    z.lifeState := CONST.LIFE_TOUCHED
    z.touchCount := math.max(z.touchCount, 0) + 1
    z.barEnd := bar_index
    z.rejectCount := math.max(z.rejectCount, 0)
    z

process_data_zone_lifecycle(array<KitSMC.PDArray> zones, float _atr, int _biasVal, bool canEmitSignals) =>
    float o0 = open
    float h0 = high
    float l0 = low
    float c0 = close
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    if zones.size() > 0
        for i = zones.size() - 1 to 0
            z = zones.get(i)
            z := KitSMC.normalize_pricezone_state(z, SMC_CONST)
            if not na(z.barStart) and (bar_index - z.barStart > effectiveCurrLookbackBars)
                if not na(z.visualLabel)
                    z.visualLabel.delete()
                if not na(z.visualBox)
                    z.visualBox.delete()
                zones.remove(i)
                continue
            if not z.broken
                float _boxLow = not na(z.visualBox) ? z.visualBox.get_bottom() : z.bottom
                float _boxHigh = not na(z.visualBox) ? z.visualBox.get_top() : z.top
                if z.visible
                    KitSMC.ZoneTypeConfig cfg = get_pdarray_cfg(z.type)
                    bool isHtfZone = z.sourceTfRank >= 2
                    color resolvedLabelColor = isHtfZone ? (z.sourceTfRank >= 3 ? color.new(htf2Cfg.zigzagColor, 0) : color.new(htf1Cfg.zigzagColor, 0)) :
                     z.type == "OB" ? (z.isBullish ? uiCfg.colorBullish : color.new(uiCfg.colorBearish, 20)) :
                     z.type == "RJB" ? (z.isBullish ? uiCfg.colorBullish : color.new(uiCfg.colorBearish, THEME.T_LOW)) :
                     z.type == "FVG" ? (z.isBullish ? uiCfg.colorBullish : color.new(uiCfg.colorBearish, THEME.T_LOW)) :
                     uiCfg.ltfColor
                    color resolvedBorderColor = cfg.noBorder ? na :
                     isHtfZone ? (z.sourceTfRank >= 3 ? color.new(htf2Cfg.zigzagColor, 85) : color.new(htf1Cfg.zigzagColor, 85)) :
                     z.type == "OB" ? (z.isBullish ? color.new(uiCfg.colorBullish, 55) : color.new(uiCfg.colorBearish, 55)) :
                     z.type == "RJB" ? (z.isBullish ? color.new(uiCfg.colorBullish, 55) : color.new(uiCfg.colorBearish, 55)) :
                     color.new(uiCfg.ltfColor, 85)
                    string borderStyle = KitSMC.get_pdarray_border_style(z.type, z.labelText, cfg.borderStyle, SMC_CONST)
                    int rightIdx = get_cached_pdarray_min_right(z, bar_index + z.extendBars, uiCfg.zoneCurrMinWidthBars)
                    float labelY = (z.top + z.bottom) * 0.5
                    z := KitSMC.draw_price_zone(z, z.barStart, rightIdx, z.top, z.bottom, uiCfg.colorBg, resolvedBorderColor, borderStyle, z.labelText, resolvedLabelColor, "", rightIdx, labelY, ZONE_VIS_CFG, SR_VIS_CFG, true, false, na, resolvedBorderColor, "AREA", true)
                    _boxLow := not na(z.visualBox) ? z.visualBox.get_bottom() : z.bottom
                    _boxHigh := not na(z.visualBox) ? z.visualBox.get_top() : z.top
                    z := update_pdarray_box_label(z, _boxHigh, _boxLow)
                if z.type == "SD"
                    int sdRight = get_cached_pdarray_min_right(z, bar_index + z.extendBars, uiCfg.zoneCurrMinWidthBars)
                    if z.visible and not na(z.visualBox) and box.get_right(z.visualBox) != sdRight
                        z.visualBox.set_right(sdRight)
                    bool sdTouched = KitSMC.check_touch(_boxHigh, _boxLow, localCfg.detBasis, o0, h0, l0, c0)
                    bool canEmitSd = na(z.barEnd) or z.barEnd != bar_index
                    if canEmitSignals and sdTouched and canEmitSd
                        process_data_register_pdarray_retest_signal(smcCtx.events, z, _biasVal, "", "")
                        z.barEnd := bar_index
                    zones.set(i, z)
                    continue
                bool isBull = z.isBullish
                bool postTouch = KitSMC.is_pdarray_post_touch(z)
                if not postTouch
                    bool derivedNeedsDelay = z.type == "BB" or z.type == "IFVG"
                    bool canCheckMitigation = not derivedNeedsDelay or bar_index > z.barStart
                    entered = canCheckMitigation and KitSMC.check_mitigation(z.type, z.isBullish, _boxHigh, _boxLow, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, _atr, localCfg.detImpulseAtr, o0, h0, l0, c0, o1, h1, l1, c1)

                    if not entered
                        ext = z.extendBars
                        int nextRight = get_cached_pdarray_min_right(z, bar_index + ext, uiCfg.zoneCurrMinWidthBars)
                        if z.visible and not na(z.visualBox) and box.get_right(z.visualBox) != nextRight
                            z.visualBox.set_right(nextRight)
                        zones.set(i, z)
                    else
                        if canEmitSignals
                            process_data_register_pdarray_retest_signal(smcCtx.events, z, _biasVal, "", "")
                        z := mark_pdarray_mitigated_visual(z)
                        zones.set(i, z)
                else
                    breakLevel = isBull ? _boxLow : _boxHigh
                    respected = KitSMC.check_pdarray_respect(isBull, _boxHigh, _boxLow, h0, l0, c0)
                    [stratEnabled, _, _, _, _] = get_data_strategy_meta_by_key(str.upper(z.type))
                    canEmitRespect = na(z.barEnd) and stratEnabled
                    if respected
                        z.barEnd := bar_index
                        z.lifeState := CONST.LIFE_RESPECTED
                        z.rejectCount := math.max(z.rejectCount, 0) + 1
                        int latestTouchRight = get_cached_pdarray_min_right(z, z.barEnd + 10, uiCfg.zoneCurrMinWidthBars)
                        if box.get_right(z.visualBox) != latestTouchRight
                            z.visualBox.set_right(latestTouchRight)
                    if canEmitSignals and respected and canEmitRespect
                        process_data_register_pdarray_retest_signal(smcCtx.events, z, _biasVal, z.type + " touch respected", z.type + " R")
                        z.barEnd := bar_index
                    isBroken = KitSMC.check_break(not isBull, breakLevel, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, _atr, localCfg.detImpulseAtr, o0, h0, l0, c0, o1, h1, l1, c1)
                    if isBroken
                        string breakDirection = z.isBullish ? "Sell" : "Buy"
                        if canEmitSignals
                            KitSMC.register_break_retest_event(smcCtx.events, z.type, breakDirection, z.top, z.bottom, bar_index, z.qualityPct, syminfo.mintick)
                        if z.type == "FVG" and plotFVG
                            spawn_derived_zone(zones, "IFVG", not z.isBullish, _boxHigh, _boxLow, z.qualityPct)
                        if z.type == "OB" and plotOB
                            spawn_derived_zone(zones, "BB", not z.isBullish, _boxHigh, _boxLow, z.qualityPct)
                        z.broken := true
                        z.lifeState := CONST.LIFE_BROKEN
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                        z.visualBox.delete()
                        zones.remove(i)
                        continue
                    else
                        zones.set(i, z)
                if KitSMC.is_pdarray_post_touch(z) and KitCore.is_life_formed(z.lifeState, CONST)
                    z.lifeState := CONST.LIFE_TOUCHED
                    zones.set(i, z)
    bool(na)

get_data_latest_swing_high() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = KitSMC.market_structure_latest_hilo(ltfData.mss)
    latestHigh

get_data_latest_swing_low() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = KitSMC.market_structure_latest_hilo(ltfData.mss)
    latestLow

get_data_zone_rank_score(KitSMC.PDArray z, float lastSwingHigh, float lastSwingLow) =>
    float zoneMid = (z.top + z.bottom) * 0.5
    float tick = math.max(syminfo.mintick, 1e-10)
    bool isAbove = zoneMid >= close
    float drMid = (not na(lastSwingHigh) and not na(lastSwingLow)) ? ((lastSwingHigh + lastSwingLow) * 0.5) : na
    bool inPreferredHalf = not na(drMid) and (isAbove ? zoneMid >= drMid : zoneMid <= drMid)
    bool isUntouched = not KitSMC.is_pdarray_post_touch(z) and not z.mitigated
    float distSwing = 0.0
    if isAbove and not na(lastSwingHigh)
        distSwing := math.abs(zoneMid - lastSwingHigh) / tick
    if (not isAbove) and not na(lastSwingLow)
        distSwing := math.abs(zoneMid - lastSwingLow) / tick
    float nearSwingScore = 1000.0 / (1.0 + distSwing)
    float ageBars = math.max(bar_index - z.barStart, 0)
    float ageScore = ageBars * 0.05
    float touchScore = 100.0 / (1.0 + math.max(z.touchCount, 0))
    float qualityScore = nz(z.qualityPct, 0.0) * 0.2
    float premiumScore = inPreferredHalf ? 75.0 : 0.0
    isUntouched ? 1000000.0 : (ageScore + nearSwingScore + premiumScore + touchScore + qualityScore)

get_data_is_type_enabled(string zType) =>
    zType == "OB" ? plotOB : zType == "FVG" ? plotFVG : zType == "SD" ? plotSD : zType == "BB" ? useBB : zType == "IFVG" ? useIFVG : zType == "RJB" ? true : true

get_data_display_type_by_idx(int idx) =>
    idx == 0 ? "OB" : idx == 1 ? "FVG" : idx == 2 ? "SD" : idx == 3 ? "BB" : idx == 4 ? "IFVG" : "RJB"

get_data_zone_display_score(KitSMC.PDArray z, float lastSwingHigh, float lastSwingLow) =>
    float base = get_data_zone_rank_score(z, lastSwingHigh, lastSwingLow)
    float tick = math.max(syminfo.mintick, 1e-10)
    float zoneMid = (z.top + z.bottom) * 0.5
    float distPrice = math.abs(zoneMid - close) / tick
    float distSwing = 0.0
    bool isAbove = zoneMid >= close
    if isAbove and not na(lastSwingHigh)
        distSwing := math.abs(zoneMid - lastSwingHigh) / tick
    if (not isAbove) and not na(lastSwingLow)
        distSwing := math.abs(zoneMid - lastSwingLow) / tick
    float nearSwingScore = 1000.0 / (1.0 + distSwing)
    pdDisplayMode == "Extreme" ? (distPrice * 10.0 + nearSwingScore + nz(z.qualityPct, 0.0) * 0.2) : base

process_data_prune_zones_by_relevance(array<KitSMC.PDArray> zones) =>
    int n = array.size(zones)
    if n <= 0
        bool(na)
    else
        float lastSwingHigh = get_data_latest_swing_high()
        float lastSwingLow = get_data_latest_swing_low()
        array<string> typeFilters = array.new_string()
        for ti = 0 to 5
            string tz = get_data_display_type_by_idx(ti)
            if get_data_is_type_enabled(tz)
                array.push(typeFilters, tz)
        for i = 0 to n - 1
            KitSMC.PDArray z = array.get(zones, i)
            z.volScore := get_data_zone_display_score(z, lastSwingHigh, lastSwingLow)
            z.visible := pdDisplayMode == "All" and get_data_is_type_enabled(z.type) and not z.broken
            array.set(zones, i, z)
        array<bool> keep = array.new_bool(n, false)
        if pdDisplayMode != "All"
            bool extremeMode = pdDisplayMode == "Extreme"
            array<string> selectorFilters = extremeMode ? array.new_string() : typeFilters
            keep := KitSMC.select_visible_pricezones(zones, close, selectorFilters, extremeMode ? 0 : localCfg.displayZonePerTypeSideCap, localCfg.displayZoneSideTotalCap, true, 0.0)
        int j = 0
        while j < n
            KitSMC.PDArray z = array.get(zones, j)
            bool active = not z.broken and get_data_is_type_enabled(z.type)
            bool selected = pdDisplayMode == "All" ? active : array.get(keep, j)
            z.visible := active and selected
            if not z.visible
                if not na(z.visualBox)
                    z.visualBox.set_bgcolor(color.new(uiCfg.colorBg, 100))
                    z.visualBox.set_border_color(color.new(uiCfg.colorBg, 100))
                if not na(z.visualLine)
                    z.visualLine.set_color(color.new(uiCfg.colorBg, 100))
                if not na(z.visualLabel)
                    z.visualLabel.delete()
                    z.visualLabel := na
                    z.visLabelGeomSig := ""
                    z.visLabelStyleSig := ""
            array.set(zones, j, z)
            j += 1
        bool(na)

process_data_entries(int breakRetestWindowBars, bool canEmitSignals) =>
    KitCore.ChartContext ctx = chartCtx
    process_data_zone_lifecycle(smcCtx.zones, commonAtr, ctx.biasVal, canEmitSignals)
    if canEmitSignals
        process_data_barrier_touch_setup(ctx)
        process_data_events_queue(smcCtx.events, ctx, breakRetestWindowBars)
        process_data_lsr_model(ctx)
    process_data_trades()
    bool(na)

draw_data_trades_dashboard() =>
    var array<KitCore.Trade> dashboardTrades = array.new<KitCore.Trade>()
    [showPendingEntries, showStartEntries, showTpEntries, showSlEntries] = KitCore.get_display_mode_trade_visibility(localCfg.displayMode)
    KitCore.collect_dashboard_trades(trades, dashboardTrades, showPendingEntries, showStartEntries, showTpEntries, showSlEntries, perfLookbackBars, CONST)
    int dashCount = array.size(dashboardTrades)
    if dashCount > 0
        KitCore.render_entries_dashboard_from_entries(true, signalStatsTableTopRight, dashboardTrades, math.max(1, dashCount), THEME, CONST, 3)
    else
        table.clear(signalStatsTableTopRight, 0, 0, 4, 23)
    KitCore.draw_bias_row_under_trades(signalStatsTableTopRight, 0, chartCtx, THEME, SETTINGS, CONST)
    bool(na)

draw_data_htf_pdarray_set(array<box> store, int tfSlot, bool showTf, string tfLabel, string tfStr,
 float top0, float btm0, int start0, float q0, bool bull0, string type0,
 float top1, float btm1, int start1, float q1, bool bull1, string type1,
 float top2, float btm2, int start2, float q2, bool bull2, string type2,
 float top3, float btm3, int start3, float q3, bool bull3, string type3) =>
    float adOb = na
    int aiOb = na
    float adFvg = na
    int aiFvg = na
    float bdOb = na
    int biOb = na
    float bdFvg = na
    int biFvg = na
    float adObFb = na
    int aiObFb = na
    float adFvgFb = na
    int aiFvgFb = na
    float bdObFb = na
    int biObFb = na
    float bdFvgFb = na
    int biFvgFb = na
    [tf1Local, tf2Local] = KitCore.get_htf_pair()
    string tfNameForSet = tfSlot == 0 ? tf1Local : tf2Local
    int recentTsCut = get_data_htf_detection_cutoff_time(tfSlot, tfNameForSet)

    for i = 0 to 3
        float top = i == 0 ? top0 : i == 1 ? top1 : i == 2 ? top2 : top3
        float btm = i == 0 ? btm0 : i == 1 ? btm1 : i == 2 ? btm2 : btm3
        int st = i == 0 ? start0 : i == 1 ? start1 : i == 2 ? start2 : start3
        float q = i == 0 ? q0 : i == 1 ? q1 : i == 2 ? q2 : q3
        string zType = i == 0 ? type0 : i == 1 ? type1 : i == 2 ? type2 : type3
        bool showType = zType == "OB" ? plotOB : plotFVG
        bool isBull = i == 0 ? bull0 : i == 1 ? bull1 : i == 2 ? bull2 : bull3
        bool baseValid = showTf and showType and not na(st) and not na(top) and not na(btm) and top > btm
        if baseValid
            float midFb = (top + btm) * 0.5
            float distFb = math.abs(midFb - close)
            bool isAboveFb = midFb > close
            string famFb = KitSMC.get_pdarray_cap_family(zType)
            if isAboveFb
                if famFb == "OB_FAMILY"
                    if na(adObFb) or distFb < adObFb
                        adObFb := distFb
                        aiObFb := i
                else if famFb == "FVG_FAMILY"
                    if na(adFvgFb) or distFb < adFvgFb
                        adFvgFb := distFb
                        aiFvgFb := i
            else
                if famFb == "OB_FAMILY"
                    if na(bdObFb) or distFb < bdObFb
                        bdObFb := distFb
                        biObFb := i
                else if famFb == "FVG_FAMILY"
                    if na(bdFvgFb) or distFb < bdFvgFb
                        bdFvgFb := distFb
                        biFvgFb := i
        bool unmitigated = isBull ? (low > top) : (high < btm)
        bool recent = not na(st) and st >= recentTsCut
        bool valid = showTf and showType and recent and not na(st) and not na(top) and not na(btm) and top > btm and nz(q, 0) >= localCfg.htfProjectionMinQualityPct and unmitigated
        if valid
            float mid = (top + btm) * 0.5
            float dist = math.abs(mid - close)
            bool isAbove = mid > close
            string fam = KitSMC.get_pdarray_cap_family(zType)
            if isAbove
                if fam == "OB_FAMILY"
                    if na(adOb) or dist < adOb
                        adOb := dist
                        aiOb := i
                else if fam == "FVG_FAMILY"
                    if na(adFvg) or dist < adFvg
                        adFvg := dist
                        aiFvg := i
            else
                if fam == "OB_FAMILY"
                    if na(bdOb) or dist < bdOb
                        bdOb := dist
                        biOb := i
                else if fam == "FVG_FAMILY"
                    if na(bdFvg) or dist < bdFvg
                        bdFvg := dist
                        biFvg := i

    bool obFirst = true
    int aOb = not na(aiOb) ? aiOb : aiObFb
    int aFvg = not na(aiFvg) ? aiFvg : aiFvgFb
    int bOb = not na(biOb) ? biOb : biObFb
    int bFvg = not na(biFvg) ? biFvg : biFvgFb
    int aboveFirst = obFirst ? (not na(aOb) ? aOb : aFvg) : (not na(aFvg) ? aFvg : aOb)
    int aboveSecond = obFirst ? (not na(aOb) and not na(aFvg) ? aFvg : na) : (not na(aFvg) and not na(aOb) ? aOb : na)
    int belowFirst = obFirst ? (not na(bOb) ? bOb : bFvg) : (not na(bFvg) ? bFvg : bOb)
    int belowSecond = obFirst ? (not na(bOb) and not na(bFvg) ? bFvg : na) : (not na(bFvg) and not na(bOb) ? bOb : na)

    float dAbove = na
    if not na(aboveFirst)
        float topA = aboveFirst == 0 ? top0 : aboveFirst == 1 ? top1 : aboveFirst == 2 ? top2 : top3
        float btmA = aboveFirst == 0 ? btm0 : aboveFirst == 1 ? btm1 : aboveFirst == 2 ? btm2 : btm3
        dAbove := math.abs(((topA + btmA) * 0.5) - close)
    float dBelow = na
    if not na(belowFirst)
        float topB = belowFirst == 0 ? top0 : belowFirst == 1 ? top1 : belowFirst == 2 ? top2 : top3
        float btmB = belowFirst == 0 ? btm0 : belowFirst == 1 ? btm1 : belowFirst == 2 ? btm2 : btm3
        dBelow := math.abs(((topB + btmB) * 0.5) - close)

    int p0 = na
    int p1 = na
    if not na(aboveFirst) and not na(belowFirst)
        bool aboveNearest = dAbove <= dBelow
        p0 := aboveNearest ? aboveFirst : belowFirst
        p1 := aboveNearest ? belowFirst : aboveFirst
    else
        p0 := not na(aboveFirst) ? aboveFirst : belowFirst
        p1 := na
    int p2 = not na(p1) and p1 == aboveFirst ? belowSecond : p1 == belowFirst ? aboveSecond : aboveSecond
    int p3 = not na(p2) and p2 == aboveSecond ? belowSecond : belowSecond

    int outMax = math.max(1, HTF_pdarray_PER_TF)
    for outPos = 0 to outMax - 1
        int cand = na
        if outPos == 0
            cand := p0
        else if outPos == 1
            cand := p1
        else if outPos == 2
            cand := p2
        else if outPos == 3
            cand := p3
        int boxIdx = tfSlot * HTF_pdarray_PER_TF + outPos
        if not na(cand)
            float top = cand == 0 ? top0 : cand == 1 ? top1 : cand == 2 ? top2 : top3
            float btm = cand == 0 ? btm0 : cand == 1 ? btm1 : cand == 2 ? btm2 : btm3
            int st = cand == 0 ? start0 : cand == 1 ? start1 : cand == 2 ? start2 : start3
            float q = cand == 0 ? q0 : cand == 1 ? q1 : cand == 2 ? q2 : q3
            bool isBull = cand == 0 ? bull0 : cand == 1 ? bull1 : cand == 2 ? bull2 : bull3
            string zType = cand == 0 ? type0 : cand == 1 ? type1 : cand == 2 ? type2 : type3
            int ext = KitCore.get_htf_pdarray_extend(tfSlot, HTF1_EXT_BASE + HTF_EXT_PAD, HTF2_EXT_BASE + HTF_EXT_PAD)
            color txtCol = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 0) : color.new(htf2Cfg.zigzagColor, 0)
            string txt = str.upper(zType)
            color htfFill = color.new(THEME.COLOR_NEUTRAL, uiCfg.htfZoneBgTransp)
            color tfBorder = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 85) : color.new(htf2Cfg.zigzagColor, 85)
            KitUI.update_projected_box_slot(store, boxIdx, showTf, st, ext, top, btm, htfFill, txtCol, txt, bar_index, time, time[1], htfProjectionSpanBars, bar_index >= workingFirstBar, tfBorder, line.style_dotted, HTF_BOX_VIS_CFG)
        else
            KitUI.update_projected_box_slot(store, boxIdx, false, int(na), 0, float(na), float(na), color.new(THEME.COLOR_NEUTRAL, uiCfg.htfZoneBgTransp), THEME.COLOR_NEUTRAL, "", bar_index, time, time[1], htfProjectionSpanBars, bar_index >= workingFirstBar, color.new(THEME.COLOR_NEUTRAL, 15), line.style_dotted, HTF_BOX_VIS_CFG)

get_data_htf_pdarray_snapshots(string htf1, string htf2, bool zshow0, bool reqHtf2Zones, KitSMC.ZoneQualityCfg zqCfg) =>
    int srPivotLen = int(math.max(PIVOT_LEN_BASE + 2, 3))
    [h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1ObUpQ, h1ObDnQ, h1FvgUpQ, h1FvgDnQ, h1SrHiDummy, h1SrHiTDummy, h1SrLoDummy, h1SrLoTDummy] = if zshow0
        request.security(syminfo.tickerid, htf1, KitSMC.get_htf_pdarray_sr_snapshot(localCfg.zoneFormationLockBars, zqCfg, 14, srPivotLen))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), float(na), float(na), float(na), int(na), float(na), int(na)]
    [h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2ObUpQ, h2ObDnQ, h2FvgUpQ, h2FvgDnQ, h2SrHi, h2SrHiT, h2SrLo, h2SrLoT] = if reqHtf2Zones
        request.security(syminfo.tickerid, htf2, KitSMC.get_htf_pdarray_sr_snapshot(localCfg.zoneFormationLockBars, zqCfg, 14, srPivotLen))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), float(na), float(na), float(na), int(na), float(na), int(na)]
    [h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1ObUpQ, h1ObDnQ, h1FvgUpQ, h1FvgDnQ, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2ObUpQ, h2ObDnQ, h2FvgUpQ, h2FvgDnQ, h2SrHi, h2SrHiT, h2SrLo, h2SrLoT]

[htf1, htf2] = KitCore.get_htf_pair()
localCfg.currPivotLenNormal := KitCore.get_pivot_len_for_tf(timeframe.period, timeframe.period, CONST.PIVOT_MODE_FIXED, "Normal", PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION)
localCfg.htf1PivotLenNormal := KitCore.get_pivot_len_for_tf(htf1, timeframe.period, CONST.PIVOT_MODE_FIXED, "Normal", PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION)
localCfg.htf2PivotLenNormal := KitCore.get_pivot_len_for_tf(htf2, timeframe.period, CONST.PIVOT_MODE_FIXED, "Normal", PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION)

zshow0 = uiCfg.htfShowProjectedZones and not na(htf1)
zshow1 = uiCfg.htfShowProjectedZones and not na(htf2)
zdraw0 = zshow0
zdraw1 = zshow1
bool needHtf2Anchors = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf2)

var float h1ObUpTop = na
var float h1ObUpBtm = na
var int h1ObUpStart = na
var float h1ObDnTop = na
var float h1ObDnBtm = na
var int h1ObDnStart = na
var float h1FvgUpTop = na
var float h1FvgUpBtm = na
var int h1FvgUpStart = na
var float h1FvgDnTop = na
var float h1FvgDnBtm = na
var int h1FvgDnStart = na
var float h1ObUpQ = na
var float h1ObDnQ = na
var float h1FvgUpQ = na
var float h1FvgDnQ = na
var float h1SdSupTop = na
var float h1SdSupBtm = na
var int h1SdSupStart = na
var float h1SdDemTop = na
var float h1SdDemBtm = na
var int h1SdDemStart = na
var float h2ObUpTop = na
var float h2ObUpBtm = na
var int h2ObUpStart = na
var float h2ObDnTop = na
var float h2ObDnBtm = na
var int h2ObDnStart = na
var float h2FvgUpTop = na
var float h2FvgUpBtm = na
var int h2FvgUpStart = na
var float h2FvgDnTop = na
var float h2FvgDnBtm = na
var int h2FvgDnStart = na
var float h2ObUpQ = na
var float h2ObDnQ = na
var float h2FvgUpQ = na
var float h2FvgDnQ = na
var float h2SdSupTop = na
var float h2SdSupBtm = na
var int h2SdSupStart = na
var float h2SdDemTop = na
var float h2SdDemBtm = na
var int h2SdDemStart = na

bool reqHtf2Zones = zshow1 or needHtf2Anchors
var bool prevZshow0 = false
var bool prevReqHtf2Zones = false
var bool initialTradesSyncDone = false
bool htf1BarChanged = zshow0 and not na(htf1) and ta.change(time(htf1)) != 0
bool htf2BarChanged = reqHtf2Zones and not na(htf2) and ta.change(time(htf2)) != 0
bool htfCfgChanged = barstate.isfirst or zshow0 != prevZshow0 or reqHtf2Zones != prevReqHtf2Zones
bool needRefreshHtfSnapshots = htfCfgChanged or htf1BarChanged or htf2BarChanged
if needRefreshHtfSnapshots
    [_h1ObUpTop, _h1ObUpBtm, _h1ObUpStart, _h1ObDnTop, _h1ObDnBtm, _h1ObDnStart, _h1FvgUpTop, _h1FvgUpBtm, _h1FvgUpStart, _h1FvgDnTop, _h1FvgDnBtm, _h1FvgDnStart, _h1ObUpQ, _h1ObDnQ, _h1FvgUpQ, _h1FvgDnQ, _h2ObUpTop, _h2ObUpBtm, _h2ObUpStart, _h2ObDnTop, _h2ObDnBtm, _h2ObDnStart, _h2FvgUpTop, _h2FvgUpBtm, _h2FvgUpStart, _h2FvgDnTop, _h2FvgDnBtm, _h2FvgDnStart, _h2ObUpQ, _h2ObDnQ, _h2FvgUpQ, _h2FvgDnQ, _, _, _, _] = get_data_htf_pdarray_snapshots(htf1, htf2, zshow0, reqHtf2Zones, zqCfg)
    h1ObUpTop := _h1ObUpTop
    h1ObUpBtm := _h1ObUpBtm
    h1ObUpStart := _h1ObUpStart
    h1ObDnTop := _h1ObDnTop
    h1ObDnBtm := _h1ObDnBtm
    h1ObDnStart := _h1ObDnStart
    h1FvgUpTop := _h1FvgUpTop
    h1FvgUpBtm := _h1FvgUpBtm
    h1FvgUpStart := _h1FvgUpStart
    h1FvgDnTop := _h1FvgDnTop
    h1FvgDnBtm := _h1FvgDnBtm
    h1FvgDnStart := _h1FvgDnStart
    h1ObUpQ := _h1ObUpQ
    h1ObDnQ := _h1ObDnQ
    h1FvgUpQ := _h1FvgUpQ
    h1FvgDnQ := _h1FvgDnQ
    h2ObUpTop := _h2ObUpTop
    h2ObUpBtm := _h2ObUpBtm
    h2ObUpStart := _h2ObUpStart
    h2ObDnTop := _h2ObDnTop
    h2ObDnBtm := _h2ObDnBtm
    h2ObDnStart := _h2ObDnStart
    h2FvgUpTop := _h2FvgUpTop
    h2FvgUpBtm := _h2FvgUpBtm
    h2FvgUpStart := _h2FvgUpStart
    h2FvgDnTop := _h2FvgDnTop
    h2FvgDnBtm := _h2FvgDnBtm
    h2FvgDnStart := _h2FvgDnStart
    h2ObUpQ := _h2ObUpQ
    h2ObDnQ := _h2ObDnQ
    h2FvgUpQ := _h2FvgUpQ
    h2FvgDnQ := _h2FvgDnQ
prevZshow0 := zshow0
prevReqHtf2Zones := reqHtf2Zones
int htfSdLookback = math.max(20, math.min(localCfg.htfZoneLookbackBars, 300))
var bool prevZshow0Sd = false
var bool prevZshow1 = false
var bool prevPlotSd = false
bool sdCfgChanged = barstate.isfirst or zshow0 != prevZshow0Sd or zshow1 != prevZshow1 or plotSD != prevPlotSd
bool refreshHtf1Sd = sdCfgChanged or (zshow0 and plotSD and not na(htf1) and ta.change(time(htf1)) != 0)
bool refreshHtf2Sd = sdCfgChanged or (zshow1 and plotSD and not na(htf2) and ta.change(time(htf2)) != 0)
if refreshHtf1Sd
    [h1SdSupTopRaw, h1SdSupBtmRaw, h1SdSupStartRaw, h1SdDemTopRaw, h1SdDemBtmRaw, h1SdDemStartRaw] = if zshow0 and plotSD
        request.security(syminfo.tickerid, htf1, get_data_htf_sd_snapshot(10.0, 50, htfSdLookback))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na)]
    h1SdSupTop := h1SdSupTopRaw
    h1SdSupBtm := h1SdSupBtmRaw
    h1SdSupStart := h1SdSupStartRaw
    h1SdDemTop := h1SdDemTopRaw
    h1SdDemBtm := h1SdDemBtmRaw
    h1SdDemStart := h1SdDemStartRaw
if refreshHtf2Sd
    [h2SdSupTopRaw, h2SdSupBtmRaw, h2SdSupStartRaw, h2SdDemTopRaw, h2SdDemBtmRaw, h2SdDemStartRaw] = if zshow1 and plotSD
        request.security(syminfo.tickerid, htf2, get_data_htf_sd_snapshot(10.0, 50, htfSdLookback))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na)]
    h2SdSupTop := h2SdSupTopRaw
    h2SdSupBtm := h2SdSupBtmRaw
    h2SdSupStart := h2SdSupStartRaw
    h2SdDemTop := h2SdDemTopRaw
    h2SdDemBtm := h2SdDemBtmRaw
    h2SdDemStart := h2SdDemStartRaw
prevZshow1 := zshow1
prevPlotSd := plotSD
prevZshow0Sd := zshow0

process_data_run_pdarray_pipeline(string htf1Name, string htf2Name, bool showHtf1, bool showHtf2, int ltfZoneStartIdx, bool canEmitSignals) =>
    process_data_detect_ltf_pdarrays()
    annotate_new_pricezones(smcCtx.zones, ltfZoneStartIdx, timeframe.period, 1, ltfData)
    array<KitSMC.PDArray> prunedOld = KitSMC.prune_old_current_zones(smcCtx.zones, effectiveCurrLookbackBars, last_bar_index)
    apply_removed_pdarray_visuals(prunedOld)
    process_data_attach_htf_pdarrays_for_tf(smcCtx.zones, htf1Name, 0, showHtf1,
     plotOB, h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObUpQ,
     h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1ObDnQ,
     plotFVG, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgUpQ,
     h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1FvgDnQ,
     plotSD, h1SdSupTop, h1SdSupBtm, h1SdSupStart,
     h1SdDemTop, h1SdDemBtm, h1SdDemStart,
     htf1Data, 2)
    process_data_attach_htf_pdarrays_for_tf(smcCtx.zones, htf2Name, 1, showHtf2,
     plotOB, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObUpQ,
     h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2ObDnQ,
     plotFVG, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgUpQ,
     h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2FvgDnQ,
     plotSD, h2SdSupTop, h2SdSupBtm, h2SdSupStart,
     h2SdDemTop, h2SdDemBtm, h2SdDemStart,
     htf2Data, 3)
    int breakRetestWindowBars = KitCore.get_dynamic_confirmation_window_bars(timeframe.period, false, localCfg.sweepReclaimMinBars, localCfg.sweepReclaimMaxBars, localCfg.breakRetestMinBars, localCfg.breakRetestMaxBars)
    process_data_prune_zones_by_relevance(smcCtx.zones)
    process_data_entries(breakRetestWindowBars, canEmitSignals)
    int postTouchKeepMax = 16
    prune_post_touch_pdarrays(smcCtx.zones, postTouchKeepMax, localCfg.zonePriorityAgeDecay)
    bool(na)

int htf2ObAnchorTs = KitCore.get_latest_time4(h2ObUpStart, h2ObDnStart, h2FvgUpStart, h2FvgDnStart)
int htf2SrAnchorTs = na
runtimeCtx := KitCore.update_runtime_context(runtimeCtx)
bool canEmitSignals = barstate.isconfirmed and entryEngineEnabled
bool calcOnClosedBar = barstate.ishistory or barstate.isconfirmed
if not initialTradesSyncDone
    if tradeEntriesEnabled
        process_data_trades()
    initialTradesSyncDone := true

// Other logics
if calcOnClosedBar
    int currPivotLen = localCfg.currPivotLenNormal
    int htf1PivotLen = localCfg.htf1PivotLenNormal
    int htf2PivotLen = localCfg.htf2PivotLenNormal
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    [sh1Real, sh1RealT, sl1Real, sl1RealT] = get_data_real_htf_swings(htf1, htf1PivotLen)
    [sh2Real, sh2RealT, sl2Real, sl2RealT] = get_data_real_htf_swings(htf2, htf2PivotLen)
    float hv = ta.valuewhen(not na(ta.pivothigh(high, PIVOT_LEN_BASE, PIVOT_LEN_BASE)), high[PIVOT_LEN_BASE], 0)
    float lv = ta.valuewhen(not na(ta.pivotlow(low, PIVOT_LEN_BASE, PIVOT_LEN_BASE)), low[PIVOT_LEN_BASE], 0)
    KitSMC.EngineCfg engineCfg = KitSMC.EngineCfg.new()
    engineCfg.runSwingCycle := true
    engineCfg.runStructureState := false
    engineCfg.runPDArray := true
    engineCfg.pdWantObFamily := plotOB
    engineCfg.pdWantFvg := plotFVG
    engineCfg.pdFormationLockBars := localCfg.zoneFormationLockBars
    KitSMC.process_engine_base_cycle(
     smcCtx, engineCfg,
     htf1, htf2,
     currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na,
     sh1Real, int(sh1RealT), sl1Real, int(sl1RealT),
     sh2Real, int(sh2RealT), sl2Real, int(sl2RealT),
     SETTINGS.SWING_HISTORY_MAX,
     int(na), high, low, bar_index,
     hv, lv, commonAtr, syminfo.mintick, zqCfg)
[h2LastHi, h2LastHiT, h2LastLo, h2LastLoT] = KitSMC.market_structure_latest_hilo(htf2Data.mss)
int htf2SwingAnchorTs = KitCore.get_latest_time4(h2LastHiT, h2LastLoT, int(na), int(na))
int htf2AnchorTsFinal = KitCore.get_dynamic_anchor_ts("OB_FIRST", "SR_FIRST", "SWING_FIRST", htf2ObAnchorTs, htf2SrAnchorTs, htf2SwingAnchorTs)
bool recalcByHtf2 = not na(htf2) and ta.change(time(htf2)) != 0
bool shouldDynRecalc = SETTINGS.DYN_LOOKBACK_ENABLE and calcOnClosedBar and (barstate.isfirst or recalcByHtf2)
if shouldDynRecalc
    int dynHtf1Candles = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf1) ? KitCore.get_candles_to_anchor(htf1, htf2AnchorTsFinal, SETTINGS.DYN_HTF1_CANDLES_MIN, SETTINGS.DYN_HTF1_CANDLES_MAX, SETTINGS.HTF_CANDLES_BASE) : SETTINGS.HTF_CANDLES_BASE
    int htf1SecForDyn = not na(htf1) ? math.max(KitUI.get_tf_seconds(htf1), 1) : na
    int htf2SecForDyn = not na(htf2) ? math.max(KitUI.get_tf_seconds(htf2), 1) : na
    float htf2PerHtf1Dyn = not na(htf1SecForDyn) and not na(htf2SecForDyn) and htf2SecForDyn > htf1SecForDyn ? float(htf2SecForDyn) / float(htf1SecForDyn) : na
    int dynHtf2Candles = not na(htf2PerHtf1Dyn) ? int(math.round(float(dynHtf1Candles) / htf2PerHtf1Dyn)) : SETTINGS.DYN_HTF2_CANDLES_FALLBACK
    dynHtf2Candles := math.max(SETTINGS.DYN_HTF2_CANDLES_MIN, math.min(dynHtf2Candles, SETTINGS.DYN_HTF2_CANDLES_MAX))
    int dynHtf1FromHtf2 = not na(htf2PerHtf1Dyn) ? int(math.ceil(float(dynHtf2Candles) * htf2PerHtf1Dyn)) : dynHtf1Candles
    dynHtf1Candles := math.max(dynHtf1Candles, dynHtf1FromHtf2)
    dynHtf1Candles := math.max(SETTINGS.DYN_HTF1_CANDLES_MIN, math.min(dynHtf1Candles, SETTINGS.DYN_HTF1_CANDLES_MAX))
    int dynCurrLookbackBars = KitCore.get_curr_lookback_from_htf2(htf2, dynHtf2Candles, SETTINGS.DYN_CURR_LOOKBACK_MIN_BARS, SETTINGS.DYN_CURR_LOOKBACK_MAX_BARS)
    dynCachedCurrLookbackBars := dynCurrLookbackBars
effectiveCurrLookbackBars := SETTINGS.DYN_LOOKBACK_ENABLE ? dynCachedCurrLookbackBars : localCfg.workingLookbackBars
effectiveCurrLookbackBars := math.max(bar_index - workingFirstBar + 1, 1)
perfLookbackBars := effectiveCurrLookbackBars
htfProjectionSpanBars := effectiveCurrLookbackBars
if calcOnClosedBar
    workingFirstBar := KitCore.get_working_first_bar_from_lookback(localCfg.workingLookbackBars)
    int ltfOffSafe = math.max(0, math.min(math.min(bar_index - workingFirstBar, bar_index), 10000))
    int ltfFirstTime = int(time[ltfOffSafe])
    int htf1FirstTime = not na(htf1) ? get_data_htf_detection_cutoff_time(0, htf1) : na
    int htf2FirstTime = not na(htf2) ? get_data_htf_detection_cutoff_time(1, htf2) : na
    if not na(htf1FirstTime) and htf1FirstTime > ltfFirstTime
        htf1FirstTime := ltfFirstTime
    int htf2MaxTime = not na(htf1FirstTime) ? htf1FirstTime : ltfFirstTime
    if not na(htf2FirstTime) and htf2FirstTime > htf2MaxTime
        htf2FirstTime := htf2MaxTime
    process_data_prune_outside_working_zone(smcCtx.zones)
    chartCtx := process_data_chart_context()

int ltfZoneStartIdx = array.size(smcCtx.zones)
if calcOnClosedBar
    process_data_run_pdarray_pipeline(htf1, htf2, zshow0, zshow1, ltfZoneStartIdx, canEmitSignals)
else
    // Realtime open bar: keep trade states fresh so dashboard TP/SL stats update intrabar.
    if tradeEntriesEnabled
        process_data_trades()
// barstate.islast
if barstate.islast or barstate.islastconfirmedhistory
    draw_data_trades_dashboard()
