type LocalCfg
    int detMethod = 0
    int detMethodCross = 1
    string detBasis = "Wick" // Wick/Close basis.
    bool detUseImpulse = false
    float detImpulseAtr = 0.5
    int scoreHtf = 2
    int scoreConfirm = 2
    bool entryZoneFilterEnable = true
    float entryZoneMinQualityPct = 0.0
    bool entryFilterNearLegEnable = false
    int entryFilterNearLegMaxSeq = 99
    bool entryFilterNearLegRequireDirMatch = false
    bool entryFilterNearLegAllowUnknown = true
    int zoneCapPerType = 100000
    int zoneCapTotal = 100000
    int zoneCurrMaxPerTypeSide = 100000
    float zonePriorityAgeDecay = 0.01
    int zoneFormationLockBars = 1
    float zoneMinHeightAtr = 0.05
    int htfZoneLookbackBars = 1000000
    float htfProjectionMinQualityPct = 0.0
    string displayMode = "Normal"
    int workingLookbackBars = 0
    int displayZonePerTypeSideCap = 1
    int displayZoneSideTotalCap = 999
    int currPivotLenNormal = 0
    int htf1PivotLenNormal = 0
    int htf2PivotLenNormal = 0
    int sweepReclaimMinBars = 2
    int sweepReclaimMaxBars = 14
    int breakRetestMinBars = 6
    int breakRetestMaxBars = 34
    float riskPerRRUsd = 100.0
    float minTradeSizeTicks = 0
    float minTradeRR = 0.0

type UIConfig
    color colorBearish = color.red
    color colorBullish = color.teal
    color colorBg = color.gray
    color colorText = color.white
    color ltfColor = color.gray
    int ltfBarsExt = 5
    int ltfLineBarsExt = 8
    bool msHtf1SwingShow = true
    bool msHtf1ZigzagShow = true
    bool msHtf2SwingShow = true
    bool msHtf2ZigzagShow = true
    int htfZoneBgTransp = 90
    int zoneCurrMinWidthBars = 6
    bool htfShowProjectedZones = true

get_ui_cfg(KitCore.Theme th) =>
    UIConfig cfg = UIConfig.new()
    cfg.colorBearish := color.new(th.COLOR_BEARISH, th.T_NORMAL)
    cfg.colorBullish := color.new(th.COLOR_BULLISH, th.T_NORMAL)
    cfg.colorBg := color.new(th.COLOR_NEUTRAL, th.T_NORMAL)
    cfg.colorText := color.new(th.TEXT_COLOR, th.T_NORMAL)
    cfg.ltfColor := color.new(color.rgb(215, 215, 215), 0)
    cfg

get_data_local_cfg(int globalLookbackBars, string displayMode) =>
    LocalCfg cfg = LocalCfg.new()
    cfg.displayMode := displayMode
    cfg.workingLookbackBars := KitCore.get_display_mode_working_lookback_bars(displayMode, globalLookbackBars)
    cfg.displayZonePerTypeSideCap := displayMode == "Less" ? 2 : displayMode == "Normal" ? 1 : 999
    cfg.displayZoneSideTotalCap := displayMode == "Extreme" ? 1 : 999
    cfg.htfZoneLookbackBars := cfg.workingLookbackBars <= 0 ? 1000000 : cfg.workingLookbackBars
    cfg.entryZoneMinQualityPct := 35.0
    cfg.htfProjectionMinQualityPct := 25.0
    cfg.zoneCapPerType := 100000
    cfg.zoneCapTotal := 100000
    cfg.zoneCurrMaxPerTypeSide := 100000
    cfg.zonePriorityAgeDecay := 0.010
    cfg

