plotOB = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? true : uiPlotObInput
plotFVG = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? true : uiPlotFvgInput
plotSD = uiModeNone ? false : uiModeAll ? true : uiModeLess ? false : uiModeExtreme ? false : uiPlotSdInput
useBB = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? true : uiUseBbInput
useIFVG = uiModeNone ? false : uiModeAll ? true : uiModeLess ? true : uiModeExtreme ? false : uiUseIfvgInput
