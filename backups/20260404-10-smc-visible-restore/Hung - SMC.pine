// ==================== INPUT SETTINGS ====================
GROUP_UI_CONFIG = "1. UI Config"
GROUP_TRADE_MODELS = "2. Trade Models"
GROUP_TRADES_CONFIG = "3. Trade Config"

uiPlotObInput = input.bool(true, "OB", inline = "ui0", group = GROUP_UI_CONFIG)
uiPlotFvgInput = input.bool(true, "FVG", inline = "ui0", group = GROUP_UI_CONFIG)
uiPlotSdInput = input.bool(true, "SD", inline = "ui0", group = GROUP_UI_CONFIG)
uiUseBbInput = input.bool(true, "BB", inline = "ui0", group = GROUP_UI_CONFIG)
uiUseIfvgInput = input.bool(true, "iFVG", inline = "ui0", group = GROUP_UI_CONFIG)
pdDisplayMode = input.string("Normal", "Display", options = ["All", "Less", "Normal", "Extreme", "None"], group = GROUP_UI_CONFIG)

bool uiModeAll = pdDisplayMode == "All"
bool uiModeLess = pdDisplayMode == "Less"
bool uiModeExtreme = pdDisplayMode == "Extreme"
