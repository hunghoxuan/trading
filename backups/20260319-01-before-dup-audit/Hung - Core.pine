// Bias toggle config: built once from input booleans, reused in get_bias_data.
BIAS_TOG = LIB.BiasToggles.new(
     bias_use_structure, bias_use_vwap, bias_use_ema, bias_use_rsi,
     bias_use_adx, bias_use_rsi_impulse, bias_use_supertrend, bias_use_donchian)

get_bias_slot_text_color(int slotIdx) =>
    slotIdx == 0 ? color.rgb(120, 190, 255) :
     slotIdx == 1 ? color.rgb(242, 132, 72) :
     slotIdx == 2 ? color.rgb(166, 108, 232) :
     slotIdx == 3 ? color.rgb(236, 109, 156) :
     color.rgb(92, 201, 176)

set_dashboard_table_visible(table t, bool active, int maxCol, int maxRow) =>
    if active
        table.set_frame_width(t, 1)
        table.set_border_width(t, 1)
        table.set_frame_color(t, color.new(THEME.COLOR_UI_FG, 75))
        table.set_border_color(t, color.new(THEME.COLOR_UI_FG, 80))
        table.set_bgcolor(t, color.new(THEME.COLOR_UI_BG, 85))
    else
        table.clear(t, 0, 0, maxCol, maxRow)
        table.set_frame_width(t, 0)
        table.set_border_width(t, 0)
        table.set_frame_color(t, color.new(THEME.COLOR_UI_FG, 100))
        table.set_border_color(t, color.new(THEME.COLOR_UI_FG, 100))
        table.set_bgcolor(t, color.new(THEME.COLOR_UI_BG, 100))
    bool(na)

process_htf_candle_panel() =>
    [htf1, htf2] = LIB.get_htf_pair()
    [_o1, _h1, _l1, _c1, _htfPat1] = LIB.get_data_htf_candles(htf1)
    [_o2, _h2, _l2, _c2, _htfPat2] = LIB.get_data_htf_candles(htf2)
    [slot_tf_0, slot_tf_1, slot_count_0, slot_count_1, show_0, show_1, off_0, off_1, need_reset_0, need_reset_1] = LIB.get_data_htf_candle_layout(htf1, htf2, SETTINGS.HTF_CANDLES_BASE, SETTINGS.HTF_CANDLES_BIAS1, prev_slot_tf_0, prev_slot_tf_1, 25, HTF_CANDLE_LAYOUT_CFG)
    [nextHtfLabel0, nextHtfLabel1] = LIB.process_data_htf_candles(htf1_candles, htf2_candles, htfLabel0, htfLabel1, slot_tf_0, slot_tf_1, slot_count_0, slot_count_1, show_0, show_1, off_0, off_1, need_reset_0, need_reset_1, _o1, _h1, _l1, _c1, _htfPat1, _o2, _h2, _l2, _c2, _htfPat2, THEME.COLOR_HTF1, THEME.COLOR_HTF2, THEME, HTF_CANDLE_VIS_CFG)
    [nextHtfLabel0, nextHtfLabel1, slot_tf_0, slot_tf_1]

// Core (Bias Data): Computes current + 15m/4h/1D/1W bias set, plus higher-TF composite power.
get_bias_data() =>
    [bCur, sCur, mCur, tCur] = LIB.get_bias_data_for_tf(timeframe.period, SETTINGS, BIAS_TOG)
    [b15,  s15,  m15,  t15 ] = request.security(syminfo.tickerid, "15",  LIB.get_bias_data_for_tf("15", SETTINGS, BIAS_TOG))
    [b240, s240, m240, t240] = request.security(syminfo.tickerid, "240", LIB.get_bias_data_for_tf("240", SETTINGS, BIAS_TOG))
    [b1d,  s1d,  m1d,  t1d ] = request.security(syminfo.tickerid, "1D",  LIB.get_bias_data_for_tf("1D", SETTINGS, BIAS_TOG))
    [b1w,  s1w,  m1w,  t1w ] = request.security(syminfo.tickerid, "1W",  LIB.get_bias_data_for_tf("1W", SETTINGS, BIAS_TOG))

    int currSec = LIB.get_tf_seconds(timeframe.period)
    bool use15  = LIB.get_tf_seconds("15")  > currSec
    bool use240 = LIB.get_tf_seconds("240") > currSec
    bool use1d  = LIB.get_tf_seconds("1D")  > currSec
    bool use1w  = LIB.get_tf_seconds("1W")  > currSec

    float power    = (bCur * sCur * 1.0)
                   + (use15  ? (b15  * s15  * 1.5) : 0.0)
                   + (use240 ? (b240 * s240 * 2.0) : 0.0)
                   + (use1d  ? (b1d  * s1d  * 3.0) : 0.0)
                   + (use1w  ? (b1w  * s1w  * 4.0) : 0.0)
    float powerMax = (mCur * 1.0)
                   + (use15  ? (m15  * 1.5) : 0.0)
                   + (use240 ? (m240 * 2.0) : 0.0)
                   + (use1d  ? (m1d  * 3.0) : 0.0)
                   + (use1w  ? (m1w  * 4.0) : 0.0)
    float powerPercent = powerMax > 0 ? math.min(math.max((power / powerMax) * 100.0, -100.0), 100.0) : 0.0
    int compositeBias = powerPercent > 20 ? 1 : powerPercent < -20 ? -1 : 0
    [bCur, sCur, mCur, tCur, b15, s15, m15, t15, b240, s240, m240, t240, b1d, s1d, m1d, t1d, b1w, s1w, m1w, t1w, powerPercent, compositeBias]

[b0, s0, m0, t0, b15, s15, m15, t15, b240, s240, m240, t240, b1d, s1d, m1d, t1d, b1w, s1w, m1w, t1w, powerPercent, compositeBias] = get_bias_data()

// Core (Bias UI): Positionable dashboard with fixed 5 columns: current + up to 4 HTFs.
draw_bias_data(string dashPos, int _b0, int _s0, int _m0, int _t0, int _b15, int _s15, int _m15, int _t15, int _b240, int _s240, int _m240, int _t240, int _b1d, int _s1d, int _m1d, int _t1d, int _b1w, int _s1w, int _m1w, int _t1w) =>
    var table biasDashTopRight = table.new(position.top_right, 5, 1, bgcolor = color.new(THEME.COLOR_UI_BG, 85), frame_color = color.new(THEME.COLOR_UI_FG, 75), frame_width = 1, border_color = color.new(THEME.COLOR_UI_FG, 80), border_width = 1)
    var table biasDashBottomRight = table.new(position.bottom_right, 5, 1, bgcolor = color.new(THEME.COLOR_UI_BG, 85), frame_color = color.new(THEME.COLOR_UI_FG, 75), frame_width = 1, border_color = color.new(THEME.COLOR_UI_FG, 80), border_width = 1)
    var table biasDashTopCenter = table.new(position.top_center, 5, 1, bgcolor = color.new(THEME.COLOR_UI_BG, 85), frame_color = color.new(THEME.COLOR_UI_FG, 75), frame_width = 1, border_color = color.new(THEME.COLOR_UI_FG, 80), border_width = 1)
    var table biasDashBottomCenter = table.new(position.bottom_center, 5, 1, bgcolor = color.new(THEME.COLOR_UI_BG, 85), frame_color = color.new(THEME.COLOR_UI_FG, 75), frame_width = 1, border_color = color.new(THEME.COLOR_UI_FG, 80), border_width = 1)
    bool showDash = dashPos != CONST.DASH_NONE
    bool showTopRight = showDash and dashPos == CONST.DASH_TOP_RIGHT
    bool showBottomRight = showDash and dashPos == CONST.DASH_BOTTOM_RIGHT
    bool showTopCenter = showDash and dashPos == CONST.DASH_TOP_CENTER
    bool showBottomCenter = showDash and dashPos == CONST.DASH_BOTTOM_CENTER
    set_dashboard_table_visible(biasDashTopRight, showTopRight, 4, 0)
    set_dashboard_table_visible(biasDashBottomRight, showBottomRight, 4, 0)
    set_dashboard_table_visible(biasDashTopCenter, showTopCenter, 4, 0)
    set_dashboard_table_visible(biasDashBottomCenter, showBottomCenter, 4, 0)
    table biasDash = dashPos == CONST.DASH_TOP_RIGHT ? biasDashTopRight :
         dashPos == CONST.DASH_BOTTOM_RIGHT ? biasDashBottomRight :
         dashPos == CONST.DASH_TOP_CENTER ? biasDashTopCenter :
         biasDashBottomCenter
    int currSec = LIB.get_tf_seconds(timeframe.period)
    bool show15  = LIB.get_tf_seconds("15")  > currSec
    bool show240 = LIB.get_tf_seconds("240") > currSec
    bool show1d  = LIB.get_tf_seconds("1D")  > currSec
    bool show1w  = LIB.get_tf_seconds("1W")  > currSec
    if showDash
        int col = 0
        int level0 = LIB.get_bias_strength_level(_s0, _m0)
        color bg0 = LIB.get_strength_color(_b0 == 1 ? "bull" : _b0 == -1 ? "bear" : "neutral", level0)
        string tfTxt0 = LIB.get_friendly_tf(timeframe.period)
        string cellTx0 = str.length(tfTxt0) > 2 ? str.substring(tfTxt0, 0, 2) : tfTxt0
        string baseTt0 = LIB.get_bias_tooltip(timeframe.period, _b0, _s0, _m0, _t0, SETTINGS)
        string cpLine0 = cpIsPat ? "\nCandle Pattern: " + cpAggName + " (" + (cpIsBull ? "▲BULL" : cpIsBear ? "▼BEAR" : "●NEUT") + ") score" + str.tostring(cpPatScore) + " conv" + str.tostring(cpConvScore) : ""
        table.cell(biasDash, col, 0, cellTx0, bgcolor = bg0, text_color = color.white, text_size = size.tiny, tooltip = baseTt0 + cpLine0)
        col += 1
        if show15 and col <= 4
            int level15 = LIB.get_bias_strength_level(_s15, _m15)
            color bg15 = LIB.get_strength_color(_b15 == 1 ? "bull" : _b15 == -1 ? "bear" : "neutral", level15)
            string tfTxt15 = LIB.get_friendly_tf("15")
            string cellTx15 = str.length(tfTxt15) > 2 ? str.substring(tfTxt15, 0, 2) : tfTxt15
            string baseTt15 = LIB.get_bias_tooltip("15", _b15, _s15, _m15, _t15, SETTINGS)
            table.cell(biasDash, col, 0, cellTx15, bgcolor = bg15, text_color = color.white, text_size = size.tiny, tooltip = baseTt15)
            col += 1
        if show240 and col <= 4
            int level240 = LIB.get_bias_strength_level(_s240, _m240)
            color bg240 = LIB.get_strength_color(_b240 == 1 ? "bull" : _b240 == -1 ? "bear" : "neutral", level240)
            string tfTxt240 = LIB.get_friendly_tf("240")
            string cellTx240 = str.length(tfTxt240) > 2 ? str.substring(tfTxt240, 0, 2) : tfTxt240
            string baseTt240 = LIB.get_bias_tooltip("240", _b240, _s240, _m240, _t240, SETTINGS)
            table.cell(biasDash, col, 0, cellTx240, bgcolor = bg240, text_color = color.white, text_size = size.tiny, tooltip = baseTt240)
            col += 1
        if show1d and col <= 4
            int level1d = LIB.get_bias_strength_level(_s1d, _m1d)
            color bg1d = LIB.get_strength_color(_b1d == 1 ? "bull" : _b1d == -1 ? "bear" : "neutral", level1d)
            string tfTxt1d = LIB.get_friendly_tf("1D")
            string cellTx1d = str.length(tfTxt1d) > 2 ? str.substring(tfTxt1d, 0, 2) : tfTxt1d
            string baseTt1d = LIB.get_bias_tooltip("1D", _b1d, _s1d, _m1d, _t1d, SETTINGS)
            table.cell(biasDash, col, 0, cellTx1d, bgcolor = bg1d, text_color = color.white, text_size = size.tiny, tooltip = baseTt1d)
            col += 1
        if show1w and col <= 4
            int level1w = LIB.get_bias_strength_level(_s1w, _m1w)
            color bg1w = LIB.get_strength_color(_b1w == 1 ? "bull" : _b1w == -1 ? "bear" : "neutral", level1w)
            string tfTxt1w = LIB.get_friendly_tf("1W")
            string cellTx1w = str.length(tfTxt1w) > 2 ? str.substring(tfTxt1w, 0, 2) : tfTxt1w
            string baseTt1w = LIB.get_bias_tooltip("1W", _b1w, _s1w, _m1w, _t1w, SETTINGS)
            table.cell(biasDash, col, 0, cellTx1w, bgcolor = bg1w, text_color = color.white, text_size = size.tiny, tooltip = baseTt1w)
            col += 1
        if col <= 4
            for c = col to 4
                table.cell(biasDash, c, 0, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    else
        for c = 0 to 4
            table.cell(biasDash, c, 0, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    if dashPos != CONST.DASH_TOP_RIGHT
        for c = 0 to 4
            table.cell(biasDashTopRight, c, 0, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    if dashPos != CONST.DASH_BOTTOM_RIGHT
        for c = 0 to 4
            table.cell(biasDashBottomRight, c, 0, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    if dashPos != CONST.DASH_TOP_CENTER
        for c = 0 to 4
            table.cell(biasDashTopCenter, c, 0, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    if dashPos != CONST.DASH_BOTTOM_CENTER
        for c = 0 to 4
            table.cell(biasDashBottomCenter, c, 0, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    bool(na)

draw_bias_data(biasDashboardPos, b0, s0, m0, t0, b15, s15, m15, t15, b240, s240, m240, t240, b1d, s1d, m1d, t1d, b1w, s1w, m1w, t1w)
[nextHtfLabel0, nextHtfLabel1, nextSlotTf0, nextSlotTf1] = process_htf_candle_panel()
htfLabel0 := nextHtfLabel0
htfLabel1 := nextHtfLabel1
prev_slot_tf_0 := nextSlotTf0
prev_slot_tf_1 := nextSlotTf1

[msHtf1, msHtf2] = LIB.get_htf_pair()
int msBaseLookback = perfLookbackBars > 0 ? perfLookbackBars : 500
int msStructureLookbackBars = math.max(150, int(math.round(float(msBaseLookback) * STRUCTURE_LOOKBACK_MULT)))
[_currSh, _currSl, _currPivotOffSafe, _structRecentTsCut, _structRecentIdxCut, _sh1Mimic, _sl1Mimic, _sh1MimicT, _sl1MimicT, _sh1MimicIdx, _sl1MimicIdx, _sh2Mimic, _sl2Mimic, _sh2MimicT, _sl2MimicT, _sh2MimicIdx, _sl2MimicIdx] = get_data_market_structure(msHtf1, msHtf2, PIVOT_LEN_BASE, msStructureLookbackBars)
process_data_market_structure(msHtf1, msHtf2, msShowLtf, msShowTf1, msShowTf2, _currSh, _currSl, _currPivotOffSafe, _structRecentTsCut, _structRecentIdxCut, _sh1Mimic, _sl1Mimic, _sh1MimicT, _sl1MimicT, _sh1MimicIdx, _sl1MimicIdx, _sh2Mimic, _sl2Mimic, _sh2MimicT, _sl2MimicT, _sh2MimicIdx, _sl2MimicIdx)
[_ltfFib1, _ltfFib2, _ltfFib3, _ltfLeg, _ltfLb1, _ltfLb2, _ltfLb3] = draw_data_tf_live_leg_fib(msLtfData, msLtfCfg, msShowLtf, _structRecentIdxCut, msFibLtf1, msFibLtf2, msFibLtf3, msFibLtfLeg, msFibLtfLb1, msFibLtfLb2, msFibLtfLb3)
msFibLtf1 := _ltfFib1
msFibLtf2 := _ltfFib2
msFibLtf3 := _ltfFib3
msFibLtfLeg := _ltfLeg
msFibLtfLb1 := _ltfLb1
msFibLtfLb2 := _ltfLb2
msFibLtfLb3 := _ltfLb3
[_h1Fib1, _h1Fib2, _h1Fib3, _h1Leg, _h1Lb1, _h1Lb2, _h1Lb3] = draw_data_tf_live_leg_fib(msHtf1Data, msHtf1Cfg, msShowTf1 and not na(msHtf1), _structRecentIdxCut, msFibHtf11, msFibHtf12, msFibHtf13, msFibHtf1Leg, msFibHtf1Lb1, msFibHtf1Lb2, msFibHtf1Lb3)
msFibHtf11 := _h1Fib1
msFibHtf12 := _h1Fib2
msFibHtf13 := _h1Fib3
msFibHtf1Leg := _h1Leg
msFibHtf1Lb1 := _h1Lb1
msFibHtf1Lb2 := _h1Lb2
msFibHtf1Lb3 := _h1Lb3
[_h2Fib1, _h2Fib2, _h2Fib3, _h2Leg, _h2Lb1, _h2Lb2, _h2Lb3] = draw_data_tf_live_leg_fib(msHtf2Data, msHtf2Cfg, msShowTf2 and not na(msHtf2), _structRecentIdxCut, msFibHtf21, msFibHtf22, msFibHtf23, msFibHtf2Leg, msFibHtf2Lb1, msFibHtf2Lb2, msFibHtf2Lb3)
msFibHtf21 := _h2Fib1
msFibHtf22 := _h2Fib2
msFibHtf23 := _h2Fib3
msFibHtf2Leg := _h2Leg
msFibHtf2Lb1 := _h2Lb1
msFibHtf2Lb2 := _h2Lb2
msFibHtf2Lb3 := _h2Lb3

draw_data_entries_dashboard(string dashPos) =>
    bool _keepArg = str.length(dashPos) >= 0
    var table entriesDash = table.new(position.bottom_right, 5, 13, bgcolor = color.new(THEME.COLOR_UI_BG, 85), frame_color = color.new(THEME.COLOR_UI_FG, 75), frame_width = 1, border_color = color.new(THEME.COLOR_UI_FG, 80), border_width = 1)
    bool showDash = SIGNAL_STATS_SHOW and dashPos != CONST.DASH_NONE
    set_dashboard_table_visible(entriesDash, showDash, 4, 12)
    table t = entriesDash
    if SIGNAL_STATS_SHOW
        table.clear(t, 0, 0, 4, 12)
        color hdrBg = color.new(THEME.COLOR_UI_BG, 60)
        color rowBg = color.new(THEME.COLOR_UI_BG, 75)
        color totalBg = color.new(THEME.COLOR_UI_BG, 60)
        table.cell(t, 0, 0, "", text_color = THEME.COLOR_UI_FG, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 1, 0, "TP", text_color = THEME.COLOR_BULLISH, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 2, 0, "SL", text_color = THEME.COLOR_BEARISH, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 3, 0, "WR", text_color = THEME.COLOR_UI_FG, bgcolor = hdrBg, text_size = size.tiny)
        table.cell(t, 4, 0, "+R", text_color = THEME.COLOR_UI_ACCENT, bgcolor = hdrBg, text_size = size.tiny)
        array<string> names = array.new_string()
        array<float> tps = array.new_float()
        array<float> sls = array.new_float()
        array<float> grs = array.new_float()
        float totalTp = 0.0
        float totalSl = 0.0
        float totalGr = 0.0
        if array.size(entries) > 0
            for i = 0 to array.size(entries) - 1
                LIB.Entry e = array.get(entries, i)
                bool resolved = e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL
                if resolved
                    string setup = str.length(e.type) > 0 ? e.type : "N/A"
                    int idx = array.indexof(names, setup)
                    if idx == -1 and array.size(names) < 11
                        array.push(names, setup)
                        array.push(tps, 0.0)
                        array.push(sls, 0.0)
                        array.push(grs, 0.0)
                        idx := array.size(names) - 1
                    if idx >= 0
                        if e.state == CONST.SIGNAL_STATE_TP
                            array.set(tps, idx, array.get(tps, idx) + 1)
                            array.set(grs, idx, array.get(grs, idx) + e.rrValue)
                            totalTp += 1
                            totalGr += e.rrValue
                        else
                            array.set(sls, idx, array.get(sls, idx) + 1)
                            array.set(grs, idx, array.get(grs, idx) - 1)
                            totalSl += 1
                            totalGr -= 1
        float totalN = totalTp + totalSl
        float totalWr = totalN > 0 ? totalTp * 100.0 / totalN : 0.0
        table.cell(t, 0, 1, "Total", text_color = THEME.COLOR_UI_FG, bgcolor = totalBg, text_size = size.tiny)
        table.cell(t, 1, 1, str.tostring(int(math.round(totalTp))), text_color = THEME.COLOR_BULLISH, bgcolor = totalBg, text_size = size.tiny)
        table.cell(t, 2, 1, str.tostring(int(math.round(totalSl))), text_color = THEME.COLOR_BEARISH, bgcolor = totalBg, text_size = size.tiny)
        table.cell(t, 3, 1, str.tostring(int(math.round(totalWr))), text_color = THEME.COLOR_UI_FG, bgcolor = totalBg, text_size = size.tiny)
        table.cell(t, 4, 1, str.tostring(totalGr, "#.##"), text_color = THEME.COLOR_UI_ACCENT, bgcolor = totalBg, text_size = size.tiny)
        if array.size(names) > 0
            for r = 0 to array.size(names) - 1
                int row = r + 2
                if row <= 12
                    float tp = array.get(tps, r)
                    float sl = array.get(sls, r)
                    float gr = array.get(grs, r)
                    float n = tp + sl
                    float wr = n > 0 ? tp * 100.0 / n : 0.0
                    table.cell(t, 0, row, array.get(names, r), text_color = THEME.COLOR_UI_FG, bgcolor = rowBg, text_size = size.tiny)
                    table.cell(t, 1, row, str.tostring(int(math.round(tp))), text_color = THEME.COLOR_BULLISH, bgcolor = rowBg, text_size = size.tiny)
                    table.cell(t, 2, row, str.tostring(int(math.round(sl))), text_color = THEME.COLOR_BEARISH, bgcolor = rowBg, text_size = size.tiny)
                    table.cell(t, 3, row, str.tostring(int(math.round(wr))), text_color = THEME.COLOR_UI_FG, bgcolor = rowBg, text_size = size.tiny)
                    table.cell(t, 4, row, str.tostring(gr, "#.##"), text_color = THEME.COLOR_UI_ACCENT, bgcolor = rowBg, text_size = size.tiny)
    else
        table.clear(t, 0, 0, 4, 12)
    bool(na)

// ── Tier-1 CP Context Marker (deduplicated vs Tier-2) ────────────────────
// Suppressed when a Tier-2 Strategy Signal will fire on this same bar
// (score≥3 + bias aligned) to avoid double-marking the same signal.
bool cpTier2WillFire = cpShowPat and cpPatScore >= 3 and
     ((cpIsBull and LIB.bias_allows_direction(compositeBias, "Buy")) or
      (cpIsBear and LIB.bias_allows_direction(compositeBias, "Sell")))

if CP_VIS_CFG.showMarkers and cpShowPat and not cpTier2WillFire
    string cpIcon  = cpIsBull ? CONST.SYM_UP : cpIsBear ? CONST.SYM_DN : CONST.SYM_DOT
    color  cpLCol  = THEME.COLOR_LTF
    float  cpYPos  = cpIsBull ? low - cpAtr * 0.4 : high + cpAtr * 0.4
    string cpBLbl  = cpIsBull ? "BULLISH" : cpIsBear ? "BEARISH" : "NEUTRAL"
    string cpStars = LIB.cp_score_stars(cpPatScore)
    string cpVLbl  = cpVolRatio >= SETTINGS.CP_VOL_EXTREME ? "⚡ EXTREME VOL" : cpVolRatio >= SETTINGS.CP_VOL_HIGH ? "🟡 HIGH VOL" : "vol: normal"
    string cpTip   = cpBLbl + "  |  " + cpAggName + "  |  Score: " + str.tostring(cpPatScore) + "  " + cpStars + "\nConviction: " + str.tostring(cpConvScore) + "  |  " + cpVLbl + (cpAggStrength > 1 ? "\nConfluence: ×" + str.tostring(cpAggStrength) + " patterns agree" : "")
    label.new(bar_index, cpYPos, text = cpIcon, tooltip = cpTip, color = color.new(THEME.COLOR_UI_BG, 100), textcolor = cpLCol, style = label.style_none, size = THEME.SIZE_TINY)

// Core (Sessions/Killzones): Top line = killzone, bottom line = session. Overlap highlighted by background box.
process_killzones_sessions() =>
    bool enabled = kz_show and timeframe.isintraday and timeframe.multiplier < 60 and is_in_draw_window()
    if enabled
        bool isAsiaKz  = not na(time(timeframe.period, asS,   "UTC-5")) and kz_show
        bool isLdnKz   = not na(time(timeframe.period, ldnOS, "UTC-5")) and kz_show
        bool isNYAMKz  = not na(time(timeframe.period, nyS,   "UTC-5")) and kz_show
        bool isNYPmKz  = not na(time(timeframe.period, ldnCS, "UTC-5")) and kz_show

        bool isAsiaSess = not na(time(timeframe.period, sessAsia,         "UTC-5")) and kz_show
        bool isLdnSess  = not na(time(timeframe.period, sessLondon,       "UTC-5")) and kz_show
        bool isNYSess   = not na(time(timeframe.period, sessNY,           "UTC-5")) and kz_show
        bool isOverlap  = not na(time(timeframe.period, sessOverlap_LdnNy,"UTC-5")) and kz_show

        // Top lines: killzones (running highs).
        color winClr = color.new(kz_color, WIN_LINE_TRANSP)
        LIB.manage_window_line(kzAsiaTop, isAsiaKz, high, low, time, winClr, "Asia KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: Asia dealing window.", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        LIB.manage_window_line(kzLondonTop, isLdnKz, high, low, time, winClr, "London KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: London dealing window (often sets AM range).", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        LIB.manage_window_line(kzNYAMTop, isNYAMKz, high, low, time, winClr, "NY AM KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: NY AM dealing window (often expands/raids liquidity).", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        LIB.manage_window_line(kzNYPMTop, isNYPmKz, high, low, time, winClr, "NY PM KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: NY PM dealing window (PM distribution).", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)

        // Bottom lines: sessions (running lows). Use the same visual format as killzones.
        LIB.manage_window_line(sessAsiaBot, isAsiaSess, high, low, time, winClr, "Asia", false, false, WIN_LINE_WIDTH, kzLB, kz_size, "Session: Asia liquidity regime.", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        LIB.manage_window_line(sessLondonBot, isLdnSess, high, low, time, winClr, "London", false, false, WIN_LINE_WIDTH, kzLB, kz_size, "Session: London liquidity regime.", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        LIB.manage_window_line(sessNYBot, isNYSess, high, low, time, winClr, "NY", false, false, WIN_LINE_WIDTH, kzLB, kz_size, "Session: New York liquidity regime.", "H:mm aa", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)

        // Overlap highlight: no border, very transparent.
        color ovBg = color.new(kz_color, 92)
        LIB.manage_window_box(sessOverlap, isOverlap, high, low, time, ovBg)

        // Specific time markers.
        bool isMidnight = not na(time(timeframe.period, CONST.TIME_EVENT_WINDOW_MIDNIGHT, "UTC-5"))
        bool is0830 = not na(time(timeframe.period, CONST.TIME_EVENT_WINDOW_0830, "UTC-5"))
        bool isNYOpen = not na(time(timeframe.period, CONST.TIME_EVENT_WINDOW_NY_OPEN, "UTC-5"))
        bool is1000 = not na(time(timeframe.period, CONST.TIME_EVENT_WINDOW_1000, "UTC-5"))
        bool isLdnClose = not na(time(timeframe.period, CONST.TIME_EVENT_WINDOW_LDN_CLOSE, "UTC-5"))
        bool isPMBull = not na(time(timeframe.period, CONST.TIME_EVENT_WINDOW_PM_BULL, "UTC-5"))
        
        if TIME_EVENT_SHOW
            if isMidnight and not isMidnight[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "NY Midnight", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_MIDNIGHT)
                float yTop = kzAsiaTop.active and not na(kzAsiaTop.extreme) ? kzAsiaTop.extreme : high
                LIB.draw_time_event_top(time, yTop, LIB.get_time_event_label(TIME_EVENT_LABEL_MODE, CONST.TIME_EVENT_LABEL_MODE_TIME, CONST.TIME_EVENT_TXT_MIDNIGHT, CONST.TIME_EVENT_NAME_MIDNIGHT), CONST.TIME_EVENT_TT_MIDNIGHT, winClr, THEME)
            if is0830 and not is0830[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "8:30 Macro", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_0830)
                float yTop = kzNYAMTop.active and not na(kzNYAMTop.extreme) ? kzNYAMTop.extreme : high
                LIB.draw_time_event_top(time, yTop, LIB.get_time_event_label(TIME_EVENT_LABEL_MODE, CONST.TIME_EVENT_LABEL_MODE_TIME, CONST.TIME_EVENT_TXT_0830, CONST.TIME_EVENT_NAME_0830), CONST.TIME_EVENT_TT_0830, winClr, THEME)
            if isNYOpen and not isNYOpen[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "NY Open", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_NY_OPEN)
                float yTop = kzNYAMTop.active and not na(kzNYAMTop.extreme) ? kzNYAMTop.extreme : high
                LIB.draw_time_event_top(time, yTop, LIB.get_time_event_label(TIME_EVENT_LABEL_MODE, CONST.TIME_EVENT_LABEL_MODE_TIME, CONST.TIME_EVENT_TXT_NY_OPEN, CONST.TIME_EVENT_NAME_NY_OPEN), CONST.TIME_EVENT_TT_NY_OPEN, winClr, THEME)
            if is1000 and not is1000[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "10:00 AM Macro", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_1000)
                float yTop = kzNYAMTop.active and not na(kzNYAMTop.extreme) ? kzNYAMTop.extreme : high
                LIB.draw_time_event_top(time, yTop, LIB.get_time_event_label(TIME_EVENT_LABEL_MODE, CONST.TIME_EVENT_LABEL_MODE_TIME, CONST.TIME_EVENT_TXT_1000, CONST.TIME_EVENT_NAME_1000), CONST.TIME_EVENT_TT_1000, winClr, THEME)
            if isLdnClose and not isLdnClose[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "London Close", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_LDN_CLOSE)
                float yTop = kzLondonTop.active and not na(kzLondonTop.extreme) ? kzLondonTop.extreme : high
                LIB.draw_time_event_top(time, yTop, LIB.get_time_event_label(TIME_EVENT_LABEL_MODE, CONST.TIME_EVENT_LABEL_MODE_TIME, CONST.TIME_EVENT_TXT_LDN_CLOSE, CONST.TIME_EVENT_NAME_LDN_CLOSE), CONST.TIME_EVENT_TT_LDN_CLOSE, winClr, THEME)
            if isPMBull and not isPMBull[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "2:00 PM Bullet", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_PM_BULL)
                float yTop = kzNYPMTop.active and not na(kzNYPMTop.extreme) ? kzNYPMTop.extreme : high
                LIB.draw_time_event_top(time, yTop, LIB.get_time_event_label(TIME_EVENT_LABEL_MODE, CONST.TIME_EVENT_LABEL_MODE_TIME, CONST.TIME_EVENT_TXT_PM_BULL, CONST.TIME_EVENT_NAME_PM_BULL), CONST.TIME_EVENT_TT_PM_BULL, winClr, THEME)
    else
        LIB.reset_window_line(kzAsiaTop)
        LIB.reset_window_line(kzLondonTop)
        LIB.reset_window_line(kzNYAMTop)
        LIB.reset_window_line(kzNYPMTop)
        LIB.reset_window_line(sessAsiaBot)
        LIB.reset_window_line(sessLondonBot)
        LIB.reset_window_line(sessNYBot)
        LIB.reset_window_box(sessOverlap)
    bool(na)

process_killzones_sessions()


// HTF candle overlay ownership moved to core file (ict_smc_structure_zones.pine)
   


// Core SMC zone/liquidity/EQ/key-level blocks were removed from this file.

// ==================== FEATURE: DIVERGENCE ====================

// Core (Divergence): Scans a source series and returns [topText, bottomText] fragments for optional stacked labels.
scan_and_draw_div(float _src, string _name, bool _showIcons) =>
    [t, l] = LIB.div_check_all(_src, searchdiv, prd, maxbars, dontconfirm, ph_positions, pl_positions, ph_vals, pl_vals)
    string txt_b = ""
    string txt_t = ""
    if t == 1 // Pos Reg (Bullish Reversal)
        if _showIcons
            string tip = CONST.TT_BUY + SETTINGS.TOOLTIP_REASON_PREFIX + "Regular Bullish Divergence (" + _name + "): Price makes a Lower Low while momentum makes a Higher Low. Suggests a strong potential reversal from Bearish to Bullish."
            LIB.draw_icon_tooltip(bar_index, drawLookbackBars, is_in_signal_window(), "Bottom", THEME.COLOR_LTF, CONST.SYM_ARR1_UP, tip, THEME.SIZE_SMALL, THEME)
        txt_b := _name + "\n"
    if t == 2 // Neg Reg (Bearish Reversal)
        if _showIcons
            string tip = CONST.TT_SELL + SETTINGS.TOOLTIP_REASON_PREFIX + "Regular Bearish Divergence (" + _name + "): Price makes a Higher High while momentum makes a Lower High. Suggests a strong potential reversal from Bullish to Bearish."
            LIB.draw_icon_tooltip(bar_index, drawLookbackBars, is_in_signal_window(), "Top", THEME.COLOR_LTF, CONST.SYM_ARR1_DN, tip, THEME.SIZE_SMALL, THEME)
        txt_t := _name + "\n"
    if t == 3 // Pos Hid (Bullish Continuation)
        if _showIcons
            string tip = CONST.TT_BUY + SETTINGS.TOOLTIP_REASON_PREFIX + "Hidden Bullish Divergence (" + _name + "): Price makes a Higher Low while momentum makes a Lower Low. Suggests Bullish trend continuation."
            LIB.draw_icon_tooltip(bar_index, drawLookbackBars, is_in_signal_window(), "Bottom", THEME.COLOR_LTF, CONST.SYM_ARR2_UP, tip, THEME.SIZE_SMALL, THEME)
        txt_b := "h" + _name + "\n"
    if t == 4 // Neg Hid (Bearish Continuation)
        if _showIcons
            string tip = CONST.TT_SELL + SETTINGS.TOOLTIP_REASON_PREFIX + "Hidden Bearish Divergence (" + _name + "): Price makes a Lower High while momentum makes a Higher High. Suggests Bearish trend continuation."
            LIB.draw_icon_tooltip(bar_index, drawLookbackBars, is_in_signal_window(), "Top", THEME.COLOR_LTF, CONST.SYM_ARR2_DN, tip, THEME.SIZE_SMALL, THEME)
        txt_t := "h" + _name + "\n"
    [txt_t, txt_b]

// Core (Divergence): Full divergence pipeline (maintains pivot caches + runs RSI/MACD/OBV scans + optional stacked labels).
process_divergence(bool _showDiv, bool _calcRsi, bool _calcMacd, bool _calcObv, bool _showIcons, bool _showLabels, int _prd, int _maxArrSize, color _posTxtCol, color _negTxtCol, array<int> _phPos, array<int> _plPos, array<float> _phVals, array<float> _plVals) =>
    if _showDiv
        rsi = ta.rsi(close, 14)
        [macd, signal, _] = ta.macd(close, 12, 26, 9)
        Obv = ta.obv
        
        ph = ta.pivothigh(close, _prd, _prd)
        pl = ta.pivotlow(close, _prd, _prd)
        
        if not na(ph)
            array.unshift(_phPos, bar_index)
            array.unshift(_phVals, ph)
            if array.size(_phPos) > _maxArrSize
                array.pop(_phPos)
                array.pop(_phVals)
        if not na(pl)
            array.unshift(_plPos, bar_index)
            array.unshift(_plVals, pl)
            if array.size(_plPos) > _maxArrSize
                array.pop(_plPos)
                array.pop(_plVals)

        txt_top = ""
        txt_bot = ""
        
        if _calcRsi
            [t_add, b_add] = scan_and_draw_div(rsi, "RSI", _showIcons)
            txt_top += t_add
            txt_bot += b_add

        if _calcMacd
            [t_add, b_add] = scan_and_draw_div(macd, "MACD", _showIcons)
            txt_top += t_add
            txt_bot += b_add

        if _calcObv
            [t_add, b_add] = scan_and_draw_div(Obv, "OBV", _showIcons)
            txt_top += t_add
            txt_bot += b_add


        if _showLabels and div_size != "None"
            if txt_top != ""
                if is_in_signal_window()
                    label.new(bar_index, high, txt_top, color=color(na), textcolor=_negTxtCol, style=label.style_label_down, yloc=yloc.abovebar, size=div_size, tooltip = "Potential Sell\nReason: Bearish Divergence: Price creates higher highs while momentum (RSI/MACD/OBV) creates lower highs, signaling a potential downward reversal.")
            if txt_bot != ""
                if is_in_signal_window()
                    label.new(bar_index, low, txt_bot, color=color(na), textcolor=_posTxtCol, style=label.style_label_up, yloc=yloc.belowbar, size=div_size, tooltip = "Potential Buy\nReason: Bullish Divergence: Price creates lower lows while momentum (RSI/MACD/OBV) creates higher lows, signaling a potential upward reversal.")

process_divergence(showDiv, calcrsi, calcmacd, calcobv, showlines, showlabels, prd, maxarraysize, THEME.COLOR_LTF, THEME.COLOR_LTF, ph_positions, pl_positions, ph_vals, pl_vals)


// Helper (Aux): Computes lightweight current-TF events for strategies (no drawing side effects).
// Returns: [hvbColor, vwapState, evtVwapBull, evtVwapBear, evtRsiBull, evtRsiBear, evtHvbBull, evtHvbBear]
get_data_aux_events(float biasPowerPct, int prevVwapState) =>
    float hvbMultiplier = 1.5
    int hvbEMAPeriod = 12
    float volEma = ta.ema(volume, hvbEMAPeriod)
    bool isHighVolume = volume > (hvbMultiplier * volEma)
    color hvbColor = plotHVB and isHighVolume ? (LIB.is_bull_candle(0) ? hvbB_col : LIB.is_bear_candle(0) ? hvbS_col : na) : na
    bool evtHvbBull = isHighVolume and LIB.is_bull_candle(0)
    bool evtHvbBear = isHighVolume and LIB.is_bear_candle(0)

    float vwapVal = ta.vwap(hlc3)
    float rsiVal = ta.rsi(close, PIVOT_PERIOD_NORMAL)
    int vwapState = prevVwapState
    bool evtVwapBull = false
    bool evtVwapBear = false
    bool evtRsiBull = false
    bool evtRsiBear = false

    if plotVWAP_F
        if ta.crossover(close, vwapVal) and vwapState != 1
            vwapState := 1
            evtVwapBull := true
        else if ta.crossunder(close, vwapVal) and vwapState != -1
            vwapState := -1
            evtVwapBear := true

    if plotRSI_F
        if biasPowerPct > 20 and ta.crossover(rsiVal, 40)
            evtRsiBull := true
        else if biasPowerPct < -20 and ta.crossunder(rsiVal, 60)
            evtRsiBear := true
    [hvbColor, vwapState, evtVwapBull, evtVwapBear, evtRsiBull, evtRsiBear, evtHvbBull, evtHvbBear]

// Core (Aux): Draw markers for VWAP/RSI/HVB events using draw_strategy for visual consistency.
draw_data_aux_event_markers(bool show, int vwapStatePrev, int vwapStateNow, bool evtRsiBull, bool evtRsiBear) =>
    if show
        // VWAP cross
        if dispVwapEvt != CONST.DISP_NONE
            if vwapStateNow == 1 and vwapStatePrev != 1
                LIB.draw_strategy("VWAP Cross", is_in_signal_window(), dispVwapEvt, "Buy", CONST.SYM_VWAP, "VWAP BULLISH: Price has moved above the Session VWAP. Institutional value now supports the upside.", THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
            if vwapStateNow == -1 and vwapStatePrev != -1
                LIB.draw_strategy("VWAP Cross", is_in_signal_window(), dispVwapEvt, "Sell", CONST.SYM_VWAP, "VWAP BEARISH: Price has moved below the Session VWAP. Institutional value now resists the upside.", THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
        // RSI trend zone
        if dispRsiEvt != CONST.DISP_NONE
            if evtRsiBull
                LIB.draw_strategy("RSI Trend Zone", is_in_signal_window(), dispRsiEvt, "Buy", CONST.SYM_RSI, "RSI TREND ZONE (Bull): RSI dipped to 40 in an uptrend — institutional floor.", THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
            if evtRsiBear
                LIB.draw_strategy("RSI Trend Zone", is_in_signal_window(), dispRsiEvt, "Sell", CONST.SYM_RSI, "RSI TREND ZONE (Bear): RSI rallied to 60 in a downtrend — institutional ceiling.", THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
        // HVB
        if dispHvb != CONST.DISP_NONE
            bool isHvbBar = volume > ta.sma(volume, 12) * 1.5
            if isHvbBar
                string hvbDir = LIB.is_bull_candle(0) ? "Buy" : "Sell"
                LIB.draw_strategy("HVB", is_in_signal_window(), dispHvb, hvbDir, "HVB", "High Volume Bar: ≥ 1.5× average. Possible institutional activity.", THEME, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
    bool(na)

// Helper (Strategy): Creates one Event payload.
make_entry_signal(string setupName, string dir, string reasonText, int scoreVal, float qualityVal) =>
    LIB.Event es = LIB.Event.new(setupName, dir, na, na, na, bar_index, int(na), false, reasonText, qualityVal, scoreVal)
    es

get_strategy_short_name(int stratId) =>
    string out = "str"
    if array.size(STRATEGIES) > 0
        for i = 0 to array.size(STRATEGIES) - 1
            LIB.Strategy s = array.get(STRATEGIES, i)
            if s.id == stratId
                out := s.shortName
                break
    out

get_strategy_bucket_idx(int stratId) =>
    stratId == STRAT_ID_VWAP_EMA_CROSS ? 0 :
     stratId == STRAT_ID_EMA_STOCH_PULLBACK ? 1 :
     stratId == STRAT_ID_EMA200_BB_SQUEEZE ? 2 :
     stratId == STRAT_ID_ICHIMOKU_MACD_FLIP ? 3 :
     stratId == STRAT_ID_FIB_PULLBACK ? 4 :
     stratId == STRAT_ID_SMA200_DIVERGENCE ? 5 :
     stratId == STRAT_ID_ADX_EMA_CROSS ? 6 :
     stratId == STRAT_ID_SWEEP ? 10 :
     stratId == STRAT_ID_CANDLE_PATTERN ? 7 :
     stratId == STRAT_ID_GOLDEN_DEATH_CROSS ? 8 :
     stratId == STRAT_ID_TPG_RSI_SCALP ? 9 :
     10

get_strategy_risk_atr_mult(int stratId) =>
    stratId == STRAT_ID_VWAP_EMA_CROSS ? 1.0 :
     stratId == STRAT_ID_EMA_STOCH_PULLBACK ? 1.2 :
     stratId == STRAT_ID_EMA200_BB_SQUEEZE ? 1.3 :
     stratId == STRAT_ID_ICHIMOKU_MACD_FLIP ? 1.5 :
     stratId == STRAT_ID_FIB_PULLBACK ? 1.1 :
     stratId == STRAT_ID_SMA200_DIVERGENCE ? 1.6 :
     stratId == STRAT_ID_ADX_EMA_CROSS ? 1.2 :
     stratId == STRAT_ID_SWEEP ? 0.9 :
     stratId == STRAT_ID_CANDLE_PATTERN ? 1.1 :
     stratId == STRAT_ID_GOLDEN_DEATH_CROSS ? 2.0 :
     stratId == STRAT_ID_TPG_RSI_SCALP ? 0.8 :
     1.2

get_strategy_sl_max_atr(int stratId) =>
    stratId == STRAT_ID_TPG_RSI_SCALP ? 1.2 :
     stratId == STRAT_ID_CANDLE_PATTERN ? 1.8 :
     stratId == STRAT_ID_VWAP_EMA_CROSS ? 2.0 :
     stratId == STRAT_ID_EMA_STOCH_PULLBACK ? 2.0 :
     stratId == STRAT_ID_ADX_EMA_CROSS ? 2.2 :
     stratId == STRAT_ID_EMA200_BB_SQUEEZE ? 2.2 :
     stratId == STRAT_ID_FIB_PULLBACK ? 2.5 :
     stratId == STRAT_ID_ICHIMOKU_MACD_FLIP ? 3.0 :
     stratId == STRAT_ID_SMA200_DIVERGENCE ? 3.0 :
     stratId == STRAT_ID_GOLDEN_DEATH_CROSS ? 3.5 :
     stratId == STRAT_ID_SWEEP ? 1.6 :
     stratId == STRAT_ID_CONFLUENCE_VRHS ? 2.0 :
     SL_MAX_ATR

// Core (Strategy): Builds entry/SL/TP plan per strategy profile.
get_strategy_entry_plan(int stratId, bool isBuy, float rrInput) =>
    float rrv = na(rrInput) or rrInput <= 0 ? SETTINGS.SIGNAL_RR_DEFAULT : rrInput
    float entry = close
    float atrRef = math.max(ta.atr(14), syminfo.mintick)
    float fallbackRisk = math.max(atrRef * get_strategy_risk_atr_mult(stratId), syminfo.mintick * 2)
    float buffer = math.max(syminfo.mintick * SIGNAL_PLAN_SL_BUFFER_TICKS, syminfo.mintick)

    float ema21 = ta.ema(close, 21)
    float ema50 = ta.ema(close, 50)
    float ema200 = ta.ema(close, 200)
    float vwap = ta.vwap(hlc3)
    float bbBasis = ta.sma(close, 20)
    float bbDev = 2.0 * ta.stdev(close, 20)
    float bbUpper = bbBasis + bbDev
    float bbLower = bbBasis - bbDev
    float kijun = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2.0
    float spanA = ((ta.highest(high, 9) + ta.lowest(low, 9)) / 2.0 + kijun) / 2.0
    float spanB = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2.0
    float cloudLow = math.min(spanA, spanB)
    float cloudHigh = math.max(spanA, spanB)
    float fibHi = ta.highest(high, 55)
    float fibLo = ta.lowest(low, 55)
    float sma200 = ta.sma(close, 200)

    float stop = na
    if stratId == STRAT_ID_VWAP_EMA_CROSS
        stop := isBuy ? (math.min(ema21, vwap) - buffer) : (math.max(ema21, vwap) + buffer)
    else if stratId == STRAT_ID_EMA_STOCH_PULLBACK
        stop := isBuy ? (ta.lowest(low, 8) - buffer) : (ta.highest(high, 8) + buffer)
    else if stratId == STRAT_ID_EMA200_BB_SQUEEZE
        stop := isBuy ? (math.min(bbBasis, ema200) - buffer) : (math.max(bbBasis, ema200) + buffer)
    else if stratId == STRAT_ID_ICHIMOKU_MACD_FLIP
        stop := isBuy ? (math.min(kijun, cloudLow) - buffer) : (math.max(kijun, cloudHigh) + buffer)
    else if stratId == STRAT_ID_FIB_PULLBACK
        stop := isBuy ? (fibLo - buffer) : (fibHi + buffer)
    else if stratId == STRAT_ID_SMA200_DIVERGENCE
        stop := isBuy ? (math.min(sma200, ta.lowest(low, 20)) - buffer) : (math.max(sma200, ta.highest(high, 20)) + buffer)
    else if stratId == STRAT_ID_ADX_EMA_CROSS
        stop := isBuy ? (math.min(ema50, ta.lowest(low, 10)) - buffer) : (math.max(ema50, ta.highest(high, 10)) + buffer)
    else if stratId == STRAT_ID_SWEEP
        stop := isBuy ? (ta.lowest(low, 3) - buffer) : (ta.highest(high, 3) + buffer)
    else if stratId == STRAT_ID_CANDLE_PATTERN
        stop := isBuy ? (math.min(low, low[1]) - buffer) : (math.max(high, high[1]) + buffer)
    else if stratId == STRAT_ID_GOLDEN_DEATH_CROSS
        stop := isBuy ? (ema200 - atrRef * 0.5) : (ema200 + atrRef * 0.5)
    else if stratId == STRAT_ID_TPG_RSI_SCALP
        stop := isBuy ? (ta.lowest(low, 3) - buffer) : (ta.highest(high, 3) + buffer)
    else
        stop := isBuy ? (entry - fallbackRisk) : (entry + fallbackRisk)

    // Sanitize stop: correct side and minimum distance.
    bool stopInvalid = na(stop) or (isBuy and stop >= entry) or (not isBuy and stop <= entry)
    if stopInvalid
        stop := isBuy ? (entry - fallbackRisk) : (entry + fallbackRisk)

    // Clamp SL risk so it is not too small or too large.
    float riskRaw = math.max(math.abs(entry - stop), syminfo.mintick)
    float riskMin = math.max(syminfo.mintick * SL_MIN_TICKS, atrRef * SL_MIN_ATR)
    float riskMaxAtr = atrRef * get_strategy_sl_max_atr(stratId)
    float riskMaxPct = math.max(math.abs(entry) * SL_MAX_PCT, syminfo.mintick * SL_MIN_TICKS)
    float riskMax = math.max(math.min(riskMaxAtr, riskMaxPct), riskMin)
    float risk = math.min(math.max(riskRaw, riskMin), riskMax)
    stop := isBuy ? (entry - risk) : (entry + risk)
    stop := isBuy ? math.min(stop, entry - syminfo.mintick) : math.max(stop, entry + syminfo.mintick)
    float target = isBuy ? (entry + risk * rrv) : (entry - risk * rrv)
    [entry, stop, target, rrv]

get_entry_gap(float entry, float slRaw, float atrRef) =>
    float gapFixed = syminfo.mintick * entryGapTicks
    float gapRisk = math.abs(entry - slRaw) * entryGapRiskPct
    float gapAtr = atrRef * entryGapAtrMult
    entryGapModel == GAP_MODEL_FIXED ? gapFixed :
     entryGapModel == GAP_MODEL_RISK ? gapRisk :
     entryGapModel == GAP_MODEL_ATR ? gapAtr :
     math.max(gapFixed, math.max(gapRisk, gapAtr))

get_nearest_swing_targets(float refPrice) =>
    float above = na
    float below = na
    if array.size(msLtfData.swingHighPrices) > 0
        for i = 0 to array.size(msLtfData.swingHighPrices) - 1
            float p = array.get(msLtfData.swingHighPrices, i)
            if p > refPrice and (na(above) or p < above)
                above := p
    if array.size(msHtf1Data.swingHighPrices) > 0
        for i = 0 to array.size(msHtf1Data.swingHighPrices) - 1
            float p = array.get(msHtf1Data.swingHighPrices, i)
            if p > refPrice and (na(above) or p < above)
                above := p
    if array.size(msHtf2Data.swingHighPrices) > 0
        for i = 0 to array.size(msHtf2Data.swingHighPrices) - 1
            float p = array.get(msHtf2Data.swingHighPrices, i)
            if p > refPrice and (na(above) or p < above)
                above := p
    if array.size(msLtfData.swingLowPrices) > 0
        for i = 0 to array.size(msLtfData.swingLowPrices) - 1
            float p = array.get(msLtfData.swingLowPrices, i)
            if p < refPrice and (na(below) or p > below)
                below := p
    if array.size(msHtf1Data.swingLowPrices) > 0
        for i = 0 to array.size(msHtf1Data.swingLowPrices) - 1
            float p = array.get(msHtf1Data.swingLowPrices, i)
            if p < refPrice and (na(below) or p > below)
                below := p
    if array.size(msHtf2Data.swingLowPrices) > 0
        for i = 0 to array.size(msHtf2Data.swingLowPrices) - 1
            float p = array.get(msHtf2Data.swingLowPrices, i)
            if p < refPrice and (na(below) or p > below)
                below := p
    [above, below]

add_strategy_entry(int stratId, LIB.Event sig, float rrInput) =>
    if not na(sig) and sig.direction != ""
        bool hasActive = LIB.has_active_entry_for_strategy(entries, entryStrategyIds, stratId, sig.direction, CONST)
        bool hasRecent = LIB.has_recent_active_entry_for_strategy(entries, entryStrategyIds, stratId, sig.direction, SETTINGS.ENTRY_RECENT_DUP_BARS, CONST)
        if not hasActive and not hasRecent
            bool isBuy = sig.direction == "Buy"
            [entryBase, stoplossBase, _takeprofitBase, rrv] = get_strategy_entry_plan(stratId, isBuy, rrInput)
            float limitOff = math.max(math.abs(close - open) * 0.5, syminfo.mintick)
            float entry = isBuy ? math.min(entryBase, close - limitOff) : math.max(entryBase, close + limitOff)
            float slRaw = stoplossBase
            if entryDynamicTp
                [swAbove, swBelow] = get_nearest_swing_targets(entry)
                if isBuy
                    if not na(swBelow)
                        slRaw := swBelow
                else
                    if not na(swAbove)
                        slRaw := swAbove
            float slGap = get_entry_gap(entry, slRaw, ta.atr(14))
            float stoploss = isBuy ? (slRaw - slGap) : (slRaw + slGap)
            float risk = math.max(math.abs(entry - stoploss), syminfo.mintick)
            float fixedTp = isBuy ? (entry + risk * rrv) : (entry - risk * rrv)
            float minTp = isBuy ? (entry + risk) : (entry - risk)
            float takeprofit = fixedTp
            if entryDynamicTp
                [swAbove2, swBelow2] = get_nearest_swing_targets(entry)
                if isBuy and not na(swAbove2)
                    float swingTp = swAbove2 - slGap
                    takeprofit := math.min(fixedTp, swingTp)
                    takeprofit := math.max(takeprofit, minTp)
                if not isBuy and not na(swBelow2)
                    float swingTp = swBelow2 + slGap
                    takeprofit := math.max(fixedTp, swingTp)
                    takeprofit := math.min(takeprofit, minTp)
            float zTop = float(na)
            float zBtm = float(na)
            string setupShort = str.length(sig.type) > 5 ? str.substring(sig.type, 0, 5) : sig.type
            LIB.Entry e = LIB.create_entry_if_valid(sig.direction, setupShort, zTop, zBtm, entry, stoploss, takeprofit, rrv, bar_index, sig.reason, sig.score, CONST, syminfo.mintick)
            if not na(e)
                array.push(entries, e)
                array.push(entryStrategyIds, stratId)
    bool(na)

get_start_entries_count() =>
    int cnt = 0
    if array.size(entries) > 0
        for i = 0 to array.size(entries) - 1
            LIB.Entry e = array.get(entries, i)
            if e.state == CONST.SIGNAL_STATE_START
                cnt += 1
    cnt

prune_pending_entries() =>
    if array.size(entries) > 0 and array.size(entryStrategyIds) == array.size(entries)
        for i = array.size(entries) - 1 to 0
            LIB.Entry e = array.get(entries, i)
            if e.state == CONST.SIGNAL_STATE_PENDING
                LIB.delete_entry_visuals(e)
                array.remove(entries, i)
                array.remove(entryStrategyIds, i)
    bool(na)

process_data_entries() =>
    bool doResolve = true
    float rHi = high
    float rLo = low
    int rBar = bar_index
    if array.size(entries) > 0 and array.size(entryStrategyIds) == array.size(entries)
        int i = array.size(entries) - 1
        while i >= 0
            LIB.Entry e = array.get(entries, i)
            int sid = array.get(entryStrategyIds, i)
            if doResolve
                [eResolved, outcome] = LIB.resolve_entry_state(e, rHi, rLo, rBar, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
                e := eResolved
                if outcome == 2
                    LIB.delete_entry_visuals(e)
                    array.remove(entries, i)
                    array.remove(entryStrategyIds, i)
                    i -= 1
                    continue
                if outcome == 1 or outcome == -1
                    int bIdx = get_strategy_bucket_idx(sid)
                    LIB.apply_entry_outcome_stats(strategyStats, bIdx, outcome, e.rrValue, CONST, CONST.SIG_METRIC_COUNT)
            array.set(entries, i, e)

            e := LIB.draw_entry_visual(e, CONST, THEME, ENTRY_VIS_CFG, SIGNAL_PLAN_SHOW, showEntries, showTpEntries, showSlEntries, perfLookbackBars, 12, "RESULT_LINES", "RESULT_LINES", 1)
            array.set(entries, i, e)
            i -= 1
        // Synchronized prune: remove stale resolved entries and enforce size cap.
        int j = array.size(entries) - 1
        while j >= 0
            LIB.Entry e = array.get(entries, j)
            bool resolved = e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL
            bool staleResolved = resolved and not na(e.barClosed) and (bar_index - e.barClosed > ENTRY_RESOLVED_KEEP_BARS)
            bool overCap = array.size(entries) > ENTRY_TRACK_MAX_COUNT
            if staleResolved or overCap
                LIB.delete_entry_visuals(e)
                array.remove(entries, j)
                array.remove(entryStrategyIds, j)
            j -= 1
        if entryLimitStart
            int startCount = get_start_entries_count()
            if startCount >= entryMaxStart
                prune_pending_entries()
    bool(na)

get_data_chart_context(int biasVal) =>
    float atrVal = ta.atr(14)
    LIB.get_data_chart_context(bar_index, close, high, low, biasVal, atrVal, ctxZones, ctxLevels, eventsQueue)

process_data_events_queue(LIB.ChartContext ctx, float rrInput) =>
    bool _ctxTouched = array.size(ctx.events) >= 0
    if array.size(eventsQueue) > 0 and array.size(eventStrategyIds) == array.size(eventsQueue)
        int i = array.size(eventsQueue) - 1
        while i >= 0
            LIB.Event ev = array.get(eventsQueue, i)
            int sid = array.get(eventStrategyIds, i)
            if ev.direction != "" and get_data_strategy_disp(sid) == CONST.DISP_ENTRY
                add_strategy_entry(sid, ev, rrInput)
            array.remove(eventsQueue, i)
            array.remove(eventStrategyIds, i)
            i -= 1
    _ctxTouched

// Core (Strategy): Evaluate all strategies applicable to current TF, return best Event.
process_data_strategies(int tfSec, int compositeBias, bool evtVwapBull, bool evtVwapBear, bool evtRsiBull, bool evtRsiBear, bool evtHvbBull, bool evtHvbBear) =>
    LIB.Event best = na
    int bestStratId = 0
    int bestScore = 0
    int bestEffect = 0
    string dbg = ""

    int countBuy = 0
    int countSell = 0
    string whyBConfluence = ""
    string whySConfluence = ""

    float ema9   = ta.ema(close, 9)
    float ema21  = ta.ema(close, 21)
    float ema50  = ta.ema(close, 50)
    float ema200 = ta.ema(close, 200)
    float rsi14  = ta.rsi(close, 14)
    [_, _, adx14] = ta.dmi(14, 14)

    for i = 0 to array.size(STRATEGIES) - 1
        s = array.get(STRATEGIES, i)
        if not get_data_strategy_enabled(s.id)
            continue
        if not is_strategy_applicable(s, tfSec)
            continue

        // Candidate outputs (0 means "no signal").
        string candDir = ""
        int candScore = 0
        string candWhy = ""

        if s.id == STRAT_ID_VWAP_EMA_CROSS
            if LIB.bias_allows_direction(compositeBias, "Buy") and close > ta.vwap(hlc3) and ta.crossover(ema9, ema21)
                candDir := "Buy"
                candScore := 4
                candWhy := "VWAP bullish + EMA9 crosses above EMA21."
            if LIB.bias_allows_direction(compositeBias, "Sell") and close < ta.vwap(hlc3) and ta.crossunder(ema9, ema21)
                candDir := "Sell"
                candScore := 4
                candWhy := "VWAP bearish + EMA9 crosses below EMA21."

        else if s.id == STRAT_ID_EMA_STOCH_PULLBACK
            bool upTrend = ema50 > ema50[1]
            bool dnTrend = ema50 < ema50[1]
            float k = ta.stoch(close, high, low, 14)
            float d = ta.sma(k, 3)
            bool pullbackBuy = low <= ema21 and close >= ema21
            bool pullbackSell = high >= ema21 and close <= ema21
            bool stochBuy = ta.crossover(k, d) and k < 20
            bool stochSell = ta.crossunder(k, d) and k > 80
            if LIB.bias_allows_direction(compositeBias, "Buy") and upTrend and pullbackBuy and stochBuy
                candDir := "Buy"
                candScore := 4
                candWhy := "EMA50 rising + pullback to EMA21 + Stoch cross up (<20)."
            if LIB.bias_allows_direction(compositeBias, "Sell") and dnTrend and pullbackSell and stochSell
                candDir := "Sell"
                candScore := 4
                candWhy := "EMA50 falling + pullback to EMA21 + Stoch cross down (>80)."

        else if s.id == STRAT_ID_EMA200_BB_SQUEEZE
            float bbBasis = ta.sma(close, 20)
            float bbDev = 2.0 * ta.stdev(close, 20)
            float bbU = bbBasis + bbDev
            float bbL = bbBasis - bbDev
            float bw = bbBasis != 0 ? (bbU - bbL) / bbBasis : 0.0
            float bwAvg = ta.sma(bw, 20)
            bool squeeze = bwAvg > 0 ? bw <= bwAvg * 0.8 : bw < 0.04
            bool biasBull = close > ema200 and rsi14 > 50
            bool biasBear = close < ema200 and rsi14 < 50
            if LIB.bias_allows_direction(compositeBias, "Buy") and biasBull and squeeze and close > bbU
                candDir := "Buy"
                candScore := 4
                candWhy := "EMA200 bull + RSI>50 + BB squeeze + close above upper band."
            if LIB.bias_allows_direction(compositeBias, "Sell") and biasBear and squeeze and close < bbL
                candDir := "Sell"
                candScore := 4
                candWhy := "EMA200 bear + RSI<50 + BB squeeze + close below lower band."

        else if s.id == STRAT_ID_ICHIMOKU_MACD_FLIP
            float conv = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2.0
            float base = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2.0
            float spanA = (conv + base) / 2.0
            float spanB = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2.0
            float cloudTop = math.max(spanA[26], spanB[26])
            float cloudBtm = math.min(spanA[26], spanB[26])
            bool aboveCloud = close > cloudTop
            bool belowCloud = close < cloudBtm
            [_, _, hist] = ta.macd(close, 12, 26, 9)
            bool flipUp = hist > 0 and hist[1] <= 0
            bool flipDn = hist < 0 and hist[1] >= 0
            if LIB.bias_allows_direction(compositeBias, "Buy") and aboveCloud and flipUp
                candDir := "Buy"
                candScore := 4
                candWhy := "Price above Kumo + MACD histogram flips up."
            if LIB.bias_allows_direction(compositeBias, "Sell") and belowCloud and flipDn
                candDir := "Sell"
                candScore := 4
                candWhy := "Price below Kumo + MACD histogram flips down."

        else if s.id == STRAT_ID_FIB_PULLBACK
            bool bullTrend = ta.ema(close, 50) > ta.ema(close, 200)
            bool bearTrend = ta.ema(close, 50) < ta.ema(close, 200)
            float hi = ta.highest(high, 55)
            float lo = ta.lowest(low, 55)
            float rng = math.max(hi - lo, syminfo.mintick)
            float fib618Bull = hi - rng * 0.618
            float fib618Bear = lo + rng * 0.618
            float fibTol = rng * 0.03
            bool buyNearFib = low <= fib618Bull + fibTol and close >= fib618Bull - fibTol
            bool sellNearFib = high >= fib618Bear - fibTol and close <= fib618Bear + fibTol
            if LIB.bias_allows_direction(compositeBias, "Buy") and bullTrend and buyNearFib
                candDir := "Buy"
                candScore := 3
                candWhy := "Bull trend + pullback near ~0.618 with reclaim tolerance."
            if LIB.bias_allows_direction(compositeBias, "Sell") and bearTrend and sellNearFib
                candDir := "Sell"
                candScore := 3
                candWhy := "Bear trend + pullback near ~0.618 with rejection tolerance."

        else if s.id == STRAT_ID_SMA200_DIVERGENCE
            float sma200w = ta.sma(close, 200)
            float atrw = ta.atr(14)
            bool nearSma = math.abs(close - sma200w) <= atrw * 0.5
            if nearSma
                float rsiW = ta.rsi(close, 14)
                [tDiv, _] = LIB.div_check_all(rsiW, searchdiv, prd, maxbars, dontconfirm, ph_positions, pl_positions, ph_vals, pl_vals)
                if LIB.bias_allows_direction(compositeBias, "Buy") and tDiv == 1
                    candDir := "Buy"
                    candScore := 3
                    candWhy := "Near SMA200 + regular bullish RSI divergence."
                if LIB.bias_allows_direction(compositeBias, "Sell") and tDiv == 2
                    candDir := "Sell"
                    candScore := 3
                    candWhy := "Near SMA200 + regular bearish RSI divergence."

        else if s.id == STRAT_ID_ADX_EMA_CROSS
            bool adxStrong = adx14 > 25
            float ema20 = ta.ema(close, 20)
            // Reuse ema50 computed above instead of a separate ema50x.
            if LIB.bias_allows_direction(compositeBias, "Buy") and adxStrong and ta.crossover(ema20, ema50)
                candDir := "Buy"
                candScore := 3
                candWhy := "EMA20 crosses above EMA50 and ADX crosses above 25."
            if LIB.bias_allows_direction(compositeBias, "Sell") and adxStrong and ta.crossunder(ema20, ema50)
                candDir := "Sell"
                candScore := 3
                candWhy := "EMA20 crosses below EMA50 and ADX crosses above 25."

        else if s.id == STRAT_ID_SWEEP
            [htf1Sw, _] = LIB.get_htf_pair()
            string sweepTf = na(htf1Sw) ? timeframe.period : htf1Sw
            [topRef, btmRef] = LIB.get_first_swingrefs_around_price(sweepTf, 120, close)
            bool sellSweep = false
            bool buySweep = false
            if not na(topRef)
                float lvTop = topRef.price
                bool bodyCrossTop = (open > lvTop and close < lvTop) or (open < lvTop and close > lvTop)
                sellSweep := high > lvTop and close < lvTop and not bodyCrossTop
            if not na(btmRef)
                float lvBtm = btmRef.price
                bool bodyCrossBtm = (open > lvBtm and close < lvBtm) or (open < lvBtm and close > lvBtm)
                buySweep := low < lvBtm and close > lvBtm and not bodyCrossBtm
            if LIB.bias_allows_direction(compositeBias, "Buy") and buySweep
                candDir := "Buy"
                candScore := 4
                candWhy := "Sweep low + reclaim (" + sweepTf + ")."
            if LIB.bias_allows_direction(compositeBias, "Sell") and sellSweep
                candDir := "Sell"
                candScore := 4
                candWhy := "Sweep high + reclaim (" + sweepTf + ")."

        else if s.id == STRAT_ID_CANDLE_PATTERN
            // Fires on confirmed bars only when a quality pattern (score ≥ 3) aligns with MTF bias.
            // Strong reversal patterns (Engulfing, Marubozu, Stars, Kickers) score 3-5 natively.
            if cpShowPat and cpPatScore >= 3
                if LIB.bias_allows_direction(compositeBias, "Buy") and cpIsBull
                    string volTxt = cpVolBonus >= 2 ? " + extreme vol" : cpVolBonus >= 1 ? " + high vol" : ""
                    candDir := "Buy"
                    candScore := cpPatScore + cpVolBonus
                    candWhy := cpAggName + volTxt + (cpAggStrength > 1 ? " (×" + str.tostring(cpAggStrength) + " confluence)" : "")
                if LIB.bias_allows_direction(compositeBias, "Sell") and cpIsBear
                    string volTxt = cpVolBonus >= 2 ? " + extreme vol" : cpVolBonus >= 1 ? " + high vol" : ""
                    candDir := "Sell"
                    candScore := cpPatScore + cpVolBonus
                    candWhy := cpAggName + volTxt + (cpAggStrength > 1 ? " (×" + str.tostring(cpAggStrength) + " confluence)" : "")

        else if s.id == STRAT_ID_GOLDEN_DEATH_CROSS
            // Reuse ema50 / ema200 computed above — no extra series needed.
            if LIB.bias_allows_direction(compositeBias, "Buy") and ta.crossover(ema50, ema200)
                candDir := "Buy"
                candScore := 2
                candWhy := "EMA50 crosses above EMA200 (macro bull shift)."
            if LIB.bias_allows_direction(compositeBias, "Sell") and ta.crossunder(ema50, ema200)
                candDir := "Sell"
                candScore := 2
                candWhy := "EMA50 crosses below EMA200 (macro bear shift)."

        else if s.id == STRAT_ID_TPG_RSI_SCALP
            float myRsi = ta.rsi(close, tpgRsiLen)
            bool rsiOB = myRsi >= tpgRsiOb
            bool rsiOS = myRsi <= tpgRsiOs
            float bullFib = (low - high) * tpgHammerBody + high
            float bearFib = (high - low) * tpgHammerBody + low
            float bearCandle = math.min(close, open)
            float bullCandle = math.max(close, open)
            bool hammer = bearCandle >= bullFib and rsiOS
            bool shooting = bullCandle <= bearFib and rsiOB
            bool twoGreenBars = close > open and close[1] > open[1] and rsiOS
            bool twoRedBars = close < open and close[1] < open[1] and rsiOB
            bool bullE = close > open[1] and close[1] < open[1]
            bool bearE = close < open[1] and close[1] > open[1]
            bool tradeSignal = ((rsiOS or rsiOS[1]) and bullE) or ((rsiOB or rsiOB[1]) and bearE)
            int buyScore = 0
            int sellScore = 0
            string whyB = ""
            string whyS = ""
            if tpgUseEngulf and tradeSignal and bullE
                buyScore += 3
                whyB += "engulfing+RSI OS, "
            if tpgUseEngulf and tradeSignal and bearE
                sellScore += 3
                whyS += "engulfing+RSI OB, "
            if tpgUseHammerShooting and hammer
                buyScore += 2
                whyB += "hammer+RSI OS, "
            if tpgUseHammerShooting and shooting
                sellScore += 2
                whyS += "shooting+RSI OB, "
            if tpgUseTwoBars and twoGreenBars
                buyScore += 2
                whyB += "two green bars+RSI OS, "
            if tpgUseTwoBars and twoRedBars
                sellScore += 2
                whyS += "two red bars+RSI OB, "
            if buyScore >= 2 and buyScore > sellScore
                candDir := "Buy"
                candScore := buyScore
                candWhy := "TPG scalp: " + whyB
            if sellScore >= 2 and sellScore > buyScore
                candDir := "Sell"
                candScore := sellScore
                candWhy := "TPG scalp: " + whyS

        else if s.id == STRAT_ID_CONFLUENCE_VRHS
            if countBuy >= ENTRY_SCORE_MIN and LIB.bias_allows_direction(compositeBias, "Buy")
                candDir := "Buy"
                candScore := countBuy * 10
                candWhy := "Confluence of: " + whyBConfluence
            if countSell >= ENTRY_SCORE_MIN and LIB.bias_allows_direction(compositeBias, "Sell")
                candDir := "Sell"
                candScore := countSell * 10
                candWhy := "Confluence of: " + whySConfluence

        if s.id != STRAT_ID_CONFLUENCE_VRHS
            if candDir == "Buy"
                countBuy += 1
                whyBConfluence += s.shortName + " "
            if candDir == "Sell"
                countSell += 1
                whySConfluence += s.shortName + " "

        bool hasCand = candDir != "" and candScore >= 2
        bool tpgWins = hasCand and s.id == STRAT_ID_TPG_RSI_SCALP
        bool better = tpgWins or (hasCand and (candScore > bestScore or (candScore == bestScore and s.effectiveness > bestEffect)))
        if better
            string shortSetup = str.upper(s.shortName)
            best := make_entry_signal(shortSetup, candDir, s.description + " " + candWhy, candScore, float(s.effectiveness) / 10.0)
            bestStratId := s.id
            bestScore := candScore
            bestEffect := s.effectiveness

    [best, bestStratId, dbg]

// Aux state + strategy processing.
int vwapPrev = vwap_bias_state
[hvbColorNew, vwapStateNew, evtVwapBull, evtVwapBear, evtRsiBull, evtRsiBear, evtHvbBull, evtHvbBear] = get_data_aux_events(powerPercent, vwap_bias_state)
hvbBarColor := hvbColorNew
vwap_bias_state := vwapStateNew
bool canEmitSignals = (REPAINT or barstate.isconfirmed)
bool strictRun = entryResolveMode == CONST.ENTRY_RESOLVE_INTRABAR ? true : barstate.isconfirmed
// Entry/event emission follows selected resolve mode:
// - Intrabar: emit on live ticks
// - Bar Close: emit only on confirmed bars
canEmitSignals := strictRun
draw_data_aux_event_markers(canEmitSignals, vwapPrev, vwap_bias_state, evtRsiBull, evtRsiBear)

// Reuse currSec already computed inside process_bias_stack (avoids extra get_tf_seconds call).
int tfSec = LIB.get_tf_seconds(timeframe.period)
LIB.Event stratSig = na
int stratSigId = 0
if canEmitSignals
    [sigTmp, sigIdTmp, _] = process_data_strategies(tfSec, compositeBias, evtVwapBull, evtVwapBear, evtRsiBull, evtRsiBear, evtHvbBull, evtHvbBear)
    stratSig := sigTmp
    stratSigId := sigIdTmp
int entryDir = not na(stratSig) ? (stratSig.direction == "Buy" ? 1 : stratSig.direction == "Sell" ? -1 : 0) : 0
string entrySetup = not na(stratSig) ? stratSig.type : ""
string entryReason = not na(stratSig) ? stratSig.reason : ""
string entryDispMode = get_data_strategy_disp(stratSigId)
string entryShortName = get_strategy_short_name(stratSigId)
LIB.draw_entry_signal(SHOW_STRATEGY_ENTRIES and canEmitSignals, entryDir, entrySetup, entryReason, entryShortName, entryDispMode, THEME, true, CONST.TT_BUY, CONST.TT_SELL, SETTINGS.TOOLTIP_REASON_PREFIX, CONST.DISP_NONE, CONST.DISP_MARKER, CONST.DISP_EVENT, CONST.DISP_ENTRY)
LIB.ChartContext ctx = get_data_chart_context(compositeBias)
if canEmitSignals and not na(stratSig)
    array.push(eventsQueue, stratSig)
    array.push(eventStrategyIds, stratSigId)
if canEmitSignals
    process_data_events_queue(ctx, entryRrInput)
process_data_entries()
draw_data_entries_dashboard(entriesDashboardPos)

// barcolor(hvbBarColor, title = "HVB", editable = false)
