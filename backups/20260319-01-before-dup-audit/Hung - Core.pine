// Times are anchored to UTC-5 to preserve existing behavior across chart timezones.
sessSH = kz_show // Sessions enabled (reuse Killzones toggle to stay minimal).
sessAsia = "2000-0200" // Asia session window (approx).
sessLondon = "0200-0700" // London session window (approx).
sessNY = "0700-1600" // New York session window (approx).
sessOverlap_LdnNy = "0800-1000" // London/NY overlap highlight window (approx).

// Time events: draw icon markers at specific times (UTC-5), e.g. 08:30 US data release window.
// Time events: draw vertical line markers at specific times (UTC-5).
TIME_EVENT_SHOW = true // Enable time-event markers (kept constant to reduce inputs).
TIME_EVENT_SHOW_BOTTOM = false // Temporary: hide below-bar event labels (noise reduction).
TIME_EVENT_LABEL_MODE = CONST.TIME_EVENT_LABEL_MODE_TEXT // Default: show short names instead of HH:mm.
TIME_EVENT_LINE_TRANSP = 55

// Sessions/Killzones label placement.
WIN_LABEL_PAD_BARS = 2 // Horizontal padding from window start for time labels (in bars).
WIN_LINE_TRANSP = 50 // Shared KZ+Session line/text transparency (higher = blurrier).
WIN_LINE_WIDTH  = 1           // Shared KZ+Session line width.

perfLookbackBars = SETTINGS.GLOBAL_MAX_LOOKBACK_BARS // Kept for compatibility with shared helpers.
PIVOT_LEN_SCALP = 15
PIVOT_LEN_INTRADAY = 12
PIVOT_LEN_MULTI_DAY = 8
PIVOT_LEN_SWING = 6
PIVOT_LEN_POSITION = 4
PIVOT_LEN_BASE = LIB.get_tf_seconds(timeframe.period) <= 300 ? PIVOT_LEN_SCALP :
 LIB.get_tf_seconds(timeframe.period) <= 3600 ? PIVOT_LEN_INTRADAY :
 LIB.get_tf_seconds(timeframe.period) <= 14400 ? PIVOT_LEN_MULTI_DAY :
 LIB.get_tf_seconds(timeframe.period) <= 86400 ? PIVOT_LEN_SWING : PIVOT_LEN_POSITION

// Dynamic short-term signal window by chart TF.
// 1m: 20–40 (use 30), 5m: 15–30 (use 20), 15m: 10–20 (use 15), others: default 20.
get_signal_context_bars() =>
    int tfSec = LIB.get_tf_seconds(timeframe.period)
    tfSec <= 60 ? 30 :
     tfSec <= 300 ? 20 :
     tfSec <= 900 ? 15 :
     SIGNAL_CONTEXT_BARS_DEFAULT

signalContextBars = get_signal_context_bars()
drawLookbackBars = signalContextBars // Restrict entry/signal/context visuals to latest bars.

// ── Divergence config (fixed, shared with SMA200-Div strategy if enabled) ──
prd          = PIVOT_PERIOD_SHORT // Divergence pivot length.
maxbars      = 50                 // Divergence scan max window (bars).
dontconfirm  = false              // Require confirmation candle.
calcrsi      = true               // Scan RSI.
calcmacd     = true               // Scan MACD.
calcobv      = true               // Scan OBV.
searchdiv    = "Regular/Hidden"   // Divergence mode.
showlabels   = false              // Stacked text labels (off by default).
div_size     = size.tiny          // Label size for stacked divergence text (showlabels=false, so unused).

// ── Events (contextual, gated by bias internally) ──────────────────────
dispVwapEvt   = input.string("Marker", "VWAP Cross",           options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT, tooltip="Marker: text-only. Event: soft event icon. Entry: strong entry marker.")
dispRsiEvt    = input.string("Marker", "RSI Trend Zone",       options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT, tooltip="Marker: text-only. Event: soft event icon. Entry: strong entry marker.")
dispHvb       = input.string("Marker", "HVB (High Vol Bar)",   options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT, tooltip="Marker: text-only. Event: soft event icon. Entry: strong entry marker.")
