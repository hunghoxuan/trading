// ── Strategies ───────────────────────────────────────────────────
dispVwapEma   = input.string("Entry", "[1m]    VWAP + EMA Cross",      options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispEmaStoch  = input.string("Entry", "[5m]    EMA Pullback + Stoch",   options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispEmaBb     = input.string("Entry", "[15m+]  BB Squeeze",             options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispIchMacd   = input.string("Entry", "[4h]    Ichimoku + MACD",        options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispFib       = input.string("Entry", "[1D]    Fib Pullback",            options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispSmaDiv    = input.string("Entry", "[1W]    SMA200 + Divergence",     options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispAdxEma    = input.string("Entry", "[Any]   ADX + EMA Cross",         options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispSweep     = input.string("Entry", "[Any]   Sweep Reclaim",           options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispGdCross   = input.string("Entry", "[1D-1W] Golden/Death Cross",      options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispTpgRsi    = input.string("Entry", "[Any]   TPG RSI Scalp",           options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
dispConfluence = input.string("Entry", "[CF]   Confluence",             options=["None", "Marker", "Event", "Entry"], group=STRATEGY_TEXT)
ENTRY_SCORE_MIN = input.int(2, "Min confluence score", group=STRATEGY_TEXT, minval=1, maxval=10, tooltip="Minimum number of strategies that must agree for Confluence to fire.")
showEntries = input.bool(true, "Show Entries", inline = "en0", group = STRATEGY_TEXT)
showTpEntries = input.bool(false, "Show TP", inline = "en0", group = STRATEGY_TEXT)
showSlEntries = input.bool(false, "Show SL", inline = "en0", group = STRATEGY_TEXT)
entryRrInput = input.float(2.0, "RR", inline = "en0", minval = 0.1, maxval = 10.0, step = 0.1, group = STRATEGY_TEXT)
entryDynamicTp = input.bool(true, "Dynamic TP", inline = "en0", group = STRATEGY_TEXT)
entryResolveMode = input.string("Intrabar", "Resolve", options = ["Intrabar", "Bar Close"], inline = "en1", group = STRATEGY_TEXT)
entryLimitStart = input.bool(true, "Limit START", inline = "en1", group = STRATEGY_TEXT)
entryMaxStart = input.int(1, "Max START", inline = "en1", minval = 1, maxval = 50, group = STRATEGY_TEXT)
entryGapModel = input.string(GAP_MODEL_HYBRID, "SL Gap", options = [GAP_MODEL_FIXED, GAP_MODEL_RISK, GAP_MODEL_ATR, GAP_MODEL_HYBRID], inline = "en2", group = STRATEGY_TEXT)
entryGapTicks = input.float(2.0, "T", inline = "en2", minval = 0.0, step = 0.5, group = STRATEGY_TEXT)
entryGapRiskPct = input.float(0.10, "R%", inline = "en2", minval = 0.0, step = 0.01, group = STRATEGY_TEXT)
entryGapAtrMult = input.float(0.05, "A", inline = "en2", minval = 0.0, step = 0.01, group = STRATEGY_TEXT)
entriesDashboardPos = CONST.DASH_BOTTOM_RIGHT // Keep fixed to match ICT default.

// Derived booleans for internal use (keep existing call-sites working)
plotVWAP_F   = dispVwapEvt  != CONST.DISP_NONE
plotRSI_F    = dispRsiEvt   != CONST.DISP_NONE
plotHVB      = dispHvb      != CONST.DISP_NONE
showDiv      = dispDiv      != CONST.DISP_NONE
showlines    = showDiv // alias used in div scanning

// TPG RSI scalping parameters (from strategies/good-TPG Buy Sell RSI Scalping.pine).
tpgRsiLen = 7 // input.int(7, "RSI Length", minval = 2, maxval = 50, group = STRATEGY_TEXT)
tpgRsiOb = 85 // input.int(85, "RSI Overbought", minval = 50, maxval = 99, group = STRATEGY_TEXT)
tpgRsiOs = 15 // input.int(15, "RSI Oversold", minval = 1, maxval = 50, group = STRATEGY_TEXT)

// ── TPG RSI scalping pattern settings (fixed constants) ──
tpgHammerBody        = 0.333
tpgUseEngulf         = true
tpgUseHammerShooting = false
tpgUseTwoBars        = false

hvbB_col = THEME.COLOR_BULLISH
hvbS_col = THEME.COLOR_BEARISH

// ==================== CANDLE PATTERN DETECTION (merged) ====================
var LIB.CandlePatternCfg cpCfg = LIB.get_candle_pattern_cfg(SETTINGS, 1, 1)

[cpAggName, cpAggBias, cpBaseScore, cpAggStrength] = LIB.cp_detect(cpCfg)
bool cpIsBull   = cpAggBias == 1
bool cpIsBear   = cpAggBias == -1
bool cpIsPat    = cpAggName != "None"
int  cpPatScore = cpBaseScore + math.max(0, cpAggStrength - 1)

float cpVolAvg   = ta.sma(volume, 20)
float cpVolRatio = cpVolAvg > 0 ? volume / cpVolAvg : 1.0
int   cpVolBonus = cpVolRatio >= SETTINGS.CP_VOL_EXTREME ? 2 : cpVolRatio >= SETTINGS.CP_VOL_HIGH ? 1 : 0
int   cpConvScore = cpPatScore + cpVolBonus
bool  cpShowPat   = cpIsPat and cpConvScore >= SETTINGS.CP_MIN_CONV and LIB.is_in_draw_lookback_current(signalContextBars)

// ── Pattern candle visuals ─────────────────────────────────────────────
color cpNormBody = close >= open ? CP_VIS_CFG.normBull : CP_VIS_CFG.normBear

color cpPatBody   = CP_VIS_CFG.showCandles and cpShowPat ? LIB.cp_score_color(cpPatScore, cpAggBias, CP_VIS_CFG.bull, CP_VIS_CFG.bear)            : cpNormBody
color cpPatBorder = CP_VIS_CFG.showCandles and cpShowPat ? LIB.cp_border_color(cpPatScore, cpAggBias, CP_VIS_CFG.bull, CP_VIS_CFG.bear)           : cpNormBody
color cpPatWick   = CP_VIS_CFG.showCandles and cpShowPat ? LIB.cp_wick_color(cpPatScore, cpAggBias, cpVolRatio, CP_VIS_CFG.bull, CP_VIS_CFG.bear) : cpNormBody

plotcandle(open, high, low, close, title="Pattern Candles", color=cpPatBody, wickcolor=cpPatWick, bordercolor=cpPatBorder)

bool cpHasBg  = CP_VIS_CFG.showHalo and cpShowPat and cpPatScore >= 4
color cpHaloC = cpIsBull ? color.new(CP_VIS_CFG.bull, cpPatScore >= 5 ? 92 : 95) : color.new(CP_VIS_CFG.bear, cpPatScore >= 5 ? 92 : 95)
if cpHasBg
    box.new(bar_index, high, bar_index + 1, low, bgcolor = cpHaloC, border_color = na)

// Tier-1 CP markers deferred — drawn after compositeBias is known (below process_bias_stack) to allow deduplication with Tier-2 strategy signal.
float cpAtr = ta.atr(14) // ATR pre-computed here; used both in marker placement and strategy engine.


// ==================== FEATURE: STRATEGIES ====================

STRAT_TF_ANY = 0

STRAT_ID_VWAP_EMA_CROSS = 1
STRAT_ID_EMA_STOCH_PULLBACK = 2
STRAT_ID_EMA200_BB_SQUEEZE = 3
STRAT_ID_ICHIMOKU_MACD_FLIP = 4
STRAT_ID_FIB_PULLBACK = 5
STRAT_ID_SMA200_DIVERGENCE = 6
STRAT_ID_ADX_EMA_CROSS = 7
STRAT_ID_SWEEP = 8
STRAT_ID_CANDLE_PATTERN = 9   // New: candle pattern bias alignment strategy.
STRAT_ID_GOLDEN_DEATH_CROSS = 10
STRAT_ID_TPG_RSI_SCALP = 12
STRAT_ID_CONFLUENCE_VRHS = 90

// Helper (Strategy): True if strategy should be evaluated on current TF seconds.
is_strategy_applicable(LIB.Strategy s, int tfSec) =>
    s.tfSecMin == STRAT_TF_ANY or (tfSec >= s.tfSecMin and tfSec <= s.tfSecMax)

// Helper (Strategy): Builds the strategy list based on docs/features/STRATEGIES.md.
init_data_strategies() =>
    array<LIB.Strategy> out = array.new<LIB.Strategy>()
    int tf1m = LIB.get_tf_seconds("1")
    int tf5m = LIB.get_tf_seconds("5")
    int tf15m = LIB.get_tf_seconds("15")
    int tf1h = LIB.get_tf_seconds("60")
    int tf4h = LIB.get_tf_seconds("240")
    int tf1d = LIB.get_tf_seconds("1D")
    int tf1w = LIB.get_tf_seconds("1W")
    array.push(out, LIB.Strategy.new(STRAT_ID_VWAP_EMA_CROSS, "VWAP bias + EMA momentum cross", "vwap", tf1m, tf1m, "Bias is price above/below VWAP; enter when EMA(9) crosses EMA(21) in the bias direction.", 9))
    array.push(out, LIB.Strategy.new(STRAT_ID_EMA_STOCH_PULLBACK, "EMA trend + pullback mean reversion", "stoch", tf5m, tf5m, "Bias from EMA(50) slope; enter on pullback to EMA(21) plus Stoch cross from oversold/overbought in bias direction.", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_EMA200_BB_SQUEEZE, "EMA200 regime + volatility breakout", "bb", tf15m, tf1h, "Bias is price vs EMA(200) and RSI vs 50; enter after BB squeeze then close outside bands in bias direction.", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_ICHIMOKU_MACD_FLIP, "Ichimoku regime + MACD momentum flip", "ichi", tf4h, tf4h, "Bias is price above/below Kumo; enter when MACD histogram flips while price is outside cloud.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_FIB_PULLBACK, "Macro trend + fib pullback", "fib", tf1d, tf1d, "Bias from 50/200 cross plus swing structure; enter on pullback to 0.618 after trend confirmation.", 5))
    array.push(out, LIB.Strategy.new(STRAT_ID_SMA200_DIVERGENCE, "SMA200 macro anchor + divergence reversal", "div", tf1w, tf1w, "Bias from SMA(200) slope; enter on RSI divergence at/near SMA(200) contact.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_ADX_EMA_CROSS, "ADX + EMA crossover trend system", "adx", STRAT_TF_ANY, STRAT_TF_ANY, "Enter when EMA(20) crosses EMA(50) and ADX crosses above 25; exit on reverse EMA cross or ADX falling below 25.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_SWEEP, "Swing sweep reclaim", "swp", STRAT_TF_ANY, STRAT_TF_ANY, "Wick sweeps nearest swing liquidity then closes back through level (reclaim).", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_CANDLE_PATTERN, "Candle pattern bias alignment", "CP", STRAT_TF_ANY, STRAT_TF_ANY, "Score-3+ candle pattern (Engulfing/Marubozu/Star/3-line) aligned with composite MTF bias. Volume confirmation boosts conviction.", 8))
    array.push(out, LIB.Strategy.new(STRAT_ID_GOLDEN_DEATH_CROSS, "Golden/Death cross (macro alignment)", "gdc", tf1d, tf1w, "Use EMA(50)/EMA(200) cross as macro trend alignment; treat cross events as regime shift signals.", 5))
    array.push(out, LIB.Strategy.new(STRAT_ID_TPG_RSI_SCALP, "TPG RSI Scalping", "rsi", STRAT_TF_ANY, STRAT_TF_ANY, "RSI OB/OS + engulfing/hammer/shooting/two-bars price-action trigger from TPG RSI scalping model.", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_CONFLUENCE_VRHS, "Confluence", "CF", STRAT_TF_ANY, STRAT_TF_ANY, "Confluence of multiple active winning strategies; gated by MTF composite bias.", 10))
    out

var array<LIB.Strategy> STRATEGIES = init_data_strategies()

// Helper: Full-history mode when perfLookbackBars <= 0.
is_in_draw_window() =>
    perfLookbackBars <= 0 or LIB.is_in_draw_lookback_current(perfLookbackBars)

// Helper: Short signal/context window.
is_in_signal_window() =>
    LIB.is_in_draw_lookback_current(signalContextBars)

get_tf_text_size(string tfName, string htf1, string htf2) =>
    tfName == htf2 ? size.small : tfName == htf1 ? size.small : size.small

should_emit_structure_event(string tf, int side, int pivotTime) =>
    bool out = true
    if na(pivotTime)
        out := false
    else
        int found = -1
        if array.size(msEmitTf) > 0
            for i = 0 to array.size(msEmitTf) - 1
                if array.get(msEmitTf, i) == tf and array.get(msEmitSide, i) == side
                    found := i
                    break
        if found == -1
            array.push(msEmitTf, tf)
            array.push(msEmitSide, side)
            array.push(msEmitPivotTime, pivotTime)
            out := true
        else
            int prev = array.get(msEmitPivotTime, found)
            out := prev != pivotTime
            if out
                array.set(msEmitPivotTime, found, pivotTime)
    out

process_structure_from_ledger(LIB.TFData tfData, string tf, int recentTsCut, color tfLineColor, string tfLineStyle, int tfLineWidth, string htf1, string htf2) =>
    bool highArmedNext = tfData.highArmed
    bool lowArmedNext = tfData.lowArmed
    int prevBreakoutNext = tfData.prevBreakout
    int msBiasNext = tfData.msBias
    bool highBroken = false
    bool lowBroken = false
    float lastHigh = array.size(tfData.swingHighPrices) > 0 ? array.get(tfData.swingHighPrices, array.size(tfData.swingHighPrices) - 1) : na
    int lastHighTime = array.size(tfData.swingHighTimes) > 0 ? array.get(tfData.swingHighTimes, array.size(tfData.swingHighTimes) - 1) : na
    float lastLow = array.size(tfData.swingLowPrices) > 0 ? array.get(tfData.swingLowPrices, array.size(tfData.swingLowPrices) - 1) : na
    int lastLowTime = array.size(tfData.swingLowTimes) > 0 ? array.get(tfData.swingLowTimes, array.size(tfData.swingLowTimes) - 1) : na
    if highArmedNext and not na(lastHigh) and high > lastHigh
        highBroken := true
        highArmedNext := false
    if lowArmedNext and not na(lastLow) and low < lastLow
        lowBroken := true
        lowArmedNext := false
    bool highRecent = not na(lastHighTime) and lastHighTime >= recentTsCut
    bool lowRecent = not na(lastLowTime) and lastLowTime >= recentTsCut
    LIB.LineTextVisualCfg evtCfg = LIB.LineTextVisualCfg.new(lineStyle = tfLineStyle, lineWidth = math.max(tfLineWidth, 1), textSize = get_tf_text_size(tf, htf1, htf2), vPos = 1, yPadTicks = 8.0, xRatio = 0.5, xPadBars = 0, textAlign = text.align_center)

    if highBroken and highRecent and is_in_draw_window()
        if should_emit_structure_event(tf, 1, lastHighTime)
            bool isMssUp = prevBreakoutNext == -1
            string eventTxt = (tf == timeframe.period ? str.lower(isMssUp ? "MSS" : "BOS") : (isMssUp ? "MSS" : "BOS")) + " " + CONST.SYM_ARR2_UP
            [_, _] = LIB.draw_line_with_text(lastHighTime, lastHigh, time, lastHigh, xloc.bar_time, color.new(tfLineColor, 55), eventTxt, true, color.new(tfLineColor, 0), "", evtCfg, THEME)
            prevBreakoutNext := 1
            msBiasNext := 1
            tfData.legEventTime := lastHighTime

    if lowBroken and lowRecent and is_in_draw_window()
        if should_emit_structure_event(tf, -1, lastLowTime)
            bool isMssDn = prevBreakoutNext == 1
            string eventTxt = (tf == timeframe.period ? str.lower(isMssDn ? "MSS" : "BOS") : (isMssDn ? "MSS" : "BOS")) + " " + CONST.SYM_ARR2_DN
            evtCfg.vPos := -1
            evtCfg.yPadTicks := 25.0
            [_, _] = LIB.draw_line_with_text(lastLowTime, lastLow, time, lastLow, xloc.bar_time, color.new(tfLineColor, 55), eventTxt, true, color.new(tfLineColor, 0), "", evtCfg, THEME)
            prevBreakoutNext := -1
            msBiasNext := -1
            tfData.legEventTime := lastLowTime

    tfData.highArmed := highArmedNext
    tfData.lowArmed := lowArmedNext
    tfData.prevBreakout := prevBreakoutNext
    tfData.msBias := msBiasNext

get_tf_fib_ext(LIB.TFConfig cfg) =>
    cfg.id == "HTF2" ? 16 : cfg.id == "HTF1" ? 12 : 8

draw_data_tf_live_leg_fib(
     LIB.TFData tfData, LIB.TFConfig cfg, bool enabled, int recentIdxCut,
     line inLine1, line inLine2, line inLine3, line inLegLine,
     label inLabel1, label inLabel2, label inLabel3) =>
    line outLine1 = inLine1
    line outLine2 = inLine2
    line outLine3 = inLine3
    line outLegLine = inLegLine
    label outLabel1 = inLabel1
    label outLabel2 = inLabel2
    label outLabel3 = inLabel3
    if not enabled or not cfg.showZigzag
        if not na(outLine1)
            outLine1.delete()
            outLine1 := na
        if not na(outLine2)
            outLine2.delete()
            outLine2 := na
        if not na(outLine3)
            outLine3.delete()
            outLine3 := na
        if not na(outLegLine)
            outLegLine.delete()
            outLegLine := na
        if not na(outLabel1)
            outLabel1.delete()
            outLabel1 := na
        if not na(outLabel2)
            outLabel2.delete()
            outLabel2 := na
        if not na(outLabel3)
            outLabel3.delete()
            outLabel3 := na
    else
        bool fibOk = false
        int startIdx = na
        int endIdx = na
        float startP = na
        float endP = na
        bool isBull = false
        if not na(tfData.zzLastIndex) and not na(tfData.zzLastPrice) and tfData.zzLastIndex >= recentIdxCut
            bool wantLow = tfData.zzLastIsHigh
            int liveScanBars = math.min(math.max(bar_index - tfData.zzLastIndex, 1), 90)
            [liveOk, liveIdx, livePrice] = LIB.get_range_extreme_from_index(tfData.zzLastIndex, wantLow, liveScanBars)
            bool liveStepOk = liveOk and not na(liveIdx) and liveIdx > tfData.zzLastIndex
            bool liveDirOk = liveStepOk and not na(livePrice) and (wantLow ? livePrice <= tfData.zzLastPrice : livePrice >= tfData.zzLastPrice)
            if liveDirOk
                fibOk := true
                startIdx := math.max(tfData.zzLastIndex, recentIdxCut)
                endIdx := liveIdx
                startP := tfData.zzLastPrice
                endP := livePrice
                isBull := not tfData.zzLastIsHigh
        if fibOk
            float fib1 = LIB.get_leg_retracement(startP, endP, FIB_RATIO_1, isBull)
            float fib2 = LIB.get_leg_retracement(startP, endP, FIB_RATIO_2, isBull)
            float fib3 = LIB.get_leg_retracement(startP, endP, FIB_RATIO_3, isBull)
            int fibRight = bar_index + get_tf_fib_ext(cfg)
            int fibLabelX = fibRight
            color fibClr1 = color.new(cfg.zigzagColor, 22)
            color fibClr2 = color.new(cfg.zigzagColor, 38)
            color fibClr3 = color.new(cfg.zigzagColor, 54)
            color fibTxtClr = color.new(cfg.zigzagColor, 0)
            outLine1 := LIB.draw_hline(outLine1, bar_index, fib1, fibRight, fibClr1, cfg.zigzagStyle, 1)
            outLine2 := LIB.draw_hline(outLine2, bar_index, fib2, fibRight, fibClr2, cfg.zigzagStyle, 1)
            outLine3 := LIB.draw_hline(outLine3, bar_index, fib3, fibRight, fibClr3, cfg.zigzagStyle, 1)
            outLegLine := LIB.draw_dline(outLegLine, startIdx, startP, endIdx, endP, fibClr1, cfg.zigzagStyle, 1)
            outLabel1 := LIB.draw_line_label(outLabel1, fibLabelX, fib1, "0.5", fibTxtClr, size.tiny, "")
            if not na(outLabel2)
                outLabel2.delete()
                outLabel2 := na
            if not na(outLabel3)
                outLabel3.delete()
                outLabel3 := na
        else
            if not na(outLine1)
                outLine1.delete()
                outLine1 := na
            if not na(outLine2)
                outLine2.delete()
                outLine2 := na
            if not na(outLine3)
                outLine3.delete()
                outLine3 := na
            if not na(outLegLine)
                outLegLine.delete()
                outLegLine := na
            if not na(outLabel1)
                outLabel1.delete()
                outLabel1 := na
            if not na(outLabel2)
                outLabel2.delete()
                outLabel2 := na
            if not na(outLabel3)
                outLabel3.delete()
                outLabel3 := na
    [outLine1, outLine2, outLine3, outLegLine, outLabel1, outLabel2, outLabel3]

get_data_market_structure(string htf1, string htf2, int currPivotLen, int structureLookbackBars) =>
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    int htf1MimicPivotLenRaw = not na(htf1) ? LIB.get_mimic_pivot_len(timeframe.period, htf1, PIVOT_LEN_BASE, PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION) : na
    int htf1MimicPivotLen = not na(htf1MimicPivotLenRaw) ? math.max(htf1MimicPivotLenRaw, currPivotLen + 2) : na
    int htf2MimicPivotLenRaw = not na(htf2) ? LIB.get_mimic_pivot_len(timeframe.period, htf2, PIVOT_LEN_BASE, PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION) : na
    int htf2Floor = not na(htf1MimicPivotLen) ? htf1MimicPivotLen + 2 : currPivotLen + 4
    int htf2MimicPivotLen = not na(htf2MimicPivotLenRaw) ? math.max(htf2MimicPivotLenRaw, htf2Floor) : na
    int htf1PivotOffSafe = not na(htf1MimicPivotLen) ? math.max(0, math.min(htf1MimicPivotLen, maxSafeHistOff)) : na
    int htf2PivotOffSafe = not na(htf2MimicPivotLen) ? math.max(0, math.min(htf2MimicPivotLen, maxSafeHistOff)) : na
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    int htf1LenSafe = not na(htf1MimicPivotLen) ? htf1MimicPivotLen : currPivotLen
    float sh1Raw = ta.pivothigh(high, htf1LenSafe, htf1LenSafe)
    float sl1Raw = ta.pivotlow(low, htf1LenSafe, htf1LenSafe)
    float sh1Mimic = not na(htf1MimicPivotLen) ? sh1Raw : na
    float sl1Mimic = not na(htf1MimicPivotLen) ? sl1Raw : na
    int sh1MimicT = not na(sh1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
    int sl1MimicT = not na(sl1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
    int sh1MimicIdx = not na(sh1Mimic) and not na(htf1PivotOffSafe) ? bar_index[htf1PivotOffSafe] : na
    int sl1MimicIdx = not na(sl1Mimic) and not na(htf1PivotOffSafe) ? bar_index[htf1PivotOffSafe] : na
    int htf2LenSafe = not na(htf2MimicPivotLen) ? htf2MimicPivotLen : currPivotLen
    float sh2Raw = ta.pivothigh(high, htf2LenSafe, htf2LenSafe)
    float sl2Raw = ta.pivotlow(low, htf2LenSafe, htf2LenSafe)
    float sh2Mimic = not na(htf2MimicPivotLen) ? sh2Raw : na
    float sl2Mimic = not na(htf2MimicPivotLen) ? sl2Raw : na
    int sh2MimicT = not na(sh2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
    int sl2MimicT = not na(sl2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
    int sh2MimicIdx = not na(sh2Mimic) and not na(htf2PivotOffSafe) ? bar_index[htf2PivotOffSafe] : na
    int sl2MimicIdx = not na(sl2Mimic) and not na(htf2PivotOffSafe) ? bar_index[htf2PivotOffSafe] : na
    int structRecentTsCut = LIB.get_recent_time_cutoff(structureLookbackBars)
    int structRecentIdxCut = math.max(last_bar_index - math.max(structureLookbackBars, 1), 0)
    [currSh, currSl, currPivotOffSafe, structRecentTsCut, structRecentIdxCut, sh1Mimic, sl1Mimic, sh1MimicT, sl1MimicT, sh1MimicIdx, sl1MimicIdx, sh2Mimic, sl2Mimic, sh2MimicT, sl2MimicT, sh2MimicIdx, sl2MimicIdx]

process_data_market_structure(string htf1, string htf2, bool showLtf, bool showTf1, bool showTf2, float currSh, float currSl, int currPivotOffSafe, int structRecentTsCut, int structRecentIdxCut, float sh1Mimic, float sl1Mimic, int sh1MimicT, int sl1MimicT, int sh1MimicIdx, int sl1MimicIdx, float sh2Mimic, float sl2Mimic, int sh2MimicT, int sl2MimicT, int sh2MimicIdx, int sl2MimicIdx) =>
    msLtfCfg.showSwings := showLtf
    msLtfCfg.showZigzag := showLtf
    msHtf1Cfg.showSwings := showTf1
    msHtf1Cfg.showZigzag := showTf1
    msHtf2Cfg.showSwings := showTf2
    msHtf2Cfg.showZigzag := showTf2
    LIB.process_tf_armed_state(msLtfData, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, SETTINGS.SWING_HISTORY_MAX)
    LIB.process_tf_armed_state(msHtf1Data, not na(htf1), sh1Mimic, int(sh1MimicT), sl1Mimic, int(sl1MimicT), SETTINGS.SWING_HISTORY_MAX)
    LIB.process_tf_armed_state(msHtf2Data, not na(htf2), sh2Mimic, int(sh2MimicT), sl2Mimic, int(sl2MimicT), SETTINGS.SWING_HISTORY_MAX)
    LIB.process_tf_swing_markers(msLtfData, msLtfCfg, true, timeframe.period, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentTsCut)
    process_structure_from_ledger(msLtfData, timeframe.period, structRecentTsCut, msLtfCfg.zigzagColor, msLtfCfg.zigzagStyle, msLtfCfg.zigzagWidth, htf1, htf2)
    process_structure_from_ledger(msHtf1Data, htf1, structRecentTsCut, msHtf1Cfg.zigzagColor, msHtf1Cfg.zigzagStyle, msHtf1Cfg.zigzagWidth, htf1, htf2)
    process_structure_from_ledger(msHtf2Data, htf2, structRecentTsCut, msHtf2Cfg.zigzagColor, msHtf2Cfg.zigzagStyle, msHtf2Cfg.zigzagWidth, htf1, htf2)
    LIB.process_tf_swing_markers(msHtf1Data, msHtf1Cfg, not na(htf1), htf1, sh1Mimic, sh1MimicT, sh1MimicIdx, sl1Mimic, sl1MimicT, sl1MimicIdx, structRecentTsCut)
    LIB.process_tf_swing_markers(msHtf2Data, msHtf2Cfg, not na(htf2), htf2, sh2Mimic, sh2MimicT, sh2MimicIdx, sl2Mimic, sl2MimicT, sl2MimicIdx, structRecentTsCut)
    LIB.process_tf_zigzag_from_pivots(msLtfData, msLtfCfg, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, not na(currSh) ? bar_index - currPivotOffSafe : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, not na(currSl) ? bar_index - currPivotOffSafe : na, structRecentIdxCut)
    LIB.process_tf_zigzag_from_pivots(msHtf1Data, msHtf1Cfg, not na(htf1), sh1Mimic, sh1MimicT, sh1MimicIdx, sl1Mimic, sl1MimicT, sl1MimicIdx, structRecentIdxCut)
    LIB.process_tf_zigzag_from_pivots(msHtf2Data, msHtf2Cfg, not na(htf2), sh2Mimic, sh2MimicT, sh2MimicIdx, sl2Mimic, sl2MimicT, sl2MimicIdx, structRecentIdxCut)
    LIB.process_tf_live_tail(msLtfData, msLtfCfg, true, timeframe.period, structRecentIdxCut, CONST.SYM_DOT_TINY)
    LIB.process_tf_live_tail(msHtf1Data, msHtf1Cfg, not na(htf1), htf1, structRecentIdxCut, CONST.SYM_DOT)
    LIB.process_tf_live_tail(msHtf2Data, msHtf2Cfg, not na(htf2), htf2, structRecentIdxCut, CONST.SYM_DOT)

// Helper (Strategy): Return display mode for a strategy ID.
get_data_strategy_disp(int stratId) =>
    stratId == STRAT_ID_VWAP_EMA_CROSS     ? dispVwapEma :
     stratId == STRAT_ID_EMA_STOCH_PULLBACK ? dispEmaStoch :
     stratId == STRAT_ID_EMA200_BB_SQUEEZE  ? dispEmaBb :
     stratId == STRAT_ID_ICHIMOKU_MACD_FLIP ? dispIchMacd :
     stratId == STRAT_ID_FIB_PULLBACK       ? dispFib :
     stratId == STRAT_ID_SMA200_DIVERGENCE  ? dispSmaDiv :
     stratId == STRAT_ID_ADX_EMA_CROSS      ? dispAdxEma :
     stratId == STRAT_ID_SWEEP              ? dispSweep :
     stratId == STRAT_ID_CANDLE_PATTERN     ? dispCpBias :
     stratId == STRAT_ID_GOLDEN_DEATH_CROSS ? dispGdCross :
     stratId == STRAT_ID_TPG_RSI_SCALP      ? dispTpgRsi :
     stratId == STRAT_ID_CONFLUENCE_VRHS    ? dispConfluence : CONST.DISP_NONE

// Helper (Strategy): Enabled when display mode is not None.
get_data_strategy_enabled(int stratId) =>
    get_data_strategy_disp(stratId) != CONST.DISP_NONE

