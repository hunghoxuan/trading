//@version=5
// @kit-version: 2
library("KitSMC", dynamic_requests = true)
import hunghoxuan/KitCore/2 as CORE

// SMC domain: visual configuration for line-based level rendering.
export type ZoneDrawConfig
    color lineColor
    string lineStyle
    int lineWidth
    string labelSize
    bool showLabel

// SMC domain: zone taxonomy + behavior config.
export type ZoneTypeConfig
    int id
    string type
    string shortName
    string name
    string description
    int sigScore
    float activeAreaScore
    int extendBarsCurr
    string borderStyle
    bool noBorder
    bool isDerived
    string spawnOnBreak

// SMC domain: quality filter/scoring config for OB/FVG/RJB/SD zones.
export type ZoneQualityCfg
    float minHeightAtr = 0.1
    bool useVolume = true
    float minRelVolume = 1.1
    bool useImpulse = false
    float minBodyAtr = 0.35
    float sizeStrongMult = 1.8
    float volStrong = 1.5
    float impStrong = 1.0
    float dispMin = 0.65
    int volLen = 20
    int scoreSizeStrong = 2
    int scoreSizeBase = 1
    int scoreVolStrong = 2
    int scoreVolBase = 1
    int scoreImpStrong = 2
    int scoreImpBase = 1
    int scoreDisp = 1

// Returns TF text-size by hierarchy (LTF < HTF1/HTF2).
export ms_get_tf_text_size(string tfName, string htf1Name, string htf2Name) =>
    tfName == htf2Name ? size.small : tfName == htf1Name ? size.small : size.tiny

// Deduplicates structure events by (tf, side, pivotTime).
// Mutates ledgers in-place and returns whether event should be emitted.
export ms_should_emit_structure_event(string tfName, int side, int pivotTime, array<string> emitTf, array<int> emitSide, array<int> emitPivotTime) =>
    bool out = true
    if na(pivotTime)
        out := false
    else
        int found = -1
        if array.size(emitTf) > 0
            for i = 0 to array.size(emitTf) - 1
                if array.get(emitTf, i) == tfName and array.get(emitSide, i) == side
                    found := i
                    break
        if found == -1
            array.push(emitTf, tfName)
            array.push(emitSide, side)
            array.push(emitPivotTime, pivotTime)
            out := true
        else
            int prev = array.get(emitPivotTime, found)
            out := prev != pivotTime
            if out
                array.set(emitPivotTime, found, pivotTime)
    out

// Returns true when new zone formation is allowed on closed history only.
export zone_formation_allowed(int lockBars) =>
    barstate.isconfirmed and bar_index <= (last_bar_index - lockBars)

// Returns true when current candle structure forms a valid OB.
export smc_is_ob(bool isBull, int index, int lockBars) =>
    zone_formation_allowed(lockBars) and (isBull ? (close[index + 1] < open[index + 1] and close[index] > open[index] and close[index] > high[index + 1]) : (close[index + 1] > open[index + 1] and close[index] < open[index] and close[index] < low[index + 1]))

// Returns true when current candle structure forms a valid FVG.
export smc_is_fvg(bool isBull, int index, int lockBars) =>
    zone_formation_allowed(lockBars) and (isBull ? (low[index] > high[index + 2]) : (high[index] < low[index + 2]))

// Signal/display labels by SMC zone type.
export signal_reason_text(string type, bool isBullishZone) =>
    type == "OB" ? (isBullishZone ? "Bullish OB retest" : "Bearish OB retest") :
     type == "BB" ? (isBullishZone ? "Bullish BB retest" : "Bearish BB retest") :
     type == "FVG" ? (isBullishZone ? "Bullish FVG retest" : "Bearish FVG retest") :
     type == "IFVG" ? (isBullishZone ? "Bullish iFVG retest" : "Bearish iFVG retest") :
     type == "RJB" ? (isBullishZone ? "Bullish RJB retest" : "Bearish RJB retest") :
     (isBullishZone ? "Bullish zone retest" : "Bearish zone retest")

// OB classification helpers.
export ob_class_name(string cls, CORE.Const c) =>
    cls == c.OB_CLASS_ORIGIN ? c.OB_CLASS_ORIGIN :
     cls == c.OB_CLASS_DECISIONAL ? c.OB_CLASS_DECISIONAL :
     cls == c.OB_CLASS_EXTREME ? c.OB_CLASS_EXTREME :
     cls == c.OB_CLASS_MITIGATION ? c.OB_CLASS_MITIGATION : c.OB_CLASS_ORIGIN

export ob_label_text(string cls) =>
    cls == "D" ? "OB.d" :
     cls == "X" ? "OB.x" :
     cls == "M" ? "OB.m" : "OB.o"

export get_ob_class_from_label(string labelText, CORE.Const c) =>
    str.contains(labelText, ".d") ? c.OB_CLASS_DECISIONAL :
     str.contains(labelText, ".x") ? c.OB_CLASS_EXTREME :
     str.contains(labelText, ".m") ? c.OB_CLASS_MITIGATION :
     c.OB_CLASS_ORIGIN

export get_ob_border_style(string cls, string fallbackStyle, CORE.Const c) =>
    cls == c.OB_CLASS_ORIGIN or cls == c.OB_CLASS_EXTREME ? line.style_solid :
     cls == c.OB_CLASS_DECISIONAL or cls == c.OB_CLASS_MITIGATION ? line.style_dotted :
     fallbackStyle

export get_pdarray_border_style(string type, string labelText, string fallbackStyle, CORE.Const c) =>
    type == "OB" ? get_ob_border_style(ob_class_name(get_ob_class_from_label(labelText, c), c), fallbackStyle, c) :
     type == "IFVG" ? line.style_solid :
     fallbackStyle

export get_pdarray_cap_family(string type) =>
    type == "OB" or type == "BB" or type == "RJB" ? "OBF" :
     type == "FVG" or type == "IFVG" ? "FVGF" : type

export get_current_pdarray_extend(string type, int extFvgIfvg, int extObFamily) =>
    type == "FVG" or type == "IFVG" ? extFvgIfvg : extObFamily

export get_htf_pdarray_extend(int tfSlot, int extHtf1, int extHtf2) =>
    tfSlot == 0 ? extHtf1 : extHtf2

export is_signal_bias_valid(bool isBullishZone, int biasVal, bool useBiasFilter) =>
    not useBiasFilter or (isBullishZone ? biasVal >= 0 : biasVal <= 0)

export is_body_cross_level(float level, float openV, float closeV) =>
    (openV > level and closeV < level) or (openV < level and closeV > level)

export is_level_wick_touch(float level, float band, float openV, float highV, float lowV, float closeV, float mintick) =>
    float tol = math.max(band, mintick * 0.5)
    bool nearWick = (highV >= level - tol and lowV <= level + tol)
    bool bodyCross = is_body_cross_level(level, openV, closeV)
    nearWick and not bodyCross


// Returns true when two PDArray price ranges overlap.
export pd_arrays_overlap(float topA, float btmA, float topB, float btmB) =>
    math.min(topA, topB) >= math.max(btmA, btmB)

export has_nearby_pd_array(array<CORE.PDArray> pdArrays, array<string> types, bool isBull, float top, float btm, int startIdx, int maxBarsApart) =>
    bool found = false
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            z = array.get(pdArrays, i)
            bool isTarget = array.includes(types, z.type) and z.isBullish == isBull
            if isTarget and not z.broken
                bool nearBar = math.abs(startIdx - z.barStart) <= maxBarsApart
                bool overlap = pd_arrays_overlap(top, btm, z.top, z.bottom)
                if nearBar or overlap
                    found := true
                    break
    found

export has_active_pd_array_same_side(array<CORE.PDArray> pdArrays, array<string> types, bool isBull) =>
    bool found = false
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            z = array.get(pdArrays, i)
            if array.includes(types, z.type) and z.isBullish == isBull and not z.broken
                found := true
                break
    found

export is_extreme_pd_array_candidate(array<CORE.PDArray> pdArrays, array<string> types, bool isBull, float top, float btm) =>
    bool extreme = true
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            z = array.get(pdArrays, i)
            if array.includes(types, z.type) and z.isBullish == isBull and not z.broken
                if isBull and btm > z.bottom
                    extreme := false
                    break
                if not isBull and top < z.top
                    extreme := false
                    break
    extreme

export can_merge_ob_sd(string existingType, string incomingType) =>
    (existingType == "OB" and incomingType == "SD") or (existingType == "SD" and incomingType == "OB") or (existingType == "SD" and incomingType == "SD")

export build_ob_sd_merged_label(string oldLabel, string existingType, string incomingType) =>
    bool needsSdTag = existingType == "SD" or incomingType == "SD"
    string core = oldLabel == "" ? "OB" : oldLabel
    if needsSdTag and not str.contains(core, "SD")
        core += "+SD"
    core

export try_merge_ob_sd_pdarray(array<CORE.PDArray> zones, string incomingType, bool isBull, float top, float btm, int ext, float qualityPct, string tooltipText, float tickSize, int mergeTolTicks, int minWidthBars) =>
    bool merged = false
    bool isFamily = incomingType == "OB" or incomingType == "SD"
    if isFamily and array.size(zones) > 0
        float pad = mergeTolTicks * tickSize
        float inTop = top + pad
        float inBtm = btm - pad
        for i = array.size(zones) - 1 to 0
            CORE.PDArray z = array.get(zones, i)
            if not z.broken and z.isBullish == isBull and can_merge_ob_sd(z.type, incomingType)
                float zTop = z.top + pad
                float zBtm = z.bottom - pad
                bool overlap = math.min(inTop, zTop) >= math.max(inBtm, zBtm)
                if overlap
                    string oldType = z.type
                    z.top := math.max(z.top, top)
                    z.bottom := math.min(z.bottom, btm)
                    z.extendBars := math.max(z.extendBars, ext)
                    z.qualityPct := math.max(nz(z.qualityPct, 0.0), nz(qualityPct, 0.0))
                    z.type := "OB"
                    z.labelText := build_ob_sd_merged_label(z.labelText, oldType, incomingType)
                    if not na(z.visualBox)
                        z.visualBox.set_top(z.top)
                        z.visualBox.set_bottom(z.bottom)
                        z.visualBox.set_right(math.max(bar_index + z.extendBars, z.barStart + minWidthBars))
                    if not na(z.visualLabel)
                        z.visualLabel.set_text(z.labelText)
                        if tooltipText != ""
                            z.visualLabel.set_tooltip(tooltipText)
                    array.set(zones, i, z)
                    merged := true
                    break
    merged

export has_nearby_ob(array<CORE.PDArray> zones, bool isBull, float top, float btm, int startIdx, int maxBarsApart) =>
    has_nearby_pd_array(zones, array.new<string>(1, "OB"), isBull, top, btm, startIdx, maxBarsApart)

export has_active_ob_same_side(array<CORE.PDArray> zones, bool isBull) =>
    has_active_pd_array_same_side(zones, array.new<string>(1, "OB"), isBull)

export is_extreme_ob_candidate(array<CORE.PDArray> zones, bool isBull, float top, float btm) =>
    is_extreme_pd_array_candidate(zones, array.new<string>(1, "OB"), isBull, top, btm)

export classify_new_ob(array<CORE.PDArray> zones, bool isBull, float top, float btm, float q, CORE.Const c) =>
    bool isOrigin = not has_active_ob_same_side(zones, isBull)
    bool isExtreme = is_extreme_ob_candidate(zones, isBull, top, btm)
    isOrigin ? c.OB_CLASS_ORIGIN : isExtreme ? c.OB_CLASS_EXTREME : q >= 70 ? c.OB_CLASS_DECISIONAL : c.OB_CLASS_DECISIONAL

// Compatibility helper during lifeState-first migration.
// A zone is treated as "post-touch" when lifecycle advanced beyond FORMED,
export is_pdarray_post_touch(CORE.PDArray z) =>
    z.lifeState == 1 or z.lifeState == 2 or z.lifeState == 3

append_pdarray_removed(array<CORE.PDArray> dst, array<CORE.PDArray> src) =>
    if array.size(src) > 0
        for i = 0 to array.size(src) - 1
            array.push(dst, array.get(src, i))
    bool(na)

export prune_pdarray_bucket_weakest(array<CORE.PDArray> zones, string type, bool isBull, int bucketMax) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    int bucketCount = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.type == type and z.isBullish == isBull and not z.broken and not is_pdarray_post_touch(z)
                bucketCount += 1
    while bucketCount > bucketMax
        int weakestIdx = na
        float weakestScore = 10e10
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                z = array.get(zones, i)
                if z.type == type and z.isBullish == isBull and not z.broken and not is_pdarray_post_touch(z)
                    float s = nz(z.qualityPct, 0.0)
                    if na(weakestIdx) or s < weakestScore
                        weakestScore := s
                        weakestIdx := i
        if not na(weakestIdx)
            zDel = array.get(zones, weakestIdx)
            array.push(removed, zDel)
            array.remove(zones, weakestIdx)
        bucketCount -= 1
    removed

// Computes zone quality component data for one zone and impulse candle offset.
export get_pdarray_quality_data(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    int maxSafeOff = 300
    int off = math.max(0, math.min(impulseOff, maxSafeOff))
    float atrRef = nz(atrSeries[off], atrSeries)
    float safeAtr = atrRef > 0 ? atrRef : tickSize
    float zoneAtr = (top - btm) / safeAtr
    float relVol = CORE.get_rel_volume(off, cfg.volLen)
    float bodyAtr = math.abs(close[off] - open[off]) / safeAtr
    float barRange = math.max(high[off] - low[off], tickSize)
    float dispRatio = math.abs(close[off] - open[off]) / barRange

    int sizePts = zoneAtr >= (cfg.minHeightAtr * cfg.sizeStrongMult) ? cfg.scoreSizeStrong : zoneAtr >= cfg.minHeightAtr ? cfg.scoreSizeBase : 0
    int volPts = relVol >= cfg.volStrong ? cfg.scoreVolStrong : relVol >= cfg.minRelVolume ? cfg.scoreVolBase : 0
    int impPts = bodyAtr >= cfg.impStrong ? cfg.scoreImpStrong : bodyAtr >= cfg.minBodyAtr ? cfg.scoreImpBase : 0
    int dispPts = dispRatio >= cfg.dispMin ? cfg.scoreDisp : 0

    int score = sizePts + volPts + impPts + dispPts
    int maxScore = cfg.scoreSizeStrong + cfg.scoreVolStrong + cfg.scoreImpStrong + cfg.scoreDisp
    [score, maxScore, zoneAtr, relVol, bodyAtr, dispRatio]

// Returns normalized zone quality percentage (0..100).
export get_pdarray_quality_pct(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    [score, maxScore, _, _, _, _] = get_pdarray_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    maxScore > 0 ? (score * 100.0 / maxScore) : 0.0

// Builds zone quality tooltip text.
export build_pdarray_quality_tooltip(string baseText, float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    [score, maxScore, zoneAtr, relVol, bodyAtr, dispRatio] = get_pdarray_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    baseText + "\nQ " + str.tostring(score) + "/" + str.tostring(maxScore) + " (" + str.tostring(math.round(score * 100.0 / maxScore)) + "%)" +
     "\nATR " + str.tostring(zoneAtr, "#.##") + " | Vol " + str.tostring(relVol, "#.##") + " | Body " + str.tostring(bodyAtr, "#.##") + " | Disp " + str.tostring(dispRatio, "#.##")

passes_pdarray_quality(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    bool sizeOk = (top - btm) >= (cfg.minHeightAtr * nz(atrSeries, tickSize))
    [_, _, _, relVol, bodyAtr, _] = get_pdarray_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    bool volOk = not cfg.useVolume or relVol >= cfg.minRelVolume
    bool impulseOk = not cfg.useImpulse or bodyAtr >= cfg.minBodyAtr
    sizeOk and volOk and impulseOk

// Evaluates zone quality once and returns [ok, qualityPct, tooltipText].
export zone_quality_eval(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg, string baseTooltipText, bool showTooltip) =>
    bool ok = passes_pdarray_quality(top, btm, impulseOff, atrSeries, tickSize, cfg)
    float q = ok ? get_pdarray_quality_pct(top, btm, impulseOff, atrSeries, tickSize, cfg) : 0.0
    string tt = showTooltip and ok ? build_pdarray_quality_tooltip(baseTooltipText, top, btm, impulseOff, atrSeries, tickSize, cfg) : ""
    [ok, q, tt]

export prune_old_current_zones(array<CORE.PDArray> zones, int lookbackBars, int lastBarIndex) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    if array.size(zones) > 0
        for i = array.size(zones) - 1 to 0
            z = array.get(zones, i)
            bool tooOld = z.barStart < math.max(lastBarIndex - math.max(lookbackBars, 1), 0)
            if tooOld
                array.push(removed, z)
                array.remove(zones, i)
    removed

export prune_current_pdarray_side_caps(array<CORE.PDArray> zones, int perTypeSideMax, float closeV, int barIndex, float ageDecay) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    string[] zTypes = array.from("OB_FAMILY", "FVG_FAMILY")
    for t = 0 to array.size(zTypes) - 1
        string zt = array.get(zTypes, t)
        for side = 0 to 1
            bool wantAbove = side == 0
            int count = 0
            if array.size(zones) > 0
                for i = 0 to array.size(zones) - 1
                    z = array.get(zones, i)
                    bool sideMatch = ((z.top + z.bottom) * 0.5 > closeV) == wantAbove
                    if get_pdarray_cap_family(z.type) == zt and sideMatch and not z.broken and not is_pdarray_post_touch(z)
                        count += 1
            while count > perTypeSideMax
                int weakestIdx = na
                float weakestScore = 10e10
                if array.size(zones) > 0
                    for i = 0 to array.size(zones) - 1
                        z = array.get(zones, i)
                        bool sideMatch = ((z.top + z.bottom) * 0.5 > closeV) == wantAbove
                        if get_pdarray_cap_family(z.type) == zt and sideMatch and not z.broken and not is_pdarray_post_touch(z)
                            float s = nz(z.qualityPct, 0.0) - (math.max(barIndex - z.barStart, 0) * ageDecay)
                            if na(weakestIdx) or s < weakestScore
                                weakestScore := s
                                weakestIdx := i
                if not na(weakestIdx)
                    zDel = array.get(zones, weakestIdx)
                    array.push(removed, zDel)
                    array.remove(zones, weakestIdx)
                    count -= 1
                else
                    count := perTypeSideMax
    removed

export add_active_zone(array<CORE.PDArray> zones, CORE.PDArray z, int bucketMax, int totalMax, int perTypeSideMax, int lookbackBars, int lastBarIndex, float closeV, int barIndex, float ageDecay) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    array.push(zones, z)
    append_pdarray_removed(removed, prune_old_current_zones(zones, lookbackBars, lastBarIndex))
    append_pdarray_removed(removed, prune_pdarray_bucket_weakest(zones, z.type, z.isBullish, bucketMax))
    append_pdarray_removed(removed, prune_current_pdarray_side_caps(zones, perTypeSideMax, closeV, barIndex, ageDecay))
    while array.size(zones) > totalMax
        old = array.shift(zones)
        array.push(removed, old)
    removed

// Unified detection basis helper.
export get_detection_series(bool isBullBreak, string basis, float o, float h, float l, float c) =>
    if basis == "Body"
        isBullBreak ? math.max(o, c) : math.min(o, c)
    else if basis == "Close"
        c
    else
        isBullBreak ? h : l

export check_impulse_filter(bool useImpulse, float atrVal, float atrMult, float o, float c) =>
    not useImpulse or math.abs(c - o) >= (atrVal * atrMult)

export check_break(bool isBullBreak, float level, int method, int methodCross, string basis, bool useImpulse, float atrVal, float atrMult,
 float o0, float h0, float l0, float c0, float o1, float h1, float l1, float c1) =>
    bool crossed = method == methodCross ? (isBullBreak ? (o0 <= level and c0 > level) : (o0 >= level and c0 < level)) :
     (get_detection_series(isBullBreak, basis, o0, h0, l0, c0) > level and get_detection_series(isBullBreak, basis, o1, h1, l1, c1) <= level ? isBullBreak : get_detection_series(isBullBreak, basis, o0, h0, l0, c0) < level and get_detection_series(isBullBreak, basis, o1, h1, l1, c1) >= level)
    crossed and check_impulse_filter(useImpulse, atrVal, atrMult, o0, c0)

export check_touch(float zoneTop, float zoneBtm, string basis, float o, float h, float l, float c) =>
    float hiRef = basis == "Body" ? math.max(o, c) : basis == "Close" ? c : h
    float loRef = basis == "Body" ? math.min(o, c) : basis == "Close" ? c : l
    hiRef >= zoneBtm and loRef <= zoneTop

export check_pdarray_respect(bool isBullZone, float zoneTop, float zoneBtm, float highV, float lowV, float closeV) =>
    isBullZone ? (lowV <= zoneTop and closeV > zoneTop) : (highV >= zoneBtm and closeV < zoneBtm)

export check_mitigation(string type, bool isBullZone, float zoneTop, float zoneBtm, int method, int methodCross, string basis, bool useImpulse, float atrVal, float atrMult,
 float o0, float h0, float l0, float c0, float o1, float h1, float l1, float c1) =>
    bool isFVG = type == "FVG" or type == "IFVG"
    if isFVG
        float mid = (zoneTop + zoneBtm) / 2.0
        check_break(not isBullZone, mid, method, methodCross, basis, useImpulse, atrVal, atrMult, o0, h0, l0, c0, o1, h1, l1, c1)
    else
        check_touch(zoneTop, zoneBtm, basis, o0, h0, l0, c0)

export has_sweep_event_for(array<CORE.Event> events, string direction, float price, float tickSize) =>
    bool found = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            e = array.get(events, i)
            if e.direction == direction and math.abs(e.zonePrice - price) <= tickSize * 2
                found := true
                break
    found

export register_sweep_reclaim_event(array<CORE.Event> events, string direction, float price, int barIdx, float tickSize) =>
    if not has_sweep_event_for(events, direction, price, tickSize)
        CORE.Event e = CORE.Event.new()
        e.type := "SWEEP"
        e.direction := direction
        e.zonePrice := price
        e.barDetected := barIdx
        array.push(events, e)
    bool(na)

export has_break_retest_event_for(array<CORE.Event> events, string type, string direction, float top, float btm, float tickSize) =>
    bool found = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            e = array.get(events, i)
            bool sameZone = math.abs(e.zoneTop - top) <= tickSize * 2 and math.abs(e.zoneBtm - btm) <= tickSize * 2
            bool isBreakRetestEvent = not na(e.barBreak)
            if isBreakRetestEvent and e.type == type and e.direction == direction and sameZone
                found := true
                break
    found

export register_break_retest_event(array<CORE.Event> events, string type, string direction, float top, float btm, int barIdx, float quality, float tickSize) =>
    if not has_break_retest_event_for(events, type, direction, top, btm, tickSize)
        CORE.Event e = CORE.Event.new()
        e.type := type
        e.direction := direction
        e.zoneTop := top
        e.zoneBtm := btm
        e.quality := quality
        e.barDetected := barIdx
        e.barBreak := barIdx
        array.push(events, e)
    bool(na)

export direction_matches_bias(string direction, int biasDir) =>
    direction == "Buy" ? biasDir > 0 : direction == "Sell" ? biasDir < 0 : false

export has_pending_trade_signal(array<CORE.Event> events, string type, string direction, float top, float btm, float tickSize) =>
    bool result = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            CORE.Event e = array.get(events, i)
            bool sameZone = math.abs(e.zoneTop - top) < tickSize * 2 and math.abs(e.zoneBtm - btm) < tickSize * 2
            bool isSignalEvent = e.type != "SWEEP" and na(e.barBreak)
            if isSignalEvent and e.type == type and e.direction == direction and sameZone
                result := true
                break
    result

export is_signal_memory_candidate(CORE.Event e) =>
    e.direction != "" and e.score > 0

export has_signal_memory_duplicate(array<CORE.Event> hist, CORE.Event e, float tickSize) =>
    bool dup = false
    if array.size(hist) > 0
        for i = array.size(hist) - 1 to 0
            CORE.Event x = array.get(hist, i)
            bool sameBar = x.barDetected == e.barDetected
            bool sameDir = x.direction == e.direction
            bool sameType = x.type == e.type
            bool sameZone = (na(x.zoneTop) and na(e.zoneTop)) or (math.abs(nz(x.zoneTop, 0.0) - nz(e.zoneTop, 0.0)) <= tickSize * 2 and math.abs(nz(x.zoneBtm, 0.0) - nz(e.zoneBtm, 0.0)) <= tickSize * 2)
            if sameBar and sameDir and sameType and sameZone
                dup := true
                break
    dup

export cache_signal_memory_event(array<CORE.Event> hist, CORE.Event e, float tickSize, int maxEvents) =>
    if is_signal_memory_candidate(e) and not has_signal_memory_duplicate(hist, e, tickSize)
        array.push(hist, e)
        while array.size(hist) > maxEvents
            array.remove(hist, 0)
    bool(na)

export add_signal(array<CORE.Event> signalsList, array<CORE.Event> signalMemoryEvents, string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal, int barIdx, float tickSize, int memMaxEvents) =>
    if not has_pending_trade_signal(signalsList, type, direction, levelTop, levelBtm, tickSize)
        CORE.Event e = CORE.Event.new(type, direction, levelTop, levelBtm, na, barIdx, int(na), false, reason, qualityPct, scoreVal)
        array.push(signalsList, e)
        cache_signal_memory_event(signalMemoryEvents, e, tickSize, memMaxEvents)
    bool(na)

export get_trade_gap_profile_floors(string slProfile, int strictLv, string slProfileStrict, string slProfileLoose) =>
    float baseTicks = slProfile == slProfileStrict ? 10.0 : slProfile == slProfileLoose ? 3.0 : 6.0
    float baseAtr = slProfile == slProfileStrict ? 0.50 : slProfile == slProfileLoose ? 0.20 : 0.35
    float strictTicksAdd = strictLv >= 3 ? 2.0 : strictLv == 2 ? 1.0 : 0.0
    float strictAtrMult = strictLv >= 3 ? 1.20 : strictLv == 2 ? 1.10 : 1.00
    float minTicks = baseTicks + strictTicksAdd
    float minAtr = baseAtr * strictAtrMult
    [minTicks, minAtr]

export get_trade_score_min(int profileId) =>
    profileId == 0 ? 45.0 : profileId == 2 ? 65.0 : profileId == 3 ? 74.0 : 55.0

export compute_trade_score(float qualityPct, float riskTicks, float riskAtr, float rrReal, float relVol, bool alignBias, bool useBiasFilter) =>
    float tickScore = riskTicks < 2.0 ? 10.0 : riskTicks < 4.0 ? 35.0 : riskTicks <= 24.0 ? 100.0 : riskTicks <= 48.0 ? 75.0 : 45.0
    float atrScore = riskAtr < 0.10 ? 10.0 : riskAtr < 0.20 ? 35.0 : riskAtr <= 1.80 ? 100.0 : riskAtr <= 3.00 ? 75.0 : 45.0
    float sRisk = (tickScore + atrScore) * 0.5
    float sBias = useBiasFilter ? (alignBias ? 100.0 : 40.0) : 60.0
    float sQ = math.min(math.max(nz(qualityPct, 50.0), 0.0), 100.0)
    float sRr = rrReal < 0.85 ? 15.0 : rrReal < 1.0 ? 35.0 : rrReal < 1.2 ? 55.0 : rrReal < 1.5 ? 72.0 : rrReal < 2.0 ? 88.0 : 100.0
    float sVol = na(relVol) ? 50.0 : relVol < 0.8 ? 35.0 : relVol < 1.0 ? 50.0 : relVol < 1.5 ? 75.0 : relVol < 2.0 ? 90.0 : 100.0
    (sRisk * 0.35) + (sQ * 0.30) + (sRr * 0.20) + (sVol * 0.10) + (sBias * 0.05)

export compute_signal_memory_bias(array<CORE.Event> hist, int memWindowBars) =>
    float score = 0.0
    int bullCount = 0
    int bearCount = 0
    if array.size(hist) > 0
        for i = array.size(hist) - 1 to 0
            CORE.Event e = array.get(hist, i)
            int age = bar_index - e.barDetected
            if age > memWindowBars
                continue
            float decay = 1.0 - (float(age) / float(memWindowBars + 1))
            float weight = math.max(float(e.score), 1.0) * math.max(decay, 0.1)
            if e.direction == "Buy"
                score += weight
                bullCount += 1
            else if e.direction == "Sell"
                score -= weight
                bearCount += 1
    int memDir = score > 1.0 ? 1 : score < -1.0 ? -1 : 0
    [score, memDir, bullCount, bearCount]

// Returns true when a zone belongs to the OB/SD overlap family.
export is_ob_sd_family(string type) =>
    type == "OB" or type == "SD"

// Returns SR x-position for line end or label placement.
export get_sr_x(int barIndex, int extendBars, bool forLabel) =>
    barIndex + extendBars + (forLabel ? 1 : 0)

// Returns true when SR source label implies higher-timeframe origin.
export is_sr_source_htf(CORE.PDArray z, string currentTf) =>
    z.labelText != "" and z.labelText != currentTf

// Returns true when SR level is above current price and acts as resistance.
export is_sr_res_now(CORE.PDArray z, float closeV) =>
    z.price > closeV

// Returns SR label text from HTF/source role and touch count.
export get_sr_label_text(bool isHtfSource, bool isResNow, int touchN) =>
    touchN <= 1 ? (isHtfSource ? "IDM" : "idm") : (isResNow ? "R" : "S") + str.tostring(math.max(touchN, 1))

export get_score_sr_strength(CORE.PDArray z) =>
    float q = nz(z.qualityPct, 1.0)
    float rej = math.max(z.rejectCount, 0)
    float agePenalty = math.max(bar_index - z.barStart, 0) * 0.0005
    q + rej * 0.5 - agePenalty

export get_sr_rank_text(bool isRes, int rank) =>
    (isRes ? "R" : "S") + str.tostring(math.max(rank, 1))

// Shared lifecycle state normalization for horizontal-level engines.
export normalize_pricezone_state(CORE.PDArray z, CORE.Const c) =>
    CORE.PDArray out = z
    bool postTouch = is_pdarray_post_touch(out)
    if out.lifeState == c.LIFE_FORMED
        if out.broken
            out.lifeState := c.LIFE_BROKEN
        else if postTouch
            out.lifeState := c.LIFE_TOUCHED
    if out.touchCount < 0
        out.touchCount := 0
    if out.rejectCount < 0
        out.rejectCount := 0
    out

// Finds nearest swing price within tolerance.
export get_data_nearest_swing_price_in_tol(array<float> prices, float refPrice, float tol) =>
    float bestPrice = na
    float bestDist = na
    if array.size(prices) > 0
        for i = 0 to array.size(prices) - 1
            float p = array.get(prices, i)
            float d = math.abs(p - refPrice)
            if d <= tol and (na(bestDist) or d < bestDist)
                bestDist := d
                bestPrice := p
    [bestPrice, bestDist]

// Snaps SR seed to nearest swing among LTF/HTF1/HTF2.
export get_data_sr_price_snapped_to_swing(float srPrice, float tol, array<float> ltfSw, array<float> h1Sw, array<float> h2Sw) =>
    [p0, d0] = get_data_nearest_swing_price_in_tol(ltfSw, srPrice, tol)
    [p1, d1] = get_data_nearest_swing_price_in_tol(h1Sw, srPrice, tol)
    [p2, d2] = get_data_nearest_swing_price_in_tol(h2Sw, srPrice, tol)
    float out = srPrice
    float bestD = na
    if not na(p0)
        out := p0
        bestD := d0
    if not na(p1) and (na(bestD) or d1 < bestD)
        out := p1
        bestD := d1
    if not na(p2) and (na(bestD) or d2 < bestD)
        out := p2
    out

// Kind matcher for unified horizontal-level processing.
export get_data_level_matches_kind(int kind, string levelType, int hlKindLiq, int hlKindEq, int hlKindSr) =>
    kind == hlKindLiq ? levelType == "LIQ" : kind == hlKindEq ? (levelType == "eqh" or levelType == "eql") : kind == hlKindSr ? levelType == "SR" : false

export is_in_virtual_price_zone(float price, float top, float btm) =>
    not na(price) and not na(top) and not na(btm) and price <= top and price >= btm

// Checks whether zone or LIQ/EQ keylevels overlap a virtual zone range.
export get_data_has_keylevel_overlap_in_zone(array<CORE.PDArray> zones, array<CORE.PDArray> levels, float top, float btm) =>
    bool overlap = false
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.top >= btm and z.bottom <= top
                overlap := true
                break
    if not overlap and array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            bool isLevelType = z.type == "LIQ" or z.type == "eqh" or z.type == "eql"
            if isLevelType and is_in_virtual_price_zone(z.price, top, btm)
                overlap := true
                break
    overlap

// LIQ/EQ-only overlap helper for MSS line-seed flow.
export get_data_has_keylevel_overlap_in_levels(array<CORE.PDArray> levels, float top, float btm) =>
    bool overlap = false
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            bool isLevelType = z.type == "LIQ" or z.type == "eqh" or z.type == "eql"
            if isLevelType and is_in_virtual_price_zone(z.price, top, btm)
                overlap := true
                break
    overlap

export get_data_sr_tooltip_text(int rejectCount, int state, CORE.Const c) =>
    "Rejects: " + str.tostring(math.max(rejectCount, 0)) + "\nState: " + CORE.get_lifecycle_name(state, c.LIFE_FORMED, c.LIFE_TOUCHED, c.LIFE_RESPECTED, c.LIFE_RECLAIMED)

export delete_level_at(array<CORE.PDArray> levels, int idx) =>
    CORE.PDArray z = array.get(levels, idx)
    array.remove(levels, idx)
    z

export draw_sr_rank_labels(array<CORE.PDArray> levels, float closeV) =>
    int rRank = 0
    int sRank = 0
    array<int> used = array.new_int()
    if array.size(levels) > 0
        for pass = 0 to 1
            int remain = 99
            while remain > 0
                int bestIdx = na
                float bestScore = -10e10
                for i = 0 to array.size(levels) - 1
                    CORE.PDArray z = array.get(levels, i)
                    if z.type == "SR"
                        bool isRes = is_sr_res_now(z, closeV)
                        bool sidePass = (pass == 0 and isRes) or (pass == 1 and not isRes)
                        if sidePass and not array.includes(used, i)
                            float s = get_score_sr_strength(z)
                            if na(bestIdx) or s > bestScore
                                bestScore := s
                                bestIdx := i
                if na(bestIdx)
                    break
                CORE.PDArray zBest = array.get(levels, bestIdx)
                bool isResBest = pass == 0
                if isResBest
                    rRank += 1
                else
                    sRank += 1
                string rankTxt = get_sr_rank_text(isResBest, isResBest ? rRank : sRank)
                if not na(zBest.visualLabel)
                    zBest.visualLabel.set_text(rankTxt)
                array.set(levels, bestIdx, zBest)
                array.push(used, bestIdx)
                remain -= 1
    bool(na)

export prune_sr_side_cap(array<CORE.PDArray> levels, int maxPerSide, float closeV) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    int keptRes = 0
    int keptSup = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            CORE.PDArray z = array.get(levels, i)
            if z.type == "SR"
                bool isRes = is_sr_res_now(z, closeV)
                if isRes
                    keptRes += 1
                else
                    keptSup += 1
    while keptRes > maxPerSide or keptSup > maxPerSide
        int dropIdx = na
        float weakest = 10e10
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                CORE.PDArray z = array.get(levels, i)
                if z.type == "SR"
                    bool isRes = is_sr_res_now(z, closeV)
                    bool overCap = (isRes and keptRes > maxPerSide) or ((not isRes) and keptSup > maxPerSide)
                    if overCap
                        float s = get_score_sr_strength(z)
                        if na(dropIdx) or s < weakest
                            weakest := s
                            dropIdx := i
        if na(dropIdx)
            break
        CORE.PDArray zDrop = array.get(levels, dropIdx)
        bool dropIsRes = is_sr_res_now(zDrop, closeV)
        array.push(removed, delete_level_at(levels, dropIdx))
        if dropIsRes
            keptRes -= 1
        else
            keptSup -= 1
    removed

export prune_sr_source_cap(array<CORE.PDArray> levels, int sourcePrio, int maxPerSide, float closeV) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    int keptRes = 0
    int keptSup = 0
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            CORE.PDArray z = array.get(levels, i)
            if z.type == "SR" and int(math.max(nz(z.extendBars, 0), 0)) == sourcePrio
                bool isRes = is_sr_res_now(z, closeV)
                if isRes
                    keptRes += 1
                else
                    keptSup += 1
    while keptRes > maxPerSide or keptSup > maxPerSide
        int dropIdx = na
        float weakest = 10e10
        if array.size(levels) > 0
            for i = 0 to array.size(levels) - 1
                CORE.PDArray z = array.get(levels, i)
                bool sameSrc = int(math.max(nz(z.extendBars, 0), 0)) == sourcePrio
                if z.type == "SR" and sameSrc
                    bool isRes = is_sr_res_now(z, closeV)
                    bool overCap = (isRes and keptRes > maxPerSide) or ((not isRes) and keptSup > maxPerSide)
                    if overCap
                        float s = get_score_sr_strength(z)
                        if na(dropIdx) or s < weakest
                            weakest := s
                            dropIdx := i
        if na(dropIdx)
            break
        CORE.PDArray zDrop = array.get(levels, dropIdx)
        bool dropIsRes = is_sr_res_now(zDrop, closeV)
        array.push(removed, delete_level_at(levels, dropIdx))
        if dropIsRes
            keptRes -= 1
        else
            keptSup -= 1
    removed

export prune_nearby_sr_levels(array<CORE.PDArray> levels, float minDist) =>
    array<CORE.PDArray> removed = array.new<CORE.PDArray>()
    int i = array.size(levels) - 1
    while i >= 1 and array.size(levels) > 1
        if i >= array.size(levels)
            i := array.size(levels) - 1
            continue
        CORE.PDArray zi = array.get(levels, i)
        if zi.type != "SR"
            i -= 1
            continue
        int j = i - 1
        bool merged = false
        while j >= 0 and j < array.size(levels)
            CORE.PDArray zj = array.get(levels, j)
            bool sameSide = zi.isHigh == zj.isHigh
            bool sameSourcePrio = int(math.max(nz(zi.extendBars, 0), 0)) == int(math.max(nz(zj.extendBars, 0), 0))
            if zj.type == "SR" and sameSide and sameSourcePrio and math.abs(zi.price - zj.price) <= minDist
                bool keepI = get_score_sr_strength(zi) >= get_score_sr_strength(zj)
                int dropIdx = keepI ? j : i
                int keepIdx = keepI ? i : j
                CORE.PDArray zKeep = array.get(levels, keepIdx)
                CORE.PDArray zDrop = array.get(levels, dropIdx)
                zKeep.qualityPct := math.max(nz(zKeep.qualityPct, 1.0), nz(zDrop.qualityPct, 1.0))
                int keepReject = math.max(zKeep.rejectCount, 0)
                int dropReject = math.max(zDrop.rejectCount, 0)
                int mergedReject = math.max(keepReject, dropReject)
                int keepState = zKeep.lifeState
                int dropState = zDrop.lifeState
                CORE.Const c = CORE.Const.new()
                int mergedState = CORE.merge_lifecycle_state(keepState, dropState, c.LIFE_BROKEN)
                zKeep.rejectCount := mergedReject
                zKeep.lifeState := mergedState
                if keepI and i < array.size(levels)
                    array.set(levels, i, zKeep)
                else if not keepI and j < array.size(levels)
                    array.set(levels, j, zKeep)
                if dropIdx >= 0 and dropIdx < array.size(levels)
                    array.push(removed, delete_level_at(levels, dropIdx))
                merged := true
                break
            j -= 1
        if not merged
            i -= 1
    removed

export get_nearest_barriers(array<CORE.PDArray> zones, float refPrice, float tickSize) =>
    float above = na
    float below = na
    float aboveH = na
    float belowH = na
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            bool isHtf = z.sourceTfRank >= 2
            bool isObBb = z.type == "OB" or z.type == "BB"
            if not z.broken and isHtf and isObBb
                float zHi = z.top
                float zLo = z.bottom
                float zH = math.max(zHi - zLo, tickSize)
                if zLo > refPrice and (na(above) or zLo < above)
                    above := zLo
                    aboveH := zH
                if zHi < refPrice and (na(below) or zHi > below)
                    below := zHi
                    belowH := zH
    [above, below, aboveH, belowH]

// Builds one HTF zone snapshot tuple (OB/FVG + quality).
export get_htf_pdarray_snapshot(int zoneFormationLockBars, ZoneQualityCfg zqCfg, int atrLen) =>
    bool obUp = smc_is_ob(true, 1, zoneFormationLockBars)
    bool obDn = smc_is_ob(false, 1, zoneFormationLockBars)
    bool fvgUp = smc_is_fvg(true, 0, zoneFormationLockBars)
    bool fvgDn = smc_is_fvg(false, 0, zoneFormationLockBars)
    float atrRef = ta.atr(atrLen)
    float obUpQTop = high[2]
    float obUpQBtm = math.min(low[2], low[1])
    float obDnQTop = math.max(high[2], high[1])
    float obDnQBtm = low[2]
    float fvgUpQTop = low
    float fvgUpQBtm = high[2]
    float fvgDnQTop = low[2]
    float fvgDnQBtm = high
    float obUpTop = ta.valuewhen(obUp, high[2], 0)
    float obUpBtm = ta.valuewhen(obUp, math.min(low[2], low[1]), 0)
    int obUpStart = ta.valuewhen(obUp, time[2], 0)
    float obDnTop = ta.valuewhen(obDn, math.max(high[2], high[1]), 0)
    float obDnBtm = ta.valuewhen(obDn, low[2], 0)
    int obDnStart = ta.valuewhen(obDn, time[2], 0)
    float fvgUpTop = ta.valuewhen(fvgUp, low, 0)
    float fvgUpBtm = ta.valuewhen(fvgUp, high[2], 0)
    int fvgUpStart = ta.valuewhen(fvgUp, time[2], 0)
    float fvgDnTop = ta.valuewhen(fvgDn, low[2], 0)
    float fvgDnBtm = ta.valuewhen(fvgDn, high, 0)
    int fvgDnStart = ta.valuewhen(fvgDn, time[2], 0)
    float obUpQ = ta.valuewhen(obUp, get_pdarray_quality_pct(obUpQTop, obUpQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float obDnQ = ta.valuewhen(obDn, get_pdarray_quality_pct(obDnQTop, obDnQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float fvgUpQ = ta.valuewhen(fvgUp, get_pdarray_quality_pct(fvgUpQTop, fvgUpQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float fvgDnQ = ta.valuewhen(fvgDn, get_pdarray_quality_pct(fvgDnQTop, fvgDnQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ]

// Builds one HTF SR snapshot tuple.
export get_htf_sr_snapshot(int srPivotLen) =>
    float srHi = ta.valuewhen(not na(ta.pivothigh(high, srPivotLen, srPivotLen)), ta.pivothigh(high, srPivotLen, srPivotLen), 0)
    float srLo = ta.valuewhen(not na(ta.pivotlow(low, srPivotLen, srPivotLen)), ta.pivotlow(low, srPivotLen, srPivotLen), 0)
    int srHiT = ta.valuewhen(not na(ta.pivothigh(high, srPivotLen, srPivotLen)), time[srPivotLen], 0)
    int srLoT = ta.valuewhen(not na(ta.pivotlow(low, srPivotLen, srPivotLen)), time[srPivotLen], 0)
    [srHi, srHiT, srLo, srLoT]

// Bundles HTF zone + SR snapshots in one tuple.
export get_htf_pdarray_sr_snapshot(int zoneFormationLockBars, ZoneQualityCfg zqCfg, int atrLen, int srPivotLen) =>
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ] = get_htf_pdarray_snapshot(zoneFormationLockBars, zqCfg, atrLen)
    [srHi, srHiT, srLo, srLoT] = get_htf_sr_snapshot(srPivotLen)
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ, srHi, srHiT, srLo, srLoT]

export type DensitySeed
    float lPrice
    bool isRes
    string tfLbl

export get_density_seeds(CORE.TFData tfData, float _maxRange, float _minRange, string sourceTf, int sourcePrio, int lookback, int div, int barIndex, float closeV) =>
    array<DensitySeed> out = array.new<DensitySeed>()
    int rCount = array.size(tfData.swingHighPrices)
    int sCount = array.size(tfData.swingLowPrices)
    bool isHtf = sourcePrio > 0
    if (rCount > 0 or sCount > 0) and div > 0
        float sR = (_maxRange - _minRange) / div
        if sR > 0
            array<float> rProf = array.new_float(div, 0.0)
            array<float> sProf = array.new_float(div, 0.0)
            int safeBarsBack = barIndex < lookback ? barIndex : lookback
            int cutoffTime = time[safeBarsBack]
            if rCount > 0
                for i = 0 to rCount - 1
                    if array.get(tfData.swingHighTimes, i) >= cutoffTime
                        float p = array.get(tfData.swingHighPrices, i)
                        int bin = math.max(0, math.min(int((_maxRange - p) / sR), div - 1))
                        array.set(rProf, bin, array.get(rProf, bin) + 1.0)
            if sCount > 0
                for i = 0 to sCount - 1
                    if array.get(tfData.swingLowTimes, i) >= cutoffTime
                        float p = array.get(tfData.swingLowPrices, i)
                        int bin = math.max(0, math.min(int((p - _minRange) / sR), div - 1))
                        array.set(sProf, bin, array.get(sProf, bin) + 1.0)
            float reqDensity = isHtf ? 2.0 : 3.0
            for b = 1 to div - 2
                float v = array.get(rProf, b)
                if v >= reqDensity and v > array.get(rProf, b - 1) and v >= array.get(rProf, b + 1)
                    float top = _maxRange - b * sR
                    float btm = _maxRange - (b + 1) * sR
                    float lPrice = math.avg(top, btm)
                    bool isRes = lPrice > closeV
                    string tfLbl = sourceTf
                    array.push(out, DensitySeed.new(lPrice, isRes, tfLbl))
            for b = 1 to div - 2
                float v = array.get(sProf, b)
                if v >= reqDensity and v > array.get(sProf, b - 1) and v >= array.get(sProf, b + 1)
                    float btm = _minRange + b * sR
                    float top = _minRange + (b + 1) * sR
                    float lPrice = math.avg(top, btm)
                    bool isRes = lPrice > closeV
                    string tfLbl = sourceTf
                    array.push(out, DensitySeed.new(lPrice, isRes, tfLbl))
    out
