//@version=5
// @version: 1
// @trace_ts: 2026-03-23 20:20:00 +0100
// @trace_update: initial MSS helper split from Hung - MSS indicator
// @trace_features: market structure + horizontal-level data helpers
library("TradingKitMSS", dynamic_requests = true)
import hunghoxuan/TradingKitCore/56 as CORE

// Returns TF text-size by hierarchy (LTF < HTF1/HTF2).
export ms_get_tf_text_size(string tfName, string htf1Name, string htf2Name) =>
    tfName == htf2Name ? size.small : tfName == htf1Name ? size.small : size.tiny

// Deduplicates structure events by (tf, side, pivotTime).
// Mutates ledgers in-place and returns whether event should be emitted.
export ms_should_emit_structure_event(string tfName, int side, int pivotTime, array<string> emitTf, array<int> emitSide, array<int> emitPivotTime) =>
    bool out = true
    if na(pivotTime)
        out := false
    else
        int found = -1
        if array.size(emitTf) > 0
            for i = 0 to array.size(emitTf) - 1
                if array.get(emitTf, i) == tfName and array.get(emitSide, i) == side
                    found := i
                    break
        if found == -1
            array.push(emitTf, tfName)
            array.push(emitSide, side)
            array.push(emitPivotTime, pivotTime)
            out := true
        else
            int prev = array.get(emitPivotTime, found)
            out := prev != pivotTime
            if out
                array.set(emitPivotTime, found, pivotTime)
    out

// Normalizes lifecycle state and guards negative counters.
export normalize_pricezone_state(CORE.PDArray z, CORE.Const c) =>
    CORE.PDArray out = z
    if out.lifeState == c.LIFE_FORMED
        if out.broken
            out.lifeState := c.LIFE_BROKEN
        else if out.mitigated
            out.lifeState := c.LIFE_TOUCHED
    if out.touchCount < 0
        out.touchCount := 0
    if out.rejectCount < 0
        out.rejectCount := 0
    out

// Finds nearest swing price within tolerance.
export get_data_nearest_swing_price_in_tol(array<float> prices, float refPrice, float tol) =>
    float bestPrice = na
    float bestDist = na
    if array.size(prices) > 0
        for i = 0 to array.size(prices) - 1
            float p = array.get(prices, i)
            float d = math.abs(p - refPrice)
            if d <= tol and (na(bestDist) or d < bestDist)
                bestDist := d
                bestPrice := p
    [bestPrice, bestDist]

// Snaps SR level to nearest swing among LTF/HTF1/HTF2 within tolerance.
export get_data_sr_price_snapped_to_swing(float srPrice, float tol,
 array<float> ltfSw, array<float> h1Sw, array<float> h2Sw) =>
    [p0, d0] = get_data_nearest_swing_price_in_tol(ltfSw, srPrice, tol)
    [p1, d1] = get_data_nearest_swing_price_in_tol(h1Sw, srPrice, tol)
    [p2, d2] = get_data_nearest_swing_price_in_tol(h2Sw, srPrice, tol)
    float out = srPrice
    float bestD = na
    if not na(p0)
        out := p0
        bestD := d0
    if not na(p1) and (na(bestD) or d1 < bestD)
        out := p1
        bestD := d1
    if not na(p2) and (na(bestD) or d2 < bestD)
        out := p2
    out

// Kind matcher for unified horizontal-level processing.
export get_data_level_matches_kind(int kind, string levelType, int hlKindLiq, int hlKindEq, int hlKindSr) =>
    kind == hlKindLiq ? levelType == "LIQ" : kind == hlKindEq ? (levelType == "eqh" or levelType == "eql") : kind == hlKindSr ? levelType == "SR" : false

// Checks whether level price lies within a virtual zone.
export is_in_virtual_price_zone(float price, float top, float btm) =>
    not na(price) and not na(top) and not na(btm) and price <= top and price >= btm

// Any LIQ/EQ level overlaps with virtual zone.
export get_data_has_keylevel_overlap_in_zone(array<CORE.PDArray> levels, float top, float btm) =>
    bool overlap = false
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            z = array.get(levels, i)
            bool isLevelType = z.type == "LIQ" or z.type == "eqh" or z.type == "eql"
            if isLevelType and is_in_virtual_price_zone(z.price, top, btm)
                overlap := true
                break
    overlap

// SR tooltip text builder.
export get_data_sr_tooltip_text(int rejectCount, int state, CORE.Const c) =>
    "Rejects: " + str.tostring(math.max(rejectCount, 0)) + "\nState: " + CORE.get_lifecycle_name(state, c.LIFE_FORMED, c.LIFE_TOUCHED, c.LIFE_RESPECTED, c.LIFE_RECLAIMED)
