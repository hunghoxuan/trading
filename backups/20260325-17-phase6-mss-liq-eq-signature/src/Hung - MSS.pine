modelSweep = input.bool(true, "Sweep.", inline = "m2", group = G_MODELS)
modelSweepWhen = input.string(TRIGGER_WHEN_RETEST, "When", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m2", group = G_MODELS)
modelSweepType = input.string(TRIGGER_TYPE_TRADE, "Type", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m2", group = G_MODELS)
modelSweepMss = input.bool(true, "SW>MS.", inline = "m3", group = G_MODELS)
modelSweepMssWhen = input.string(TRIGGER_WHEN_TOUCH, "When", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m3", group = G_MODELS)
modelSweepMssType = input.string(TRIGGER_TYPE_TRADE, "Type", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m3", group = G_MODELS)
modelSweepMssFvg = input.bool(true, "SW>MS>FVG.", inline = "m4", group = G_MODELS)
modelSweepMssFvgWhen = input.string(TRIGGER_WHEN_TOUCH, "When", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline = "m4", group = G_MODELS)
modelSweepMssFvgType = input.string(TRIGGER_TYPE_TRADE, "Type", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline = "m4", group = G_MODELS)
scoreProfile = input.string(SCORE_PROFILE_BALANCED, "Score Profile", options = [SCORE_PROFILE_LOOSE, SCORE_PROFILE_BALANCED, SCORE_PROFILE_STRICT, SCORE_PROFILE_EXTREME], inline = "en1", group = G_POS)
signalEntryMode = input.string(ENTRY_MODE_AFTER_RETEST, "Event", options = [ENTRY_MODE_OFF, ENTRY_MODE_LIMIT, ENTRY_MODE_AFTER_RETEST], inline = "en0", group = G_POS)
signalMaxStartEntries = input.int(1, "Max Active", minval = 1, maxval = 50, inline = "en0", group = G_POS)
signalDynamicTp = input.bool(true, "Dynamic TP/SL", inline = "en1", group = G_POS)
signalRrInput = input.float(2.0, "Fixed RR", minval = 0.1, maxval = 10.0, step = 0.1, inline = "en1", group = G_POS)
signalFilterBiasLtf = input.bool(true, "LTF Bias", inline = "en2", group = G_POS)
signalFilterBiasHtf1 = input.bool(false, "HTF1 Bias", inline = "en2", group = G_POS)
signalFilterBiasHtf2 = input.bool(false, "HTF2 Bias", inline = "en2", group = G_POS)
signalFilterLong = input.bool(true, "Long", inline = "en3", group = G_POS)
signalFilterShort = input.bool(true, "Short", inline = "en3", group = G_POS)
