signalShowStart = input.bool(true, "Start", inline = "v0", group = G_VIS)
signalShowTp = input.bool(true, "TP", inline = "v0", group = G_VIS)
signalShowSl = input.bool(true, "SL", inline = "v0", group = G_VIS)
