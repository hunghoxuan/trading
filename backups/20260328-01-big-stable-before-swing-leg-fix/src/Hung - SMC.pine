var CORE.TFConfig htf1Cfg = CORE.TFConfig.new("HTF1", uiCfg.msHtf1SwingShow, uiCfg.msHtf1ZigzagShow, color.new(THEME.COLOR_HTF1, 70), color.new(THEME.COLOR_HTF1, 70), size.normal, color.new(THEME.COLOR_HTF1, 70), line.style_dotted, 1, SETTINGS.MS_HTF1_SWING_Y_SHIFT_TICKS)
