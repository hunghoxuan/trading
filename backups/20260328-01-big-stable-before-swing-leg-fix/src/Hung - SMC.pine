var array<int> rtTimeToIdxVals = array.new_int()

commonAtr = ta.atr(14)

var zqCfg = SMC.ZoneQualityCfg.new()
zqCfg.minHeightAtr := localCfg.zoneMinHeightAtr
zqCfg.useVolume := true
zqCfg.minRelVolume := 1.1
zqCfg.useImpulse := false
zqCfg.minBodyAtr := 0.35
zqCfg.sizeStrongMult := 1.8
zqCfg.volStrong := 1.5
zqCfg.impStrong := 1.0
zqCfg.dispMin := 0.65
zqCfg.volLen := 20
zqCfg.scoreSizeStrong := 2
zqCfg.scoreSizeBase := 1
zqCfg.scoreVolStrong := 2
zqCfg.scoreVolBase := 1
zqCfg.scoreImpStrong := 2
zqCfg.scoreImpBase := 1
zqCfg.scoreDisp := 1

if barstate.isfirst
    chartCtx.zones := array.new<CORE.PDArray>()
    chartCtx.levels := array.new<CORE.PDArray>()
    chartCtx.events := array.new<CORE.Event>()
    chartCtx.signalHist := array.new<CORE.Event>()
    workingFirstBar := math.max(bar_index - WORKING_MAX_BARS, 0)
    workingFirstBarLine := line.new(workingFirstBar, close, workingFirstBar, close + syminfo.mintick, xloc = xloc.bar_index, extend = extend.both, color = color.new(uiCfg.ltfColor, 0), width = 1, style = line.style_dotted)

GROUP_TRADE_CONFIG = "3. Trade Config"
GROUP_UI_CONFIG = "1. UI Config"

plotOB = input.bool(true, "OB", inline="pda", group=GROUP_UI_CONFIG)
plotFVG = input.bool(true, "FVG", inline="pda", group=GROUP_UI_CONFIG)
plotSD = input.bool(true, "SD", inline="pda", group=GROUP_UI_CONFIG)
useBB = input.bool(true, "BB", inline="pda", group=GROUP_UI_CONFIG)
useIFVG = input.bool(true, "iFVG", inline="pda", group=GROUP_UI_CONFIG)
pdDisplayMode = input.string("Normal", "Display", options = ["All", "Less", "Normal", "Extreme"], group = GROUP_UI_CONFIG, tooltip = "All: no prune. Normal: baseline prune behavior. Less: looser (keep up to 4/side). Extreme: tighter (keep 1/side).")

emTrend = input.bool(true, "TR - Trend.", tooltip="Trend: PD Array Mitigation", inline="em1", group="2. Trade Models")
emTrendWhen = input.string(TRIGGER_WHEN_RETEST, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline="em1", group="2. Trade Models")
emTrendType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline="em1", group="2. Trade Models")
emBreakout = input.bool(true, "BO - Breakout.", tooltip="Breakout: Structure Flip Retest", inline="em2", group="2. Trade Models")
emBreakoutWhen = input.string(TRIGGER_WHEN_RETEST, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline="em2", group="2. Trade Models")
emBreakoutType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline="em2", group="2. Trade Models")
emRejection = input.bool(true, "RJ - Rejection.", tooltip="Rejection: Key Level Rejection", inline="em3", group="2. Trade Models")
emRejectionWhen = input.string(TRIGGER_WHEN_TOUCH, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline="em3", group="2. Trade Models")
emRejectionType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline="em3", group="2. Trade Models")
emSweep = input.bool(false, "SW - Sweep.", tooltip="Sweep: Liquidity Sweep RTO", inline="em4", group="2. Trade Models")
emSweepWhen = input.string(TRIGGER_WHEN_RETEST, "", options = [TRIGGER_WHEN_TOUCH, TRIGGER_WHEN_RETEST], inline="em4", group="2. Trade Models")
emSweepType = input.string(TRIGGER_TYPE_TRADE, "", options = [TRIGGER_TYPE_SIGNAL, TRIGGER_TYPE_TRADE], inline="em4", group="2. Trade Models")


signalShowPending = input.bool(true, "Pending", inline = "en3", group = "4. Trade Display")
signalShowStart = input.bool(true, "Start", inline = "en3", group = "4. Trade Display")
signalShowTp = input.bool(true, "TP", inline = "en3", group = "4. Trade Display")
signalShowSl = input.bool(true, "SL", inline = "en3", group = "4. Trade Display")
entryEngineEnabled = input.bool(true, "Entry Engine", inline = "en3", group = "4. Trade Display")

if barstate.isfirst
    localCfg := get_data_local_cfg(WORKING_MAX_BARS)
    uiCfg := get_ui_cfg(THEME)
    zqCfg.minHeightAtr := localCfg.zoneMinHeightAtr
    ZONE_VIS_CFG.minWidthBars := uiCfg.zoneCurrMinWidthBars
    cfgOB.extendBarsCurr := uiCfg.ltfBarsExt
    cfgFVG.extendBarsCurr := uiCfg.ltfBarsExt - 4
    cfgRJB.extendBarsCurr := uiCfg.ltfBarsExt
    cfgSD.extendBarsCurr := uiCfg.ltfBarsExt
    cfgBB.extendBarsCurr := uiCfg.ltfBarsExt
    cfgIFVG.extendBarsCurr := uiCfg.ltfBarsExt - 4

get_working_first_bar() =>
    math.max(bar_index - WORKING_MAX_BARS, 0)

is_in_working_zone_current() =>
    bar_index >= get_working_first_bar()

is_in_working_zone_idx(int idx) =>
    not na(idx) and idx >= get_working_first_bar()

process_data_update_working_bar_line(line currLine, int currFirst) =>
    if not na(currLine)
        line.delete(currLine)
    line.new(currFirst, close, currFirst, close + syminfo.mintick, xloc = xloc.bar_index, extend = extend.both, color = color.new(uiCfg.ltfColor, 0), width = 1, style = line.style_dotted)

get_working_first_time_for_tf(string tfName) =>
    int currSec = math.max(CORE.get_tf_seconds(timeframe.period), 1)
    int tfSec = math.max(CORE.get_tf_seconds(tfName), currSec)
    int tfBarsBack = int(math.round(float(WORKING_MAX_BARS) * float(tfSec) / float(currSec)))
    int safeOff = math.max(0, math.min(math.min(tfBarsBack, bar_index), 10000))
    int(time[safeOff])

get_data_tf_struct_pair_start_time(int tfSlot) =>
    float hi = na
    int hiT = na
    float lo = na
    int loT = na
    if tfSlot == 0
        [hi, hiT, lo, loT] = CORE.market_structure_latest_hilo(htf1Data.ms)
    else
        [hi, hiT, lo, loT] = CORE.market_structure_latest_hilo(htf2Data.ms)
    not na(hiT) and not na(loT) ? math.min(hiT, loT) : not na(hiT) ? hiT : loT

get_data_htf_detection_cutoff_time(int tfSlot, string tfName) =>
    int ratioTime = not na(tfName) ? get_working_first_time_for_tf(tfName) : 0
    int structTime = get_data_tf_struct_pair_start_time(tfSlot)
    na(structTime) ? ratioTime : math.max(ratioTime, structTime)

get_data_working_first_idx_for_tf_name(string tfName) =>
    if na(tfName) or tfName == "" or tfName == timeframe.period
        get_working_first_bar()
    else
        [tf1Local, tf2Local] = CORE.get_htf_pair()
        int tfSlot = tfName == tf1Local ? 0 : tfName == tf2Local ? 1 : 0
        int cutoffTime = get_data_htf_detection_cutoff_time(tfSlot, tfName)
        int cutoffIdx = CORE.closest_bar_index_from_time(cutoffTime)
        na(cutoffIdx) ? get_working_first_bar() : cutoffIdx

get_data_real_htf_swings(string tfName, int pivotLen) =>
    float sh = na
    int shT = na
    float sl = na
    int slT = na
    if not na(tfName) and tfName != ""
        sh := request.security(syminfo.tickerid, tfName, ta.pivothigh(high, pivotLen, pivotLen), lookahead = barmerge.lookahead_off)
        sl := request.security(syminfo.tickerid, tfName, ta.pivotlow(low, pivotLen, pivotLen), lookahead = barmerge.lookahead_off)
        shT := int(request.security(syminfo.tickerid, tfName, not na(ta.pivothigh(high, pivotLen, pivotLen)) ? time[pivotLen] : int(na), lookahead = barmerge.lookahead_off))
        slT := int(request.security(syminfo.tickerid, tfName, not na(ta.pivotlow(low, pivotLen, pivotLen)) ? time[pivotLen] : int(na), lookahead = barmerge.lookahead_off))
    [sh, shT, sl, slT]

process_data_update_working_debug_line(line currLine, int currIdx, color lnColor) =>
    if not na(currLine)
        line.delete(currLine)
    line.new(currIdx, close, currIdx, close + syminfo.mintick, xloc = xloc.bar_index, extend = extend.both, color = color.new(lnColor, 0), width = 1, style = line.style_dotted)

process_data_prune_outside_working_zone(array<CORE.PDArray> zones) =>
    if array.size(zones) > 0
        for i = array.size(zones) - 1 to 0 by 1
            CORE.PDArray z = array.get(zones, i)
            int anchorIdx = na(z.barStart) ? na : z.barStart
            string sourceTf = na(z.sourceTf) or z.sourceTf == "" ? timeframe.period : z.sourceTf
            int firstIdx = get_data_working_first_idx_for_tf_name(sourceTf)
            if not na(anchorIdx) and anchorIdx < firstIdx
                UI.delete_pd_array_drawings(z)
                array.remove(zones, i)
    bool(na)


get_pdarray_cfg(string zoneType) =>
    zoneType == "OB" ? cfgOB :
     zoneType == "FVG" ? cfgFVG :
     zoneType == "RJB" ? cfgRJB :
     zoneType == "SD" ? cfgSD :
     zoneType == "BB" ? cfgBB :
     zoneType == "IFVG" ? cfgIFVG :
     SMC.ZoneTypeConfig.new(0, "", "", "", "", 0, 0.0, 0, line.style_solid, false, false, "")

get_data_required_events_preset(string modelKey) =>
    string k = str.upper(modelKey)
    k == "BREAK_OUT" ? "MSS,BOS" : k == "REJECTION" ? "SWEEP" : ""

process_data_init_strategy_defs() =>
    array.clear(strategyDefs)
    array.push(strategyDefs, CORE.EntryModelDef.new("TREND", "TR", 7, emTrend, emTrendType, emTrendWhen, 2.2, "edge", 1, 1, 0, get_data_required_events_preset("TREND"), 80, "na", 2, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, CORE.EntryModelDef.new("BREAK_OUT", "BO", 6, emBreakout, emBreakoutType, emBreakoutWhen, 2.0, "edge", 1, 1, 0, get_data_required_events_preset("BREAK_OUT"), 80, "na", 1, true, 0.20, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, CORE.EntryModelDef.new("REJECTION", "RJ", 5, emRejection, emRejectionType, emRejectionWhen, 1.6, "middle", 2, 0, 0, get_data_required_events_preset("REJECTION"), 120, "na", 1, true, 0.15, ENTRY_MODE_AFTER_RETEST))
    array.push(strategyDefs, CORE.EntryModelDef.new("SWEEP", "SW", 6, emSweep, emSweepType, emSweepWhen, 2.4, "edge", 1, 0, 0, get_data_required_events_preset("SWEEP"), 80, "na", 1, true, 0.18, ENTRY_MODE_LIMIT))
    bool(na)

get_data_strategy_defs_sig() =>
    int sig = 0
    sig += (emTrend ? 1 : 0) * 10000000 + SMC.trigger_type_code(emTrendType, TRIGGER_TYPE_SIGNAL) * 1000000 + SMC.trigger_when_code(emTrendWhen, TRIGGER_WHEN_TOUCH) * 100000
    sig += (emBreakout ? 1 : 0) * 10000 + SMC.trigger_type_code(emBreakoutType, TRIGGER_TYPE_SIGNAL) * 1000 + SMC.trigger_when_code(emBreakoutWhen, TRIGGER_WHEN_TOUCH) * 100
    sig += (emRejection ? 1 : 0) * 10 + SMC.trigger_type_code(emRejectionType, TRIGGER_TYPE_SIGNAL) * 2 + SMC.trigger_when_code(emRejectionWhen, TRIGGER_WHEN_TOUCH)
    sig += ((emSweep ? 1 : 0) * 100000000) + SMC.trigger_type_code(emSweepType, TRIGGER_TYPE_SIGNAL) * 17 + SMC.trigger_when_code(emSweepWhen, TRIGGER_WHEN_TOUCH) * 31
    sig

process_data_refresh_strategy_defs() =>
    int nextSig = get_data_strategy_defs_sig()
    int cachedSig = array.get(strategyDefsSigBox, 0)
    if na(cachedSig) or cachedSig != nextSig or array.size(strategyDefs) == 0
        process_data_init_strategy_defs()
        array.set(strategyDefsSigBox, 0, nextSig)
    bool(na)

process_data_reset_runtime_context_if_new_bar() =>
    int cachedBar = array.get(rtBarBox, 0)
    if na(cachedBar) or cachedBar != bar_index
        array.set(rtBarBox, 0, bar_index)
        array.clear(rtStrategyKeys)
        array.clear(rtStrategyEnabled)
        array.clear(rtStrategyScore)
        array.clear(rtStrategyShort)
        array.clear(rtStrategyTriggerType)
        array.clear(rtStrategyTriggerWhen)
        array.clear(rtPdMetaKeys)
        array.clear(rtPdMetaRank)
        array.clear(rtPdMetaLegId)
        array.clear(rtPdMetaLegDir)
        array.clear(rtPdMetaLegSeq)
        array.clear(rtMinRightKeys)
        array.clear(rtMinRightVals)
        array.clear(rtTimeToIdxKeys)
        array.clear(rtTimeToIdxVals)
    bool(na)

get_data_strategy_meta_by_key(string key) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(key)
    process_data_reset_runtime_context_if_new_bar()
    int cachedIdx = na
    if array.size(rtStrategyKeys) > 0
        for i = 0 to array.size(rtStrategyKeys) - 1
            if array.get(rtStrategyKeys, i) == k
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtStrategyEnabled, cachedIdx), array.get(rtStrategyScore, cachedIdx), array.get(rtStrategyShort, cachedIdx), array.get(rtStrategyTriggerType, cachedIdx), array.get(rtStrategyTriggerWhen, cachedIdx)]
    else
        bool enabled = false
        int score = 0
        string shortName = ""
        string triggerType = TRIGGER_TYPE_TRADE
        string triggerWhen = TRIGGER_WHEN_RETEST
        if array.size(strategyDefs) > 0
            for i = 0 to array.size(strategyDefs) - 1
                CORE.EntryModelDef s = array.get(strategyDefs, i)
                if s.key == k
                    enabled := s.enabled
                    score := s.baseScore
                    shortName := s.shortName
                    triggerType := s.trigger_type
                    triggerWhen := s.trigger_when
                    break
        array.push(rtStrategyKeys, k)
        array.push(rtStrategyEnabled, enabled)
        array.push(rtStrategyScore, score)
        array.push(rtStrategyShort, shortName)
        array.push(rtStrategyTriggerType, triggerType)
        array.push(rtStrategyTriggerWhen, triggerWhen)
        [enabled, score, shortName, triggerType, triggerWhen]

get_data_cached_bar_index_from_time(int t) =>
    process_data_reset_runtime_context_if_new_bar()
    if na(t)
        na
    else
        int idx = na
        if array.size(rtTimeToIdxKeys) > 0
            for i = 0 to array.size(rtTimeToIdxKeys) - 1
                if array.get(rtTimeToIdxKeys, i) == t
                    idx := i
                    break
        if not na(idx)
            array.get(rtTimeToIdxVals, idx)
        else
            int v = CORE.closest_bar_index_from_time(t)
            array.push(rtTimeToIdxKeys, t)
            array.push(rtTimeToIdxVals, v)
            v

BIAS_TOG = CORE.BiasToggles.new(true, true, true, true, true, true, true, true)


get_data_post_touch_keep_max() =>
    16

prune_post_touch_pdarrays(array<CORE.PDArray> zones, int keepMax, float ageDecay) =>
    int cnt = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            bool isCurrentTf = z.sourceTfRank <= 1
            if isCurrentTf and SMC.is_pdarray_post_touch(z) and not z.broken
                cnt += 1
    while cnt > keepMax
        int weakestIdx = na
        float weakestScore = 10e10
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                CORE.PDArray z = array.get(zones, i)
                bool isCurrentTf = z.sourceTfRank <= 1
                if isCurrentTf and SMC.is_pdarray_post_touch(z) and not z.broken
                    float s = nz(z.qualityPct, 0.0) - (math.max(bar_index - z.barStart, 0) * ageDecay)
                    if na(weakestIdx) or s < weakestScore
                        weakestScore := s
                        weakestIdx := i
        if not na(weakestIdx)
            CORE.PDArray zDel = array.get(zones, weakestIdx)
            UI.delete_pd_array_drawings(zDel)
            array.remove(zones, weakestIdx)
            cnt -= 1
        else
            cnt := keepMax
    bool(na)

apply_removed_pdarray_visuals(array<CORE.PDArray> removed) =>
    if array.size(removed) > 0
        for i = 0 to array.size(removed) - 1
            CORE.PDArray zDel = array.get(removed, i)
            UI.delete_pd_array_drawings(zDel)
    bool(na)


add_primary_zone(array<CORE.PDArray> zones, string type, bool isBull, float top, float btm, int leftIdx, int ext, string labelText, int labelX, float labelY, color labelColor, color borderColor, string borderStyle, float qualityPct, string tooltipText, int tfSlot) =>
    bool merged = false
    if not is_in_working_zone_idx(leftIdx)
        bool(na)
    else if merged
        bool(na)
    else
        string labelSize = tfSlot == 1 ? THEME.SIZE_SMALL : tfSlot == 0 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL
        bool showLabel = labelSize != "None"
        color resolvedLabelColor = na(labelColor) ? uiCfg.ltfColor : labelColor
        color resolvedBorderColor = borderColor
        if tfSlot < 0 and not na(resolvedBorderColor)
            resolvedBorderColor := color.new(uiCfg.ltfColor, 85)
        color areaFillColor = uiCfg.colorBg
        bool strong = not na(qualityPct) and qualityPct >= 70.0
        if strong
            resolvedLabelColor := color.new(resolvedLabelColor, 0)
        CORE.ZoneVisualCfg zoneCfg = ZONE_VIS_CFG
        zoneCfg.textSize := labelSize
        SR_VIS_CFG.lineStyle := CFG_SR.lineStyle
        SR_VIS_CFG.lineWidth := CFG_SR.lineWidth
        SR_VIS_CFG.labelSize := labelSize
        SR_VIS_CFG.showLabel := CFG_SR.showLabel
        CORE.PDArray z = CORE.PDArray.new(type, top, btm, leftIdx, false, false, na, na, na, na, na, na, isBull, labelText, ext, qualityPct)
        z := UI.draw_price_zone(z, leftIdx, bar_index + ext, top, btm, areaFillColor, resolvedBorderColor, borderStyle, labelText, resolvedLabelColor, tooltipText, labelX, labelY, zoneCfg, SR_VIS_CFG, true, false, (top + btm) / 2.0, CFG_SR.lineColor, "AREA", showLabel)
        z.lifeState := CONST.LIFE_FORMED
        z.touchCount := 0
        array<CORE.PDArray> removed = SMC.add_active_zone(chartCtx.zones, z, localCfg.zoneCapPerType, localCfg.zoneCapTotal, localCfg.zoneCurrMaxPerTypeSide, effectiveCurrLookbackBars, last_bar_index, close, bar_index, localCfg.zonePriorityAgeDecay)
        apply_removed_pdarray_visuals(removed)
    bool(na)

spawn_derived_zone(array<CORE.PDArray> zones, string newType, bool isBull, float top, float btm, float qualityPct) =>
    SMC.ZoneTypeConfig cfg = get_pdarray_cfg(newType)
    float q = nz(qualityPct, 0.0)
    int ext = cfg.extendBarsCurr > 0 ? cfg.extendBarsCurr : SMC.get_current_pdarray_extend(newType, uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
    color txtColor = uiCfg.ltfColor
    borderStyle = cfg.borderStyle
    color borderColor = cfg.noBorder ? na : color.new(uiCfg.ltfColor, 85)
    string lbl = cfg.shortName != "" ? cfg.shortName : (newType == "BB" ? "BB" : "iFVG")
    string tt = newType == "BB" ?
     CORE.tt_side(isBull, isBull ? "BB flip to demand" : "BB flip to supply") :
     CORE.tt_side(isBull, isBull ? "iFVG support flip" : "iFVG resistance flip")
    string zoneTip = uiCfg.zoneTooltipEnable ? tt : ""
    CORE.PDArray z = CORE.PDArray.new(newType, top, btm, bar_index, false, false, na, na, na, na, na, na, isBull, lbl, ext, q)
    z := UI.draw_price_zone(z, bar_index, bar_index + ext, top, btm, uiCfg.colorBg, borderColor, borderStyle, lbl, txtColor, zoneTip, bar_index + ext, (top + btm) / 2.0, ZONE_VIS_CFG, SR_VIS_CFG, true, false, na, borderColor, "AREA", true)
    z.lifeState := CONST.LIFE_FORMED
    z.touchCount := 0
    z.rejectCount := 0
    array<CORE.PDArray> removed = SMC.add_active_zone(chartCtx.zones, z, localCfg.zoneCapPerType, localCfg.zoneCapTotal, localCfg.zoneCurrMaxPerTypeSide, effectiveCurrLookbackBars, last_bar_index, close, bar_index, localCfg.zonePriorityAgeDecay)
    apply_removed_pdarray_visuals(removed)

get_data_normalize_pdarray_label_text(string zoneType, string rawText) =>
    string out = rawText
    if zoneType == "OB"
        string r = str.replace_all(rawText, " ", "")
        int rLen = str.length(r)
        if r == "OB" or r == "ob"
            out := "ob"
        else if rLen >= 3 and str.substring(r, 0, 3) == "OB."
            string tag = str.lower(str.substring(r, 3, rLen))
            out := tag + ".ob"
        else if rLen >= 3 and str.substring(r, 0, 3) == "OB-"
            string tag = str.lower(str.substring(r, 3, rLen))
            out := tag + ".ob"
    out

process_data_tf_ms_trend_light(CORE.TFData tfData, bool enabled, CORE.MarketStructure ms) =>
    SMC.process_tf_ms_trend_light(tfData, enabled, ms)

annotate_new_pricezones(array<CORE.PDArray> zones, int startIdx, string sourceTf, int sourceTfRank, CORE.TFData tfData) =>
    int zoneCount = array.size(zones)
    if startIdx < zoneCount
        for i = startIdx to zoneCount - 1
            CORE.PDArray z = array.get(zones, i)
            if z.sourceTf == ""
                tfData.legSeqAll += 1
                int seqType = 0
                if z.type == "OB" or z.type == "BB"
                    tfData.legSeqOb += 1
                    seqType := tfData.legSeqOb
                else if z.type == "FVG" or z.type == "IFVG"
                    tfData.legSeqFvg += 1
                    seqType := tfData.legSeqFvg
                else if z.type == "RJB"
                    tfData.legSeqRjb += 1
                    seqType := tfData.legSeqRjb
                else
                    tfData.legSeqLevel += 1
                    seqType := tfData.legSeqLevel
                z.sourceTf := sourceTf
                z.sourceTfRank := sourceTfRank
                z.legId := tfData.legId
                z.legDir := tfData.legDir
                z.legSeqAll := tfData.legSeqAll
                z.legSeqType := seqType
                array.set(zones, i, z)

is_pdarray_trade_type(string type) =>
    string t = str.upper(type)
    str.contains(t, "OB") or str.contains(t, "BB") or str.contains(t, "FVG") or str.contains(t, "IFVG") or str.contains(t, "RJB") or str.contains(t, "SD")

get_trade_pdarray_meta(string type, float zoneTop, float zoneBtm) =>
    process_data_reset_runtime_context_if_new_bar()
    string metaKey = type + "|" + str.tostring(zoneTop, "#.#####") + "|" + str.tostring(zoneBtm, "#.#####")
    int cachedIdx = na
    if array.size(rtPdMetaKeys) > 0
        for i = 0 to array.size(rtPdMetaKeys) - 1
            if array.get(rtPdMetaKeys, i) == metaKey
                cachedIdx := i
                break
    if not na(cachedIdx)
        [array.get(rtPdMetaRank, cachedIdx), array.get(rtPdMetaLegId, cachedIdx), array.get(rtPdMetaLegDir, cachedIdx), array.get(rtPdMetaLegSeq, cachedIdx)]
    else
        int outRank = 0
        int outLegId = -1
        int outLegDir = 0
        int outLegSeq = -1
        float tol = syminfo.mintick * 2.0
        if array.size(chartCtx.zones) > 0
            for i = array.size(chartCtx.zones) - 1 to 0
                CORE.PDArray z = array.get(chartCtx.zones, i)
                bool sameType = z.type == type
                bool nearTop = math.abs(z.top - zoneTop) <= tol
                bool nearBtm = math.abs(z.bottom - zoneBtm) <= tol
                if sameType and nearTop and nearBtm
                    outRank := z.sourceTfRank
                    outLegId := z.legId
                    outLegDir := z.legDir
                    outLegSeq := z.legSeqAll
                    break
        array.push(rtPdMetaKeys, metaKey)
        array.push(rtPdMetaRank, outRank)
        array.push(rtPdMetaLegId, outLegId)
        array.push(rtPdMetaLegDir, outLegDir)
        array.push(rtPdMetaLegSeq, outLegSeq)
        [outRank, outLegId, outLegDir, outLegSeq]

passes_pdarray_trade_filter(string type, float qualityPct, float zoneTop, float zoneBtm, string direction) =>
    bool pass = true
    if localCfg.entryZoneFilterEnable and is_pdarray_trade_type(type)
        [srcRank, legId, legDir, legSeq] = get_trade_pdarray_meta(type, zoneTop, zoneBtm)
        float q = nz(qualityPct, 0.0)
        if pass and q < localCfg.entryZoneMinQualityPct
            pass := false
        if pass and localCfg.entryFilterNearLegEnable
            bool known = legId >= 0 and legSeq > 0
            bool seqOk = known and legSeq <= localCfg.entryFilterNearLegMaxSeq
            bool dirOk = true
            if localCfg.entryFilterNearLegRequireDirMatch and known
                bool isBuy = str.upper(direction) == "BUY"
                dirOk := (isBuy and legDir >= 0) or ((not isBuy) and legDir <= 0)
            pass := known ? (seqOk and dirOk) : localCfg.entryFilterNearLegAllowUnknown
    pass

get_data_mark_pdarray_label_mitigated(string zoneType, string labelText) =>
    string out = labelText
    if zoneType == "OB"
        int tLen = str.length(labelText)
        bool endsOb = false
        if tLen >= 3
            string sfx = str.substring(labelText, tLen - 3, tLen)
            endsOb := sfx == ".OB" or sfx == ".ob"
        if endsOb
            string base = str.substring(labelText, 0, tLen - 3)
            int bLen = str.length(base)
            if base == "d" or base == "o" or base == "x" or base == "m"
                base := ""
                bLen := 0
            bool endsDotD = false
            bool endsDotO = false
            bool endsDotX = false
            bool endsDotM = false
            if bLen >= 2
                string suffix = str.substring(base, bLen - 2, bLen)
                endsDotD := suffix == ".d"
                endsDotO := suffix == ".o"
                endsDotX := suffix == ".x"
                endsDotM := suffix == ".m"
            if endsDotD or endsDotO or endsDotX or endsDotM
                base := str.substring(base, 0, bLen - 2)
            out := base == "" ? "m.ob" : base + ".m.ob"
        else
            out := "m.ob"
    out

add_htf_pdarray_core(array<CORE.PDArray> zones, int tfSlot, string zoneType, bool isBull, float top, float btm, int startTs, float qPct) =>
    int ext = SMC.get_htf_pdarray_extend(tfSlot, 14, 25)
    string lbl = zoneType == "SD" ? (isBull ? "D" : "S") : str.upper(zoneType)
    bool hasDupSameSlot = false
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            bool sameTypeSide = z.type == zoneType and z.isBullish == isBull
            bool sameSlot = z.extendBars == ext
            if sameTypeSide and sameSlot and SMC.pd_arrays_overlap(top, btm, z.top, z.bottom)
                hasDupSameSlot := true
                break
    if not hasDupSameSlot
        int leftIdxRaw = get_data_cached_bar_index_from_time(startTs)
        int leftIdx = na(leftIdxRaw) ? bar_index : leftIdxRaw
        SMC.ZoneTypeConfig cfg = get_pdarray_cfg(zoneType)
        color lineClr = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 0) : color.new(htf2Cfg.zigzagColor, 0)
        color tfBorder = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 85) : color.new(htf2Cfg.zigzagColor, 85)
        color borderClr = cfg.noBorder ? na : tfBorder
        string borderStyle = cfg.borderStyle
        float y = (top + btm) * 0.5
        int labelX = bar_index + 5
        string tt = CORE.tt_side(isBull, lbl)
        add_primary_zone(zones, zoneType, isBull, top, btm, leftIdx, ext, lbl, labelX, y, lineClr, borderClr, borderStyle, qPct, tt, tfSlot)
    bool(na)

add_htf_pdarray_if_valid(array<CORE.PDArray> zones, string tfLabel, int tfSlot, bool showTf, bool showType, string zoneType, bool isBull, float top, float btm, int startTs, float qPct) =>
    [tf1Local, tf2Local] = CORE.get_htf_pair()
    string tfName = tfSlot == 0 ? tf1Local : tf2Local
    int recentTsCut = get_data_htf_detection_cutoff_time(tfSlot, tfName)
    bool recent = not na(startTs) and startTs >= recentTsCut
    bool unmitigated = zoneType == "SD" ? true : (isBull ? (low > top) : (high < btm))
    bool valid = showTf and showType and recent and not na(startTs) and not na(top) and not na(btm) and top > btm and nz(qPct, 0) >= localCfg.htfProjectionMinQualityPct and unmitigated
    if valid
        add_htf_pdarray_core(zones, tfSlot, zoneType, isBull, top, btm, startTs, qPct)
    bool(na)

get_data_has_zone_side_in_range(array<CORE.PDArray> zones, int startIdx, bool wantAbove) =>
    bool found = false
    int n = array.size(zones)
    if n > startIdx
        for i = startIdx to n - 1
            CORE.PDArray z = array.get(zones, i)
            bool typeOk = z.type == "OB" or z.type == "FVG"
            float mid = (z.top + z.bottom) * 0.5
            bool sideOk = wantAbove ? mid >= close : mid <= close
            if typeOk and sideOk
                found := true
                break
    found

process_data_add_htf_side_fallback(array<CORE.PDArray> zones, int startIdx, int tfSlot, bool showTf, bool wantAbove,
 bool showType0, string type0, bool bull0, float top0, float btm0, int st0, float q0,
 bool showType1, string type1, bool bull1, float top1, float btm1, int st1, float q1,
 bool showType2, string type2, bool bull2, float top2, float btm2, int st2, float q2,
 bool showType3, string type3, bool bull3, float top3, float btm3, int st3, float q3) =>
    if not showTf or get_data_has_zone_side_in_range(zones, startIdx, wantAbove)
        bool(na)
    else
        [tf1Local, tf2Local] = CORE.get_htf_pair()
        string tfName = tfSlot == 0 ? tf1Local : tf2Local
        int recentTsCut = get_data_htf_detection_cutoff_time(tfSlot, tfName)
        int bestIdx = na
        float bestScore = na
        for i = 0 to 3
            bool showType = i == 0 ? showType0 : i == 1 ? showType1 : i == 2 ? showType2 : showType3
            string zType = i == 0 ? type0 : i == 1 ? type1 : i == 2 ? type2 : type3
            bool isBull = i == 0 ? bull0 : i == 1 ? bull1 : i == 2 ? bull2 : bull3
            float top = i == 0 ? top0 : i == 1 ? top1 : i == 2 ? top2 : top3
            float btm = i == 0 ? btm0 : i == 1 ? btm1 : i == 2 ? btm2 : btm3
            int st = i == 0 ? st0 : i == 1 ? st1 : i == 2 ? st2 : st3
            float q = i == 0 ? q0 : i == 1 ? q1 : i == 2 ? q2 : q3
            bool baseValid = showType and not na(st) and not na(top) and not na(btm) and top > btm
            float mid = (top + btm) * 0.5
            bool sideOk = wantAbove ? mid >= close : mid <= close
            if baseValid and sideOk
                bool recent = st >= recentTsCut
                bool qOk = nz(q, 0) >= localCfg.htfProjectionMinQualityPct
                bool unmitigated = isBull ? (low > top) : (high < btm)
                float score = 0.0
                score += recent ? 1000.0 : 0.0
                score += qOk ? 100.0 : 0.0
                score += unmitigated ? 10.0 : 0.0
                score -= math.abs(mid - close) / math.max(syminfo.mintick, 0.0000001)
                if na(bestIdx) or score > bestScore
                    bestIdx := i
                    bestScore := score
        if not na(bestIdx)
            string zType = bestIdx == 0 ? type0 : bestIdx == 1 ? type1 : bestIdx == 2 ? type2 : type3
            bool isBull = bestIdx == 0 ? bull0 : bestIdx == 1 ? bull1 : bestIdx == 2 ? bull2 : bull3
            float top = bestIdx == 0 ? top0 : bestIdx == 1 ? top1 : bestIdx == 2 ? top2 : top3
            float btm = bestIdx == 0 ? btm0 : bestIdx == 1 ? btm1 : bestIdx == 2 ? btm2 : btm3
            int st = bestIdx == 0 ? st0 : bestIdx == 1 ? st1 : bestIdx == 2 ? st2 : st3
            float q = bestIdx == 0 ? q0 : bestIdx == 1 ? q1 : bestIdx == 2 ? q2 : q3
            add_htf_pdarray_core(zones, tfSlot, zType, isBull, top, btm, st, q)
    bool(na)

get_data_htf_sd_snapshot(float thresholdPct, int divBins, int lookbackBars) =>
    int lb = math.max(5, lookbackBars)
    float hi = ta.highest(high, lb)
    float lo = ta.lowest(low, lb)
    float csum = math.sum(volume, lb)
    float bin = (hi - lo) / divBins
    int safeOff = math.max(0, math.min(math.min(lb - 1, bar_index), 10000))
    int st = int(time[safeOff])
    float sTop = na
    float sBtm = na
    float dTop = na
    float dBtm = na
    if csum > 0 and bin > 0
        float sAcc = 0.0
        float dAcc = 0.0
        for i = 0 to divBins - 1
            float sLvl = hi - (i + 1) * bin
            float sPrev = hi - i * bin
            float dLvl = lo + (i + 1) * bin
            float dPrev = lo + i * bin
            float sVol = 0.0
            float dVol = 0.0
            for j = 0 to lb - 1
                if high[j] > sLvl and high[j] <= sPrev
                    sVol += volume[j]
                if low[j] >= dPrev and low[j] < dLvl
                    dVol += volume[j]
            sAcc += sVol
            dAcc += dVol
            if na(sBtm) and sAcc / csum * 100 > thresholdPct
                sTop := hi
                sBtm := sLvl
            if na(dTop) and dAcc / csum * 100 > thresholdPct
                dTop := dLvl
                dBtm := lo
            if not na(sBtm) and not na(dTop)
                break
    [sTop, sBtm, st, dTop, dBtm, st]


get_data_entry_model_dynamic_cfg(string modelKey) =>
    process_data_refresh_strategy_defs()
    string k = str.upper(modelKey)
    float rrCfg = 2.0
    string entryPoint = "edge"
    int biasLtfMode = 1
    int biasHtf1Mode = 0
    int biasHtf2Mode = 0
    string requiredPrevEvents = ""
    int requiredWindowBars = 80
    string biasDirection = "na"
    int maxActiveCfg = 1
    bool dynamicTpCfg = true
    float riskZonePctCfg = 0.20
    string entryModeCfg = ENTRY_MODE_AFTER_RETEST
    if array.size(strategyDefs) > 0
        for i = 0 to array.size(strategyDefs) - 1
            CORE.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                rrCfg := s.rr
                entryPoint := s.entry_point
                biasLtfMode := s.bias_ltf
                biasHtf1Mode := s.bias_htf1
                biasHtf2Mode := s.bias_htf2
                requiredPrevEvents := s.required_previous_events
                requiredWindowBars := s.required_window_bars
                biasDirection := s.bias_direction
                maxActiveCfg := s.max_active
                dynamicTpCfg := s.dynamic_tp_sl
                riskZonePctCfg := s.risk_zone_pct
                entryModeCfg := s.entry_mode
                break
    [rrCfg, entryPoint, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, maxActiveCfg, dynamicTpCfg, riskZonePctCfg, entryModeCfg]

check_entry_direction_by_mode(string direction, int mode, int trendVal, int biasVal, bool allowPullback) =>
    mode == 0 ? true : mode == 1 ? SMC.direction_matches_bias(direction, allowPullback ? (biasVal != 0 ? biasVal : trendVal) : (trendVal != 0 ? trendVal : biasVal)) : SMC.direction_matches_bias(direction, biasVal)

get_data_has_pullback_preference(int biasLtfMode, int biasHtf1Mode, int biasHtf2Mode) =>
    biasLtfMode == 2 or biasHtf1Mode == 2 or biasHtf2Mode == 2

get_data_has_recent_signal_event(string eventType, int lookbackBars) =>
    bool hit = false
    int n = array.size(chartCtx.signalHist)
    if n > 0
        for i = n - 1 to 0
            CORE.Event ev = array.get(chartCtx.signalHist, i)
            if (bar_index - ev.barDetected) <= lookbackBars and str.upper(ev.type) == eventType
                hit := true
                break
    hit

get_data_normalize_required_events(string requiredPrevEvents) =>
    string req = str.upper(requiredPrevEvents)
    req := str.replace_all(req, " ", "")
    req := str.replace_all(req, "|", ",")
    req := str.replace_all(req, "+", ",")
    req := str.replace_all(req, ";", ",")
    req := str.replace_all(req, "/", ",")
    req

get_data_resolve_event_alias(string tokenRaw) =>
    string t = str.upper(tokenRaw)
    t == "MS" ? "MSS" : t == "BO" ? "BOS" : t == "SW" ? "SWEEP" : t

get_data_check_required_previous_events(string requiredPrevEvents, int lookbackBars) =>
    string norm = get_data_normalize_required_events(requiredPrevEvents)
    if str.length(norm) == 0
        true
    else
        bool ok = true
        array<string> toks = str.split(norm, ",")
        if array.size(toks) > 0
            for i = 0 to array.size(toks) - 1
                string token = get_data_resolve_event_alias(array.get(toks, i))
                if str.length(token) > 0
                    if not get_data_has_recent_signal_event(token, lookbackBars)
                        ok := false
                        break
        ok

check_entry_model_dynamic(string modelKey, string direction, int memDir) =>
    [_, _, biasLtfMode, biasHtf1Mode, biasHtf2Mode, requiredPrevEvents, requiredWindowBars, biasDirection, _, _, _, _] = get_data_entry_model_dynamic_cfg(modelKey)
    int bLtf = array.get(tradeBiasVals, 0)
    int bH1 = array.get(tradeBiasVals, 1)
    int bH2 = array.get(tradeBiasVals, 2)
    int tLtf = array.get(tradeTrendVals, 0)
    int tH1 = array.get(tradeTrendVals, 1)
    int tH2 = array.get(tradeTrendVals, 2)
    bool allowPullback = get_data_has_pullback_preference(biasLtfMode, biasHtf1Mode, biasHtf2Mode)
    bool dirModeOk = check_entry_direction_by_mode(direction, biasLtfMode, tLtf, bLtf, allowPullback) and check_entry_direction_by_mode(direction, biasHtf1Mode, tH1, bH1, allowPullback) and check_entry_direction_by_mode(direction, biasHtf2Mode, tH2, bH2, allowPullback)
    bool memOk = memDir == 0 or (direction == "Buy" and memDir == 1) or (direction == "Sell" and memDir == -1)
    string bd = str.upper(biasDirection)
    bool biasDirOk = bd == "" or bd == "NA" or (bd == "LONG" and direction == "Buy") or (bd == "SHORT" and direction == "Sell")
    bool requiredOk = get_data_check_required_previous_events(requiredPrevEvents, requiredWindowBars)
    dirModeOk and memOk and biasDirOk and requiredOk

get_cached_pdarray_min_right(CORE.PDArray z, int desiredRight, int minWidthBars) =>
    process_data_reset_runtime_context_if_new_bar()
    string key = z.type + "|" + str.tostring(z.barStart) + "|" + str.tostring(desiredRight) + "|" + str.tostring(minWidthBars)
    int idx = na
    if array.size(rtMinRightKeys) > 0
        for i = 0 to array.size(rtMinRightKeys) - 1
            if array.get(rtMinRightKeys, i) == key
                idx := i
                break
    if not na(idx)
        array.get(rtMinRightVals, idx)
    else
        int v = CORE.get_pdarray_min_right_idx(z, desiredRight, minWidthBars)
        array.push(rtMinRightKeys, key)
        array.push(rtMinRightVals, v)
        v

get_model_key_for_type(string t) =>
    string u = str.upper(t)
    (u == "OB" or u == "FVG" or u == "SD" or u == "TR" or u == "TREND") ? "TREND" :
     (u == "BB" or u == "IFVG" or u == "RJB" or u == "BO" or u == "BREAK_OUT") ? "BREAK_OUT" :
     ((u == "RJ" or u == "REJECTION") ? "REJECTION" :
     ((u == "SW" or u == "SWEEP") ? "SWEEP" : u))

is_pdarray_type_enabled(string t) =>
    string u = str.upper(t)
    (u == "OB" and plotOB) or (u == "FVG" and plotFVG) or (u == "SD" and plotSD) or (u == "BB" and useBB) or (u == "IFVG" and useIFVG) or (u == "RJB") or (u == "SWEEP")

entry_direction_allowed(string direction, int biasVal) =>
    int cachedBar = array.get(rtBarBox, 0)
    int cachedBias = array.get(rtBiasBox, 0)
    bool canUseCache = not na(cachedBar) and cachedBar == bar_index and cachedBias == biasVal
    if canUseCache
        direction == "Buy" ? array.get(rtAllowBuyBox, 0) == 1 : array.get(rtAllowSellBox, 0) == 1
    else
        SMC.direction_allowed_raw(direction, chartCtx.signalMemoryDir)

process_data_add_entry(string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal) =>
    bool isBuy = direction == "Buy"
    float zoneTop = math.max(levelTop, levelBtm)
    float zoneBtm = math.min(levelTop, levelBtm)
    string modelKey = get_model_key_for_type(type)
    [rrCfg, entryPointCfg, _, _, _, _, _, _, maxActiveCfg, _, riskPctCfg, _] = get_data_entry_model_dynamic_cfg(modelKey)
    bool passDynamic = check_entry_model_dynamic(modelKey, direction, chartCtx.signalMemoryDir)
    bool passSide = true
    bool allowEntry = passes_pdarray_trade_filter(type, qualityPct, zoneTop, zoneBtm, direction) and passSide and passDynamic
    int maxEntries = math.max(maxActiveCfg, 1)
    bool passBatchCap = CORE.count_start_trades(trades, CONST) < maxEntries
    if allowEntry and passBatchCap
        SMC.cache_signal_memory_event(chartCtx.signalHist, CORE.Event.new(type, direction, levelTop, levelBtm, na, bar_index, int(na), false, reason, qualityPct, scoreVal), syminfo.mintick, 80)
        float rrUsed = math.max(rrCfg, 0.1)
        float tick = syminfo.mintick
        float sameZoneTol = tick * 2.0
        float zoneHeight = math.max(zoneTop - zoneBtm, syminfo.mintick)
        float slRaw = isBuy ? zoneBtm : zoneTop
        float riskPct = math.max(riskPctCfg, 0.01)

        for mode = 0 to 2
            bool modeEnabled = entryPointCfg == "edge" ? mode == 0 : entryPointCfg == "middle" ? mode == 1 : entryPointCfg == "end" ? mode == 2 : mode == 0
            if modeEnabled
                float entry = mode == 0 ? (isBuy ? zoneTop : zoneBtm) : mode == 1 ? ((zoneTop + zoneBtm) * 0.5) : slRaw
                float riskDist = math.max(zoneHeight * riskPct, syminfo.mintick)
                float stoploss = isBuy ? (slRaw - riskDist) : (slRaw + riskDist)
                float takeprofit = isBuy ? (entry + riskDist * rrUsed) : (entry - riskDist * rrUsed)
                string modeTag = mode == 0 ? ".E" : mode == 1 ? ".M" : ".N"
                string tradeType = type + modeTag
                string reasonFinal = reason + " [" + modeTag + "]" +
                 "\nL B/T:" + str.tostring(array.get(tradeBiasVals, 0)) + "/" + str.tostring(array.get(tradeTrendVals, 0)) +
                 "\nH1 B/T:" + str.tostring(array.get(tradeBiasVals, 1)) + "/" + str.tostring(array.get(tradeTrendVals, 1)) +
                 "\nH2 B/T:" + str.tostring(array.get(tradeBiasVals, 2)) + "/" + str.tostring(array.get(tradeTrendVals, 2))
                int entryIdx = na
                if array.size(trades) > 0
                    for k = array.size(trades) - 1 to 0
                        CORE.Trade ex = array.get(trades, k)
                        bool sameZone = math.abs(ex.zoneTop - levelTop) <= sameZoneTol and math.abs(ex.zoneBtm - levelBtm) <= sameZoneTol
                        if ex.direction == direction and ex.type == tradeType and sameZone and ex.state == CONST.SIGNAL_STATE_PENDING
                            entryIdx := k
                            break
                if na(entryIdx)
                    CORE.Trade e = CORE.create_trade_if_valid(direction, tradeType, levelTop, levelBtm, entry, stoploss, takeprofit, rrUsed, bar_index, reasonFinal, scoreVal, CONST, tick)
                    if not na(e)
                        array.push(trades, e)
                else
                    CORE.Trade e = array.get(trades, entryIdx)
                    e.type := tradeType
                    e.entry := entry
                    e.stoploss := stoploss
                    e.takeprofit := takeprofit
                    e.rrValue := rrUsed
                    e.reason := reasonFinal
                    e.score := scoreVal
                    array.set(trades, entryIdx, e)
    bool(na)

process_data_chart_context() =>
    chartCfg.useBias := true
    chartCfg.allowLong := true
    chartCfg.allowShort := true
    chartCfg.showPending := signalShowPending
    chartCfg.showStart := signalShowStart
    chartCfg.showTp := signalShowTp
    chartCfg.showSl := signalShowSl

    ctxDataCfg.needBias := true
    ctxDataCfg.needMsTrendDirs := true
    ctxDataCfg.needPdPw := true
    ctxDataCfg.needPriceRange := true
    ctxDataCfg.needHtfCandles := false
    ctxDataCfg.needMsSwingArrays := true
    ctxDataCfg.initBiasFactorArrays := true
    ctxDataCfg.rangeLookbackBars := math.max(effectiveCurrLookbackBars, 50)
    CORE.ChartContext ctx = CORE.get_data_context(ctxDataCfg, SETTINGS, BIAS_TOG, chartCtx.zones, chartCtx.levels, chartCtx.events, chartCtx.signalHist, ltfData, htf1Data, htf2Data)

    string h1Name = ctx.htf1Name
    string h2Name = ctx.htf2Name
    int h1Bias = h1Name == "15" ? ctx.b15 : h1Name == "240" ? ctx.b240 : h1Name == "1D" ? ctx.b1d : h1Name == "1W" ? ctx.b1w : ctx.b0
    int h2Bias = h2Name == "15" ? ctx.b15 : h2Name == "240" ? ctx.b240 : h2Name == "1D" ? ctx.b1d : h2Name == "1W" ? ctx.b1w : ctx.b0
    int h1Trend = h1Name == "15" ? ctx.dir15 : h1Name == "240" ? ctx.dir240 : h1Name == "1D" ? ctx.dir1d : h1Name == "1W" ? ctx.dir1w : ctx.dir0
    int h2Trend = h2Name == "15" ? ctx.dir15 : h2Name == "240" ? ctx.dir240 : h2Name == "1D" ? ctx.dir1d : h2Name == "1W" ? ctx.dir1w : ctx.dir0
    array.set(tradeBiasVals, 0, ctx.b0)
    array.set(tradeBiasVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.b0 : h1Bias)
    array.set(tradeBiasVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.b0 : h2Bias)
    array.set(tradeTrendVals, 0, ctx.dir0)
    array.set(tradeTrendVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.dir0 : h1Trend)
    array.set(tradeTrendVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.dir0 : h2Trend)
    [memScore, memDir, bullCount, bearCount] = SMC.compute_signal_memory_bias(chartCtx.signalHist, 20)
    ctx.signalMemoryScore := memScore
    ctx.signalMemoryDir := memDir
    ctx.signalBullCount := bullCount
    ctx.signalBearCount := bearCount
    int effBias = ctx.activeBias
    if memDir != 0
        if effBias == 0
            effBias := memDir
        else if effBias != memDir
            effBias := 0
    ctx.biasVal := effBias
    process_data_reset_runtime_context_if_new_bar()
    array.set(rtBiasBox, 0, ctx.biasVal)
    array.set(rtAllowBuyBox, 0, SMC.direction_allowed_raw("Buy", memDir) ? 1 : 0)
    array.set(rtAllowSellBox, 0, SMC.direction_allowed_raw("Sell", memDir) ? 1 : 0)
    ctx

process_data_barrier_touch_setup(CORE.ChartContext ctx) =>
    [btEnabled, btScore, shortName, btType, btWhen] = get_data_strategy_meta_by_key("REJECTION")
    [_, _, _, _, _, _, _, _, _, _, _, btEntryMode] = get_data_entry_model_dynamic_cfg("REJECTION")
    if not btEnabled or btEntryMode == ENTRY_MODE_OFF
        bool(na)
    else
        [aboveBarrier, belowBarrier, aboveH, belowH] = SMC.get_nearest_barriers(chartCtx.zones, close, syminfo.mintick)
        bool hasRes = not na(aboveBarrier) and not na(aboveH)
        bool hasSup = not na(belowBarrier) and not na(belowH)
        if hasRes
            bool touchedRes = SMC.check_touch(aboveBarrier + aboveH, aboveBarrier, localCfg.detBasis, open, high, low, close)
            bool validSell = entry_direction_allowed("Sell", ctx.biasVal)
            int scoreSell = btScore + (chartCfg.useBias and validSell ? localCfg.scoreHtf : 0)
            string reasonSell = "Barrier Touch (resistance touch)"
            if touchedRes and validSell
                if btWhen == TRIGGER_WHEN_TOUCH and btType == TRIGGER_TYPE_TRADE
                    process_data_add_entry(shortName, "Sell", reasonSell, aboveBarrier + aboveH, aboveBarrier, na, scoreSell)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, shortName, "Sell", reasonSell, aboveBarrier + aboveH, aboveBarrier, float(na), scoreSell, bar_index, syminfo.mintick, 80)
        if hasSup
            bool touchedSup = SMC.check_touch(belowBarrier, belowBarrier - belowH, localCfg.detBasis, open, high, low, close)
            bool validBuy = entry_direction_allowed("Buy", ctx.biasVal)
            int scoreBuy = btScore + (chartCfg.useBias and validBuy ? localCfg.scoreHtf : 0)
            string reasonBuy = "Barrier Touch (support touch)"
            if touchedSup and validBuy
                if btWhen == TRIGGER_WHEN_TOUCH and btType == TRIGGER_TYPE_TRADE
                    process_data_add_entry(shortName, "Buy", reasonBuy, belowBarrier, belowBarrier - belowH, na, scoreBuy)
                else
                    SMC.add_signal(chartCtx.events, chartCtx.signalHist, shortName, "Buy", reasonBuy, belowBarrier, belowBarrier - belowH, float(na), scoreBuy, bar_index, syminfo.mintick, 80)
        bool(na)

process_data_trades() =>
    bool doResolve = true
    float rHi = high
    float rLo = low
    int rBar = bar_index
    if doResolve and array.size(trades) > 0
        for i = array.size(trades) - 1 to 0
            CORE.Trade e = array.get(trades, i)
            [eResolved, outcome] = CORE.resolve_trade_state(e, rHi, rLo, rBar, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
            e := eResolved
            if outcome == 2
                UI.delete_trade_visuals(e)
                array.remove(trades, i)
                continue
            if outcome == 1 or outcome == -1
                float exitPrice = outcome > 0 ? e.takeprofit : e.stoploss
                float denom = math.max(math.abs(e.entry - e.stoploss), syminfo.mintick)
                float realizedR = math.abs(exitPrice - e.entry) / denom
                float rrForStats = math.max(0.1, realizedR)
                e.rrValue := rrForStats
            string entryDisplayMode = (e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL) ? "RESULT_LINES" : "NORMAL"
            bool signalShowActive = e.state == CONST.SIGNAL_STATE_PENDING ? chartCfg.showPending : e.state == CONST.SIGNAL_STATE_START ? chartCfg.showStart : false
            e := UI.draw_trade_visual(e, CONST, THEME, ENTRY_VIS_CFG, true, signalShowActive, chartCfg.showTp, chartCfg.showSl, perfLookbackBars, 0, entryDisplayMode, "RESULT_LINES", 0)
            array.set(trades, i, e)
    bool(na)

process_data_events_queue(array<CORE.Event> events, CORE.ChartContext ctx, int breakRetestWindowBars) =>
    if events.size() > 0
        for i = events.size() - 1 to 0
            e = events.get(i)
            bool isBreakRetestEvent = not na(e.barBreak)
            bool isSignalEvent = not isBreakRetestEvent
            if isSignalEvent
                if e.type == "SWEEP"
                    continue
                string signalModelKey = get_model_key_for_type(e.type)
                [sigEnabled, _, _, sigTriggerType, sigTriggerWhen] = get_data_strategy_meta_by_key(signalModelKey)
                [_, _, _, _, _, _, _, _, _, _, _, sigEntryMode] = get_data_entry_model_dynamic_cfg(signalModelKey)
                if not sigEnabled
                    events.remove(i)
                    continue
                if sigTriggerType != TRIGGER_TYPE_TRADE
                    events.remove(i)
                    continue
                if e.direction == "Buy" and close > e.zoneTop
                    bool validBuy = entry_direction_allowed("Buy", ctx.biasVal)
                    if sigEntryMode == ENTRY_MODE_AFTER_RETEST and sigTriggerWhen == TRIGGER_WHEN_RETEST and validBuy
                        process_data_add_entry(e.type, "Buy", e.reason + " (close reclaimed zone top)", e.zoneTop, e.zoneBtm, e.quality, e.score + localCfg.scoreConfirm)
                    events.remove(i)
                    continue
                else if e.direction == "Sell" and close < e.zoneBtm
                    bool validSell = entry_direction_allowed("Sell", ctx.biasVal)
                    if sigEntryMode == ENTRY_MODE_AFTER_RETEST and sigTriggerWhen == TRIGGER_WHEN_RETEST and validSell
                        process_data_add_entry(e.type, "Sell", e.reason + " (close rejected below zone bottom)", e.zoneTop, e.zoneBtm, e.quality, e.score + localCfg.scoreConfirm)
                    events.remove(i)
                    continue
            else
                int age = bar_index - e.barBreak
                if age > breakRetestWindowBars
                    events.remove(i)
                    continue
                bool isBuy = e.direction == "Buy"
                string modelKey = get_model_key_for_type(e.type)
                [stratEnabled, stratScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
                [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = get_data_entry_model_dynamic_cfg(modelKey)
                bool allowedPdArray = is_pdarray_type_enabled(e.type)
                bool validType = stratEnabled and allowedPdArray
                bool validDirection = entry_direction_allowed(e.direction, ctx.biasVal)
                bool touched = SMC.check_touch(e.zoneTop, e.zoneBtm, localCfg.detBasis, open, high, low, close)
                if touched
                    e.retestSeen := true
                    events.set(i, e)
                bool confirmed = e.retestSeen and (isBuy ? (close > e.zoneTop) : (close < e.zoneBtm))
                bool invalidated = isBuy ? (close < e.zoneBtm) : (close > e.zoneTop)
                if invalidated
                    events.remove(i)
                    continue
                bool tradeCandidate = validType and validDirection and modelEntryMode != ENTRY_MODE_OFF and triggerWhen == TRIGGER_WHEN_RETEST and triggerType == TRIGGER_TYPE_TRADE
                if confirmed and tradeCandidate
                    int baseScore = stratScore + localCfg.scoreConfirm + (chartCfg.useBias and validDirection ? localCfg.scoreHtf : 0)
                    string reason = e.type + " Break-Retest confirmed"
                    process_data_add_entry(shortName, e.direction, reason, e.zoneTop, e.zoneBtm, e.quality, baseScore)
                    events.remove(i)
                    continue
                if confirmed
                    events.remove(i)
                    continue
    bool(na)

process_data_register_pdarray_retest_signal(array<CORE.Event> _triggersQueue, CORE.PDArray z, int biasVal, string reasonOverride, string setupOverride) =>
    string type = z.type
    string modelKey = get_model_key_for_type(type)
    [stratEnabled, stratScore, shortName, triggerType, triggerWhen] = get_data_strategy_meta_by_key(modelKey)
    [_, _, _, _, _, _, _, _, _, _, _, modelEntryMode] = get_data_entry_model_dynamic_cfg(modelKey)
    bool allowedPdArray = is_pdarray_type_enabled(type)
    bool enabledType = stratEnabled and allowedPdArray
    string direction = z.isBullish ? "Buy" : "Sell"
    bool validBias = entry_direction_allowed(direction, biasVal)
    int baseScore = stratScore
    int biasScore = chartCfg.useBias and validBias ? localCfg.scoreHtf : 0
    int totalScore = baseScore + biasScore
    string reason = reasonOverride == "" ? SMC.signal_reason_text(type, z.isBullish) : reasonOverride
    reason := reason + (chartCfg.useBias ? " (HTF Bias Confirmed)" : "")
    string setup = setupOverride == "" ? shortName : setupOverride
    if enabledType and validBias and modelEntryMode != ENTRY_MODE_OFF and not SMC.has_pending_trade_signal(_triggersQueue, setup, direction, z.top, z.bottom, syminfo.mintick)
        bool directEntry = triggerWhen == TRIGGER_WHEN_TOUCH and triggerType == TRIGGER_TYPE_TRADE and modelEntryMode == ENTRY_MODE_LIMIT
        if directEntry
            process_data_add_entry(setup, direction, reason, z.top, z.bottom, z.qualityPct, totalScore)
        else if triggerType == TRIGGER_TYPE_SIGNAL or triggerWhen == TRIGGER_WHEN_RETEST or modelEntryMode == ENTRY_MODE_AFTER_RETEST
            SMC.add_signal(_triggersQueue, chartCtx.signalHist, setup, direction, reason, z.top, z.bottom, z.qualityPct, totalScore, bar_index, syminfo.mintick, 80)
    bool(na)

var array<int> lsrBarState = array.new<int>(2, na) // 0: bear, 1: bull

process_data_lsr_model(CORE.ChartContext ctx) =>
    [lsrEnabled, lsrScore, shortName, _, _] = get_data_strategy_meta_by_key("SWEEP")
    if lsrEnabled
        int bearBar = array.get(lsrBarState, 0)
        int bullBar = array.get(lsrBarState, 1)
        int evSize = array.size(chartCtx.events)
        if evSize > 0
            for i = evSize - 1 to 0
                CORE.Event e = array.get(chartCtx.events, i)
                if e.type == "SWEEP"
                    if e.direction == "Sell"
                        bearBar := e.barDetected
                        array.set(lsrBarState, 0, bearBar)
                    else if e.direction == "Buy"
                        bullBar := e.barDetected
                        array.set(lsrBarState, 1, bullBar)
                    array.remove(chartCtx.events, i)
                    
        int chochBarsLimit = 50
        bool bearSweepValid = not na(bearBar) and (bar_index - bearBar) <= chochBarsLimit
        int lastLtfLegBar = get_data_cached_bar_index_from_time(ltfData.legEventTime)
        bool bearChoch = bearSweepValid and ltfData.msBias == -1 and lastLtfLegBar > bearBar
        if bearSweepValid and bearChoch // Seek Bearish extreme zone
            CORE.PDArray extremeOrigin = na
            float highestTop = -999999.0
            if array.size(chartCtx.zones) > 0
                for i = 0 to array.size(chartCtx.zones) - 1
                    CORE.PDArray z = array.get(chartCtx.zones, i)
                    bool isTrendZone = z.type == "OB" or z.type == "FVG" or z.type == "SD"
                    if isTrendZone and not z.isBullish
                        if z.barStart >= bearBar - 2 and z.barStart <= lastLtfLegBar + 2
                            if z.top > highestTop // highest structure near top
                                extremeOrigin := z
                                highestTop := z.top
            if not na(extremeOrigin)
                process_data_register_pdarray_retest_signal(chartCtx.events, extremeOrigin, ctx.biasVal, "LSR Swept: Bearish Origin RTO", shortName)
                array.set(lsrBarState, 0, na) // Flush memory
                
        bool bullSweepValid = not na(bullBar) and (bar_index - bullBar) <= chochBarsLimit
        bool bullChoch = bullSweepValid and ltfData.msBias == 1 and lastLtfLegBar > bullBar
        if bullSweepValid and bullChoch // Seek Bullish extreme zone
            CORE.PDArray extremeOrigin = na
            float lowestBtm = 999999.0
            if array.size(chartCtx.zones) > 0
                for i = 0 to array.size(chartCtx.zones) - 1
                    CORE.PDArray z = array.get(chartCtx.zones, i)
                    bool isTrendZone = z.type == "OB" or z.type == "FVG" or z.type == "SD"
                    if isTrendZone and z.isBullish
                        if z.barStart >= bullBar - 2 and z.barStart <= lastLtfLegBar + 2
                            if z.bottom < lowestBtm // deepest structure near dip
                                extremeOrigin := z
                                lowestBtm := z.bottom
            if not na(extremeOrigin)
                process_data_register_pdarray_retest_signal(chartCtx.events, extremeOrigin, ctx.biasVal, "LSR Swept: Bullish Origin RTO", shortName)
                array.set(lsrBarState, 1, na) // Flush memory

    bool(na)

update_pdarray_box_label(CORE.PDArray z, float boxHigh, float boxLow) =>
    if not na(z.visualLabel)
        float zoneH = math.max(boxHigh - boxLow, syminfo.mintick)
        float labelY = ((boxHigh + boxLow) * 0.5) - (zoneH * 0.12)
        int labelXRaw = box.get_right(z.visualBox) - math.max(1, 1)
        int minLabelX = math.max(bar_index - 4000, 0)
        int maxLabelX = bar_index + 500
        int labelX = math.min(math.max(labelXRaw, minLabelX), maxLabelX)
        if z.visualLabel.get_x() != labelX
            z.visualLabel.set_x(labelX)
        if z.visualLabel.get_y() != labelY
            z.visualLabel.set_y(labelY)
        string lblAlignSig = "SMC_LABEL_ALIGN|RIGHT"
        if z.visLabelStyleSig != lblAlignSig
            z.visualLabel.set_textalign(text.align_right)
            z.visLabelStyleSig := lblAlignSig
        if z.visualLabel.get_text() != z.labelText
            z.visualLabel.set_text(z.labelText)
    if not na(z.visualBox)
        string nextBorderStyle = SMC.get_pdarray_border_style(z.type, z.labelText, line.style_solid, CONST)
        string boxBorderSig = "SMC_BOX_BORDER|" + nextBorderStyle
        if z.visAreaStyleSig != boxBorderSig
            z.visualBox.set_border_style(nextBorderStyle)
            z.visAreaStyleSig := boxBorderSig
    z

mark_pdarray_mitigated_visual(CORE.PDArray z) =>
    bool isHtfZone = z.sourceTfRank >= 2
    color mitClr = isHtfZone ? (z.sourceTfRank >= 3 ? color.new(htf2Cfg.zigzagColor, 0) : color.new(htf1Cfg.zigzagColor, 0)) : THEME.COLOR_NEUTRAL
    z.visualBox.set_bgcolor(color.new(mitClr, 90))
    z.visualBox.set_border_color(z.type == "IFVG" ? na : color.new(mitClr, 85))
    z.labelText := get_data_mark_pdarray_label_mitigated(z.type, z.labelText)
    if not na(z.visualLabel)
        z.visualLabel.set_textcolor(color.new(mitClr, 40))
        if z.type == "OB"
            z.visualLabel.set_tooltip(CORE.tt_side(z.isBullish, "Mitigation Block"))
    z.lifeState := CONST.LIFE_TOUCHED
    z.touchCount := math.max(z.touchCount, 0) + 1
    z.barEnd := bar_index
    z.rejectCount := math.max(z.rejectCount, 0)
    z

process_data_zone_lifecycle(array<CORE.PDArray> zones, float _atr, int _biasVal, bool canEmitSignals) =>
    float o0 = open
    float h0 = high
    float l0 = low
    float c0 = close
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    if zones.size() > 0
        for i = zones.size() - 1 to 0
            z = zones.get(i)
            z := SMC.normalize_pricezone_state(z, CONST)
            if not na(z.barStart) and (bar_index - z.barStart > effectiveCurrLookbackBars)
                if not na(z.visualLabel)
                    z.visualLabel.delete()
                if not na(z.visualBox)
                    z.visualBox.delete()
                zones.remove(i)
                continue
            if not na(z.visualBox) and not z.broken
                _boxLow  = z.visualBox.get_bottom()
                _boxHigh = z.visualBox.get_top()
                z := update_pdarray_box_label(z, _boxHigh, _boxLow)
                if z.type == "SD"
                    int sdRight = get_cached_pdarray_min_right(z, bar_index + z.extendBars, uiCfg.zoneCurrMinWidthBars)
                    if box.get_right(z.visualBox) != sdRight
                        z.visualBox.set_right(sdRight)
                    bool sdTouched = SMC.check_touch(_boxHigh, _boxLow, localCfg.detBasis, o0, h0, l0, c0)
                    bool canEmitSd = na(z.barEnd) or z.barEnd != bar_index
                    if canEmitSignals and sdTouched and canEmitSd
                        process_data_register_pdarray_retest_signal(chartCtx.events, z, _biasVal, "", "")
                        z.barEnd := bar_index
                    zones.set(i, z)
                    continue
                bool isBull = z.isBullish
                bool postTouch = SMC.is_pdarray_post_touch(z)
                if not postTouch
                    bool derivedNeedsDelay = z.type == "BB" or z.type == "IFVG"
                    bool canCheckMitigation = not derivedNeedsDelay or bar_index > z.barStart
                    entered = canCheckMitigation and SMC.check_mitigation(z.type, z.isBullish, _boxHigh, _boxLow, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, _atr, localCfg.detImpulseAtr, o0, h0, l0, c0, o1, h1, l1, c1)

                    if not entered
                        ext = z.extendBars
                        int nextRight = get_cached_pdarray_min_right(z, bar_index + ext, uiCfg.zoneCurrMinWidthBars)
                        if box.get_right(z.visualBox) != nextRight
                            z.visualBox.set_right(nextRight)
                        zones.set(i, z)
                    else
                        if canEmitSignals
                            process_data_register_pdarray_retest_signal(chartCtx.events, z, _biasVal, "", "")
                        z := mark_pdarray_mitigated_visual(z)
                        zones.set(i, z)
                else
                    breakLevel = isBull ? _boxLow : _boxHigh
                    respected = SMC.check_pdarray_respect(isBull, _boxHigh, _boxLow, h0, l0, c0)
                    [stratEnabled, _, _, _, _] = get_data_strategy_meta_by_key(str.upper(z.type))
                    canEmitRespect = na(z.barEnd) and stratEnabled
                    if respected
                        z.barEnd := bar_index
                        z.lifeState := CONST.LIFE_RESPECTED
                        z.rejectCount := math.max(z.rejectCount, 0) + 1
                        int latestTouchRight = get_cached_pdarray_min_right(z, z.barEnd + 10, uiCfg.zoneCurrMinWidthBars)
                        if box.get_right(z.visualBox) != latestTouchRight
                            z.visualBox.set_right(latestTouchRight)
                    if canEmitSignals and respected and canEmitRespect
                        process_data_register_pdarray_retest_signal(chartCtx.events, z, _biasVal, z.type + " touch respected", z.type + " R")
                        z.barEnd := bar_index
                        if not na(z.visualLabel)
                            z.visualLabel.set_tooltip(CORE.tt_side(isBull, z.type + " touch respected"))
                    isBroken = SMC.check_break(not isBull, breakLevel, localCfg.detMethod, localCfg.detMethodCross, localCfg.detBasis, localCfg.detUseImpulse, _atr, localCfg.detImpulseAtr, o0, h0, l0, c0, o1, h1, l1, c1)
                    if isBroken
                        string breakDirection = z.isBullish ? "Sell" : "Buy"
                        if canEmitSignals
                            SMC.register_break_retest_event(chartCtx.events, z.type, breakDirection, z.top, z.bottom, bar_index, z.qualityPct, syminfo.mintick)
                        if z.type == "FVG" and plotFVG
                            spawn_derived_zone(zones, "IFVG", not z.isBullish, _boxHigh, _boxLow, z.qualityPct)
                        if z.type == "OB" and plotOB
                            spawn_derived_zone(zones, "BB", not z.isBullish, _boxHigh, _boxLow, z.qualityPct)
                        z.broken := true
                        z.lifeState := CONST.LIFE_BROKEN
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                        z.visualBox.delete()
                        zones.remove(i)
                        continue
                    else
                        zones.set(i, z)
                if SMC.is_pdarray_post_touch(z) and CORE.is_life_formed(z.lifeState, CONST)
                    z.lifeState := CONST.LIFE_TOUCHED
                    zones.set(i, z)
    bool(na)

get_data_latest_swing_high() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = CORE.market_structure_latest_hilo(ltfData.ms)
    latestHigh

get_data_latest_swing_low() =>
    [latestHigh, latestHighT, latestLow, latestLowT] = CORE.market_structure_latest_hilo(ltfData.ms)
    latestLow

get_data_zone_rank_score(CORE.PDArray z, int side, float lastSwingHigh, float lastSwingLow) =>
    float zoneMid = (z.top + z.bottom) * 0.5
    float tick = math.max(syminfo.mintick, 1e-10)
    float distPrice = math.abs(zoneMid - close) / tick
    float distSwing = 0.0
    if side == 0 and not na(lastSwingHigh)
        distSwing := math.abs(zoneMid - lastSwingHigh) / tick
    if side == 1 and not na(lastSwingLow)
        distSwing := math.abs(zoneMid - lastSwingLow) / tick
    int seqAll = z.legSeqAll
    float legPenalty = seqAll > 0 ? float(seqAll) : 0.0
    -(distPrice + distSwing + legPenalty)

get_data_pick_best_zone_idx(array<CORE.PDArray> zones, array<bool> keep, int side, int classMode, float lastSwingHigh, float lastSwingLow) =>
    int n = array.size(zones)
    int bestIdx = na
    float bestScore = na
    int i = 0
    while i < n
        bool already = array.get(keep, i)
        if not already
            CORE.PDArray z = array.get(zones, i)
            bool active = not z.broken and not na(z.visualBox)
            float zoneMid = (z.top + z.bottom) * 0.5
            bool sideOk = side == 0 ? (zoneMid >= close) : (zoneMid <= close)
            int tfRank = math.max(z.sourceTfRank, 0)
            bool classOk = classMode == 0 ? true : (classMode == 1 ? tfRank <= 1 : tfRank >= 2)
            if active and sideOk and classOk
                float s = get_data_zone_rank_score(z, side, lastSwingHigh, lastSwingLow)
                if na(bestIdx) or s > bestScore
                    bestIdx := i
                    bestScore := s
        i += 1
    bestIdx

get_data_display_ltf_keep_per_side() =>
    pdDisplayMode == "Extreme" ? 1 : pdDisplayMode == "Normal" ? 2 : pdDisplayMode == "Less" ? 4 : -1

process_data_prune_zones_by_relevance(array<CORE.PDArray> zones) =>
    int n = array.size(zones)
    int targetPerSide = get_data_display_ltf_keep_per_side()
    if targetPerSide < 0 or n <= 4
        bool(na)
    else
        float lastSwingHigh = get_data_latest_swing_high()
        float lastSwingLow = get_data_latest_swing_low()
        array<bool> keep = array.new_bool(n, false)
        int side = 0
        while side < 2
            int picked = 0
            if targetPerSide >= 1
                int bestIdxHtf = get_data_pick_best_zone_idx(zones, keep, side, 2, lastSwingHigh, lastSwingLow)
                if not na(bestIdxHtf)
                    array.set(keep, bestIdxHtf, true)
                    picked += 1
            if targetPerSide >= 2
                int bestIdxLtf = get_data_pick_best_zone_idx(zones, keep, side, 1, lastSwingHigh, lastSwingLow)
                if not na(bestIdxLtf)
                    array.set(keep, bestIdxLtf, true)
                    picked += 1
            while picked < targetPerSide
                int bestIdx = get_data_pick_best_zone_idx(zones, keep, side, 0, lastSwingHigh, lastSwingLow)
                if na(bestIdx)
                    break
                array.set(keep, bestIdx, true)
                picked += 1
            side += 1
        int j = n - 1
        while j >= 0
            CORE.PDArray z = array.get(zones, j)
            bool active = not z.broken and not na(z.visualBox)
            bool selected = array.get(keep, j)
            if active and not selected
                UI.delete_pd_array_drawings(z)
                array.remove(zones, j)
            j -= 1
        bool(na)

process_data_entries(int breakRetestWindowBars, bool canEmitSignals, bool entryEngineOn) =>
    CORE.ChartContext ctx = chartCtx
    process_data_zone_lifecycle(chartCtx.zones, commonAtr, ctx.biasVal, canEmitSignals)
    if canEmitSignals
        process_data_barrier_touch_setup(ctx)
        process_data_events_queue(chartCtx.events, ctx, breakRetestWindowBars)
        process_data_lsr_model(ctx)
    if entryEngineOn
        process_data_trades()
    bool(na)

draw_data_bias_row_under_trades_local(table t, int rowIdx, CORE.ChartContext ctx, string sourceName) =>
    int currSec = CORE.get_tf_seconds(timeframe.period)
    bool show15 = CORE.get_tf_seconds("15") > currSec
    bool show240 = CORE.get_tf_seconds("240") > currSec
    bool show1d = CORE.get_tf_seconds("1D") > currSec
    bool show1w = CORE.get_tf_seconds("1W") > currSec
    string tf0Raw = timeframe.period
    int trend0 = tf0Raw == "15" ? ctx.dir15 : tf0Raw == "240" ? ctx.dir240 : (tf0Raw == "1D" or tf0Raw == "D") ? ctx.dir1d : (tf0Raw == "1W" or tf0Raw == "W") ? ctx.dir1w : ctx.dir0
    int shortBias0 = tf0Raw == "15" ? ctx.b15 : tf0Raw == "240" ? ctx.b240 : (tf0Raw == "1D" or tf0Raw == "D") ? ctx.b1d : (tf0Raw == "1W" or tf0Raw == "W") ? ctx.b1w : ctx.b0
    int shortBias15 = ctx.b15
    int shortBias240 = ctx.b240
    int shortBias1d = ctx.b1d
    int shortBias1w = ctx.b1w
    color txt0 = shortBias0 == 1 ? THEME.COLOR_BULLISH : shortBias0 == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt15 = shortBias15 == 1 ? THEME.COLOR_BULLISH : shortBias15 == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt240 = shortBias240 == 1 ? THEME.COLOR_BULLISH : shortBias240 == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt1d = shortBias1d == 1 ? THEME.COLOR_BULLISH : shortBias1d == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    color txt1w = shortBias1w == 1 ? THEME.COLOR_BULLISH : shortBias1w == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_UI_FG
    string st0 = trend0 == 0 or shortBias0 == 0 ? "Neutral" : trend0 == shortBias0 ? "Continuation" : "Pullback"
    string st15 = ctx.dir15 == 0 or shortBias15 == 0 ? "Neutral" : ctx.dir15 == shortBias15 ? "Continuation" : "Pullback"
    string st240 = ctx.dir240 == 0 or shortBias240 == 0 ? "Neutral" : ctx.dir240 == shortBias240 ? "Continuation" : "Pullback"
    string st1d = ctx.dir1d == 0 or shortBias1d == 0 ? "Neutral" : ctx.dir1d == shortBias1d ? "Continuation" : "Pullback"
    string st1w = ctx.dir1w == 0 or shortBias1w == 0 ? "Neutral" : ctx.dir1w == shortBias1w ? "Continuation" : "Pullback"
    table.cell(t, 0, rowIdx, sourceName, bgcolor = color.new(THEME.COLOR_UI_BG, 55), text_color = color.white, text_size = size.tiny)
    int col = 1
    string tf0 = CORE.get_friendly_tf(timeframe.period)
    string tx0 = (str.length(tf0) > 2 ? str.substring(tf0, 0, 2) : tf0) + " " + UI.get_bias_symbol(shortBias0, CONST)
    table.cell(t, col, rowIdx, tx0, bgcolor = UI.get_bias_bg_from_trend(trend0, THEME), text_color = txt0, text_size = size.tiny, tooltip = "Trend: " + str.tostring(trend0) + " | BG:MSS Trend | Arrow:SMC TF Bias: " + str.tostring(shortBias0) + " | State: " + st0)
    col += 1
    if show15 and col <= 4
        string tf15 = CORE.get_friendly_tf("15")
        string tx15 = (str.length(tf15) > 2 ? str.substring(tf15, 0, 2) : tf15) + " " + UI.get_bias_symbol(shortBias15, CONST)
        table.cell(t, col, rowIdx, tx15, bgcolor = UI.get_bias_bg_from_trend(ctx.dir15, THEME), text_color = txt15, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir15) + " | BG:MSS Trend | Arrow:SMC TF Bias: " + str.tostring(shortBias15) + " | State: " + st15)
        col += 1
    if show240 and col <= 4
        string tf240 = CORE.get_friendly_tf("240")
        string tx240 = (str.length(tf240) > 2 ? str.substring(tf240, 0, 2) : tf240) + " " + UI.get_bias_symbol(shortBias240, CONST)
        table.cell(t, col, rowIdx, tx240, bgcolor = UI.get_bias_bg_from_trend(ctx.dir240, THEME), text_color = txt240, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir240) + " | BG:MSS Trend | Arrow:SMC TF Bias: " + str.tostring(shortBias240) + " | State: " + st240)
        col += 1
    if show1d and col <= 4
        string tf1d = CORE.get_friendly_tf("1D")
        string tx1d = (str.length(tf1d) > 2 ? str.substring(tf1d, 0, 2) : tf1d) + " " + UI.get_bias_symbol(shortBias1d, CONST)
        table.cell(t, col, rowIdx, tx1d, bgcolor = UI.get_bias_bg_from_trend(ctx.dir1d, THEME), text_color = txt1d, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir1d) + " | BG:MSS Trend | Arrow:SMC TF Bias: " + str.tostring(shortBias1d) + " | State: " + st1d)
        col += 1
    if show1w and col <= 4
        string tf1w = CORE.get_friendly_tf("1W")
        string tx1w = (str.length(tf1w) > 2 ? str.substring(tf1w, 0, 2) : tf1w) + " " + UI.get_bias_symbol(shortBias1w, CONST)
        table.cell(t, col, rowIdx, tx1w, bgcolor = UI.get_bias_bg_from_trend(ctx.dir1w, THEME), text_color = txt1w, text_size = size.tiny, tooltip = "Trend: " + str.tostring(ctx.dir1w) + " | BG:MSS Trend | Arrow:SMC TF Bias: " + str.tostring(shortBias1w) + " | State: " + st1w)
        col += 1
    if col <= 4
        for i = col to 4
            table.cell(t, i, rowIdx, "", bgcolor = color.new(THEME.COLOR_TRANSPARENT, 100), text_color = color.new(THEME.COLOR_UI_FG, 100), text_size = size.tiny)
    bool(na)

draw_data_trades_dashboard() =>
    var array<CORE.Trade> dashboardTrades = array.new<CORE.Trade>()
    UI.collect_dashboard_trades(trades, dashboardTrades, chartCfg.showPending, chartCfg.showStart, chartCfg.showTp, chartCfg.showSl, perfLookbackBars, CONST)
    int dashCount = array.size(dashboardTrades)
    int maxTypes = math.max(1, dashCount)
    if dashCount > 0
        UI.render_entries_dashboard_from_entries(true, signalStatsTableTopRight, dashboardTrades, maxTypes, THEME, CONST, SIG_METRIC_COUNT)
    else
        table.clear(signalStatsTableTopRight, 0, 0, 4, 23)
    draw_data_bias_row_under_trades_local(signalStatsTableTopRight, 0, chartCtx, "SMC")
    bool(na)

draw_data_htf_pdarray_set(array<box> store, int tfSlot, bool showTf, string tfLabel, string tfStr,
 float top0, float btm0, int start0, float q0, bool bull0, string type0,
 float top1, float btm1, int start1, float q1, bool bull1, string type1,
 float top2, float btm2, int start2, float q2, bool bull2, string type2,
 float top3, float btm3, int start3, float q3, bool bull3, string type3) =>
    float adOb = na
    int aiOb = na
    float adFvg = na
    int aiFvg = na
    float bdOb = na
    int biOb = na
    float bdFvg = na
    int biFvg = na
    float adObFb = na
    int aiObFb = na
    float adFvgFb = na
    int aiFvgFb = na
    float bdObFb = na
    int biObFb = na
    float bdFvgFb = na
    int biFvgFb = na
    [tf1Local, tf2Local] = CORE.get_htf_pair()
    string tfNameForSet = tfSlot == 0 ? tf1Local : tf2Local
    int recentTsCut = get_data_htf_detection_cutoff_time(tfSlot, tfNameForSet)

    for i = 0 to 3
        float top = i == 0 ? top0 : i == 1 ? top1 : i == 2 ? top2 : top3
        float btm = i == 0 ? btm0 : i == 1 ? btm1 : i == 2 ? btm2 : btm3
        int st = i == 0 ? start0 : i == 1 ? start1 : i == 2 ? start2 : start3
        float q = i == 0 ? q0 : i == 1 ? q1 : i == 2 ? q2 : q3
        string zType = i == 0 ? type0 : i == 1 ? type1 : i == 2 ? type2 : type3
        bool showType = zType == "OB" ? plotOB : plotFVG
        bool isBull = i == 0 ? bull0 : i == 1 ? bull1 : i == 2 ? bull2 : bull3
        bool baseValid = showTf and showType and not na(st) and not na(top) and not na(btm) and top > btm
        if baseValid
            float midFb = (top + btm) * 0.5
            float distFb = math.abs(midFb - close)
            bool isAboveFb = midFb > close
            string famFb = SMC.get_pdarray_cap_family(zType)
            if isAboveFb
                if famFb == "OB_FAMILY"
                    if na(adObFb) or distFb < adObFb
                        adObFb := distFb
                        aiObFb := i
                else if famFb == "FVG_FAMILY"
                    if na(adFvgFb) or distFb < adFvgFb
                        adFvgFb := distFb
                        aiFvgFb := i
            else
                if famFb == "OB_FAMILY"
                    if na(bdObFb) or distFb < bdObFb
                        bdObFb := distFb
                        biObFb := i
                else if famFb == "FVG_FAMILY"
                    if na(bdFvgFb) or distFb < bdFvgFb
                        bdFvgFb := distFb
                        biFvgFb := i
        bool unmitigated = isBull ? (low > top) : (high < btm)
        bool recent = not na(st) and st >= recentTsCut
        bool valid = showTf and showType and recent and not na(st) and not na(top) and not na(btm) and top > btm and nz(q, 0) >= localCfg.htfProjectionMinQualityPct and unmitigated
        if valid
            float mid = (top + btm) * 0.5
            float dist = math.abs(mid - close)
            bool isAbove = mid > close
            string fam = SMC.get_pdarray_cap_family(zType)
            if isAbove
                if fam == "OB_FAMILY"
                    if na(adOb) or dist < adOb
                        adOb := dist
                        aiOb := i
                else if fam == "FVG_FAMILY"
                    if na(adFvg) or dist < adFvg
                        adFvg := dist
                        aiFvg := i
            else
                if fam == "OB_FAMILY"
                    if na(bdOb) or dist < bdOb
                        bdOb := dist
                        biOb := i
                else if fam == "FVG_FAMILY"
                    if na(bdFvg) or dist < bdFvg
                        bdFvg := dist
                        biFvg := i

    bool obFirst = true // HTF_FAMILY_PRIORITY_OB >= HTF_FAMILY_PRIORITY_FVG
    int aOb = not na(aiOb) ? aiOb : aiObFb
    int aFvg = not na(aiFvg) ? aiFvg : aiFvgFb
    int bOb = not na(biOb) ? biOb : biObFb
    int bFvg = not na(biFvg) ? biFvg : biFvgFb
    int aboveFirst = obFirst ? (not na(aOb) ? aOb : aFvg) : (not na(aFvg) ? aFvg : aOb)
    int aboveSecond = obFirst ? (not na(aOb) and not na(aFvg) ? aFvg : na) : (not na(aFvg) and not na(aOb) ? aOb : na)
    int belowFirst = obFirst ? (not na(bOb) ? bOb : bFvg) : (not na(bFvg) ? bFvg : bOb)
    int belowSecond = obFirst ? (not na(bOb) and not na(bFvg) ? bFvg : na) : (not na(bFvg) and not na(bOb) ? bOb : na)

    float dAbove = na
    if not na(aboveFirst)
        float topA = aboveFirst == 0 ? top0 : aboveFirst == 1 ? top1 : aboveFirst == 2 ? top2 : top3
        float btmA = aboveFirst == 0 ? btm0 : aboveFirst == 1 ? btm1 : aboveFirst == 2 ? btm2 : btm3
        dAbove := math.abs(((topA + btmA) * 0.5) - close)
    float dBelow = na
    if not na(belowFirst)
        float topB = belowFirst == 0 ? top0 : belowFirst == 1 ? top1 : belowFirst == 2 ? top2 : top3
        float btmB = belowFirst == 0 ? btm0 : belowFirst == 1 ? btm1 : belowFirst == 2 ? btm2 : btm3
        dBelow := math.abs(((topB + btmB) * 0.5) - close)

    int p0 = na
    int p1 = na
    if not na(aboveFirst) and not na(belowFirst)
        bool aboveNearest = dAbove <= dBelow
        p0 := aboveNearest ? aboveFirst : belowFirst
        p1 := aboveNearest ? belowFirst : aboveFirst
    else
        p0 := not na(aboveFirst) ? aboveFirst : belowFirst
        p1 := na
    int p2 = not na(p1) and p1 == aboveFirst ? belowSecond : p1 == belowFirst ? aboveSecond : aboveSecond
    int p3 = not na(p2) and p2 == aboveSecond ? belowSecond : belowSecond

    int outMax = math.max(1, HTF_pdarray_PER_TF)
    for outPos = 0 to outMax - 1
        int cand = na
        if outPos == 0
            cand := p0
        else if outPos == 1
            cand := p1
        else if outPos == 2
            cand := p2
        else if outPos == 3
            cand := p3
        int boxIdx = tfSlot * HTF_pdarray_PER_TF + outPos
        if not na(cand)
            float top = cand == 0 ? top0 : cand == 1 ? top1 : cand == 2 ? top2 : top3
            float btm = cand == 0 ? btm0 : cand == 1 ? btm1 : cand == 2 ? btm2 : btm3
            int st = cand == 0 ? start0 : cand == 1 ? start1 : cand == 2 ? start2 : start3
            float q = cand == 0 ? q0 : cand == 1 ? q1 : cand == 2 ? q2 : q3
            bool isBull = cand == 0 ? bull0 : cand == 1 ? bull1 : cand == 2 ? bull2 : bull3
            string zType = cand == 0 ? type0 : cand == 1 ? type1 : cand == 2 ? type2 : type3
            int ext = SMC.get_htf_pdarray_extend(tfSlot, 14, 25)
            color txtCol = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 0) : color.new(htf2Cfg.zigzagColor, 0)
            string txt = str.upper(zType)
            color htfFill = color.new(THEME.COLOR_NEUTRAL, uiCfg.htfZoneBgTransp)
            color tfBorder = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 85) : color.new(htf2Cfg.zigzagColor, 85)
            UI.update_projected_box_slot(store, boxIdx, showTf, st, ext, top, btm, htfFill, txtCol, txt, bar_index, time, time[1], htfProjectionSpanBars, is_in_working_zone_current(), tfBorder, line.style_dotted, HTF_BOX_VIS_CFG)
        else
            UI.update_projected_box_slot(store, boxIdx, false, int(na), 0, float(na), float(na), color.new(THEME.COLOR_NEUTRAL, uiCfg.htfZoneBgTransp), THEME.COLOR_NEUTRAL, "", bar_index, time, time[1], htfProjectionSpanBars, is_in_working_zone_current(), color.new(THEME.COLOR_NEUTRAL, 15), line.style_dotted, HTF_BOX_VIS_CFG)


get_data_htf_pdarray_snapshots(string htf1, string htf2, bool zshow0, bool reqHtf2Zones, SMC.ZoneQualityCfg zqCfg) =>
    int srPivotLen = int(math.max(PIVOT_LEN_BASE + 2, 3))
    [h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1ObUpQ, h1ObDnQ, h1FvgUpQ, h1FvgDnQ, h1SrHiDummy, h1SrHiTDummy, h1SrLoDummy, h1SrLoTDummy] = if zshow0
        request.security(syminfo.tickerid, htf1, SMC.get_htf_pdarray_sr_snapshot(localCfg.zoneFormationLockBars, zqCfg, 14, srPivotLen))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), float(na), float(na), float(na), int(na), float(na), int(na)]
    [h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2ObUpQ, h2ObDnQ, h2FvgUpQ, h2FvgDnQ, h2SrHi, h2SrHiT, h2SrLo, h2SrLoT] = if reqHtf2Zones
        request.security(syminfo.tickerid, htf2, SMC.get_htf_pdarray_sr_snapshot(localCfg.zoneFormationLockBars, zqCfg, 14, srPivotLen))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), float(na), float(na), float(na), int(na), float(na), int(na)]
    [h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1ObUpQ, h1ObDnQ, h1FvgUpQ, h1FvgDnQ, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2ObUpQ, h2ObDnQ, h2FvgUpQ, h2FvgDnQ, h2SrHi, h2SrHiT, h2SrLo, h2SrLoT]

[htf1, htf2] = CORE.get_htf_pair()

zshow0 = uiCfg.htfShowProjectedZones and not na(htf1)
zshow1 = uiCfg.htfShowProjectedZones and not na(htf2)
zdraw0 = zshow0
zdraw1 = zshow1
bool needHtf2Anchors = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf2)

var float h1ObUpTop = na
var float h1ObUpBtm = na
var int h1ObUpStart = na
var float h1ObDnTop = na
var float h1ObDnBtm = na
var int h1ObDnStart = na
var float h1FvgUpTop = na
var float h1FvgUpBtm = na
var int h1FvgUpStart = na
var float h1FvgDnTop = na
var float h1FvgDnBtm = na
var int h1FvgDnStart = na
var float h1ObUpQ = na
var float h1ObDnQ = na
var float h1FvgUpQ = na
var float h1FvgDnQ = na
var float h1SdSupTop = na
var float h1SdSupBtm = na
var int h1SdSupStart = na
var float h1SdDemTop = na
var float h1SdDemBtm = na
var int h1SdDemStart = na
var float h2ObUpTop = na
var float h2ObUpBtm = na
var int h2ObUpStart = na
var float h2ObDnTop = na
var float h2ObDnBtm = na
var int h2ObDnStart = na
var float h2FvgUpTop = na
var float h2FvgUpBtm = na
var int h2FvgUpStart = na
var float h2FvgDnTop = na
var float h2FvgDnBtm = na
var int h2FvgDnStart = na
var float h2ObUpQ = na
var float h2ObDnQ = na
var float h2FvgUpQ = na
var float h2FvgDnQ = na
var float h2SdSupTop = na
var float h2SdSupBtm = na
var int h2SdSupStart = na
var float h2SdDemTop = na
var float h2SdDemBtm = na
var int h2SdDemStart = na

bool reqHtf2Zones = zshow1 or needHtf2Anchors
var bool prevZshow0 = false
var bool prevReqHtf2Zones = false
bool htf1BarChanged = zshow0 and not na(htf1) and ta.change(time(htf1)) != 0
bool htf2BarChanged = reqHtf2Zones and not na(htf2) and ta.change(time(htf2)) != 0
bool htfCfgChanged = barstate.isfirst or zshow0 != prevZshow0 or reqHtf2Zones != prevReqHtf2Zones
bool needRefreshHtfSnapshots = htfCfgChanged or htf1BarChanged or htf2BarChanged
if needRefreshHtfSnapshots
    [_h1ObUpTop, _h1ObUpBtm, _h1ObUpStart, _h1ObDnTop, _h1ObDnBtm, _h1ObDnStart, _h1FvgUpTop, _h1FvgUpBtm, _h1FvgUpStart, _h1FvgDnTop, _h1FvgDnBtm, _h1FvgDnStart, _h1ObUpQ, _h1ObDnQ, _h1FvgUpQ, _h1FvgDnQ, _h2ObUpTop, _h2ObUpBtm, _h2ObUpStart, _h2ObDnTop, _h2ObDnBtm, _h2ObDnStart, _h2FvgUpTop, _h2FvgUpBtm, _h2FvgUpStart, _h2FvgDnTop, _h2FvgDnBtm, _h2FvgDnStart, _h2ObUpQ, _h2ObDnQ, _h2FvgUpQ, _h2FvgDnQ, _, _, _, _] = get_data_htf_pdarray_snapshots(htf1, htf2, zshow0, reqHtf2Zones, zqCfg)
    h1ObUpTop := _h1ObUpTop
    h1ObUpBtm := _h1ObUpBtm
    h1ObUpStart := _h1ObUpStart
    h1ObDnTop := _h1ObDnTop
    h1ObDnBtm := _h1ObDnBtm
    h1ObDnStart := _h1ObDnStart
    h1FvgUpTop := _h1FvgUpTop
    h1FvgUpBtm := _h1FvgUpBtm
    h1FvgUpStart := _h1FvgUpStart
    h1FvgDnTop := _h1FvgDnTop
    h1FvgDnBtm := _h1FvgDnBtm
    h1FvgDnStart := _h1FvgDnStart
    h1ObUpQ := _h1ObUpQ
    h1ObDnQ := _h1ObDnQ
    h1FvgUpQ := _h1FvgUpQ
    h1FvgDnQ := _h1FvgDnQ
    h2ObUpTop := _h2ObUpTop
    h2ObUpBtm := _h2ObUpBtm
    h2ObUpStart := _h2ObUpStart
    h2ObDnTop := _h2ObDnTop
    h2ObDnBtm := _h2ObDnBtm
    h2ObDnStart := _h2ObDnStart
    h2FvgUpTop := _h2FvgUpTop
    h2FvgUpBtm := _h2FvgUpBtm
    h2FvgUpStart := _h2FvgUpStart
    h2FvgDnTop := _h2FvgDnTop
    h2FvgDnBtm := _h2FvgDnBtm
    h2FvgDnStart := _h2FvgDnStart
    h2ObUpQ := _h2ObUpQ
    h2ObDnQ := _h2ObDnQ
    h2FvgUpQ := _h2FvgUpQ
    h2FvgDnQ := _h2FvgDnQ
prevZshow0 := zshow0
prevReqHtf2Zones := reqHtf2Zones
int htfSdLookback = math.max(20, math.min(localCfg.htfZoneLookbackBars, 300))
var bool prevZshow0Sd = false
var bool prevZshow1 = false
var bool prevPlotSd = false
bool sdCfgChanged = barstate.isfirst or zshow0 != prevZshow0Sd or zshow1 != prevZshow1 or plotSD != prevPlotSd
bool refreshHtf1Sd = sdCfgChanged or (zshow0 and plotSD and not na(htf1) and ta.change(time(htf1)) != 0)
bool refreshHtf2Sd = sdCfgChanged or (zshow1 and plotSD and not na(htf2) and ta.change(time(htf2)) != 0)
if refreshHtf1Sd
    [h1SdSupTopRaw, h1SdSupBtmRaw, h1SdSupStartRaw, h1SdDemTopRaw, h1SdDemBtmRaw, h1SdDemStartRaw] = if zshow0 and plotSD
        request.security(syminfo.tickerid, htf1, get_data_htf_sd_snapshot(10.0, 50, htfSdLookback))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na)]
    h1SdSupTop := h1SdSupTopRaw
    h1SdSupBtm := h1SdSupBtmRaw
    h1SdSupStart := h1SdSupStartRaw
    h1SdDemTop := h1SdDemTopRaw
    h1SdDemBtm := h1SdDemBtmRaw
    h1SdDemStart := h1SdDemStartRaw
if refreshHtf2Sd
    [h2SdSupTopRaw, h2SdSupBtmRaw, h2SdSupStartRaw, h2SdDemTopRaw, h2SdDemBtmRaw, h2SdDemStartRaw] = if zshow1 and plotSD
        request.security(syminfo.tickerid, htf2, get_data_htf_sd_snapshot(10.0, 50, htfSdLookback))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na)]
    h2SdSupTop := h2SdSupTopRaw
    h2SdSupBtm := h2SdSupBtmRaw
    h2SdSupStart := h2SdSupStartRaw
    h2SdDemTop := h2SdDemTopRaw
    h2SdDemBtm := h2SdDemBtmRaw
    h2SdDemStart := h2SdDemStartRaw
prevZshow1 := zshow1
prevPlotSd := plotSD
prevZshow0Sd := zshow0

int htf2ObAnchorTs = CORE.get_latest_time4(h2ObUpStart, h2ObDnStart, h2FvgUpStart, h2FvgDnStart)
int htf2SrAnchorTs = na
runtimeCtx := CORE.update_runtime_context(runtimeCtx)
bool canEmitSignals = barstate.isconfirmed and runtimeCtx.tradeScanEnabled and entryEngineEnabled
bool calcOnClosedBar = barstate.ishistory or barstate.isconfirmed


if calcOnClosedBar
    int currPivotLen = PIVOT_LEN_BASE
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    [sh1Real, sh1RealT, sl1Real, sl1RealT] = get_data_real_htf_swings(htf1, currPivotLen)
    [sh2Real, sh2RealT, sl2Real, sl2RealT] = get_data_real_htf_swings(htf2, currPivotLen)
    CORE.process_tf_armed_state(ltfData, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, SETTINGS.SWING_HISTORY_MAX)
    CORE.process_tf_armed_state(htf1Data, not na(htf1), sh1Real, int(sh1RealT), sl1Real, int(sl1RealT), SETTINGS.SWING_HISTORY_MAX)
    CORE.process_tf_armed_state(htf2Data, not na(htf2), sh2Real, int(sh2RealT), sl2Real, int(sl2RealT), SETTINGS.SWING_HISTORY_MAX)
    if na(htf1)
        CORE.market_structure_reset(htf1Data.ms)
    if na(htf2)
        CORE.market_structure_reset(htf2Data.ms)
    process_data_tf_ms_trend_light(ltfData, true, ltfData.ms)
    process_data_tf_ms_trend_light(htf1Data, not na(htf1), htf1Data.ms)
    process_data_tf_ms_trend_light(htf2Data, not na(htf2), htf2Data.ms)
[h2LastHi, h2LastHiT, h2LastLo, h2LastLoT] = CORE.market_structure_latest_hilo(htf2Data.ms)
int htf2SwingAnchorTs = CORE.get_latest_time4(h2LastHiT, h2LastLoT, int(na), int(na))
int htf2AnchorTsFinal = CORE.get_dynamic_anchor_ts("OB_FIRST", "SR_FIRST", "SWING_FIRST", htf2ObAnchorTs, htf2SrAnchorTs, htf2SwingAnchorTs)
bool recalcByHtf2 = not na(htf2) and ta.change(time(htf2)) != 0
bool shouldDynRecalc = SETTINGS.DYN_LOOKBACK_ENABLE and calcOnClosedBar and (barstate.isfirst or recalcByHtf2) // Controls how often dynamic lookback/candle widths update.
if shouldDynRecalc
    int dynHtf1Candles = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf1) ? CORE.get_candles_to_anchor(htf1, htf2AnchorTsFinal, SETTINGS.DYN_HTF1_CANDLES_MIN, SETTINGS.DYN_HTF1_CANDLES_MAX, SETTINGS.HTF_CANDLES_BASE) : SETTINGS.HTF_CANDLES_BASE
    int htf1SecForDyn = not na(htf1) ? math.max(CORE.get_tf_seconds(htf1), 1) : na
    int htf2SecForDyn = not na(htf2) ? math.max(CORE.get_tf_seconds(htf2), 1) : na
    float htf2PerHtf1Dyn = not na(htf1SecForDyn) and not na(htf2SecForDyn) and htf2SecForDyn > htf1SecForDyn ? float(htf2SecForDyn) / float(htf1SecForDyn) : na
    int dynHtf2Candles = not na(htf2PerHtf1Dyn) ? int(math.round(float(dynHtf1Candles) / htf2PerHtf1Dyn)) : SETTINGS.DYN_HTF2_CANDLES_FALLBACK
    dynHtf2Candles := math.max(SETTINGS.DYN_HTF2_CANDLES_MIN, math.min(dynHtf2Candles, SETTINGS.DYN_HTF2_CANDLES_MAX))
    int dynHtf1FromHtf2 = not na(htf2PerHtf1Dyn) ? int(math.ceil(float(dynHtf2Candles) * htf2PerHtf1Dyn)) : dynHtf1Candles
    dynHtf1Candles := math.max(dynHtf1Candles, dynHtf1FromHtf2)
    dynHtf1Candles := math.max(SETTINGS.DYN_HTF1_CANDLES_MIN, math.min(dynHtf1Candles, SETTINGS.DYN_HTF1_CANDLES_MAX))
    int dynCurrLookbackBars = CORE.get_curr_lookback_from_htf2(htf2, dynHtf2Candles, SETTINGS.DYN_CURR_LOOKBACK_MIN_BARS, SETTINGS.DYN_CURR_LOOKBACK_MAX_BARS)
    dynCachedCurrLookbackBars := dynCurrLookbackBars
effectiveCurrLookbackBars := SETTINGS.DYN_LOOKBACK_ENABLE ? dynCachedCurrLookbackBars : LOOKBACK_BARS_WORK // Master working lookback for pruning + keylevel lifecycle.
effectiveCurrLookbackBars := math.max(bar_index - get_working_first_bar() + 1, 1)
perfLookbackBars := effectiveCurrLookbackBars
htfProjectionSpanBars := effectiveCurrLookbackBars
if calcOnClosedBar
    workingFirstBar := get_working_first_bar()
    workingFirstBarLine := process_data_update_working_bar_line(workingFirstBarLine, workingFirstBar)
    int ltfOffSafe = math.max(0, math.min(math.min(bar_index - workingFirstBar, bar_index), 10000))
    int ltfFirstTime = int(time[ltfOffSafe])
    int htf1FirstTime = not na(htf1) ? get_data_htf_detection_cutoff_time(0, htf1) : na
    int htf2FirstTime = not na(htf2) ? get_data_htf_detection_cutoff_time(1, htf2) : na
    if not na(htf1FirstTime) and htf1FirstTime > ltfFirstTime
        htf1FirstTime := ltfFirstTime
    int htf2MaxTime = not na(htf1FirstTime) ? htf1FirstTime : ltfFirstTime
    if not na(htf2FirstTime) and htf2FirstTime > htf2MaxTime
        htf2FirstTime := htf2MaxTime
    int htf1FirstIdx = not na(htf1FirstTime) ? CORE.closest_bar_index_from_time(htf1FirstTime) : na
    int htf2FirstIdx = not na(htf2FirstTime) ? CORE.closest_bar_index_from_time(htf2FirstTime) : na
    if not na(htf1FirstIdx)
        workingFirstBarLineHtf1 := process_data_update_working_debug_line(workingFirstBarLineHtf1, htf1FirstIdx, THEME.COLOR_HTF1)
    if not na(htf2FirstIdx)
        workingFirstBarLineHtf2 := process_data_update_working_debug_line(workingFirstBarLineHtf2, htf2FirstIdx, THEME.COLOR_HTF2)
    process_data_prune_outside_working_zone(chartCtx.zones)
    chartCtx := process_data_chart_context()



int ltfZoneStartIdx = array.size(chartCtx.zones)

if calcOnClosedBar and canEmitSignals and plotOB and SMC.smc_is_ob(true, 1, localCfg.zoneFormationLockBars)
    _t = high[2]
    _b = math.min(low[2], low[1])
    [qOk, qPct, _] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, "", false)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig obCfgBull = get_pdarray_cfg("OB")
        _ext = obCfgBull.extendBarsCurr > 0 ? obCfgBull.extendBarsCurr : SMC.get_current_pdarray_extend("OB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _obCls = SMC.classify_new_ob(chartCtx.zones, true, _t, _b, _q, CONST)
        _obTxt = get_data_normalize_pdarray_label_text("OB", SMC.ob_label_text(_obCls))
        string obTipBase = CORE.tt_side(true, SMC.ob_class_name(_obCls, CONST))
        [_, _, _tt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, obTipBase, uiCfg.zoneTooltipEnable)
        _borderColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBullish, 55)
        _borderStyle = SMC.get_ob_border_style(_obCls, THEME.STYLE_STRONG, CONST)
        add_primary_zone(chartCtx.zones, "OB", true, _t, _b, bar_index - 2, _ext, _obTxt, bar_index + 3, _t, uiCfg.colorBullish, _borderColor, _borderStyle, _q, _tt, -1)

if calcOnClosedBar and canEmitSignals and plotOB and SMC.smc_is_ob(false, 1, localCfg.zoneFormationLockBars)
    _t = math.max(high[2], high[1])
    _b = low[2]
    [qOk, qPct, _] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, "", false)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig obCfgBear = get_pdarray_cfg("OB")
        _ext = obCfgBear.extendBarsCurr > 0 ? obCfgBear.extendBarsCurr : SMC.get_current_pdarray_extend("OB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _obCls = SMC.classify_new_ob(chartCtx.zones, false, _t, _b, _q, CONST)
        _obTxt = get_data_normalize_pdarray_label_text("OB", SMC.ob_label_text(_obCls))
        string obTipBase = CORE.tt_side(false, SMC.ob_class_name(_obCls, CONST))
        [_, _, _tt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, obTipBase, uiCfg.zoneTooltipEnable)
        _borderStyle = SMC.get_ob_border_style(_obCls, THEME.STYLE_STRONG, CONST)
        add_primary_zone(chartCtx.zones, "OB", false, _t, _b, bar_index - 2, _ext, _obTxt, bar_index + 3, _b, color.new(uiCfg.colorBearish, 20), color.new(uiCfg.colorBearish, 55), _borderStyle, _q, _tt, -1)

if calcOnClosedBar and canEmitSignals and plotOB and SMC.smc_is_ob(true, 1, localCfg.zoneFormationLockBars)
    isRjb1 = (low[1] > (close[2] - 0.2 * (close[2] - low[2])))
    isRjb2 = (low[1] < low[2])
    if isRjb1 or isRjb2
        _top = isRjb1 ? close[2] : open[1]
        _btm = isRjb1 ? low[2] : low[1]
        _impOff = isRjb1 ? 2 : 1
        [qOk, qPct, qTt] = SMC.zone_quality_eval(_top, _btm, _impOff, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(true, "Bull RJB"), uiCfg.zoneTooltipEnable)
        if qOk
            _lx  = isRjb1 ? bar_index - 2 : bar_index - 1
            if not SMC.has_nearby_ob(chartCtx.zones, true, _top, _btm, _lx, 2)
                _q = qPct
                SMC.ZoneTypeConfig rjbCfgBull = get_pdarray_cfg("RJB")
                _ext = rjbCfgBull.extendBarsCurr > 0 ? rjbCfgBull.extendBarsCurr : SMC.get_current_pdarray_extend("RJB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
                _rjbTxt = "rjb"
                _borderColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBullish, 55)
                _borderStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
                add_primary_zone(chartCtx.zones, "RJB", true, _top, _btm, _lx, _ext, _rjbTxt, bar_index + 11, _top, uiCfg.colorBullish, _borderColor, _borderStyle, _q, qTt, -1)

if calcOnClosedBar and canEmitSignals and plotOB and SMC.smc_is_ob(false, 1, localCfg.zoneFormationLockBars)
    isRjb1 = (high[1] < (close[2] + 0.2 * (high[2] - close[2])))
    isRjb2 = (high[1] > high[2])
    if isRjb1 or isRjb2
        _top = isRjb1 ? high[2] : high[1]
        _btm = isRjb1 ? close[2] : open[1]
        _impOff = isRjb1 ? 2 : 1
        [qOk, qPct, qTt] = SMC.zone_quality_eval(_top, _btm, _impOff, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(false, "Bear RJB"), uiCfg.zoneTooltipEnable)
        if qOk
            _lx  = isRjb1 ? bar_index - 2 : bar_index - 1
            if not SMC.has_nearby_ob(chartCtx.zones, false, _top, _btm, _lx, 2)
                _q = qPct
                SMC.ZoneTypeConfig rjbCfgBear = get_pdarray_cfg("RJB")
                _ext = rjbCfgBear.extendBarsCurr > 0 ? rjbCfgBear.extendBarsCurr : SMC.get_current_pdarray_extend("RJB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
                _rjbTxt = "rjb"
                _borderColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBearish, 55)
                _borderStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
                add_primary_zone(chartCtx.zones, "RJB", false, _top, _btm, _lx, _ext, _rjbTxt, bar_index + 11, _btm, color.new(uiCfg.colorBearish, THEME.T_LOW), _borderColor, _borderStyle, _q, qTt, -1)

float hv = na
float lv = na
if calcOnClosedBar
    hv := ta.valuewhen(not na(ta.pivothigh(high, PIVOT_LEN_BASE, PIVOT_LEN_BASE)), high[PIVOT_LEN_BASE], 0)
    lv := ta.valuewhen(not na(ta.pivotlow(low, PIVOT_LEN_BASE, PIVOT_LEN_BASE)), low[PIVOT_LEN_BASE], 0)

if calcOnClosedBar and canEmitSignals and plotFVG and SMC.smc_is_fvg(true, 0, localCfg.zoneFormationLockBars)
    isSB = (close[1] > hv) and (low[1] < hv) and (high[2] < hv) and (low > hv)
    _t = low[0]
    _b = high[2]
    [qOk, qPct, qTt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(true, isSB ? "SB FVG" : "FVG"), uiCfg.zoneTooltipEnable)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig fvgCfgBull = get_pdarray_cfg("FVG")
        _ext = fvgCfgBull.extendBarsCurr > 0 ? fvgCfgBull.extendBarsCurr : SMC.get_current_pdarray_extend("FVG", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _fvgBaseTxt = "fvg" + (isSB ? "*" : "")
        _fvgTxt = _fvgBaseTxt
        add_primary_zone(chartCtx.zones, "FVG", true, _t, _b, bar_index - 2, _ext, _fvgTxt, bar_index + 7, (_t + _b) / 2.0, uiCfg.colorBullish, na, line.style_solid, _q, qTt, -1)

if calcOnClosedBar and canEmitSignals and plotFVG and SMC.smc_is_fvg(false, 0, localCfg.zoneFormationLockBars)
    isSB = (close[1] < lv) and (high[1] > lv) and (low[2] > lv) and (high < lv)
    _t = low[2]
    _b = high[0]
    [qOk, qPct, qTt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(false, isSB ? "SB FVG" : "FVG"), uiCfg.zoneTooltipEnable)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig fvgCfgBear = get_pdarray_cfg("FVG")
        _ext = fvgCfgBear.extendBarsCurr > 0 ? fvgCfgBear.extendBarsCurr : SMC.get_current_pdarray_extend("FVG", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _fvgBaseTxt = "fvg" + (isSB ? "*" : "")
        _fvgTxt = _fvgBaseTxt
        add_primary_zone(chartCtx.zones, "FVG", false, _t, _b, bar_index - 2, _ext, _fvgTxt, bar_index + 7, (_t + _b) / 2.0, color.new(uiCfg.colorBearish, THEME.T_LOW), na, line.style_solid, _q, qTt, -1)

if calcOnClosedBar
    annotate_new_pricezones(chartCtx.zones, ltfZoneStartIdx, timeframe.period, 1, ltfData)

    array<CORE.PDArray> prunedOld = SMC.prune_old_current_zones(chartCtx.zones, effectiveCurrLookbackBars, last_bar_index)
    apply_removed_pdarray_visuals(prunedOld)
    if true
        string htf1Label = zshow0 ? CORE.get_friendly_tf(htf1) : ""
        string htf2Label = zshow1 ? CORE.get_friendly_tf(htf2) : ""
        int htf1ZoneStartIdx = array.size(chartCtx.zones)
        add_htf_pdarray_if_valid(chartCtx.zones, htf1Label, 0, zshow0, plotOB, "OB", true, h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObUpQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf1Label, 0, zshow0, plotOB, "OB", false, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1ObDnQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf1Label, 0, zshow0, plotFVG, "FVG", true, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgUpQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf1Label, 0, zshow0, plotFVG, "FVG", false, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1FvgDnQ)
        process_data_add_htf_side_fallback(chartCtx.zones, htf1ZoneStartIdx, 0, zshow0, true,
         plotOB, "OB", true, h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObUpQ,
         plotOB, "OB", false, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1ObDnQ,
         plotFVG, "FVG", true, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgUpQ,
         plotFVG, "FVG", false, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1FvgDnQ)
        process_data_add_htf_side_fallback(chartCtx.zones, htf1ZoneStartIdx, 0, zshow0, false,
         plotOB, "OB", true, h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObUpQ,
         plotOB, "OB", false, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1ObDnQ,
         plotFVG, "FVG", true, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgUpQ,
         plotFVG, "FVG", false, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1FvgDnQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf1Label, 0, zshow0, plotSD, "SD", false, h1SdSupTop, h1SdSupBtm, h1SdSupStart, 100.0)
        add_htf_pdarray_if_valid(chartCtx.zones, htf1Label, 0, zshow0, plotSD, "SD", true, h1SdDemTop, h1SdDemBtm, h1SdDemStart, 100.0)
        annotate_new_pricezones(chartCtx.zones, htf1ZoneStartIdx, htf1, 2, htf1Data)
        int htf2ZoneStartIdx = array.size(chartCtx.zones)
        add_htf_pdarray_if_valid(chartCtx.zones, htf2Label, 1, zshow1, plotOB, "OB", true, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObUpQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf2Label, 1, zshow1, plotOB, "OB", false, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2ObDnQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf2Label, 1, zshow1, plotFVG, "FVG", true, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgUpQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf2Label, 1, zshow1, plotFVG, "FVG", false, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2FvgDnQ)
        process_data_add_htf_side_fallback(chartCtx.zones, htf2ZoneStartIdx, 1, zshow1, true,
         plotOB, "OB", true, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObUpQ,
         plotOB, "OB", false, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2ObDnQ,
         plotFVG, "FVG", true, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgUpQ,
         plotFVG, "FVG", false, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2FvgDnQ)
        process_data_add_htf_side_fallback(chartCtx.zones, htf2ZoneStartIdx, 1, zshow1, false,
         plotOB, "OB", true, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObUpQ,
         plotOB, "OB", false, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2ObDnQ,
         plotFVG, "FVG", true, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgUpQ,
         plotFVG, "FVG", false, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2FvgDnQ)
        add_htf_pdarray_if_valid(chartCtx.zones, htf2Label, 1, zshow1, plotSD, "SD", false, h2SdSupTop, h2SdSupBtm, h2SdSupStart, 100.0)
        add_htf_pdarray_if_valid(chartCtx.zones, htf2Label, 1, zshow1, plotSD, "SD", true, h2SdDemTop, h2SdDemBtm, h2SdDemStart, 100.0)
        annotate_new_pricezones(chartCtx.zones, htf2ZoneStartIdx, htf2, 3, htf2Data)
    int breakRetestWindowBars = CORE.get_dynamic_confirmation_window_bars(timeframe.period, false, localCfg.sweepReclaimMinBars, localCfg.sweepReclaimMaxBars, localCfg.breakRetestMinBars, localCfg.breakRetestMaxBars)
    process_data_prune_zones_by_relevance(chartCtx.zones)
    process_data_entries(breakRetestWindowBars, canEmitSignals, entryEngineEnabled)
    int postTouchKeepMax = get_data_post_touch_keep_max()
    prune_post_touch_pdarrays(chartCtx.zones, postTouchKeepMax, localCfg.zonePriorityAgeDecay)
if barstate.islast
    if entryEngineEnabled
        draw_data_trades_dashboard()
