var SMC.ZoneTypeConfig cfgOB = SMC.ZoneTypeConfig.new(1, "OB", "ob", "Order Block", "Primary block zone", 2, 0.0, uiCfg.ltfBarsExt, line.style_solid, false, false, "BB")
var SMC.ZoneTypeConfig cfgFVG = SMC.ZoneTypeConfig.new(2, "FVG", "fvg", "Fair Value Gap", "Imbalance zone", 1, 0.0, uiCfg.ltfBarsExt - 4, line.style_solid, true, false, "IFVG")
var SMC.ZoneTypeConfig cfgRJB = SMC.ZoneTypeConfig.new(3, "RJB", "rjb", "Rejection Block", "Rejection zone", 2, 0.0, uiCfg.ltfBarsExt, line.style_solid, false, false, "")
