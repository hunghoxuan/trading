// ==================== INPUTS ====================

string G_PDAS = "1. PD ARRAYS & LIQUIDITY"
string G_MODELS = "2. TRADING MODELS"
string G_POS = "3. POSITION"
string G_VIS = "4. TRADES DISPLAY"

plotOB = input.bool(true, "OB", inline="pda", group=G_PDAS)
plotFVG = input.bool(true, "FVG", inline="pda", group=G_PDAS)
useBB = input.bool(true, "BB", inline="pda", group=G_PDAS)
useIFVG = input.bool(true, "iFVG", inline="pda", group=G_PDAS)
