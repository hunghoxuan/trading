signalEntryMode = input.string(ENTRY_MODE_AFTER_RETEST, "Trigger", options = [ENTRY_MODE_OFF, ENTRY_MODE_LIMIT, ENTRY_MODE_AFTER_RETEST], inline = "sig3", group = G_POS)
