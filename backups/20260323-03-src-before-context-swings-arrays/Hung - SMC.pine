signalShowStart = input.bool(true, "Start", inline = "en3", group = G_VIS)
signalShowTp = input.bool(true, "TP", inline = "en3", group = G_VIS)
signalShowSl = input.bool(true, "SL", inline = "en3", group = G_VIS)
