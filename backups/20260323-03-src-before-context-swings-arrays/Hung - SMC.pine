signalMaxStartEntries = input.int(1, "Max Active", minval = 1, maxval = 50, inline = "sig3", group = G_POS)

signalDynamicTp = input.bool(true, "Dynamic TP/SL", inline = "en0", group = G_POS)
signalRrInput = input.float(2.0, "Fixed RR", inline = "en0", minval = 0.1, maxval = 10.0, step = 0.1, group = G_POS)
scoreProfile = input.string(SCORE_PROFILE_BALANCED, "Score Profile", options = [SCORE_PROFILE_LOOSE, SCORE_PROFILE_BALANCED, SCORE_PROFILE_STRICT, SCORE_PROFILE_EXTREME], inline = "en1", group = G_POS)

signalSlProfile = input.string(SL_PROFILE_BALANCED, "SL Buffer", options = [SL_PROFILE_LOOSE, SL_PROFILE_BALANCED, SL_PROFILE_STRICT], inline = "en2", group = G_POS)
signalGapRiskPct = input.float(0.10, "Risk%", inline = "en2", minval = 0.0, step = 0.01, group = G_POS)
signalEntryAtEdge = input.bool(true, "Entry Edge", inline = "en6", group = G_POS)
signalEntryAtMiddle = input.bool(false, "Middle", inline = "en6", group = G_POS)
signalEntryAtEnd = input.bool(false, "End", inline = "en6", group = G_POS)
signalFilterBiasLtf = input.bool(true, "LTF Bias", inline = "en4", group = G_POS)
signalFilterBiasHtf1 = input.bool(true, "HTF1 Bias", inline = "en4", group = G_POS)
signalFilterBiasHtf2 = input.bool(false, "HTF2 Bias", inline = "en4", group = G_POS)
signalFilterLong = input.bool(true, "Long", inline = "en5", group = G_POS)
signalFilterShort = input.bool(true, "Short", inline = "en5", group = G_POS)

