library("TradingKitSMC", dynamic_requests = true)
import hunghoxuan/TradingKitCore/51 as CORE

// SMC domain: visual configuration for line-based level rendering.
export type ZoneDrawConfig
    color lineColor
    string lineStyle
    int lineWidth
    string labelSize
    bool showLabel

// SMC domain: zone taxonomy + behavior config.
export type ZoneTypeConfig
    int id
    string type
    string shortName
    string name
    string description
    int sigScore
    float activeAreaScore
    int extendBarsCurr
    string borderStyle
    bool noBorder
    bool isDerived
    string spawnOnBreak

// SMC domain: quality filter/scoring config for OB/FVG/RJB/SD zones.
export type ZoneQualityCfg
    float minHeightAtr = 0.1
    bool useVolume = true
    float minRelVolume = 1.1
    bool useImpulse = false
    float minBodyAtr = 0.35
    float sizeStrongMult = 1.8
    float volStrong = 1.5
    float impStrong = 1.0
    float dispMin = 0.65
    int volLen = 20
    int scoreSizeStrong = 2
    int scoreSizeBase = 1
    int scoreVolStrong = 2
    int scoreVolBase = 1
    int scoreImpStrong = 2
    int scoreImpBase = 1
    int scoreDisp = 1

// Returns true when new zone formation is allowed on closed history only.
export zone_formation_allowed(int lockBars) =>
    barstate.isconfirmed and bar_index <= (last_bar_index - lockBars)

// Returns true when current candle structure forms a valid OB.
export smc_is_ob(bool isBull, int index, int lockBars) =>
    zone_formation_allowed(lockBars) and (isBull ? (close[index + 1] < open[index + 1] and close[index] > open[index] and close[index] > high[index + 1]) : (close[index + 1] > open[index + 1] and close[index] < open[index] and close[index] < low[index + 1]))

// Returns true when current candle structure forms a valid FVG.
export smc_is_fvg(bool isBull, int index, int lockBars) =>
    zone_formation_allowed(lockBars) and (isBull ? (low[index] > high[index + 2]) : (high[index] < low[index + 2]))

// Signal/display labels by SMC zone type.
export signal_reason_text(string type, bool isBullishZone) =>
    type == "OB" ? (isBullishZone ? "Bullish OB retest" : "Bearish OB retest") :
     type == "BB" ? (isBullishZone ? "Bullish BB retest" : "Bearish BB retest") :
     type == "FVG" ? (isBullishZone ? "Bullish FVG retest" : "Bearish FVG retest") :
     type == "IFVG" ? (isBullishZone ? "Bullish iFVG retest" : "Bearish iFVG retest") :
     type == "RJB" ? (isBullishZone ? "Bullish RJB retest" : "Bearish RJB retest") :
     (isBullishZone ? "Bullish zone retest" : "Bearish zone retest")

// OB classification helpers.
export ob_class_name(string cls, CORE.Const c) =>
    cls == c.OB_CLASS_ORIGIN ? c.OB_CLASS_ORIGIN :
     cls == c.OB_CLASS_DECISIONAL ? c.OB_CLASS_DECISIONAL :
     cls == c.OB_CLASS_EXTREME ? c.OB_CLASS_EXTREME :
     cls == c.OB_CLASS_MITIGATION ? c.OB_CLASS_MITIGATION : c.OB_CLASS_ORIGIN

export ob_label_text(string cls) =>
    cls == "D" ? "OB.d" :
     cls == "X" ? "OB.x" :
     cls == "M" ? "OB.m" : "OB.o"

export get_ob_class_from_label(string labelText, CORE.Const c) =>
    str.contains(labelText, ".d") ? c.OB_CLASS_DECISIONAL :
     str.contains(labelText, ".x") ? c.OB_CLASS_EXTREME :
     str.contains(labelText, ".m") ? c.OB_CLASS_MITIGATION :
     c.OB_CLASS_ORIGIN

export get_ob_border_style(string cls, string fallbackStyle, CORE.Const c) =>
    cls == c.OB_CLASS_ORIGIN or cls == c.OB_CLASS_EXTREME ? line.style_solid :
     cls == c.OB_CLASS_DECISIONAL or cls == c.OB_CLASS_MITIGATION ? line.style_dotted :
     fallbackStyle

export get_zone_border_style(string type, string labelText, string fallbackStyle, CORE.Const c) =>
    type == "OB" ? get_ob_border_style(ob_class_name(get_ob_class_from_label(labelText, c), c), fallbackStyle, c) :
     type == "IFVG" ? line.style_solid :
     fallbackStyle

export get_zone_cap_family(string type) =>
    type == "OB" or type == "BB" or type == "RJB" or type == "SD" ? "OBF" :
     type == "FVG" or type == "IFVG" ? "FVGF" : type

export get_current_zone_extend(string type, int extFvgIfvg, int extObFamily) =>
    type == "FVG" or type == "IFVG" ? extFvgIfvg : extObFamily

// Returns index of the first zone in a swing leg for a given family (OB/FVG/custom type).
export find_first_zone_from_leg(array<CORE.PDArray> zones, string sourceTf, int legId, string family, bool useBullFilter, bool wantBull) =>
    int outIdx = na
    int bestSeq = na
    string fam = str.upper(family)
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            bool sameTf = sourceTf == "" or z.sourceTf == sourceTf
            bool sameLeg = legId <= 0 or z.legId == legId
            bool famOk = fam == "OB" ? (z.type == "OB" or z.type == "BB" or z.type == "RJB" or z.type == "SD") :
             fam == "FVG" ? (z.type == "FVG" or z.type == "IFVG") :
             z.type == fam
            bool sideOk = not useBullFilter or z.isBullish == wantBull
            bool activeOk = not z.broken
            if sameTf and sameLeg and famOk and sideOk and activeOk
                int seq = z.legSeqAll > 0 ? z.legSeqAll : 1000000
                if na(bestSeq) or seq < bestSeq
                    bestSeq := seq
                    outIdx := i
    outIdx

// Convenience: returns first zone in current leg from TFData (same family semantics as find_first_zone_from_leg).
export find_first_zone_from_tf_data(array<CORE.PDArray> zones, string sourceTf, CORE.TFData tfData, string family, bool useBullFilter, bool wantBull) =>
    find_first_zone_from_leg(zones, sourceTf, tfData.legId, family, useBullFilter, wantBull)

export get_htf_zone_extend(int tfSlot, int extHtf1, int extHtf2) =>
    tfSlot == 0 ? extHtf1 : extHtf2

export get_signal_type_idx(string type, string reason, CORE.Const c) =>
    type == "OB" or type == "RJB" ? c.SIG_TYPE_OB :
     type == "BB" ? c.SIG_TYPE_BB :
     type == "FVG" or type == "IFVG" ? c.SIG_TYPE_FVG :
     reason == "SWEEP" ? c.SIG_TYPE_SWEEP :
     c.SIG_TYPE_OB

export is_signal_bias_valid(bool isBullishZone, int biasVal, bool useBiasFilter) =>
    not useBiasFilter or (isBullishZone ? biasVal >= 0 : biasVal <= 0)

export is_body_cross_level(float level, float openV, float closeV) =>
    (openV > level and closeV < level) or (openV < level and closeV > level)

export is_level_wick_touch(float level, float band, float openV, float highV, float lowV, float closeV, float mintick) =>
    float tol = math.max(band, mintick * 0.5)
    bool nearWick = (highV >= level - tol and lowV <= level + tol)
    bool bodyCross = is_body_cross_level(level, openV, closeV)
    nearWick and not bodyCross


// Returns true when the same setup signal is already queued.
export has_pending_entry_signal(array<CORE.Trigger> entries, string type, string direction, float top, float btm, float minTick) =>
    bool result = false
    if array.size(entries) > 0
        for i = 0 to array.size(entries) - 1
            e = array.get(entries, i)
            bool sameZone = math.abs(e.zoneTop - top) < minTick * 2 and math.abs(e.zoneBtm - btm) < minTick * 2
            bool isSignalEvent = e.type != "SWEEP" and na(e.barBreak)
            if isSignalEvent and e.type == type and e.direction == direction and sameZone
                result := true
                break
    result

// Returns true when two price ranges overlap.
export zones_overlap(float topA, float btmA, float topB, float btmB) =>
    math.min(topA, topB) >= math.max(btmA, btmB)

export classify_new_ob(array<CORE.PDArray> zones, bool isBull, float top, float btm, float q, CORE.Const c) =>
    bool isOrigin = not CORE.has_active_zone_same_side(zones, array.new<string>(1, "OB"), isBull)
    bool isExtreme = CORE.is_extreme_zone_candidate(zones, array.new<string>(1, "OB"), isBull, top, btm)
    isOrigin ? c.OB_CLASS_ORIGIN : isExtreme ? c.OB_CLASS_EXTREME : q >= 70 ? c.OB_CLASS_DECISIONAL : c.OB_CLASS_DECISIONAL

export prune_zone_bucket_weakest(array<CORE.PDArray> zones, string type, bool isBull, int bucketMax) =>
    int bucketCount = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.type == type and z.isBullish == isBull and not z.broken and not z.mitigated
                bucketCount += 1
    while bucketCount > bucketMax
        int weakestIdx = na
        float weakestScore = 10e10
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                z = array.get(zones, i)
                if z.type == type and z.isBullish == isBull and not z.broken and not z.mitigated
                    float s = nz(z.qualityPct, 0.0)
                    if na(weakestIdx) or s < weakestScore
                        weakestScore := s
                        weakestIdx := i
        if not na(weakestIdx)
            zDel = array.get(zones, weakestIdx)
            CORE.delete_zone_drawings(zDel)
            array.remove(zones, weakestIdx)
        bucketCount -= 1

// Computes zone quality component data for one zone and impulse candle offset.
export get_zone_quality_data(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    int maxSafeOff = 300
    int off = math.max(0, math.min(impulseOff, maxSafeOff))
    float atrRef = nz(atrSeries[off], atrSeries)
    float safeAtr = atrRef > 0 ? atrRef : tickSize
    float zoneAtr = (top - btm) / safeAtr
    float relVol = CORE.get_rel_volume(off, cfg.volLen)
    float bodyAtr = math.abs(close[off] - open[off]) / safeAtr
    float barRange = math.max(high[off] - low[off], tickSize)
    float dispRatio = math.abs(close[off] - open[off]) / barRange

    int sizePts = zoneAtr >= (cfg.minHeightAtr * cfg.sizeStrongMult) ? cfg.scoreSizeStrong : zoneAtr >= cfg.minHeightAtr ? cfg.scoreSizeBase : 0
    int volPts = relVol >= cfg.volStrong ? cfg.scoreVolStrong : relVol >= cfg.minRelVolume ? cfg.scoreVolBase : 0
    int impPts = bodyAtr >= cfg.impStrong ? cfg.scoreImpStrong : bodyAtr >= cfg.minBodyAtr ? cfg.scoreImpBase : 0
    int dispPts = dispRatio >= cfg.dispMin ? cfg.scoreDisp : 0

    int score = sizePts + volPts + impPts + dispPts
    int maxScore = cfg.scoreSizeStrong + cfg.scoreVolStrong + cfg.scoreImpStrong + cfg.scoreDisp
    [score, maxScore, zoneAtr, relVol, bodyAtr, dispRatio]

// Returns normalized zone quality percentage (0..100).
export get_zone_quality_pct(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    [score, maxScore, _, _, _, _] = get_zone_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    maxScore > 0 ? (score * 100.0 / maxScore) : 0.0

// Builds zone quality tooltip text.
export build_zone_quality_tooltip(string baseText, float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    [score, maxScore, zoneAtr, relVol, bodyAtr, dispRatio] = get_zone_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    baseText + "\nQ " + str.tostring(score) + "/" + str.tostring(maxScore) + " (" + str.tostring(math.round(score * 100.0 / maxScore)) + "%)" +
     "\nATR " + str.tostring(zoneAtr, "#.##") + " | Vol " + str.tostring(relVol, "#.##") + " | Body " + str.tostring(bodyAtr, "#.##") + " | Disp " + str.tostring(dispRatio, "#.##")

passes_zone_quality(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg) =>
    bool sizeOk = (top - btm) >= (cfg.minHeightAtr * nz(atrSeries, tickSize))
    [_, _, _, relVol, bodyAtr, _] = get_zone_quality_data(top, btm, impulseOff, atrSeries, tickSize, cfg)
    bool volOk = not cfg.useVolume or relVol >= cfg.minRelVolume
    bool impulseOk = not cfg.useImpulse or bodyAtr >= cfg.minBodyAtr
    sizeOk and volOk and impulseOk

// Evaluates zone quality once and returns [ok, qualityPct, tooltipText].
export zone_quality_eval(float top, float btm, int impulseOff, series float atrSeries, float tickSize, ZoneQualityCfg cfg, string baseTooltipText, bool showTooltip) =>
    bool ok = passes_zone_quality(top, btm, impulseOff, atrSeries, tickSize, cfg)
    float q = ok ? get_zone_quality_pct(top, btm, impulseOff, atrSeries, tickSize, cfg) : 0.0
    string tt = showTooltip and ok ? build_zone_quality_tooltip(baseTooltipText, top, btm, impulseOff, atrSeries, tickSize, cfg) : ""
    [ok, q, tt]

export prune_old_current_zones(array<CORE.PDArray> zones, int lookbackBars, int lastBarIndex) =>
    if array.size(zones) > 0
        for i = array.size(zones) - 1 to 0
            z = array.get(zones, i)
            bool tooOld = z.barStart < math.max(lastBarIndex - math.max(lookbackBars, 1), 0)
            if tooOld
                CORE.delete_zone_drawings(z)
                array.remove(zones, i)
    bool(na)

export prune_current_zone_side_caps(array<CORE.PDArray> zones, int perTypeSideMax, float closeV, int barIndex, float ageDecay) =>
    string[] zTypes = array.from("OB_FAMILY", "FVG_FAMILY")
    for t = 0 to array.size(zTypes) - 1
        string zt = array.get(zTypes, t)
        for side = 0 to 1
            bool wantAbove = side == 0
            int count = 0
            if array.size(zones) > 0
                for i = 0 to array.size(zones) - 1
                    z = array.get(zones, i)
                    bool sideMatch = ((z.top + z.bottom) * 0.5 > closeV) == wantAbove
                    if get_zone_cap_family(z.type) == zt and sideMatch and not z.broken and not z.mitigated
                        count += 1
            while count > perTypeSideMax
                int weakestIdx = na
                float weakestScore = 10e10
                if array.size(zones) > 0
                    for i = 0 to array.size(zones) - 1
                        z = array.get(zones, i)
                        bool sideMatch = ((z.top + z.bottom) * 0.5 > closeV) == wantAbove
                        if get_zone_cap_family(z.type) == zt and sideMatch and not z.broken and not z.mitigated
                            float s = nz(z.qualityPct, 0.0) - (math.max(barIndex - z.barStart, 0) * ageDecay)
                            if na(weakestIdx) or s < weakestScore
                                weakestScore := s
                                weakestIdx := i
                if not na(weakestIdx)
                    zDel = array.get(zones, weakestIdx)
                    CORE.delete_zone_drawings(zDel)
                    array.remove(zones, weakestIdx)
                    count -= 1
                else
                    count := perTypeSideMax
    bool(na)

export add_active_zone(array<CORE.PDArray> zones, CORE.PDArray z, int bucketMax, int totalMax, int perTypeSideMax, int lookbackBars, int lastBarIndex, float closeV, int barIndex, float ageDecay) =>
    array.push(zones, z)
    prune_old_current_zones(zones, lookbackBars, lastBarIndex)
    prune_zone_bucket_weakest(zones, z.type, z.isBullish, bucketMax)
    prune_current_zone_side_caps(zones, perTypeSideMax, closeV, barIndex, ageDecay)
    while array.size(zones) > totalMax
        old = array.shift(zones)
        CORE.delete_zone_drawings(old)
    bool(na)

// Unified detection basis helper.
export get_detection_series(bool isBullBreak, string basis, float o, float h, float l, float c) =>
    if basis == "Body"
        isBullBreak ? math.max(o, c) : math.min(o, c)
    else if basis == "Close"
        c
    else
        isBullBreak ? h : l

export check_impulse_filter(bool useImpulse, float atrVal, float atrMult, float o, float c) =>
    not useImpulse or math.abs(c - o) >= (atrVal * atrMult)

export check_break(bool isBullBreak, float level, int method, int methodCross, string basis, bool useImpulse, float atrVal, float atrMult,
 float o0, float h0, float l0, float c0, float o1, float h1, float l1, float c1) =>
    bool crossed = method == methodCross ? (isBullBreak ? (o0 <= level and c0 > level) : (o0 >= level and c0 < level)) :
     (get_detection_series(isBullBreak, basis, o0, h0, l0, c0) > level and get_detection_series(isBullBreak, basis, o1, h1, l1, c1) <= level ? isBullBreak : get_detection_series(isBullBreak, basis, o0, h0, l0, c0) < level and get_detection_series(isBullBreak, basis, o1, h1, l1, c1) >= level)
    crossed and check_impulse_filter(useImpulse, atrVal, atrMult, o0, c0)

export check_touch(float zoneTop, float zoneBtm, string basis, float o, float h, float l, float c) =>
    float hiRef = basis == "Body" ? math.max(o, c) : basis == "Close" ? c : h
    float loRef = basis == "Body" ? math.min(o, c) : basis == "Close" ? c : l
    hiRef >= zoneBtm and loRef <= zoneTop

export check_zone_respect(bool isBullZone, float zoneTop, float zoneBtm, float highV, float lowV, float closeV) =>
    isBullZone ? (lowV <= zoneTop and closeV > zoneTop) : (highV >= zoneBtm and closeV < zoneBtm)

export check_mitigation(string type, bool isBullZone, float zoneTop, float zoneBtm, int method, int methodCross, string basis, bool useImpulse, float atrVal, float atrMult,
 float o0, float h0, float l0, float c0, float o1, float h1, float l1, float c1) =>
    bool isFVG = type == "FVG" or type == "IFVG"
    if isFVG
        float mid = (zoneTop + zoneBtm) / 2.0
        check_break(not isBullZone, mid, method, methodCross, basis, useImpulse, atrVal, atrMult, o0, h0, l0, c0, o1, h1, l1, c1)
    else
        check_touch(zoneTop, zoneBtm, basis, o0, h0, l0, c0)

export has_sweep_event_for(array<CORE.Trigger> events, string direction, float price, float tickSize) =>
    bool found = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            e = array.get(events, i)
            if e.direction == direction and math.abs(e.zonePrice - price) <= tickSize * 2
                found := true
                break
    found

export register_sweep_reclaim_event(array<CORE.Trigger> events, string direction, float price, int barIdx, float tickSize) =>
    if not has_sweep_event_for(events, direction, price, tickSize)
        CORE.Trigger e = CORE.Trigger.new()
        e.type := "SWEEP"
        e.direction := direction
        e.zonePrice := price
        e.barDetected := barIdx
        array.push(events, e)
    bool(na)

export has_break_retest_event_for(array<CORE.Trigger> events, string type, string direction, float top, float btm, float tickSize) =>
    bool found = false
    if array.size(events) > 0
        for i = 0 to array.size(events) - 1
            e = array.get(events, i)
            bool sameZone = math.abs(e.zoneTop - top) <= tickSize * 2 and math.abs(e.zoneBtm - btm) <= tickSize * 2
            bool isBreakRetestEvent = not na(e.barBreak)
            if isBreakRetestEvent and e.type == type and e.direction == direction and sameZone
                found := true
                break
    found

export register_break_retest_event(array<CORE.Trigger> events, string type, string direction, float top, float btm, int barIdx, float quality, float tickSize) =>
    if not has_break_retest_event_for(events, type, direction, top, btm, tickSize)
        CORE.Trigger e = CORE.Trigger.new()
        e.type := type
        e.direction := direction
        e.zoneTop := top
        e.zoneBtm := btm
        e.quality := quality
        e.barDetected := barIdx
        e.barBreak := barIdx
        array.push(events, e)
    bool(na)

// Returns true when a zone belongs to the OB/SD overlap family.
export is_ob_sd_family(string type) =>
    type == "OB" or type == "SD"

// Returns true when existing and incoming zones are merge-compatible in the OB/SD family.
export can_merge_ob_sd_zone(string existingType, string incomingType) =>
    (existingType == "OB" and incomingType == "SD") or (existingType == "SD" and incomingType == "OB") or (existingType == "SD" and incomingType == "SD")

// Returns merged label text for canonical OB/SD overlap zones.
build_ob_sd_merged_label(string oldLabel, string existingType, string incomingType) =>
    bool needsSdTag = existingType == "SD" or incomingType == "SD"
    string core = oldLabel == "" ? "OB" : oldLabel
    if needsSdTag and not str.contains(core, "SD")
        core += "+SD"
    core

// Merges overlapping OB/SD zones into a canonical OB family zone (updates visuals in-place).
try_merge_zone(array<CORE.PDArray> zones, string newZoneType, string incomingType, bool isBull, float top, float btm, int ext, float qualityPct, string tooltipText, float tickSize, int mergeTolTicks, int minWidthBars) =>
    bool merged = false
    if array.size(zones) > 0
        float pad = mergeTolTicks * tickSize
        float inTop = top + pad
        float inBtm = btm - pad
        for i = array.size(zones) - 1 to 0
            CORE.PDArray z = array.get(zones, i)
            if not z.broken and z.isBullish == isBull and can_merge_ob_sd_zone(z.type, incomingType)
                float zTop = z.top + pad
                float zBtm = z.bottom - pad
                bool overlap = math.min(inTop, zTop) >= math.max(inBtm, zBtm)
                if overlap
                    z.top := math.max(z.top, top)
                    z.bottom := math.min(z.bottom, btm)
                    z.extendBars := math.max(z.extendBars, ext)
                    z.qualityPct := math.max(nz(z.qualityPct, 0.0), nz(qualityPct, 0.0))
                    z.type := newZoneType
                    z.labelText := build_ob_sd_merged_label(z.labelText, z.type, incomingType)
                    if not na(z.visualBox)
                        z.visualBox.set_top(z.top)
                        z.visualBox.set_bottom(z.bottom)
                        z.visualBox.set_right(math.max(bar_index + z.extendBars, z.barStart + minWidthBars))
                    if not na(z.visualLabel)
                        z.visualLabel.set_text(z.labelText)
                        if tooltipText != ""
                            z.visualLabel.set_tooltip(tooltipText)
                    array.set(zones, i, z)
                    merged := true
                    break
    merged

// Merges overlapping OB/SD zones into a canonical OB-family zone.
export try_merge_ob_sd_zone(array<CORE.PDArray> zones, string incomingType, bool isBull, float top, float btm, int ext, float qualityPct, string tooltipText, float tickSize, int mergeTolTicks, int minWidthBars) =>
    bool merged = false
    if is_ob_sd_family(incomingType)
        merged := try_merge_zone(zones, "OB", incomingType, isBull, top, btm, ext, qualityPct, tooltipText, tickSize, mergeTolTicks, minWidthBars)
    merged

// Returns SR x-position for line end or label placement.
export get_sr_x(int barIndex, int extendBars, bool forLabel) =>
    barIndex + extendBars + (forLabel ? 1 : 0)

// Returns true when SR source label implies higher-timeframe origin.
export is_sr_source_htf(CORE.PDArray z, string currentTf) =>
    z.labelText != "" and z.labelText != currentTf

// Returns true when SR level is above current price and acts as resistance.
export is_sr_res_now(CORE.PDArray z, float closeV) =>
    z.price > closeV

// Returns SR label text from HTF/source role and touch count.
export get_sr_label_text(bool isHtfSource, bool isResNow, int touchN) =>
    touchN <= 1 ? (isHtfSource ? "IDM" : "idm") : (isResNow ? "R" : "S") + str.tostring(math.max(touchN, 1))

// Returns default entry price by SMC setup type.
export get_default_entry_for_type(string setupType, bool isBuy, float zoneTop, float zoneBtm, float wickLow, float wickHigh) =>
    float entry = isBuy ? zoneTop : zoneBtm
    if setupType == "FVG"
        entry := (zoneTop + zoneBtm) / 2.0
    else if setupType == "Sweep"
        entry := isBuy ? wickLow : wickHigh
    entry

// Returns [furthestAbove, furthestBelow] key prices around reference price for dynamic SL placement.
export get_entry_sl_targets(array<CORE.PDArray> zones, array<CORE.PDArray> levels, float refPrice) =>
    float above = na
    float below = na
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            if not z.broken
                float cAbove = z.top
                float cBelow = z.bottom
                if cAbove > refPrice and (na(above) or cAbove > above)
                    above := cAbove
                if cBelow < refPrice and (na(below) or cBelow < below)
                    below := cBelow
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            CORE.PDArray z = array.get(levels, i)
            bool isLevelType = z.type == "SR" or z.type == "LIQ" or z.type == "eqh" or z.type == "eql"
            if isLevelType and not z.broken
                float p = z.price
                if p > refPrice and (na(above) or p > above)
                    above := p
                if p < refPrice and (na(below) or p < below)
                    below := p
    [above, below]

export get_nearest_barriers(array<CORE.PDArray> zones, float refPrice, float tickSize) =>
    float above = na
    float below = na
    float aboveH = na
    float belowH = na
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            bool isHtf = z.sourceTfRank >= 2
            bool isObBb = z.type == "OB" or z.type == "BB"
            if not z.broken and isHtf and isObBb
                float zHi = z.top
                float zLo = z.bottom
                float zH = math.max(zHi - zLo, tickSize)
                if zLo > refPrice and (na(above) or zLo < above)
                    above := zLo
                    aboveH := zH
                if zHi < refPrice and (na(below) or zHi > below)
                    below := zHi
                    belowH := zH
    [above, below, aboveH, belowH]

// Builds one HTF zone snapshot tuple (OB/FVG + quality).
export get_htf_zone_snapshot(int zoneFormationLockBars, ZoneQualityCfg zqCfg, int atrLen) =>
    bool obUp = smc_is_ob(true, 1, zoneFormationLockBars)
    bool obDn = smc_is_ob(false, 1, zoneFormationLockBars)
    bool fvgUp = smc_is_fvg(true, 0, zoneFormationLockBars)
    bool fvgDn = smc_is_fvg(false, 0, zoneFormationLockBars)
    float atrRef = ta.atr(atrLen)
    float obUpQTop = high[2]
    float obUpQBtm = math.min(low[2], low[1])
    float obDnQTop = math.max(high[2], high[1])
    float obDnQBtm = low[2]
    float fvgUpQTop = low
    float fvgUpQBtm = high[2]
    float fvgDnQTop = low[2]
    float fvgDnQBtm = high
    float obUpTop = ta.valuewhen(obUp, high[2], 0)
    float obUpBtm = ta.valuewhen(obUp, math.min(low[2], low[1]), 0)
    int obUpStart = ta.valuewhen(obUp, time[2], 0)
    float obDnTop = ta.valuewhen(obDn, math.max(high[2], high[1]), 0)
    float obDnBtm = ta.valuewhen(obDn, low[2], 0)
    int obDnStart = ta.valuewhen(obDn, time[2], 0)
    float fvgUpTop = ta.valuewhen(fvgUp, low, 0)
    float fvgUpBtm = ta.valuewhen(fvgUp, high[2], 0)
    int fvgUpStart = ta.valuewhen(fvgUp, time[2], 0)
    float fvgDnTop = ta.valuewhen(fvgDn, low[2], 0)
    float fvgDnBtm = ta.valuewhen(fvgDn, high, 0)
    int fvgDnStart = ta.valuewhen(fvgDn, time[2], 0)
    float obUpQ = ta.valuewhen(obUp, get_zone_quality_pct(obUpQTop, obUpQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float obDnQ = ta.valuewhen(obDn, get_zone_quality_pct(obDnQTop, obDnQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float fvgUpQ = ta.valuewhen(fvgUp, get_zone_quality_pct(fvgUpQTop, fvgUpQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    float fvgDnQ = ta.valuewhen(fvgDn, get_zone_quality_pct(fvgDnQTop, fvgDnQBtm, 1, atrRef, syminfo.mintick, zqCfg), 0)
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ]

// Builds one HTF SR snapshot tuple.
export get_htf_sr_snapshot(int srPivotLen) =>
    float srHi = ta.valuewhen(not na(ta.pivothigh(high, srPivotLen, srPivotLen)), ta.pivothigh(high, srPivotLen, srPivotLen), 0)
    float srLo = ta.valuewhen(not na(ta.pivotlow(low, srPivotLen, srPivotLen)), ta.pivotlow(low, srPivotLen, srPivotLen), 0)
    int srHiT = ta.valuewhen(not na(ta.pivothigh(high, srPivotLen, srPivotLen)), time[srPivotLen], 0)
    int srLoT = ta.valuewhen(not na(ta.pivotlow(low, srPivotLen, srPivotLen)), time[srPivotLen], 0)
    [srHi, srHiT, srLo, srLoT]

// Bundles HTF zone + SR snapshots in one tuple.
export get_htf_zone_sr_snapshot(int zoneFormationLockBars, ZoneQualityCfg zqCfg, int atrLen, int srPivotLen) =>
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ] = get_htf_zone_snapshot(zoneFormationLockBars, zqCfg, atrLen)
    [srHi, srHiT, srLo, srLoT] = get_htf_sr_snapshot(srPivotLen)
    [obUpTop, obUpBtm, obUpStart, obDnTop, obDnBtm, obDnStart, fvgUpTop, fvgUpBtm, fvgUpStart, fvgDnTop, fvgDnBtm, fvgDnStart, obUpQ, obDnQ, fvgUpQ, fvgDnQ, srHi, srHiT, srLo, srLoT]

export f_get_htf_s(float _p, int _d, int _l, series float h, series float l, series float v) =>
    _mx = ta.highest(h, _l), _v = math.sum(v, _l), _r = (_d > 0) ? ((_mx - ta.lowest(l, _l)) / _d) : 0.0
    _s_s = 0., _s_b = _mx, _s_t = _mx
    for _i = 0 to _d - 1
        _lv = _mx - (_i + 1) * _r, _pv = _mx - _i * _r, _bv = 0.
        for _j = 0 to _l - 1
            _bv += (h[_j] > _lv and h[_j] <= _pv) ? v[_j] : 0.0
        _s_s += _bv
        if _s_s / _v * 100 > _p
            _s_b := _lv
            break
    [_s_t, _s_b, math.avg(_s_t, _s_b)]

export f_get_htf_d(float _p, int _d, int _l, series float h, series float l, series float v) =>
    _mn = ta.lowest(l, _l), _v = math.sum(v, _l), _r = (_d > 0) ? ((ta.highest(h, _l) - _mn) / _d) : 0.0
    _d_s = 0., _d_t = _mn, _d_b = _mn
    for _i = 0 to _d - 1
        _lv = _mn + (_i + 1) * _r, _pv = _mn + _i * _r, _bv = 0.
        for _j = 0 to _l - 1
            _bv += (l[_j] >= _pv and l[_j] < _lv) ? v[_j] : 0.0
        _d_s += _bv
        if _d_s / _v * 100 > _p
            _d_t := _lv
            break
    [_d_t, _d_b, math.avg(_d_t, _d_b)]

export type DensitySeed
    float lPrice
    bool isRes
    string tfLbl

export get_density_seeds(CORE.TFData tfData, float _maxRange, float _minRange, string sourceTf, int sourcePrio, int lookback, int div, int barIndex, int timeNow, float closeV) =>
    array<DensitySeed> out = array.new<DensitySeed>()
    int rCount = array.size(tfData.swingHighPrices)
    int sCount = array.size(tfData.swingLowPrices)
    bool isHtf = sourcePrio > 0
    if (rCount > 0 or sCount > 0) and div > 0
        float sR = (_maxRange - _minRange) / div
        if sR > 0
            array<float> rProf = array.new_float(div, 0.0)
            array<float> sProf = array.new_float(div, 0.0)
            int safeBarsBack = barIndex < lookback ? barIndex : lookback
            if rCount > 0
                for i = 0 to rCount - 1
                    if array.get(tfData.swingHighTimes, i) >= timeNow - (safeBarsBack * 86400000)
                        float p = array.get(tfData.swingHighPrices, i)
                        int bin = math.max(0, math.min(int((_maxRange - p) / sR), div - 1))
                        array.set(rProf, bin, array.get(rProf, bin) + 1.0)
            if sCount > 0
                for i = 0 to sCount - 1
                    if array.get(tfData.swingLowTimes, i) >= timeNow - (safeBarsBack * 86400000)
                        float p = array.get(tfData.swingLowPrices, i)
                        int bin = math.max(0, math.min(int((p - _minRange) / sR), div - 1))
                        array.set(sProf, bin, array.get(sProf, bin) + 1.0)
            float reqDensity = isHtf ? 2.0 : 3.0
            for b = 1 to div - 2
                float v = array.get(rProf, b)
                if v >= reqDensity and v > array.get(rProf, b - 1) and v >= array.get(rProf, b + 1)
                    float top = _maxRange - b * sR
                    float btm = _maxRange - (b + 1) * sR
                    float lPrice = math.avg(top, btm)
                    bool isRes = lPrice > closeV
                    string tfLbl = sourceTf
                    array.push(out, DensitySeed.new(lPrice, isRes, tfLbl))
            for b = 1 to div - 2
                float v = array.get(sProf, b)
                if v >= reqDensity and v > array.get(sProf, b - 1) and v >= array.get(sProf, b + 1)
                    float btm = _minRange + b * sR
                    float top = _minRange + (b + 1) * sR
                    float lPrice = math.avg(top, btm)
                    bool isRes = lPrice > closeV
                    string tfLbl = sourceTf
                    array.push(out, DensitySeed.new(lPrice, isRes, tfLbl))
    out

export f_is_overlapped(array<CORE.PDArray> z_array, float top, float btm, string targetTf) =>
    bool result = false
    if array.size(z_array) > 0
        for i = 0 to array.size(z_array) - 1
            CORE.PDArray z = array.get(z_array, i)
            if z.sourceTf == targetTf and math.min(top, z.top) > math.max(btm, z.bottom)
                result := true
                break
    result
