// Persistent runtime state across bars.
var array<CORE.Trigger> eventsQueue = array.new<CORE.Trigger>() // Used for LIQ sweep event memory.

// UI theme-derived colors (declared after THEME exists).
type DetectionCfg
    int method = 0 // 0 = state, 1 = cross.
    int methodCross = 1 // Cross method value.
    string basis = "Wick" // Wick/Close basis.
    bool useImpulse = false // Enable impulse filter.
    float impulseAtr = 0.5 // Impulse threshold in ATR.

type UIConfig
    color colorBearish = color.red // Bearish text/line base color.
    color colorBullish = color.teal // Bullish text/line base color.
    color colorBg = color.gray // Zone fill neutral color.
    color colorText = color.white // Generic text color.
    color ltfColor = color.gray // Base-TF color.
    int ltfBarsExt = 5 // LTF zone extension.
    int ltfLineBarsExt = 8 // LTF line extension.
    bool msShowSwings = true // Show base-TF swings by default.
    bool msShowBosMss = true // Show BOS/MSS labels by default.
    bool msShowZigzag = true // Show base-TF zigzag by default.
    bool msHtf1SwingShow = true // Show HTF1 swings by default.
    bool msHtf1ZigzagShow = true // Show HTF1 zigzag by default.
    bool msHtf2SwingShow = true // Show HTF2 swings by default.
    bool msHtf2ZigzagShow = true // Show HTF2 zigzag by default.
    int htfZoneBgTransp = 90 // HTF projected-zone background alpha.
    int zoneCurrMinWidthBars = 6 // Minimum zone width in bars.
    bool htfShowProjectedZones = true // Toggle projected HTF zones.
    bool zoneTooltipEnable = true // Toggle zone tooltips.

get_detection_cfg(int setup) =>
    DetectionCfg cfg = DetectionCfg.new()
    if setup >= 3
        cfg.basis := "Close"
        cfg.useImpulse := true
        cfg.impulseAtr := 0.7
    else if setup == 2
        cfg.basis := "Wick"
        cfg.useImpulse := true
        cfg.impulseAtr := 0.6
    cfg

get_ui_cfg(int setup, CORE.Theme th) =>
    UIConfig cfg = UIConfig.new()
    cfg.colorBearish := color.new(th.COLOR_BEARISH, th.T_NORMAL)
    cfg.colorBullish := color.new(th.COLOR_BULLISH, th.T_NORMAL)
    cfg.colorBg := color.new(th.COLOR_NEUTRAL, th.T_NORMAL)
    cfg.colorText := color.new(th.TEXT_COLOR, th.T_NORMAL)
    cfg.ltfColor := color.new(color.rgb(215, 215, 215), 0)
    if setup >= 3
        cfg.ltfBarsExt := 4
        cfg.ltfLineBarsExt := 7
    else if setup == 2
        cfg.ltfBarsExt := 5
        cfg.ltfLineBarsExt := 8
    cfg

// Limitation config: all caps/thresholds that limit detection/entry volume.
type LimitationCfg
    bool entryZoneFilterEnable = true // Apply pre-filter before add_entry.
    float entryZoneMinQualityPct = 0.0 // Min zone quality to allow entry.
    bool entryFilterNearLegEnable = false // Require zone to be near current leg.
    int entryFilterNearLegMaxSeq = 99 // Max zone sequence in current leg.
    bool entryFilterNearLegRequireDirMatch = false // Require leg direction matches side.
    bool entryFilterNearLegAllowUnknown = true // Allow unknown leg metadata to pass.
    bool entryFilterHtfOnlyEnable = false // Restrict entry candidates to HTF zones only.
    int entryFilterHtfMinRank = 2 // Min source TF rank when HTF-only mode is on.
    int zoneCapPerType = 16 // Max zones per family.
    int zoneCapTotal = 96 // Max zones total across families.
    int zoneCurrMaxPerTypeSide = 10 // Max current-TF zones per family per side.
    float zonePriorityAgeDecay = 0.01 // Age penalty for prune ranking.
    int zoneMergeTolTicks = 4 // Merge tolerance for near-overlap zones.
    int zoneFormationLockBars = 1 // Ignore freshly forming unclosed zones.
    float zoneMinHeightAtr = 0.05 // Min zone height in ATR.
    int htfZoneLookbackBars = 1000000 // HTF projection lookback bars.
    int htfZoneMaxPerTypeSide = 2 // HTF projected zones per family per side.
    float htfProjectionMinQualityPct = 0.0 // Min HTF projected zone quality.
    int signalMinConfluenceScore = 1 // Min score to emit/create entry.
    int sweepReclaimMinBars = 2 // Min bars for sweep reclaim validity window.
    int sweepReclaimMaxBars = 14 // Max bars for sweep reclaim validity window.
    float sweepMinWickTicks = 1.0 // Min wick penetration for sweep.
    float sweepMinReclaimAtr = 0.08 // Min reclaim displacement in ATR.
    int breakRetestMinBars = 6 // Min bars for break-retest window.
    int breakRetestMaxBars = 34 // Max bars for break-retest window.
    float srTolAtrMult = 0.25 // SR merge/touch tolerance in ATR.
    float srNearbyMergeMult = 2.0 // SR min-distance multiplier for de-dup.
    float srTouchBandAtrMult = 0.10 // SR touch band in ATR.
    float srTouchBandMinTicks = 2.0 // SR touch band minimum ticks.
    int srTouchCountCooldownBars = 2 // Cooldown between SR touch increments.
    int srSeedSwingsPerTf = 2 // Number of latest swings used as SR seeds per TF.
    bool srUseLtfSeeds = false // Include LTF swings as SR seeds.
    int eqPivotLedgerMin = 20 // Min pivot ledger points for EQ detection.
    float eqTolAtr = 0.1 // EQ matching ATR tolerance.

get_limitation_cfg(int strict, int globalLookbackBars) =>
    LimitationCfg cfg = LimitationCfg.new()
    cfg.htfZoneLookbackBars := globalLookbackBars <= 0 ? 1000000 : globalLookbackBars
    if strict >= 3
        cfg.entryFilterNearLegEnable := true
        cfg.entryFilterNearLegMaxSeq := 2
        cfg.entryFilterNearLegRequireDirMatch := true
        cfg.entryFilterNearLegAllowUnknown := false
        cfg.entryFilterHtfOnlyEnable := true
        cfg.entryZoneMinQualityPct := 55.0
        cfg.signalMinConfluenceScore := 3
        cfg.htfProjectionMinQualityPct := 35.0
        cfg.zoneCapPerType := 8
        cfg.zoneCapTotal := 48
        cfg.sweepMinWickTicks := 2.0
        cfg.sweepMinReclaimAtr := 0.15
    else if strict == 2
        cfg.entryFilterNearLegEnable := true
        cfg.entryFilterNearLegMaxSeq := 3
        cfg.entryFilterNearLegRequireDirMatch := true
        cfg.entryFilterNearLegAllowUnknown := false
        cfg.entryFilterHtfOnlyEnable := false
        cfg.entryZoneMinQualityPct := 25.0
        cfg.signalMinConfluenceScore := 2
        cfg.htfProjectionMinQualityPct := 20.0
        cfg.zoneCapPerType := 12
        cfg.zoneCapTotal := 72
        cfg.sweepMinWickTicks := 1.5
        cfg.sweepMinReclaimAtr := 0.12
    cfg
