//@version=5
indicator("Supply and Demand Visible Range [LuxAlgo]", overlay = true, max_boxes_count = 500, max_bars_back = 500)

import hunghoxuan/TradingKitCore/47 as CORE

//------------------------------------------------------------------------------
//Settings
//-----------------------------------------------------------------------------{
per = input.float(10., 'Threshold %', minval = 0, maxval = 100)
div = input.int(50, 'Resolution'    , minval = 2, maxval = 500)
tf  = input.timeframe('', 'Intrabar TF')

// Scope Settings
calcMode = input.string("Visible Range", "Calculation Scope", options = ["Visible Range", "Lookback"], group = "Calculation")
lookback = input.int(500, "Lookback Bars", minval = 1, group = "Calculation", tooltip = "Only used when scope is 'Lookback'")

// MTF Settings
showMTF = input.bool(true, "Show HTF Zones", group = "MTF Settings")
htfPeriod = input.timeframe("240", "HTF Timeframe", group = "MTF Settings")
htfLookback = input.int(300, "HTF Lookback Bars", group = "MTF Settings")
htfSupplyColor = input.color(color.new(#2157f3, 85), "HTF Supply Color", group = "MTF Settings")
htfDemandColor = input.color(color.new(#ff5d00, 85), "HTF Demand Color", group = "MTF Settings")

//Colors
showSupply = input(true ,'Supply        ', inline = 'supply', group = 'Style')
supplyCss  = input(#2157f3, ''         , inline = 'supply', group = 'Style')
supplyArea = input(true ,'Area'          , inline = 'supply', group = 'Style')
supplyAvg  = input(true ,'Average'       , inline = 'supply', group = 'Style')
supplyWavg = input(true ,'Weighted'      , inline = 'supply', group = 'Style')

showEqui   = input(true ,'Equilibrium'   , inline = 'equi'  , group = 'Style')
equiCss    = input(color.gray, ''      , inline = 'equi'  , group = 'Style')
equiAvg    = input(true ,'Average'       , inline = 'equi'  , group = 'Style')
equiWavg   = input(true ,'Weighted'      , inline = 'equi'  , group = 'Style')

showDemand = input(true ,'Demand    '    , inline = 'demand', group = 'Style')
demandCss  = input(#ff5d00, ''         , inline = 'demand', group = 'Style')
demandArea = input(true ,'Area'          , inline = 'demand', group = 'Style')
demandAvg  = input(true ,'Average'       , inline = 'demand', group = 'Style')
demandWavg = input(true ,'Weighted'      , inline = 'demand', group = 'Style')

//-----------------------------------------------------------------------------}
//CORE Initialization
//-----------------------------------------------------------------------------{
var CORE.Const CONST = CORE.Const.new()
var CORE.Theme THEME = CORE.Theme.new()
//-----------------------------------------------------------------------------}
//UDT's
//-----------------------------------------------------------------------------{
type bin
    float lvl
    float prev
    float sum
    float prev_sum
    float csum
    float avg
    bool isreached

apply_sd_pricezone_visual(CORE.PriceZone z, int leftIdx, int rightIdx, float top, float btm, float avgPrice, color zoneColor, color lineColor, bool showArea, bool showAvg) =>
    if showArea
        if na(z.visualBox)
            z.visualBox := box.new(leftIdx, top, rightIdx, btm, bgcolor = color.new(zoneColor, 80), border_color = na)
        else
            z.visualBox.set_lefttop(leftIdx, top)
            z.visualBox.set_rightbottom(rightIdx, btm)
            z.visualBox.set_bgcolor(color.new(zoneColor, 80))
    else if not na(z.visualBox)
        z.visualBox.delete()
        z.visualBox := na

    if showAvg
        if na(z.visualLine)
            z.visualLine := line.new(leftIdx, avgPrice, rightIdx, avgPrice, color = lineColor)
        else
            z.visualLine.set_xy1(leftIdx, avgPrice)
            z.visualLine.set_xy2(rightIdx, avgPrice)
            z.visualLine.set_color(lineColor)
    else if not na(z.visualLine)
        z.visualLine.delete()
        z.visualLine := na
    z    

// PriceZone from CORE will be used for area storage
//-----------------------------------------------------------------------------}
//Functions
//-----------------------------------------------------------------------------{
n = bar_index

get_hlv()=> [high, low, volume]

// Function to calculate SD levels on HTF
f_calc_sd_levels(_per, _div, _lb) =>
    _max = ta.highest(high, _lb)
    _min = ta.lowest(low, _lb)
    _csum = math.sum(volume, _lb)
    _r = (_max - _min) / _div
    
    _s_top = _max
    _s_btm = _max
    _s_sum = 0.
    _s_found = false
    
    _d_top = _min
    _d_btm = _min
    _d_sum = 0.
    _d_found = false

    _s_prev = _max
    _d_prev = _min

    for _i = 0 to _div - 1
        _lvl_s = _s_prev - _r
        _lvl_d = _d_prev + _r
        
        _s_bin_vol = 0.
        _d_bin_vol = 0.
        for _j = 0 to _lb - 1
            if high[_j] > _lvl_s and high[_j] <= _s_prev
                _s_bin_vol += volume[_j]
            if low[_j] >= _d_prev and low[_j] < _lvl_d
                _d_bin_vol += volume[_j]
        
        _s_sum += _s_bin_vol
        _d_sum += _d_bin_vol
        
        if not _s_found and (_s_sum / _csum * 100 > _per)
            _s_found := true
            _s_top := _max
            _s_btm := _lvl_s
            
        if not _d_found and (_d_sum / _csum * 100 > _per)
            _d_found := true
            _d_top := _lvl_d
            _d_btm := _min
            
        if _s_found and _d_found
            break
            
        _s_prev := _lvl_s
        _d_prev := _lvl_d
    
    [_s_top, _s_btm, _d_top, _d_btm]

// Request htf levels
[htf_s_top, htf_s_btm, htf_d_top, htf_d_btm] = request.security(syminfo.tickerid, htfPeriod, f_calc_sd_levels(per, div, htfLookback))

//-----------------------------------------------------------------------------}
//Main variables
//-----------------------------------------------------------------------------{
var max  = 0. 
var min  = 0.
var x1   = 0
var csum = 0.

//Intrabar data
[h, l, v] = request.security_lower_tf(syminfo.tickerid, tf, get_hlv())

// Determine Start condition
bool isStart = calcMode == "Visible Range" ? (time == chart.left_visible_bar_time) : (last_bar_index - n == lookback)
bool isAccum = calcMode == "Visible Range" ? (time > chart.left_visible_bar_time) : (last_bar_index - n < lookback)
bool isEnd   = calcMode == "Visible Range" ? (time == chart.right_visible_bar_time) : (barstate.islast)

//Init on start bar
if isStart
    max := high
    min := low
    csum := volume
    x1 := n
else if isAccum //Accumulate
    max := math.max(high, max)
    min := math.min(low, min)
    csum += volume

//-----------------------------------------------------------------------------}
//Set zones
//-----------------------------------------------------------------------------{
var supply_zone = CORE.PriceZone.new("Supply", na, na, na, false, false, na, na, na, na, na, false, false, "Supply", 0, na)
var demand_zone = CORE.PriceZone.new("Demand", na, na, na, false, false, na, na, na, na, na, false, true, "Demand", 0, na)

var equi  = line.new(na, na, na, na, color = equiCss)
var wequi = line.new(na, na, na, na, color = equiCss, style = line.style_dashed)

var float supply_wavg = na
var float demand_wavg = na

// HTF Drawers
var htf_s_box = box.new(na, na, na, na, bgcolor = htfSupplyColor, border_color = color.new(htfSupplyColor, 30), text = "HTF Supply", text_color = color.new(htfSupplyColor, 20), text_size = size.tiny)
var htf_d_box = box.new(na, na, na, na, bgcolor = htfDemandColor, border_color = color.new(htfDemandColor, 30), text = "HTF Demand", text_color = color.new(htfDemandColor, 20), text_size = size.tiny)

if isEnd
    // Draw HTF zones
    if showMTF
        htf_left = calcMode == "Visible Range" ? x1 : (n - lookback)
        htf_s_box.set_lefttop(htf_left, htf_s_top)
        htf_s_box.set_rightbottom(n, htf_s_btm)
        htf_d_box.set_lefttop(htf_left, htf_d_top)
        htf_d_box.set_rightbottom(n, htf_d_btm)

    // Draw LTF
    r = (max - min) / div
    supply = bin.new(max, max, 0, 0, 0, 0, false)
    demand = bin.new(min, min, 0, 0, 0, 0, false)

    //Loop trough intervals
    for i = 0 to div-1
        supply.lvl -= r
        demand.lvl += r

        //Accumulated volume column
        if not supply.isreached and showSupply and supplyArea
            box.new(x1, supply.prev, x1 + int(supply.sum / csum * (n - x1)), supply.lvl, na
              , bgcolor = color.new(supplyCss, 50))
        
        if not demand.isreached and showDemand and demandArea
            box.new(x1, demand.lvl, x1 + int(demand.sum / csum * (n - x1)), demand.prev, na
              , bgcolor = color.new(demandCss, 50))
        
        //Loop trough bars
        for j = 0 to (n - x1)-1
            //Loop trough intrabars
            for k = 0 to (v[j]).size()-1
                //Accumulate if within upper internal
                supply.sum      += (h[j]).get(k) > supply.lvl and (h[j]).get(k) < supply.prev ? (v[j]).get(k) : 0
                supply.avg      += supply.lvl * (supply.sum - supply.prev_sum)
                supply.csum     += supply.sum - supply.prev_sum
                supply.prev_sum := supply.sum

                //Accumulate if within lower interval
                demand.sum      += (l[j]).get(k) < demand.lvl and (l[j]).get(k) > demand.prev ? (v[j]).get(k) : 0
                demand.avg      += demand.lvl * (demand.sum - demand.prev_sum)
                demand.csum     += demand.sum - demand.prev_sum
                demand.prev_sum := demand.sum
                
            //Test if supply accumulated volume exceed threshold and set box
            if supply.sum / csum * 100 > per and not supply.isreached
                avg_val = math.avg(max, supply.lvl)
                supply_wavg := supply.avg / supply.csum

                //Set Box/Level coordinates
                if showSupply
                    apply_sd_pricezone_visual(supply_zone, x1, n, max, supply.lvl, avg_val, supplyCss, supplyCss, supplyArea, supplyAvg)

                supply.isreached := true
            
            //Test if demand accumulated volume exceed threshold and set box
            if demand.sum / csum * 100 > per and not demand.isreached and showDemand
                avg_val = math.avg(min, demand.lvl)
                demand_wavg := demand.avg / demand.csum
                
                //Set Box/Level coordinates
                if showDemand
                    apply_sd_pricezone_visual(demand_zone, x1, n, demand.lvl, min, avg_val, demandCss, demandCss, demandArea, demandAvg)

                demand.isreached := true
            
            if supply.isreached and demand.isreached
                break
        
        if supply.isreached and demand.isreached and showEqui
            //Set equilibrium
            if equiAvg
                avg_val = math.avg(max, min)
                equi.set_xy1(x1, avg_val)
                equi.set_xy2(n, avg_val)
            
            //Set weighted equilibrium
            if equiWavg
                wavg_val = math.avg(supply_wavg, demand_wavg)
                wequi.set_xy1(x1, wavg_val)
                wequi.set_xy2(n, wavg_val)

            break
        
        supply.prev := supply.lvl
        demand.prev := demand.lvl
//-----------------------------------------------------------------------------}