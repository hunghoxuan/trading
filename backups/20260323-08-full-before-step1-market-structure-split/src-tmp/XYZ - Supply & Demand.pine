//@version=5
indicator("Hung - Supply & Demand", overlay = true, max_boxes_count = 500, max_bars_back = 500)

import hunghoxuan/TradingKitCore/56 as CORE
import hunghoxuan/TradingKitUI/12 as UI

//------------------------------------------------------------------------------
//Settings
//-----------------------------------------------------------------------------{
per = input.float(10., 'Threshold %', minval = 0, maxval = 100)
div = input.int(50, 'Resolution'    , minval = 2, maxval = 500)
subSteps = input.int(3, 'LTF Sub-Lookback Steps', minval = 1, maxval = 5, group = "Calculation", tooltip = "Number of different window sizes to check for LTF zones")

showSupply = true //input(true, 'Supply', inline = 'S', group = 'Style')
supplyArea = true //input(true, 'Area',   inline = 'S', group = 'Style')
supplyAvg  = true //input(true, 'Avg Line', inline = 'S', group = 'Style')

showDemand = true //input(true, 'Demand', inline = 'D', group = 'Style')
demandArea = true //input(true, 'Area',   inline = 'D', group = 'Style')
demandAvg  = true //input(true, 'Avg Line', inline = 'D', group = 'Style')

showEqui   = false //input(true, 'Equilibrium', group = 'Style')
equiAvg    = false //input(true, 'Average', inline = 'E', group = 'Style')
equiWavg   = false //input(true, 'Weighted', inline = 'E', group = 'Style')
equiCss    = color.gray //input(color.gray, 'Equi Color', group = 'Style')

//-----------------------------------------------------------------------------}
//CORE Initialization
//-----------------------------------------------------------------------------{
var CORE.Const CONST = CORE.Const.new()
var CORE.Theme THEME = CORE.Theme.new()
var CORE.Settings SETTINGS = CORE.Settings.new()

// Automated Timeframes & Lookback (Simple string logic bypassing compiler restrictions)
string htfPeriod = timeframe.period == "1" ? "5" : timeframe.period == "3" ? "15" : timeframe.period == "5" ? "15" : timeframe.period == "15" ? "60" : timeframe.period == "30" ? "60" : timeframe.period == "60" ? "240" : timeframe.period == "120" ? "240" : timeframe.period == "240" ? "1D" : timeframe.period == "D" or timeframe.period == "1D" ? "1W" : "1W" 

int lookback = SETTINGS.GLOBAL_MAX_LOOKBACK_BARS
int ltfSec = timeframe.in_seconds(timeframe.period)
int htfSec = timeframe.in_seconds(htfPeriod)
int tfRatio = int(math.max(htfSec / ltfSec, 1))
int htfLookback = int(lookback / tfRatio)

// Automated Colors from Theme
color supplyCss = THEME.COLOR_BEARISH
color demandCss = THEME.COLOR_BULLISH
color htfColor  = THEME.COLOR_HTF1
color bgColor   = color.new(THEME.COLOR_NEUTRAL, THEME.T_NORMAL)
bool showMTF = not na(htfPeriod)
string tf = "" // Intrabar TF automatically becomes smallest
string calcMode = "Lookback" // Switching to Lookback blocks the TV engine from resetting on pan
//-----------------------------------------------------------------------------}
//UDT's
//-----------------------------------------------------------------------------{
// UDT for volume bins (Renamed for kit reuse)
type VolumnNode
    float lvl
    float prev
    float sum
    float prev_sum
    float csum
    float avg
    bool isreached

type SDLevels
    float top
    float btm
    float avg

// Universal Zone Store (SMC Architecture)
var array<CORE.PDArray> activeZones = array.new<CORE.PDArray>()
var array<CORE.PDArray> zonePool = array.new<CORE.PDArray>()

f_get_zone(string _type, float _top, float _btm, int _start, float _avg, bool _isBull, string _lbl, int _ext, string _tf) =>
    CORE.PDArray z = na
    if array.size(zonePool) > 0
        z := array.pop(zonePool)
        z.type := _type, z.top := _top, z.bottom := _btm, z.barStart := _start, z.price := _avg
        z.isBullish := _isBull, z.labelText := _lbl, z.extendBars := _ext, z.sourceTf := _tf
    else
        z := CORE.PDArray.new(_type, _top, _btm, _start, false, false, na, na, na, na, _avg, false, _isBull, _lbl, _ext, 100.0)
        z.sourceTf := _tf
    z

// PDArray from CORE will be used for area storage
//-----------------------------------------------------------------------------}
f_is_overlapped(array<CORE.PDArray> z_array, float top, float btm, string targetTf) =>
    bool result = false
    if array.size(z_array) > 0
        for i = 0 to array.size(z_array) - 1
            CORE.PDArray z = array.get(z_array, i)
            // Only block if same TF and overlapping
            if z.sourceTf == targetTf and math.min(top, z.top) > math.max(btm, z.bottom)
                result := true
                break
    result

// PDArray from CORE will be used for area storage
//-----------------------------------------------------------------------------}
//Functions
//-----------------------------------------------------------------------------{
n = bar_index

get_hlv()=> [high, low, volume]

// Helper for HTF calculation
f_get_htf_s(_p, _d, _l) =>
    _mx = ta.highest(high, _l), _v = math.sum(volume, _l), _r = (_mx - ta.lowest(low, _l)) / _d
    _s_s = 0., _s_b = _mx, _s_t = _mx
    for _i = 0 to _d - 1
        _lv = _mx - (_i + 1) * _r, _pv = _mx - _i * _r, _bv = 0.
        for _j = 0 to _l - 1
            if high[_j] > _lv and high[_j] <= _pv
                _bv += volume[_j]
        _s_s += _bv
        if _s_s / _v * 100 > _p
            _s_b := _lv
            break
    SDLevels.new(_s_t, _s_b, math.avg(_s_t, _s_b))

f_get_htf_d(_p, _d, _l) =>
    _mn = ta.lowest(low, _l), _v = math.sum(volume, _l), _r = (ta.highest(high, _l) - _mn) / _d
    _d_s = 0., _d_t = _mn, _d_b = _mn
    for _i = 0 to _d - 1
        _lv = _mn + (_i + 1) * _r, _pv = _mn + _i * _r, _bv = 0.
        for _j = 0 to _l - 1
            if low[_j] >= _pv and low[_j] < _lv
                _bv += volume[_j]
        _d_s += _bv
        if _d_s / _v * 100 > _p
            _d_t := _lv
            break
    SDLevels.new(_d_t, _d_b, math.avg(_d_t, _d_b))

// --- DATA ACQUISITION (Hung-SMC Style) ---
// Now optimized to exactly 2 security calls since htfPeriod is natively evaluated as a simple string
h_s_obj = request.security(syminfo.tickerid, htfPeriod, f_get_htf_s(per, div, htfLookback))
h_d_obj = request.security(syminfo.tickerid, htfPeriod, f_get_htf_d(per, div, htfLookback))

h_s_top = not na(h_s_obj) ? h_s_obj.top : na, h_s_btm = not na(h_s_obj) ? h_s_obj.btm : na, h_s_avg = not na(h_s_obj) ? h_s_obj.avg : na
h_d_top = not na(h_d_obj) ? h_d_obj.top : na, h_d_btm = not na(h_d_obj) ? h_d_obj.btm : na, h_d_avg = not na(h_d_obj) ? h_d_obj.avg : na

[h_itf, l_itf, v_itf] = request.security_lower_tf(syminfo.tickerid, tf, get_hlv())

//-----------------------------------------------------------------------------}
//Main variables
//-----------------------------------------------------------------------------{
//-----------------------------------------------------------------------------{
//Main variables
//-----------------------------------------------------------------------------{
// Unified High/Low Management (Hung-SMC Style) replacing legacy visible range accumulator
float max  = ta.highest(high, lookback)
float min  = ta.lowest(low, lookback)
float csum = math.sum(volume, lookback)
int x1   = n - lookback

bool isEnd = barstate.islast

//-----------------------------------------------------------------------------}
//Set zones
//-----------------------------------------------------------------------------{
//-----------------------------------------------------------------------------}
// --- SR LOGIC METHODS ---
//-----------------------------------------------------------------------------{
var array<CORE.PDArray> activeSrZones = array.new<CORE.PDArray>()
var array<CORE.PDArray> srPool = array.new<CORE.PDArray>()

var CORE.TFData ltfData = CORE.TFData.new(timeframe.period, array.new_float(), array.new_int(), array.new_float(), array.new_int(), array.new_float(), array.new_int(), array.new_bool())
var CORE.TFData htf1Data = CORE.TFData.new(htfPeriod, array.new_float(), array.new_int(), array.new_float(), array.new_int(), array.new_float(), array.new_int(), array.new_bool())

get_data_sr() => 
    // Uses CORE logic for đỉnh đáy like Hung - SMC
    int baseLen = 10
    float currSh = ta.pivothigh(high, baseLen, baseLen)
    float currSl = ta.pivotlow(low, baseLen, baseLen)
    
    int htfMimicLen = int(math.max(baseLen * tfRatio, baseLen + 2))
    float htfSh = ta.pivothigh(high, htfMimicLen, htfMimicLen)
    float htfSl = ta.pivotlow(low, htfMimicLen, htfMimicLen)
    
    CORE.process_tf_armed_state(ltfData, true, currSh, not na(currSh) ? int(time[baseLen]) : na, currSl, not na(currSl) ? int(time[baseLen]) : na, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)
    CORE.process_tf_armed_state(htf1Data, true, htfSh, not na(htfSh) ? int(time[htfMimicLen]) : na, htfSl, not na(htfSl) ? int(time[htfMimicLen]) : na, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)

draw_data_sr() =>
    for z in activeSrZones
        bool isHtf = z.sourceTf != timeframe.period
        color baseC = z.isBullish ? THEME.COLOR_BULLISH : THEME.COLOR_BEARISH
        color c = isHtf ? htfColor : color.new(baseC, 30)
        CORE.ZoneVisualCfg zCfg = CORE.ZoneVisualCfg.new(textSize = isHtf ? size.small : size.tiny, textHAlign = text.align_right, textVAlign = text.align_center)
        CORE.PriceZoneLineVisualCfg lCfg = CORE.PriceZoneLineVisualCfg.new(lineStyle = line.style_dotted, lineWidth = 1)
        UI.draw_price_zone(z, z.barStart, n + z.extendBars, z.top, z.bottom, color.new(c, 85), c, line.style_dotted, z.labelText, c, "", n + z.extendBars, (z.top + z.bottom) / 2.0, zCfg, lCfg, false, true, z.price, c, "LINE")

f_process_tf_sr(CORE.TFData _msData, float _maxRange, float _minRange, bool _isHtf) =>
    int rCount = array.size(_msData.swingHighPrices)
    int sCount = array.size(_msData.swingLowPrices)
    
    if (rCount > 0 or sCount > 0) and div > 0
        float sR = (_maxRange - _minRange) / div
        if sR > 0
            array<float> rProf = array.new_float(div, 0.0)
            array<float> sProf = array.new_float(div, 0.0)
            
            int safeBarsBack = bar_index < lookback ? bar_index : lookback
            int cutoffTime = time[safeBarsBack]
            
            if rCount > 0
                for i = 0 to rCount - 1
                    if array.get(_msData.swingHighTimes, i) >= cutoffTime
                        float p = array.get(_msData.swingHighPrices, i)
                        int bin = int((_maxRange - p) / sR)
                        bin := bin >= div ? div - 1 : bin
                        if bin >= 0 and bin < div
                            array.set(rProf, bin, array.get(rProf, bin) + 1.0)
                            
            if sCount > 0
                for i = 0 to sCount - 1
                    if array.get(_msData.swingLowTimes, i) >= cutoffTime
                        float p = array.get(_msData.swingLowPrices, i)
                        int bin = int((p - _minRange) / sR)
                        bin := bin >= div ? div - 1 : bin
                        if bin >= 0 and bin < div
                            array.set(sProf, bin, array.get(sProf, bin) + 1.0)
                        
            float reqDensity = _isHtf ? 1.0 : 2.0
            
            // Evaluate resistance using Local Peak Detection
            for b = 1 to div - 2
                float v = array.get(rProf, b)
                float vPrev = array.get(rProf, b - 1)
                float vNext = array.get(rProf, b + 1)
                
                if v >= reqDensity and v > vPrev and v >= vNext // Peak detected!
                    float top = _maxRange - b * sR
                    float btm = _maxRange - (b + 1) * sR
                    string targetTf = _isHtf ? htfPeriod : timeframe.period
                    if not f_is_overlapped(activeSrZones, top + sR * 2, btm - sR * 2, targetTf)
                        float lPrice = math.avg(top, btm)
                        bool isBull = lPrice <= close
                        CORE.PDArray z = f_get_zone("RES", top, btm, x1, lPrice, isBull, isBull ? "S" : "R", _isHtf ? 15 : 5, targetTf)
                        array.push(activeSrZones, z)
                        
            for b = 1 to div - 2
                float v = array.get(sProf, b)
                float vPrev = array.get(sProf, b - 1)
                float vNext = array.get(sProf, b + 1)
                
                if v >= reqDensity and v > vPrev and v >= vNext // Peak detected!
                    float btm = _minRange + b * sR
                    float top = _minRange + (b + 1) * sR
                    string targetTf = _isHtf ? htfPeriod : timeframe.period
                    if not f_is_overlapped(activeSrZones, top + sR * 2, btm - sR * 2, targetTf)
                        float lPrice = math.avg(top, btm)
                        bool isBull = lPrice <= close
                        CORE.PDArray z = f_get_zone("SUP", top, btm, x1, lPrice, isBull, isBull ? "S" : "R", _isHtf ? 15 : 5, targetTf)
                        array.push(activeSrZones, z)

process_data_sr(bool _isEnd, float _maxRange, float _minRange) =>
    if _isEnd
        while array.size(activeSrZones) > 0
            array.push(srPool, array.pop(activeSrZones))
            
        f_process_tf_sr(ltfData, _maxRange, _minRange, false)
        if showMTF
            f_process_tf_sr(htf1Data, _maxRange, _minRange, true)
            
        draw_data_sr()
        
        for pZ in srPool
            if not na(pZ.visualBox)
                pZ.visualBox.delete(), pZ.visualBox := na
            if not na(pZ.visualLine)
                pZ.visualLine.delete(), pZ.visualLine := na
            if not na(pZ.visualLabel)
                pZ.visualLabel.delete(), pZ.visualLabel := na

//-----------------------------------------------------------------------------}
// --- S/D LOGIC METHODS ---
//-----------------------------------------------------------------------------{

var float supply_wavg = na
var float demand_wavg = na
var equi  = line.new(na, na, na, na, color = equiCss)
var wequi = line.new(na, na, na, na, color = equiCss, style = line.style_dashed)

// --- RENDERING (Hung-SMC Style) ---
draw_data_sd() =>
    for z in activeZones
        bool isHtf = z.sourceTf != timeframe.period
        color c = isHtf ? htfColor : (z.type == "SP" ? supplyCss : demandCss)
        CORE.ZoneVisualCfg zCfg = CORE.ZoneVisualCfg.new(textSize = isHtf ? size.small : size.tiny, textHAlign = text.align_right, textVAlign = text.align_center)
        CORE.PriceZoneLineVisualCfg lCfg = CORE.PriceZoneLineVisualCfg.new(lineStyle = line.style_dotted, lineWidth = 1)
        UI.draw_price_zone(z, z.barStart, n + z.extendBars, z.top, z.bottom, bgColor, c, line.style_dotted, z.labelText, c, "", n + z.extendBars, (z.top + z.bottom) / 2.0, zCfg, lCfg, z.type == "SP" ? supplyArea : demandArea, false, z.price, c)


// --- PROCESSING (Hung-SMC Style) ---
process_data_sd(bool _isEnd, int _win, int _x1, float _hST, float _hSB, float _hSA, float _hDT, float _hDB, float _hDA, float[] _h_itf, float[] _l_itf, float[] _v_itf) =>
    if _isEnd
        // Move all active zones to pool instead of deleting to prevent flickering
        while array.size(activeZones) > 0
            array.push(zonePool, array.pop(activeZones))
        
        // HTF Zones
        if showMTF
            float h_l = calcMode == "Visible Range" ? _x1 : (n - lookback)
            if not f_is_overlapped(activeZones, _hST, _hSB, htfPeriod)
                CORE.PDArray hs = f_get_zone("SP", _hST, _hSB, int(h_l), _hSA, false, "S", 15, htfPeriod)
                array.push(activeZones, hs)
            if not f_is_overlapped(activeZones, _hDT, _hDB, htfPeriod)
                CORE.PDArray hd = f_get_zone("DM", _hDT, _hDB, int(h_l), _hDA, true, "D", 15, htfPeriod)
                array.push(activeZones, hd)
        
        // LTF Steps (Optimized Single-Pass)
        for i = 0 to subSteps - 1
            int sIdx = subSteps - i
            int sLen = int(_win * (float(sIdx) / subSteps))
            if sLen >= 5
                int sOff = _win - sLen
                
                // Get exact Price Boundaries & Total Volume
                float sMax = -1e10, float sMin = 1e10, float sCsum = 0.
                for idx = sOff to _win - 1
                    int hist = _win - 1 - idx
                    sMax := math.max(high[hist], sMax)
                    sMin := math.min(low[hist], sMin)
                    sCsum += volume[hist]
                
                if sCsum > 0
                    float sR = (sMax - sMin) / div
                    if sR > 0
                        // Build Profiles using EXACT same historical window
                        array<float> sProf = array.new_float(div, 0.0), array<float> dProf = array.new_float(div, 0.0)
                        for idx = sOff to _win - 1
                            int hist = _win - 1 - idx
                            array<float> hist_v = _v_itf[hist]
                            array<float> hist_h = _h_itf[hist]
                            array<float> hist_l = _l_itf[hist]
                            
                            int sz = na(hist_v) ? 0 : array.size(hist_v)
                            if sz > 0
                                for k = 0 to sz - 1
                                    float v_ = array.get(hist_v, k)
                                    float h_ = array.get(hist_h, k)
                                    float l_ = array.get(hist_l, k)
                                    int sBin = int((sMax - h_) / sR)
                                    int dBin = int((l_ - sMin) / sR)
                                    sBin := sBin >= div ? div - 1 : sBin
                                    dBin := dBin >= div ? div - 1 : dBin
                                    if sBin >= 0 and sBin < div 
                                        array.set(sProf, sBin, array.get(sProf, sBin) + v_)
                                    if dBin >= 0 and dBin < div
                                        array.set(dProf, dBin, array.get(dProf, dBin) + v_)
                            else
                                // Fallback to macro bar if intrabar is missing
                                float v_ = volume[hist], h_ = high[hist], l_ = low[hist]
                                int sBin = int((sMax - h_) / sR)
                                int dBin = int((l_ - sMin) / sR)
                                sBin := sBin >= div ? div - 1 : sBin
                                dBin := dBin >= div ? div - 1 : dBin
                                if sBin >= 0 and sBin < div 
                                    array.set(sProf, sBin, array.get(sProf, sBin) + v_)
                                if dBin >= 0 and dBin < div
                                    array.set(dProf, dBin, array.get(dProf, dBin) + v_)

                        
                        // Find Thresholds
                        float sAcc = 0.0, float dAcc = 0.0
                        for b = 0 to div - 1
                            sAcc += array.get(sProf, b)
                            if sAcc / sCsum * 100 > per
                                float top = sMax, float btm = sMax - (b + 1) * sR
                                if not f_is_overlapped(activeZones, top, btm, timeframe.period)
                                    CORE.PDArray z = f_get_zone("SP", top, btm, n - _win + sOff, math.avg(top, btm), false, "S", 5, timeframe.period)
                                    array.push(activeZones, z)
                                break
                        
                        for b = 0 to div - 1
                            dAcc += array.get(dProf, b)
                            if dAcc / sCsum * 100 > per
                                float btm = sMin, float top = sMin + (b + 1) * sR
                                if not f_is_overlapped(activeZones, top, btm, timeframe.period)
                                    CORE.PDArray z = f_get_zone("DM", top, btm, n - _win + sOff, math.avg(top, btm), true, "D", 5, timeframe.period)
                                    array.push(activeZones, z)
                                break
        draw_data_sd()
        
        // Hide unused zones in pool
        for pZ in zonePool
            if not na(pZ.visualBox)
                pZ.visualBox.delete()
                pZ.visualBox := na
            if not na(pZ.visualLine)
                pZ.visualLine.delete()
                pZ.visualLine := na
            if not na(pZ.visualLabel)
                pZ.visualLabel.delete()
                pZ.visualLabel := na

// EXECUTION
get_data_sr()

if isEnd
    process_data_sd(isEnd, n - x1, x1, h_s_top, h_s_btm, h_s_avg, h_d_top, h_d_btm, h_d_avg, h_itf, l_itf, v_itf)
    process_data_sr(isEnd, max, min)

if isEnd and showEqui
    if equiAvg
        avg_val = math.avg(max, min)
        equi.set_xy1(x1, avg_val), equi.set_xy2(n, avg_val)
    if equiWavg and not na(supply_wavg) and not na(demand_wavg)
        wavg_val = math.avg(supply_wavg, demand_wavg)
        wequi.set_xy1(x1, wavg_val), wequi.set_xy2(n, wavg_val)
//-----------------------------------------------------------------------------}
