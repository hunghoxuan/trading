//@version=6
indicator('HungMagic PRO V6', overlay = true)

// --- Khai báo Inputs (Giữ nguyên từ bản trước) ---
grp_risk = "Quản Lý Vốn"
sl_points = input.float(10.0, 'Khoảng cách SL', group = grp_risk)
t1_points = input.float(10.0, 'TP1', group = grp_risk)
t2_points = input.float(20.0, 'TP2', group = grp_risk)
t3_points = input.float(30.0, 'TP3', group = grp_risk)
auto_be   = input.bool(true, "Dời SL về Entry khi chạm TP1", group = grp_risk)

grp_signal = "EMA & RSI"
ema_fast_len = input.int(9, 'EMA Nhanh', group = grp_signal)
ema_slow_len = input.int(21, 'EMA Chậm', group = grp_signal)
rsi_len      = input.int(14, 'RSI Length', group = grp_signal)
rsi_max_buy  = input.int(65, 'RSI Max BUY', group = grp_signal)
rsi_min_sell = input.int(35, 'RSI Min SELL', group = grp_signal)

// --- Tính toán ---
ma_fast = ta.ema(close, ema_fast_len)
ma_slow = ta.ema(close, ema_slow_len)
rsi_val = ta.rsi(close, rsi_len)

// --- Biến lưu trữ (Sử dụng var để không bị reset mỗi nến) ---
var int total_trades = 0
var int tp1_hits = 0
var int tp2_hits = 0
var int tp3_hits = 0
var int sl_hits  = 0
var int be_hits  = 0
var bool in_trade = false
var int trade_dir = 0 
var float entry_p = 0.0, var float sl_p = 0.0
var float tp1_p = 0.0, var float tp2_p = 0.0, var float tp3_p = 0.0
var bool is_be = false
var bool hit_tp1_already = false
var bool hit_tp2_already = false

var line ln_sl = na, var line ln_tp1 = na, var line ln_tp2 = na, var line ln_tp3 = na, var line ln_ep = na
var box bx_entry = na
var label lb_entry = na

// --- Logic Tín Hiệu ---
buy_sig  = ta.crossover(ma_fast, ma_slow) and rsi_val < rsi_max_buy
sell_sig = ta.crossunder(ma_fast, ma_slow) and rsi_val > rsi_min_sell

if (buy_sig or sell_sig) and not in_trade
    in_trade := true
    is_be := false
    hit_tp1_already := false
    hit_tp2_already := false
    trade_dir := buy_sig ? 1 : -1
    entry_p := close
    sl_p  := buy_sig ? entry_p - sl_points : entry_p + sl_points
    tp1_p := buy_sig ? entry_p + t1_points : entry_p - t1_points
    tp2_p := buy_sig ? entry_p + t2_points : entry_p - t2_points
    tp3_p := buy_sig ? entry_p + t3_points : entry_p - t3_points
    total_trades += 1
    
    color_main = buy_sig ? color.blue : color.red
    ln_ep  := line.new(bar_index, entry_p, bar_index + 1, entry_p, color=color_main, width=2, style=line.style_dashed)
    ln_sl  := line.new(bar_index, sl_p, bar_index + 1, sl_p, color=color.red, width=2)
    ln_tp1 := line.new(bar_index, tp1_p, bar_index + 1, tp1_p, color=color.new(color.green, 50), width=1)
    ln_tp2 := line.new(bar_index, tp2_p, bar_index + 1, tp2_p, color=color.new(color.green, 50), width=1)
    ln_tp3 := line.new(bar_index, tp3_p, bar_index + 1, tp3_p, color=color.green, width=2)
    lb_entry := label.new(bar_index + 1, entry_p, (buy_sig ? "BUY: " : "SELL: ") + str.tostring(entry_p, format.mintick), color=color_main, textcolor=color.white, style=label.style_label_left, size=size.small)
    bx_entry := box.new(bar_index, entry_p, bar_index + 1, sl_p, bgcolor=color.new(color_main, 90), border_color=na)

// --- Quản lý lệnh đang chạy (FIX LỖI ẢNH 1 & 2) ---
if in_trade
    line.set_x2(ln_ep, bar_index + 1)
    line.set_x2(ln_sl, bar_index + 1)
    line.set_x2(ln_tp1, bar_index + 1)
    line.set_x2(ln_tp2, bar_index + 1)
    line.set_x2(ln_tp3, bar_index + 1)
    box.set_right(bx_entry, bar_index + 1)
    label.set_x(lb_entry, bar_index + 1)

    // Kiểm tra TP1 & Dời SL (Thụt lề chuẩn)
    if not hit_tp1_already and (trade_dir == 1 ? high >= tp1_p : low <= tp1_p)
        hit_tp1_already := true
        tp1_hits += 1
        if auto_be
            is_be := true
            sl_p := entry_p
            line.set_y1(ln_sl, sl_p) // Fix lỗi line.set_y
            line.set_y2(ln_sl, sl_p) // Thụt lề thẳng hàng
            label.new(bar_index, high, "TP1: BE 🛡️", color=color.orange, style=label.style_label_down, size=size.tiny)

    if not hit_tp2_already and (trade_dir == 1 ? high >= tp2_p : low <= tp2_p)
        hit_tp2_already := true
        tp2_hits += 1

    hit_tp3 = trade_dir == 1 ? high >= tp3_p : low <= tp3_p
    hit_sl  = trade_dir == 1 ? low <= sl_p   : high >= sl_p

    if hit_tp3
        tp3_hits += 1
        label.new(bar_index, tp3_p, "TP3 WIN ✅", color=color.green, textcolor=color.white)
        in_trade := false
    else if hit_sl
        if is_be
            be_hits += 1
        else
            sl_hits += 1
        label.new(bar_index, sl_p, is_be ? "BE HIT 🤝" : "SL HIT ❌", color=is_be ? color.gray : color.red, textcolor=color.white)
        in_trade := false

    if not in_trade
        line.delete(ln_ep), line.delete(ln_sl), line.delete(ln_tp1), line.delete(ln_tp2), line.delete(ln_tp3)
        box.delete(bx_entry), label.delete(lb_entry)

// --- Dashboard (Thống kê theo yêu cầu) ---
var table st = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.gray)
if barstate.islast
    table.cell(st, 0, 0, "THỐNG KÊ", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(st, 1, 0, "SỐ LẦN", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(st, 0, 1, "Tổng tín hiệu", text_color=color.white)
    table.cell(st, 1, 1, str.tostring(total_trades), text_color=color.yellow)
    table.cell(st, 0, 2, "Chạm TP1", text_color=color.lime)
    table.cell(st, 1, 2, str.tostring(tp1_hits), text_color=color.lime)
    table.cell(st, 0, 3, "Chạm TP2", text_color=color.green)
    table.cell(st, 1, 3, str.tostring(tp2_hits), text_color=color.green)
    table.cell(st, 0, 4, "Chạm TP3 (Win)", text_color=color.aqua)
    table.cell(st, 1, 4, str.tostring(tp3_hits), text_color=color.aqua)
    table.cell(st, 0, 5, "Chạm SL (Thua)", text_color=color.red)
    table.cell(st, 1, 5, str.tostring(sl_hits), text_color=color.red)
    table.cell(st, 0, 6, "Hòa vốn (BE)", text_color=color.orange)
    table.cell(st, 1, 6, str.tostring(be_hits), text_color=color.orange)

// --- Vẽ EMA (FIX LỖI ẢNH 3: Xóa transp) ---
plot(ma_fast, "EMA Nhanh", color=color.new(color.blue, 50)) // Dùng color.new thay cho transp
plot(ma_slow, "EMA Chậm", color=color.new(color.red, 50))