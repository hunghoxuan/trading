// Helper (Strategy): True if strategy should be evaluated on current TF seconds.
is_strategy_applicable(LIB.Strategy s, int tfSec) =>
    s.tfSecMin == STRAT_TF_ANY or (tfSec >= s.tfSecMin and tfSec <= s.tfSecMax)

// Helper (Strategy): Builds the strategy list based on docs/features/STRATEGIES.md.
init_data_strategies() =>
    array<LIB.Strategy> out = array.new<LIB.Strategy>()
    int tf1m = LIB.get_tf_seconds("1")
    int tf5m = LIB.get_tf_seconds("5")
    int tf15m = LIB.get_tf_seconds("15")
    int tf1h = LIB.get_tf_seconds("60")
    int tf4h = LIB.get_tf_seconds("240")
    int tf1d = LIB.get_tf_seconds("1D")
    int tf1w = LIB.get_tf_seconds("1W")
    array.push(out, LIB.Strategy.new(STRAT_ID_VWAP_EMA_CROSS, "VWAP bias + EMA momentum cross", "vwap", tf1m, tf1m, "Bias is price above/below VWAP; enter when EMA(9) crosses EMA(21) in the bias direction.", 9))
    array.push(out, LIB.Strategy.new(STRAT_ID_EMA_STOCH_PULLBACK, "EMA trend + pullback mean reversion", "stoch", tf5m, tf5m, "Bias from EMA(50) slope; enter on pullback to EMA(21) plus Stoch cross from oversold/overbought in bias direction.", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_EMA200_BB_SQUEEZE, "EMA200 regime + volatility breakout", "bb", tf15m, tf1h, "Bias is price vs EMA(200) and RSI vs 50; enter after BB squeeze then close outside bands in bias direction.", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_ICHIMOKU_MACD_FLIP, "Ichimoku regime + MACD momentum flip", "ichi", tf4h, tf4h, "Bias is price above/below Kumo; enter when MACD histogram flips while price is outside cloud.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_FIB_PULLBACK, "Macro trend + fib pullback", "fib", tf1d, tf1d, "Bias from 50/200 cross plus swing structure; enter on pullback to 0.618 after trend confirmation.", 5))
    array.push(out, LIB.Strategy.new(STRAT_ID_SMA200_DIVERGENCE, "SMA200 macro anchor + divergence reversal", "div", tf1w, tf1w, "Bias from SMA(200) slope; enter on RSI divergence at/near SMA(200) contact.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_ADX_EMA_CROSS, "ADX + EMA crossover trend system", "adx", STRAT_TF_ANY, STRAT_TF_ANY, "Enter when EMA(20) crosses EMA(50) and ADX crosses above 25; exit on reverse EMA cross or ADX falling below 25.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_SWEEP, "Swing sweep reclaim", "swp", STRAT_TF_ANY, STRAT_TF_ANY, "Wick sweeps nearest swing liquidity then closes back through level (reclaim).", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_CANDLE_PATTERN, "Candle pattern bias alignment", "CP", STRAT_TF_ANY, STRAT_TF_ANY, "Score-3+ candle pattern (Engulfing/Marubozu/Star/3-line) aligned with composite MTF bias. Volume confirmation boosts conviction.", 8))
    array.push(out, LIB.Strategy.new(STRAT_ID_GOLDEN_DEATH_CROSS, "Golden/Death cross (macro alignment)", "gdc", tf1d, tf1w, "Use EMA(50)/EMA(200) cross as macro trend alignment; treat cross events as regime shift signals.", 5))
    array.push(out, LIB.Strategy.new(STRAT_ID_XYZ_BIAS_STACK, "XYZ bias stack confluence", "xyz", STRAT_TF_ANY, STRAT_TF_ANY, "EMA/SMA stack + RSI + VWAP alignment. Fires only when local XYZ bias agrees with composite bias.", 6))
    array.push(out, LIB.Strategy.new(STRAT_ID_TPG_RSI_SCALP, "TPG RSI Scalping", "rsi", STRAT_TF_ANY, STRAT_TF_ANY, "RSI OB/OS + engulfing/hammer/shooting/two-bars price-action trigger from TPG RSI scalping model.", 7))
    array.push(out, LIB.Strategy.new(STRAT_ID_CONFLUENCE_VRHS, "Confluence", "CF", STRAT_TF_ANY, STRAT_TF_ANY, "Confluence of multiple active winning strategies; gated by MTF composite bias.", 10))
    out

var array<LIB.Strategy> STRATEGIES = init_data_strategies()

// Helper: Full-history mode when perfLookbackBars <= 0.
is_in_draw_window() =>
    perfLookbackBars <= 0 or LIB.is_in_draw_lookback_current(perfLookbackBars)

// Helper: Short signal/context window.
is_in_signal_window() =>
    LIB.is_in_draw_lookback_current(signalContextBars)

// ==================== FEATURE: XYZ BIAS STACK ====================
get_data_xyz_stack() =>
    bool tfScalp = timeframe.period == "1" or timeframe.period == "3" or timeframe.period == "5"
    bool tfM15 = timeframe.period == "15"
    bool tfH1H4 = timeframe.period == "60" or timeframe.period == "240"

    float emaS = tfScalp ? ta.ema(close, 5) : tfM15 ? ta.ema(close, 9) : tfH1H4 ? ta.ema(close, 21) : ta.ema(close, 50)
    float emaN = tfScalp ? ta.ema(close, 13) : tfM15 ? ta.ema(close, 21) : tfH1H4 ? ta.ema(close, 55) : ta.ema(close, 100)
    float emaL = tfScalp ? ta.ema(close, 34) : tfM15 ? ta.ema(close, 89) : tfH1H4 ? ta.ema(close, 200) : ta.ema(close, 200)
    float smaS = tfScalp ? ta.sma(close, 10) : tfM15 ? ta.sma(close, 20) : tfH1H4 ? ta.sma(close, 50) : ta.sma(close, 100)
    float smaN = tfScalp ? ta.sma(close, 20) : tfM15 ? ta.sma(close, 50) : tfH1H4 ? ta.sma(close, 100) : ta.sma(close, 200)
    float smaL = tfScalp ? ta.sma(close, 50) : tfM15 ? ta.sma(close, 200) : tfH1H4 ? ta.sma(close, 200) : ta.sma(close, 300)
    float rsiS = tfScalp ? ta.rsi(close, 7) : tfM15 ? ta.rsi(close, 9) : tfH1H4 ? ta.rsi(close, 14) : ta.rsi(close, 14)
    float rsiN = tfScalp ? ta.rsi(close, 14) : tfM15 ? ta.rsi(close, 14) : tfH1H4 ? ta.rsi(close, 21) : ta.rsi(close, 21)
    float rsiL = tfScalp ? ta.rsi(close, 21) : tfM15 ? ta.rsi(close, 28) : tfH1H4 ? ta.rsi(close, 28) : ta.rsi(close, 35)
    float vwapVal = ta.vwap(hlc3)

    int bull = 0
    int bear = 0
    if emaS > emaN and emaN > emaL and close > emaL
        bull += 1
    else if emaS < emaN and emaN < emaL and close < emaL
        bear += 1
    if smaS > smaN and smaN > smaL and close > smaL
        bull += 1
    else if smaS < smaN and smaN < smaL and close < smaL
        bear += 1
    if rsiN > 50
        bull += 1
    else if rsiN < 50
        bear += 1
    if close > vwapVal
        bull += 1
    else if close < vwapVal
        bear += 1

    int biasDir = bull > bear * 1.5 ? 1 : bear > bull * 1.5 ? -1 : 0
    string biasText = biasDir == 1 ? "BULLISH" : biasDir == -1 ? "BEARISH" : "NEUTRAL"
    bool buyCond = emaS > emaN and emaN > emaL and close > emaL and rsiN > 50 and close > vwapVal
    bool sellCond = emaS < emaN and emaN < emaL and close < emaL and rsiN < 50 and close < vwapVal
    [emaS, emaN, emaL, smaS, smaN, smaL, rsiS, rsiN, rsiL, vwapVal, bull, bear, biasDir, biasText, buyCond, sellCond]

draw_data_xyz_markers(bool show, int biasDir, string biasText, float emaS, float rsiN, float vwapVal, bool buyCond, bool sellCond) =>
    if show
        color biasColor = biasDir == 1 ? THEME.COLOR_BULLISH : biasDir == -1 ? THEME.COLOR_BEARISH : THEME.COLOR_NEUTRAL
        if barstate.islast
            if biasDir == 1
                label.new(bar_index, low, "↑AA", color = biasColor, style = label.style_label_up, textcolor = color.white, tooltip = "XYZ Bias: BULLISH\nEMA Short: " + str.tostring(emaS) + "\nRSI Normal: " + str.tostring(rsiN) + "\nVWAP: " + str.tostring(vwapVal))
            else if biasDir == -1
                label.new(bar_index, high, "↓AA", color = biasColor, style = label.style_label_down, textcolor = color.white, tooltip = "XYZ Bias: BEARISH\nEMA Short: " + str.tostring(emaS) + "\nRSI Normal: " + str.tostring(rsiN) + "\nVWAP: " + str.tostring(vwapVal))
        if buyCond and is_in_signal_window()
            label.new(bar_index, low, "B▲", color = THEME.COLOR_BULLISH, style = label.style_label_up, textcolor = color.white, tooltip = "XYZ BUY\nBias: " + biasText + "\nEMA Short: " + str.tostring(emaS) + "\nRSI: " + str.tostring(rsiN) + "\nPrice > VWAP")
        if sellCond and is_in_signal_window()
            label.new(bar_index, high, "S▼", color = THEME.COLOR_BEARISH, style = label.style_label_down, textcolor = color.white, tooltip = "XYZ SELL\nBias: " + biasText + "\nEMA Short: " + str.tostring(emaS) + "\nRSI: " + str.tostring(rsiN) + "\nPrice < VWAP")
    bool(na)

[xyzEmaS, xyzEmaN, xyzEmaL, _xyzSmaS, _xyzSmaN, _xyzSmaL, _xyzRsiS, xyzRsiN, _xyzRsiL, xyzVwap, xyzBull, xyzBear, xyzBiasDir, xyzBiasText, xyzBuyCond, xyzSellCond] = get_data_xyz_stack()
bool xyzShow = dispXyz != CONST.DISP_NONE
plot(xyzEmaS, "XYZ EMA Short", color = xyzShow ? color.new(THEME.COLOR_LTF, 60) : na, linewidth = 1)
plot(xyzEmaN, "XYZ EMA Normal", color = xyzShow ? color.new(THEME.COLOR_HTF1, 60) : na, linewidth = 1)
plot(xyzEmaL, "XYZ EMA Long", color = xyzShow ? color.new(THEME.COLOR_HTF2, 70) : na, linewidth = 1)
plot(xyzVwap, "XYZ VWAP", color = xyzShow ? color.new(color.blue, 40) : na, linewidth = 2)
draw_data_xyz_markers(xyzShow and dispXyz == CONST.DISP_MARKER, xyzBiasDir, xyzBiasText, xyzEmaS, xyzRsiN, xyzVwap, xyzBuyCond, xyzSellCond)
color xyzBg = xyzShow and dispXyz == CONST.DISP_MARKER ? (xyzBiasDir == 1 ? color.new(THEME.COLOR_BULLISH, 95) : xyzBiasDir == -1 ? color.new(THEME.COLOR_BEARISH, 95) : na) : na
bgcolor(xyzBg)

get_data_market_structure(string htf1, string htf2, int currPivotLen) =>
    int maxSafeHistOff = 90
    int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
    int htf1MimicPivotLenRaw = not na(htf1) ? LIB.get_mimic_pivot_len(timeframe.period, htf1, currPivotLen, 15, 12, 8, 6, 4) : na
    int htf1MimicPivotLen = not na(htf1MimicPivotLenRaw) ? math.max(htf1MimicPivotLenRaw, currPivotLen + 2) : na
    int htf2MimicPivotLenRaw = not na(htf2) ? LIB.get_mimic_pivot_len(timeframe.period, htf2, currPivotLen, 15, 12, 8, 6, 4) : na
    int htf2Floor = not na(htf1MimicPivotLen) ? htf1MimicPivotLen + 2 : currPivotLen + 4
    int htf2MimicPivotLen = not na(htf2MimicPivotLenRaw) ? math.max(htf2MimicPivotLenRaw, htf2Floor) : na
    int htf1PivotOffSafe = not na(htf1MimicPivotLen) ? math.max(0, math.min(htf1MimicPivotLen, maxSafeHistOff)) : na
    int htf2PivotOffSafe = not na(htf2MimicPivotLen) ? math.max(0, math.min(htf2MimicPivotLen, maxSafeHistOff)) : na
    float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
    float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
    int htf1LenSafe = not na(htf1MimicPivotLen) ? htf1MimicPivotLen : currPivotLen
    float sh1Raw = ta.pivothigh(high, htf1LenSafe, htf1LenSafe)
    float sl1Raw = ta.pivotlow(low, htf1LenSafe, htf1LenSafe)
    float sh1Mimic = not na(htf1MimicPivotLen) ? sh1Raw : na
    float sl1Mimic = not na(htf1MimicPivotLen) ? sl1Raw : na
    int sh1MimicT = not na(sh1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
    int sl1MimicT = not na(sl1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
    int htf2LenSafe = not na(htf2MimicPivotLen) ? htf2MimicPivotLen : currPivotLen
    float sh2Raw = ta.pivothigh(high, htf2LenSafe, htf2LenSafe)
    float sl2Raw = ta.pivotlow(low, htf2LenSafe, htf2LenSafe)
    float sh2Mimic = not na(htf2MimicPivotLen) ? sh2Raw : na
    float sl2Mimic = not na(htf2MimicPivotLen) ? sl2Raw : na
    int sh2MimicT = not na(sh2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
    int sl2MimicT = not na(sl2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
    [currSh, currSl, currPivotOffSafe, sh1Mimic, sl1Mimic, sh1MimicT, sl1MimicT, sh2Mimic, sl2Mimic, sh2MimicT, sl2MimicT]

// Keep swing ledgers only (no Market Structure visuals in Hung - Core).
process_data_ms_swing_ledgers(string htf1, string htf2, float currSh, float currSl, int currPivotOffSafe, float sh1Mimic, float sl1Mimic, int sh1MimicT, int sl1MimicT, float sh2Mimic, float sl2Mimic, int sh2MimicT, int sl2MimicT) =>
    LIB.process_tf_armed_state(msLtfData, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, SETTINGS.SWING_HISTORY_MAX)
    LIB.process_tf_armed_state(msHtf1Data, not na(htf1), sh1Mimic, int(sh1MimicT), sl1Mimic, int(sl1MimicT), SETTINGS.SWING_HISTORY_MAX)
    LIB.process_tf_armed_state(msHtf2Data, not na(htf2), sh2Mimic, int(sh2MimicT), sl2Mimic, int(sl2MimicT), SETTINGS.SWING_HISTORY_MAX)
    bool(na)

// Helper (Strategy): Return display mode for a strategy ID.
get_data_strategy_disp(int stratId) =>
    stratId == STRAT_ID_VWAP_EMA_CROSS     ? dispVwapEma :
     stratId == STRAT_ID_EMA_STOCH_PULLBACK ? dispEmaStoch :
     stratId == STRAT_ID_EMA200_BB_SQUEEZE  ? dispEmaBb :
     stratId == STRAT_ID_ICHIMOKU_MACD_FLIP ? dispIchMacd :
     stratId == STRAT_ID_FIB_PULLBACK       ? dispFib :
     stratId == STRAT_ID_SMA200_DIVERGENCE  ? dispSmaDiv :
     stratId == STRAT_ID_ADX_EMA_CROSS      ? dispAdxEma :
     stratId == STRAT_ID_SWEEP              ? dispSweep :
     stratId == STRAT_ID_CANDLE_PATTERN     ? dispCpBias :
     stratId == STRAT_ID_GOLDEN_DEATH_CROSS ? dispGdCross :
     stratId == STRAT_ID_XYZ_BIAS_STACK     ? dispXyz :
     stratId == STRAT_ID_TPG_RSI_SCALP      ? dispTpgRsi :
     stratId == STRAT_ID_CONFLUENCE_VRHS    ? dispConfluence : CONST.DISP_NONE

// Helper (Strategy): Enabled when display mode is not None.
get_data_strategy_enabled(int stratId) =>
    get_data_strategy_disp(stratId) != CONST.DISP_NONE

// ==================== FEATURE: BIAS CONFLUENCE ====================

// Bias toggle config: built once from input booleans, reused in get_bias_data.
BIAS_TOG = LIB.BiasToggles.new(true, true, true, true, true, true, true, true)


process_htf_candle_panel() =>
    [htf1, htf2] = LIB.get_htf_pair()
    [_o1, _h1, _l1, _c1, _htfPat1] = LIB.get_data_htf_candles(htf1)
    [_o2, _h2, _l2, _c2, _htfPat2] = LIB.get_data_htf_candles(htf2)
    [slot_tf_0, slot_tf_1, slot_count_0, slot_count_1, show_0, show_1, off_0, off_1, need_reset_0, need_reset_1] = UI.get_data_htf_candle_layout(htf1, htf2, SETTINGS.HTF_CANDLES_BASE, SETTINGS.HTF_CANDLES_BIAS1, prev_slot_tf_0, prev_slot_tf_1, 25, HTF_CANDLE_LAYOUT_CFG)
    [nextHtfLabel0, nextHtfLabel1] = UI.process_data_htf_candles(htf1_candles, htf2_candles, htfLabel0, htfLabel1, slot_tf_0, slot_tf_1, slot_count_0, slot_count_1, show_0, show_1, off_0, off_1, need_reset_0, need_reset_1, _o1, _h1, _l1, _c1, _htfPat1, _o2, _h2, _l2, _c2, _htfPat2, THEME.COLOR_HTF1, THEME.COLOR_HTF2, THEME, HTF_CANDLE_VIS_CFG)
    [nextHtfLabel0, nextHtfLabel1, slot_tf_0, slot_tf_1]

// Bias table is merged into trades dashboard row (draw_data_trades_dashboard).
[nextHtfLabel0, nextHtfLabel1, nextSlotTf0, nextSlotTf1] = process_htf_candle_panel()
htfLabel0 := nextHtfLabel0
htfLabel1 := nextHtfLabel1
prev_slot_tf_0 := nextSlotTf0
prev_slot_tf_1 := nextSlotTf1

[msHtf1, msHtf2] = LIB.get_htf_pair()
[_currSh, _currSl, _currPivotOffSafe, _sh1Mimic, _sl1Mimic, _sh1MimicT, _sl1MimicT, _sh2Mimic, _sl2Mimic, _sh2MimicT, _sl2MimicT] = get_data_market_structure(msHtf1, msHtf2, 10)
process_data_ms_swing_ledgers(msHtf1, msHtf2, _currSh, _currSl, _currPivotOffSafe, _sh1Mimic, _sl1Mimic, _sh1MimicT, _sl1MimicT, _sh2Mimic, _sl2Mimic, _sh2MimicT, _sl2MimicT)

ctxDataCfg.needBias := true
ctxDataCfg.needMsTrendDirs := true
ctxDataCfg.needPdPw := false
ctxDataCfg.needPriceRange := false
ctxDataCfg.needHtfCandles := false
ctxDataCfg.needMsSwingArrays := true
ctxDataCfg.initBiasFactorArrays := true
ctxDataCfg.rangeLookbackBars := math.max(perfLookbackBars, 50)
chartCtx := LIB.get_data_context(ctxDataCfg, SETTINGS, BIAS_TOG, ctxZones, ctxLevels, triggersQueue, triggersQueue, msLtfData, msHtf1Data, msHtf2Data)
int currSec = LIB.get_tf_seconds(timeframe.period)
bool use15 = LIB.get_tf_seconds("15") > currSec
bool use240 = LIB.get_tf_seconds("240") > currSec
bool use1d = LIB.get_tf_seconds("1D") > currSec
bool use1w = LIB.get_tf_seconds("1W") > currSec
float power = (chartCtx.b0 * chartCtx.s0 * 1.0) + (use15 ? (chartCtx.b15 * chartCtx.s15 * 1.5) : 0.0) + (use240 ? (chartCtx.b240 * chartCtx.s240 * 2.0) : 0.0) + (use1d ? (chartCtx.b1d * chartCtx.s1d * 3.0) : 0.0) + (use1w ? (chartCtx.b1w * chartCtx.s1w * 4.0) : 0.0)
float powerMax = (chartCtx.m0 * 1.0) + (use15 ? (chartCtx.m15 * 1.5) : 0.0) + (use240 ? (chartCtx.m240 * 2.0) : 0.0) + (use1d ? (chartCtx.m1d * 3.0) : 0.0) + (use1w ? (chartCtx.m1w * 4.0) : 0.0)
powerPercent := powerMax > 0 ? math.min(math.max((power / powerMax) * 100.0, -100.0), 100.0) : 0.0
ltfBiasMemoryScore := get_ltf_bias_memory_score(ltfBiasSignalBars, ltfBiasSignalVals, LTF_BIAS_MEM_WINDOW_BARS)
float ltfScoreEff = float(chartCtx.t0) + ltfBiasMemoryScore * LTF_BIAS_MEM_WEIGHT
ltfBiasFinal := ltfScoreEff > 0.5 ? 1 : ltfScoreEff < -0.5 ? -1 : 0
biasGateDir := chartCtx.compositeBias != 0 ? chartCtx.compositeBias : ltfBiasFinal

draw_data_trades_dashboard(LIB.ChartContext biasCtx) =>
    var table entriesDash = table.new(position.bottom_right, 5, 24, bgcolor = color.new(THEME.COLOR_UI_BG, 85), frame_color = color.new(THEME.COLOR_UI_FG, 75), frame_width = 1, border_color = color.new(THEME.COLOR_UI_FG, 80), border_width = 1)
    bool showDash = SIGNAL_STATS_SHOW
    int maxTypes = math.max(1, array.size(trades))
    UI.render_entries_dashboard_from_entries(showDash, entriesDash, trades, maxTypes, THEME, CONST, CONST.SIG_METRIC_COUNT)
    if showDash
        UI.draw_bias_row_under_trades(entriesDash, 23, biasCtx, THEME, SETTINGS, CONST)
    bool(na)

// ── Tier-1 CP Context Marker (deduplicated vs Tier-2) ────────────────────
// Suppressed when a Tier-2 Strategy Signal will fire on this same bar
// (score≥3 + bias aligned) to avoid double-marking the same signal.
bool cpTier2WillFire = cpShowPat and cpPatScore >= 3 and
     ((cpIsBull and LIB.bias_allows_direction(biasGateDir, "Buy")) or
      (cpIsBear and LIB.bias_allows_direction(biasGateDir, "Sell")))

if CP_VIS_CFG.showMarkers and cpShowPat and not cpTier2WillFire
    string cpIcon  = cpIsBull ? CONST.SYM_UP : cpIsBear ? CONST.SYM_DN : CONST.SYM_DOT
    color  cpLCol  = THEME.COLOR_LTF
    float  cpYPos  = cpIsBull ? low - cpAtr * 0.4 : high + cpAtr * 0.4
    string cpBLbl  = cpIsBull ? "BULLISH" : cpIsBear ? "BEARISH" : "NEUTRAL"
    string cpStars = LIB.cp_score_stars(cpPatScore)
    string cpVLbl  = cpVolRatio >= SETTINGS.CP_VOL_EXTREME ? "⚡ EXTREME VOL" : cpVolRatio >= SETTINGS.CP_VOL_HIGH ? "🟡 HIGH VOL" : "vol: normal"
    string cpTip   = cpBLbl + "  |  " + cpAggName + "  |  Score: " + str.tostring(cpPatScore) + "  " + cpStars + "\nConviction: " + str.tostring(cpConvScore) + "  |  " + cpVLbl + (cpAggStrength > 1 ? "\nConfluence: ×" + str.tostring(cpAggStrength) + " patterns agree" : "")
    label.new(bar_index, cpYPos, text = cpIcon, tooltip = cpTip, color = color.new(THEME.COLOR_UI_BG, 100), textcolor = cpLCol, style = label.style_none, size = THEME.SIZE_TINY)

// Core (Sessions/Killzones): Top line = killzone, bottom line = session. Overlap highlighted by background box.
process_killzones_sessions() =>
    bool enabled = kz_show and timeframe.isintraday and timeframe.multiplier < 60 and is_in_draw_window()
    if enabled
        bool isAsiaKz  = not na(time(timeframe.period, asS,   "UTC-5")) and kz_show
        bool isLdnKz   = not na(time(timeframe.period, ldnOS, "UTC-5")) and kz_show
        bool isNYAMKz  = not na(time(timeframe.period, nyS,   "UTC-5")) and kz_show
        bool isNYPmKz  = not na(time(timeframe.period, ldnCS, "UTC-5")) and kz_show

        bool isAsiaSess = not na(time(timeframe.period, sessAsia,         "UTC-5")) and kz_show
        bool isLdnSess  = not na(time(timeframe.period, sessLondon,       "UTC-5")) and kz_show
        bool isNYSess   = not na(time(timeframe.period, sessNY,           "UTC-5")) and kz_show
        bool isOverlap  = not na(time(timeframe.period, sessOverlap_LdnNy,"UTC-5")) and kz_show

        // Top lines: killzones (running highs).
        color winClr = color.new(kz_color, WIN_LINE_TRANSP)
        UI.manage_window_line(kzAsiaTop, isAsiaKz, high, low, time, winClr, "ASIA KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: Asia dealing window.", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        UI.manage_window_line(kzLondonTop, isLdnKz, high, low, time, winClr, "LONDON KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: London dealing window (often sets AM range).", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        UI.manage_window_line(kzNYAMTop, isNYAMKz, high, low, time, winClr, "NY AM KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: NY AM dealing window (often expands/raids liquidity).", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        UI.manage_window_line(kzNYPMTop, isNYPmKz, high, low, time, winClr, "NY PM KZ", true, true, WIN_LINE_WIDTH, kzLB, kz_size, "Killzone: NY PM dealing window (PM distribution).", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)

        // Bottom lines: sessions (running lows). Use the same visual format as killzones.
        UI.manage_window_line(sessAsiaBot, isAsiaSess, high, low, time, winClr, "ASIA", false, false, WIN_LINE_WIDTH, kzLB, kz_size, "Session: Asia liquidity regime.", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        UI.manage_window_line(sessLondonBot, isLdnSess, high, low, time, winClr, "LONDON", false, false, WIN_LINE_WIDTH, kzLB, kz_size, "Session: London liquidity regime.", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)
        UI.manage_window_line(sessNYBot, isNYSess, high, low, time, winClr, "NY", false, false, WIN_LINE_WIDTH, kzLB, kz_size, "Session: New York liquidity regime.", "ha", CONST.WIN_LABEL_TIMEZONE, WIN_LABEL_PAD_BARS)

        // Overlap highlight: no border, very transparent.
