            if isPMBull and not isPMBull[1]
                line.new(time, low - syminfo.mintick * 10, time, high + syminfo.mintick * 10, xloc.bar_time, extend = extend.both, color = color.new(THEME.COLOR_NEUTRAL, TIME_EVENT_LINE_TRANSP), style = THEME.STYLE_BROKEN, width = 1)
                if TIME_EVENT_SHOW_BOTTOM
                    label.new(time, na, "2:00 PM Bullet", xloc.bar_time, yloc = yloc.belowbar, color = color.new(THEME.COLOR_TRANSPARENT, 100), textcolor = THEME.COLOR_LTF, style = label.style_label_up, size = THEME.SIZE_TINY, tooltip = CONST.TIME_EVENT_TT_PM_BULL)
