// ==================== CANDLE PATTERN DETECTION (merged) ====================
var LIB.CandlePatternCfg cpCfg = LIB.get_candle_pattern_cfg(SETTINGS, 1, 1)

[cpAggName, cpAggBias, cpBaseScore, cpAggStrength] = LIB.cp_detect(cpCfg)
bool cpIsBull   = cpAggBias == 1
bool cpIsBear   = cpAggBias == -1
bool cpIsPat    = cpAggName != "None"
int  cpPatScore = cpBaseScore + math.max(0, cpAggStrength - 1)

float cpVolAvg   = ta.sma(volume, 20)
float cpVolRatio = cpVolAvg > 0 ? volume / cpVolAvg : 1.0
int   cpVolBonus = cpVolRatio >= SETTINGS.CP_VOL_EXTREME ? 2 : cpVolRatio >= SETTINGS.CP_VOL_HIGH ? 1 : 0
int   cpConvScore = cpPatScore + cpVolBonus
bool  cpShowPat   = cpIsPat and cpConvScore >= SETTINGS.CP_MIN_CONV and LIB.is_in_draw_lookback_current(signalContextBars)

// ── Pattern candle visuals ─────────────────────────────────────────────
color cpNormBody = close >= open ? CP_VIS_CFG.normBull : CP_VIS_CFG.normBear

color cpPatBody   = CP_VIS_CFG.showCandles and cpShowPat ? LIB.cp_score_color(cpPatScore, cpAggBias, CP_VIS_CFG.bull, CP_VIS_CFG.bear, THEME)            : cpNormBody
color cpPatBorder = CP_VIS_CFG.showCandles and cpShowPat ? LIB.cp_border_color(cpPatScore, cpAggBias, CP_VIS_CFG.bull, CP_VIS_CFG.bear, THEME)           : cpNormBody
color cpPatWick   = CP_VIS_CFG.showCandles and cpShowPat ? LIB.cp_wick_color(cpPatScore, cpAggBias, cpVolRatio, CP_VIS_CFG.bull, CP_VIS_CFG.bear, THEME) : cpNormBody

plotcandle(open, high, low, close, title="Pattern Candles", color=cpPatBody, wickcolor=cpPatWick, bordercolor=cpPatBorder)

bool cpHasBg  = CP_VIS_CFG.showHalo and cpShowPat and cpPatScore >= 4
color cpHaloC = cpIsBull ? color.new(CP_VIS_CFG.bull, cpPatScore >= 5 ? 92 : 95) : color.new(CP_VIS_CFG.bear, cpPatScore >= 5 ? 92 : 95)
if cpHasBg
    box.new(bar_index, high, bar_index + 1, low, bgcolor = cpHaloC, border_color = na)

