indicator("Hung - SMC", overlay = true, scale = scale.right, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 100, max_bars_back = 100, dynamic_requests = true)

import hunghoxuan/TradingKitCore/58 as CORE
import hunghoxuan/TradingKitUI/15 as UI
import hunghoxuan/TradingKitSMC/86 as SMC


// ==================== CONSTANTS (LOGIC) ====================
// Library singletons (persistent)
