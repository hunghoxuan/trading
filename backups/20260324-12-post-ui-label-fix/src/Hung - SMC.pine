limCfg := get_limitation_cfg(limitStrict, SETTINGS.GLOBAL_MAX_LOOKBACK_BARS)
int scoreProfileId = scoreProfile == SCORE_PROFILE_LOOSE ? 0 : scoreProfile == SCORE_PROFILE_STRICT ? 2 : scoreProfile == SCORE_PROFILE_EXTREME ? 3 : 1
limCfg.entryZoneMinQualityPct := scoreProfileId == 0 ? 20.0 : scoreProfileId == 2 ? 50.0 : scoreProfileId == 3 ? 65.0 : 35.0
limCfg.htfProjectionMinQualityPct := scoreProfileId == 0 ? 10.0 : scoreProfileId == 2 ? 40.0 : scoreProfileId == 3 ? 55.0 : 25.0
limCfg.signalMinConfluenceScore := scoreProfileId == 0 ? 1 : scoreProfileId == 2 ? 3 : scoreProfileId == 3 ? 4 : 2
limCfg.zoneCapTotal := scoreProfileId == 0 ? 96 : scoreProfileId == 2 ? 48 : scoreProfileId == 3 ? 32 : 72
limCfg.zonePriorityAgeDecay := scoreProfileId == 0 ? 0.005 : scoreProfileId == 2 ? 0.020 : scoreProfileId == 3 ? 0.035 : 0.010
detCfg := get_detection_cfg(limitStrict)
uiCfg := get_ui_cfg(limitStrict, THEME)
sigCfg := get_signal_score_cfg(limitStrict)
cpCfg := CORE.get_candle_pattern_cfg(SETTINGS, sigCfg.scoreCandlePattern, sigCfg.scoreCandleVolume)
zqCfg.minHeightAtr := limCfg.zoneMinHeightAtr
ZONE_VIS_CFG.minWidthBars := uiCfg.zoneCurrMinWidthBars
cfgOB.extendBarsCurr := uiCfg.ltfBarsExt
cfgFVG.extendBarsCurr := uiCfg.ltfBarsExt - 4
cfgRJB.extendBarsCurr := uiCfg.ltfBarsExt
cfgSD.extendBarsCurr := uiCfg.ltfBarsExt
cfgBB.extendBarsCurr := uiCfg.ltfBarsExt
cfgIFVG.extendBarsCurr := uiCfg.ltfBarsExt - 4

// ==================== SMC STRATEGIES ====================

// Helper: Zone config resolver used by detection, scoring, and rendering.
get_pdarray_cfg(string zoneType) =>
    zoneType == "OB" ? cfgOB :
     zoneType == "FVG" ? cfgFVG :
     zoneType == "RJB" ? cfgRJB :
     zoneType == "SD" ? cfgSD :
     zoneType == "BB" ? cfgBB :
     zoneType == "IFVG" ? cfgIFVG :
     SMC.ZoneTypeConfig.new(0, "", "", "", "", 0, 0.0, 0, line.style_solid, false, false, "")

// Helper: Strategy metadata mapper by zone/event type.
init_data_strategy_defs() =>
    array.clear(strategyDefs)
    array.push(strategyDefs, CORE.EntryModelDef.new("TREND", "TR", 7, emTrend, emTrendType, emTrendWhen))
    array.push(strategyDefs, CORE.EntryModelDef.new("BREAK_OUT", "BO", 6, emBreakout, emBreakoutType, emBreakoutWhen))
    array.push(strategyDefs, CORE.EntryModelDef.new("REJECTION", "RJ", 5, emRejection, emRejectionType, emRejectionWhen))
    array.push(strategyDefs, CORE.EntryModelDef.new("SWEEP", "SW", 6, emSweep, emSweepType, emSweepWhen))
    bool(na)

get_trigger_type_code(string v) =>
    v == TRIGGER_TYPE_SIGNAL ? 1 : 2

get_trigger_when_code(string v) =>
    v == TRIGGER_WHEN_TOUCH ? 1 : 2

get_strategy_defs_sig() =>
    int sig = 0
    sig += (emTrend ? 1 : 0) * 10000000 + get_trigger_type_code(emTrendType) * 1000000 + get_trigger_when_code(emTrendWhen) * 100000
    sig += (emBreakout ? 1 : 0) * 10000 + get_trigger_type_code(emBreakoutType) * 1000 + get_trigger_when_code(emBreakoutWhen) * 100
    sig += (emRejection ? 1 : 0) * 10 + get_trigger_type_code(emRejectionType) * 2 + get_trigger_when_code(emRejectionWhen)
    sig += ((emSweep ? 1 : 0) * 100000000) + get_trigger_type_code(emSweepType) * 17 + get_trigger_when_code(emSweepWhen) * 31
    sig

refresh_strategy_defs() =>
    int nextSig = get_strategy_defs_sig()
    int cachedSig = array.get(strategyDefsSigBox, 0)
    if na(cachedSig) or cachedSig != nextSig or array.size(strategyDefs) == 0
        init_data_strategy_defs()
        array.set(strategyDefsSigBox, 0, nextSig)
    bool(na)

get_strategy_meta_by_key(string key) =>
    refresh_strategy_defs()
    bool enabled = false
    int score = 0
    string shortName = ""
    string triggerType = TRIGGER_TYPE_TRADE
    string triggerWhen = TRIGGER_WHEN_RETEST
    string k = str.upper(key)
    if array.size(strategyDefs) > 0
        for i = 0 to array.size(strategyDefs) - 1
            CORE.EntryModelDef s = array.get(strategyDefs, i)
            if s.key == k
                enabled := s.enabled
                score := s.baseScore
                shortName := s.shortName
                triggerType := s.trigger_type
                triggerWhen := s.trigger_when
                break
    [enabled, score, shortName, triggerType, triggerWhen]

// ==================== BIAS / TREND DATA ====================
BIAS_TOG = CORE.BiasToggles.new(true, true, true, true, true, true, true, true)

// ==================== FEATURES ====================

get_mitigated_keep_max(int profileId) =>
    profileId == 3 ? 6 : profileId == 2 ? 10 : profileId == 1 ? 16 : 24

prune_mitigated_pdarrays(array<CORE.PDArray> zones, int keepMax, float ageDecay) =>
    int cnt = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            CORE.PDArray z = array.get(zones, i)
            bool isCurrentTf = z.sourceTfRank <= 1
            if isCurrentTf and z.mitigated and not z.broken
                cnt += 1
    while cnt > keepMax
        int weakestIdx = na
        float weakestScore = 10e10
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                CORE.PDArray z = array.get(zones, i)
                bool isCurrentTf = z.sourceTfRank <= 1
                if isCurrentTf and z.mitigated and not z.broken
                    float s = nz(z.qualityPct, 0.0) - (math.max(bar_index - z.barStart, 0) * ageDecay)
                    if na(weakestIdx) or s < weakestScore
                        weakestScore := s
                        weakestIdx := i
        if not na(weakestIdx)
            CORE.PDArray zDel = array.get(zones, weakestIdx)
            UI.delete_pd_array_drawings(zDel)
            array.remove(zones, weakestIdx)
            cnt -= 1
        else
            cnt := keepMax
    bool(na)



// Core: Create/store one primary PDArray (OB/RJB/FVG).
// Core: Adds a primary PDArray object and creates visuals.
add_primary_zone(array<CORE.PDArray> zones, string type, bool isBull, float top, float btm, int leftIdx, int ext, string labelText, int labelX, float labelY, color labelColor, color borderColor, string borderStyle, float qualityPct, string tooltipText, int tfSlot) =>
    bool merged = false
    if merged
        bool(na)
    else
        string labelSize = tfSlot == 1 ? THEME.SIZE_SMALL : tfSlot == 0 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL
        bool showLabel = labelSize != "None"
        color resolvedLabelColor = na(labelColor) ? uiCfg.ltfColor : labelColor
        color resolvedBorderColor = borderColor
        if tfSlot < 0 and not na(resolvedBorderColor)
            resolvedBorderColor := color.new(uiCfg.ltfColor, 85)
        color areaFillColor = uiCfg.colorBg
        bool strong = not na(qualityPct) and qualityPct >= 70.0
        if strong
            resolvedLabelColor := color.new(resolvedLabelColor, 0)
        CORE.ZoneVisualCfg zoneCfg = ZONE_VIS_CFG
        zoneCfg.textSize := labelSize
        SR_VIS_CFG.lineStyle := CFG_SR.lineStyle
        SR_VIS_CFG.lineWidth := CFG_SR.lineWidth
        SR_VIS_CFG.labelSize := labelSize
        SR_VIS_CFG.showLabel := CFG_SR.showLabel
        CORE.PDArray z = CORE.PDArray.new(type, top, btm, leftIdx, false, false, na, na, na, na, na, na, isBull, labelText, ext, qualityPct)
        z := UI.draw_price_zone(z, leftIdx, bar_index + ext, top, btm, areaFillColor, resolvedBorderColor, borderStyle, labelText, resolvedLabelColor, tooltipText, labelX, labelY, zoneCfg, SR_VIS_CFG, true, false, (top + btm) / 2.0, CFG_SR.lineColor, "AREA", showLabel)
        z.lifeState := CONST.LIFE_FORMED
        z.touchCount := 0
        SMC.add_active_zone(pdArrays, z, limCfg.zoneCapPerType, limCfg.zoneCapTotal, limCfg.zoneCurrMaxPerTypeSide, effectiveCurrLookbackBars, last_bar_index, close, bar_index, limCfg.zonePriorityAgeDecay)
    bool(na)

// Core: Spawn derived flip zones (BB/iFVG).
// Core: Spawns derived zones (BB/iFVG) from mitigated parent zones.
spawn_derived_zone(array<CORE.PDArray> zones, string newType, bool isBull, float top, float btm, float qualityPct) =>
    SMC.ZoneTypeConfig cfg = get_pdarray_cfg(newType)
    float q = nz(qualityPct, 0.0)
    int ext = cfg.extendBarsCurr > 0 ? cfg.extendBarsCurr : SMC.get_current_pdarray_extend(newType, uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
    // Derived zones are spawned on the current TF path, so use base TF color here
    // to avoid early-scope dependency on htf1/htf2 declarations.
    color txtColor = uiCfg.ltfColor
    borderStyle = cfg.borderStyle
    color borderColor = cfg.noBorder ? na : color.new(uiCfg.ltfColor, 85)
    string lbl = cfg.shortName != "" ? cfg.shortName : (newType == "BB" ? "BB" : "iFVG")
    string tt = newType == "BB" ?
     CORE.tt_side(isBull, isBull ? "BB flip to demand" : "BB flip to supply") :
     CORE.tt_side(isBull, isBull ? "iFVG support flip" : "iFVG resistance flip")
    string zoneTip = uiCfg.zoneTooltipEnable ? tt : ""
    CORE.PDArray z = CORE.PDArray.new(newType, top, btm, bar_index, false, false, na, na, na, na, na, na, isBull, lbl, ext, q)
    z := UI.draw_price_zone(z, bar_index, bar_index + ext, top, btm, uiCfg.colorBg, borderColor, borderStyle, lbl, txtColor, zoneTip, bar_index + ext, (top + btm) / 2.0, ZONE_VIS_CFG, SR_VIS_CFG, true, false, na, borderColor, "AREA", true)
    z.lifeState := CONST.LIFE_FORMED
    z.touchCount := 0
    z.rejectCount := 0
    SMC.add_active_zone(pdArrays, z, limCfg.zoneCapPerType, limCfg.zoneCapTotal, limCfg.zoneCurrMaxPerTypeSide, effectiveCurrLookbackBars, last_bar_index, close, bar_index, limCfg.zonePriorityAgeDecay)

normalize_pdarray_label_text(string zoneType, string rawText) =>
    string out = rawText
    if zoneType == "OB"
        string r = str.replace_all(rawText, " ", "")
        int rLen = str.length(r)
        if r == "OB" or r == "ob"
            out := "ob"
        else if rLen >= 3 and str.substring(r, 0, 3) == "OB."
            string tag = str.lower(str.substring(r, 3, rLen))
            out := tag + ".ob"
        else if rLen >= 3 and str.substring(r, 0, 3) == "OB-"
            string tag = str.lower(str.substring(r, 3, rLen))
            out := tag + ".ob"
    out

refresh_tf_leg_state(CORE.TFData tfData) =>
    if not na(tfData.legEventTime) and tfData.legEventTime != tfData.legLastEventSeen
        tfData.legId += 1
        tfData.legDir := tfData.prevBreakout
        tfData.legSeqAll := 0
        tfData.legSeqOb := 0
        tfData.legSeqFvg := 0
        tfData.legSeqRjb := 0
        tfData.legSeqLevel := 0
        tfData.legLastEventSeen := tfData.legEventTime

// Lightweight MS trend updater (data-only, no visuals).
// Cost: O(1) per TF per bar (reads latest swing high/low only).
process_tf_ms_trend_light(CORE.TFData tfData, bool enabled) =>
    if not enabled
        bool(na)
    else
        int hiN = array.size(tfData.swingHighPrices)
        int loN = array.size(tfData.swingLowPrices)
        float lastHi = hiN > 0 ? array.get(tfData.swingHighPrices, hiN - 1) : na
        float lastLo = loN > 0 ? array.get(tfData.swingLowPrices, loN - 1) : na
        bool breakUp = not na(lastHi) and close > lastHi
        bool breakDn = not na(lastLo) and close < lastLo
        int nextDir = tfData.prevBreakout
        if breakUp and not breakDn
            nextDir := 1
        else if breakDn and not breakUp
            nextDir := -1
        if nextDir != tfData.prevBreakout and nextDir != 0
            tfData.prevBreakout := nextDir
            tfData.msBias := nextDir
            tfData.legEventTime := time
        else if tfData.msBias == 0 and tfData.prevBreakout != 0
            tfData.msBias := tfData.prevBreakout
        refresh_tf_leg_state(tfData)
        bool(na)

annotate_new_pricezones(array<CORE.PDArray> zones, int startIdx, string sourceTf, int sourceTfRank, CORE.TFData tfData) =>
    int zoneCount = array.size(zones)
    if startIdx < zoneCount
        for i = startIdx to zoneCount - 1
            CORE.PDArray z = array.get(zones, i)
            if z.sourceTf == ""
                tfData.legSeqAll += 1
                int seqType = 0
                if z.type == "OB" or z.type == "BB"
                    tfData.legSeqOb += 1
                    seqType := tfData.legSeqOb
                else if z.type == "FVG" or z.type == "IFVG"
                    tfData.legSeqFvg += 1
                    seqType := tfData.legSeqFvg
                else if z.type == "RJB"
                    tfData.legSeqRjb += 1
                    seqType := tfData.legSeqRjb
                else
                    tfData.legSeqLevel += 1
                    seqType := tfData.legSeqLevel
                z.sourceTf := sourceTf
                z.sourceTfRank := sourceTfRank
                z.legId := tfData.legId
                z.legDir := tfData.legDir
                z.legSeqAll := tfData.legSeqAll
                z.legSeqType := seqType
                array.set(zones, i, z)

get_label_size_for_source_tf(string sourceTf) =>
    [tf1, tf2] = CORE.get_htf_pair()
    sourceTf == tf2 ? THEME.SIZE_SMALL : sourceTf == tf1 ? THEME.SIZE_SMALL : THEME.SIZE_SMALL

is_pdarray_trade_type(string type) =>
    string t = str.upper(type)
    str.contains(t, "OB") or str.contains(t, "BB") or str.contains(t, "FVG") or str.contains(t, "IFVG") or str.contains(t, "RJB") or str.contains(t, "SD")

get_trade_pdarray_meta(string type, float zoneTop, float zoneBtm) =>
    int outRank = 0
    int outLegId = -1
    int outLegDir = 0
    int outLegSeq = -1
    float tol = syminfo.mintick * 2.0
    if array.size(pdArrays) > 0
        for i = array.size(pdArrays) - 1 to 0
            CORE.PDArray z = array.get(pdArrays, i)
            bool sameType = z.type == type
            bool nearTop = math.abs(z.top - zoneTop) <= tol
            bool nearBtm = math.abs(z.bottom - zoneBtm) <= tol
            if sameType and nearTop and nearBtm
                outRank := z.sourceTfRank
                outLegId := z.legId
                outLegDir := z.legDir
                outLegSeq := z.legSeqAll
                break
    [outRank, outLegId, outLegDir, outLegSeq]

passes_pdarray_trade_filter(string type, float qualityPct, float zoneTop, float zoneBtm, string direction) =>
    bool pass = true
    if limCfg.entryZoneFilterEnable and is_pdarray_trade_type(type)
        [srcRank, legId, legDir, legSeq] = get_trade_pdarray_meta(type, zoneTop, zoneBtm)
        if limCfg.entryFilterHtfOnlyEnable and srcRank < limCfg.entryFilterHtfMinRank
            pass := false
        float q = nz(qualityPct, 0.0)
        if pass and q < limCfg.entryZoneMinQualityPct
            pass := false
        if pass and limCfg.entryFilterNearLegEnable
            bool known = legId >= 0 and legSeq > 0
            bool seqOk = known and legSeq <= limCfg.entryFilterNearLegMaxSeq
            bool dirOk = true
            if limCfg.entryFilterNearLegRequireDirMatch and known
                bool isBuy = str.upper(direction) == "BUY"
                dirOk := (isBuy and legDir >= 0) or ((not isBuy) and legDir <= 0)
            pass := known ? (seqOk and dirOk) : limCfg.entryFilterNearLegAllowUnknown
    pass

mark_pdarray_label_mitigated(string zoneType, string labelText) =>
    string out = labelText
    if zoneType == "OB"
        int tLen = str.length(labelText)
        bool endsOb = false
        if tLen >= 3
            string sfx = str.substring(labelText, tLen - 3, tLen)
            endsOb := sfx == ".OB" or sfx == ".ob"
        if endsOb
            string base = str.substring(labelText, 0, tLen - 3)
            int bLen = str.length(base)
            if base == "d" or base == "o" or base == "x" or base == "m"
                base := ""
                bLen := 0
            bool endsDotD = false
            bool endsDotO = false
            bool endsDotX = false
            bool endsDotM = false
            if bLen >= 2
                string suffix = str.substring(base, bLen - 2, bLen)
                endsDotD := suffix == ".d"
                endsDotO := suffix == ".o"
                endsDotX := suffix == ".x"
                endsDotM := suffix == ".m"
            if endsDotD or endsDotO or endsDotX or endsDotM
                base := str.substring(base, 0, bLen - 2)
            out := base == "" ? "m.ob" : base + ".m.ob"
        else
            out := "m.ob"
    out

add_htf_pdarray_if_valid(array<CORE.PDArray> zones, string tfLabel, int tfSlot, bool showTf, bool showType, string zoneType, bool isBull, float top, float btm, int startTs, float qPct) =>
    int htfLookbackOffSafe = math.max(1, math.min(limCfg.htfZoneLookbackBars, 90))
    int recentTsCut = bar_index >= htfLookbackOffSafe ? time[htfLookbackOffSafe] : 0
    bool recent = not na(startTs) and startTs >= recentTsCut
    bool unmitigated = zoneType == "SD" ? true : (isBull ? (low > top) : (high < btm))
    bool valid = showTf and showType and recent and not na(startTs) and not na(top) and not na(btm) and top > btm and nz(qPct, 0) >= limCfg.htfProjectionMinQualityPct and unmitigated
    if valid
        int ext = SMC.get_htf_pdarray_extend(tfSlot, 14, 25)
        string lbl = zoneType == "SD" ? (isBull ? "D" : "S") : str.upper(zoneType)
        bool hasDupSameSlot = false
        if array.size(zones) > 0
            for i = 0 to array.size(zones) - 1
                CORE.PDArray z = array.get(zones, i)
                bool sameTypeSide = z.type == zoneType and z.isBullish == isBull
                bool sameSlot = z.extendBars == ext
                if sameTypeSide and sameSlot and SMC.pd_arrays_overlap(top, btm, z.top, z.bottom)
                    hasDupSameSlot := true
                    break
        if not hasDupSameSlot
            int leftIdxRaw = CORE.closest_bar_index_from_time(startTs)
            int leftIdx = na(leftIdxRaw) ? bar_index : leftIdxRaw
            SMC.ZoneTypeConfig cfg = get_pdarray_cfg(zoneType)
            color lineClr = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 0) : color.new(htf2Cfg.zigzagColor, 0)
            color tfBorder = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 85) : color.new(htf2Cfg.zigzagColor, 85)
            color borderClr = cfg.noBorder ? na : tfBorder
            string borderStyle = cfg.borderStyle
            float y = (top + btm) * 0.5
            int labelX = bar_index + 5
            string tt = CORE.tt_side(isBull, lbl)
            add_primary_zone(zones, zoneType, isBull, top, btm, leftIdx, ext, lbl, labelX, y, lineClr, borderClr, borderStyle, qPct, tt, tfSlot)
    bool(na)

get_data_htf_sd_snapshot(float thresholdPct, int divBins, int lookbackBars) =>
    int lb = math.max(5, lookbackBars)
    float hi = ta.highest(high, lb)
    float lo = ta.lowest(low, lb)
    float csum = math.sum(volume, lb)
    float bin = (hi - lo) / divBins
    int safeOff = math.max(0, math.min(lb - 1, bar_index))
    int st = int(time[safeOff])
    float sTop = na
    float sBtm = na
    float dTop = na
    float dBtm = na
    if csum > 0 and bin > 0
        float sAcc = 0.0
        float dAcc = 0.0
        for i = 0 to divBins - 1
            float sLvl = hi - (i + 1) * bin
            float sPrev = hi - i * bin
            float dLvl = lo + (i + 1) * bin
            float dPrev = lo + i * bin
            float sVol = 0.0
            float dVol = 0.0
            for j = 0 to lb - 1
                if high[j] > sLvl and high[j] <= sPrev
                    sVol += volume[j]
                if low[j] >= dPrev and low[j] < dLvl
                    dVol += volume[j]
            sAcc += sVol
            dAcc += dVol
            if na(sBtm) and sAcc / csum * 100 > thresholdPct
                sTop := hi
                sBtm := sLvl
            if na(dTop) and dAcc / csum * 100 > thresholdPct
                dTop := dLvl
                dBtm := lo
            if not na(sBtm) and not na(dTop)
                break
    [sTop, sBtm, st, dTop, dBtm, st]

// Core: Add/update an Trade lifecycle object.
// Core: Converts an Event into a tradable Trade plan.

entry_direction_allowed(string direction, int biasVal) =>
    bool allowDir = (direction == "Buy" and chartCfg.allowLong) or (direction == "Sell" and chartCfg.allowShort)
    int bLtf = array.get(tradeBiasVals, 0)
    int bH1 = array.get(tradeBiasVals, 1)
    int bH2 = array.get(tradeBiasVals, 2)
    bool allowLtfBias = not signalFilterBiasLtf or SMC.direction_matches_bias(direction, bLtf)
    bool allowHtf1Bias = not signalFilterBiasHtf1 or SMC.direction_matches_bias(direction, bH1)
    bool allowHtf2Bias = not signalFilterBiasHtf2 or SMC.direction_matches_bias(direction, bH2)
    bool allowMem = chartCtx.signalMemoryDir == 0 or (direction == "Buy" and chartCtx.signalMemoryDir == 1) or (direction == "Sell" and chartCtx.signalMemoryDir == -1)
    allowDir and allowLtfBias and allowHtf1Bias and allowHtf2Bias and allowMem

add_entry(string type, string direction, string reason, float levelTop, float levelBtm, float qualityPct, int scoreVal) =>
    bool isBuy = direction == "Buy"
    float zoneTop = math.max(levelTop, levelBtm)
    float zoneBtm = math.min(levelTop, levelBtm)
    bool allowEntry = passes_pdarray_trade_filter(type, qualityPct, zoneTop, zoneBtm, direction) and entry_direction_allowed(direction, chartCtx.biasVal)
    bool passBatchCap = not signalLimitStartEntries or CORE.count_start_trades(trades, CONST) < chartCfg.maxStartEntries
    if allowEntry and passBatchCap
        SMC.cache_signal_memory_event(signalMemoryEvents, CORE.Event.new(type, direction, levelTop, levelBtm, na, bar_index, int(na), false, reason, qualityPct, scoreVal), syminfo.mintick, 80)
        float rrUsed = math.max(chartCfg.rr, 0.1)
        float zoneHeight = math.max(zoneTop - zoneBtm, syminfo.mintick)
        float slRaw = isBuy ? zoneBtm : zoneTop
        bool alignBias = SMC.is_signal_bias_valid(direction == "Buy", chartCtx.biasVal, chartCfg.useBias)
        float relVolEntry = CORE.get_rel_volume(0, zqCfg.volLen)
        [gapMinTicks, gapMinAtr] = SMC.get_trade_gap_profile_floors(signalSlProfile, limitStrict, SL_PROFILE_STRICT, SL_PROFILE_LOOSE)

        for mode = 0 to 2
            bool modeEnabled = mode == 0 ? signalEntryAtEdge : mode == 1 ? signalEntryAtMiddle : signalEntryAtEnd
            if modeEnabled
                float entryBase = mode == 0 ? (isBuy ? zoneTop : zoneBtm) : mode == 1 ? ((zoneTop + zoneBtm) * 0.5) : slRaw
                float slGap = CORE.get_trade_gap_unified(entryBase, slRaw, commonAtr, "RISK%", 0.0, signalGapRiskPct, 0.0, gapMinTicks, gapMinAtr)
                float entryRaw = mode == 2 ? (isBuy ? (zoneBtm + slGap) : (zoneTop - slGap)) : entryBase
                float entry = isBuy ? (entryRaw - slGap) : (entryRaw + slGap)
                float stoploss = isBuy ? (slRaw - slGap) : (slRaw + slGap)
                float tpDistRaw = zoneHeight * rrUsed
                float takeprofit = isBuy ? (entry + tpDistRaw - slGap) : (entry - tpDistRaw + slGap)
                float risk = math.max(math.abs(entry - stoploss), syminfo.mintick)
                float denom = math.max(math.abs(entry - stoploss), syminfo.mintick)
                float rrReal = math.abs(takeprofit - entry) / denom
                float riskTicks = risk / syminfo.mintick
                float riskAtr = risk / math.max(commonAtr, syminfo.mintick)
                float tradeScore = SMC.compute_trade_score(qualityPct, riskTicks, riskAtr, rrReal, relVolEntry, alignBias, chartCfg.useBias)
                float tradeScoreMin = SMC.get_trade_score_min(scoreProfileId)
                float minRiskTicks = scoreProfileId == 3 ? 4.0 : scoreProfileId == 2 ? 3.0 : 2.0
                float minRiskAtr = scoreProfileId == 3 ? 0.20 : scoreProfileId == 2 ? 0.15 : 0.10
                float minRr = scoreProfileId == 3 ? 1.10 : scoreProfileId == 2 ? 1.00 : 0.85
                bool hardRiskFail = riskTicks < minRiskTicks or riskAtr < minRiskAtr or rrReal < minRr
                bool passTradeScore = (not hardRiskFail) and (tradeScore >= tradeScoreMin)
                if passTradeScore
                    string modeTag = mode == 0 ? ".E" : mode == 1 ? ".M" : ".N"
                    string tradeType = type + modeTag
                    string reasonFinal = reason + " [" + modeTag + "]" +
                     "\nTS:" + str.tostring(tradeScore, "#.0") + "/" + str.tostring(tradeScoreMin, "#.0") +
                     "\nL B/T:" + str.tostring(array.get(tradeBiasVals, 0)) + "/" + str.tostring(array.get(tradeTrendVals, 0)) +
                     "\nH1 B/T:" + str.tostring(array.get(tradeBiasVals, 1)) + "/" + str.tostring(array.get(tradeTrendVals, 1)) +
                     "\nH2 B/T:" + str.tostring(array.get(tradeBiasVals, 2)) + "/" + str.tostring(array.get(tradeTrendVals, 2))
                    int entryIdx = na
                    if array.size(trades) > 0
                        for k = array.size(trades) - 1 to 0
                            CORE.Trade ex = array.get(trades, k)
                            bool sameZone = math.abs(ex.zoneTop - levelTop) <= syminfo.mintick * 2 and math.abs(ex.zoneBtm - levelBtm) <= syminfo.mintick * 2
                            if ex.direction == direction and ex.type == tradeType and sameZone and ex.state == CONST.SIGNAL_STATE_PENDING
                                entryIdx := k
                                break
                    if na(entryIdx)
                        CORE.Trade e = CORE.create_trade_if_valid(direction, tradeType, levelTop, levelBtm, entry, stoploss, takeprofit, rrUsed, bar_index, reasonFinal, scoreVal, CONST, syminfo.mintick)
                        if not na(e)
                            array.push(trades, e)
                    else
                        CORE.Trade e = array.get(trades, entryIdx)
                        e.type := tradeType
                        e.entry := entry
                        e.stoploss := stoploss
                        e.takeprofit := takeprofit
                        e.rrValue := rrUsed
                        e.reason := reasonFinal
                        e.score := scoreVal
                        array.set(trades, entryIdx, e)
    bool(na)

process_data_chart_context() =>
    chartCfg.useBias := signalFilterBiasLtf or signalFilterBiasHtf1 or signalFilterBiasHtf2
    chartCfg.allowLong := signalFilterLong
    chartCfg.allowShort := signalFilterShort
    chartCfg.rr := signalRrInput
    chartCfg.dynamicTp := signalDynamicTp
    chartCfg.maxStartEntries := signalMaxStartEntries
    chartCfg.showPending := signalShowPending
    chartCfg.showStart := signalShowStart
    chartCfg.showTp := signalShowTp
    chartCfg.showSl := signalShowSl

    ctxDataCfg.needBias := true
    ctxDataCfg.needMsTrendDirs := true
    ctxDataCfg.needPdPw := true
    ctxDataCfg.needPriceRange := true
    ctxDataCfg.needHtfCandles := false
    ctxDataCfg.needMsSwingArrays := true
    ctxDataCfg.initBiasFactorArrays := true
    ctxDataCfg.rangeLookbackBars := math.max(effectiveCurrLookbackBars, 50)
    CORE.ChartContext ctx = CORE.get_data_context(ctxDataCfg, SETTINGS, BIAS_TOG, pdArrays, levels, triggersQueue, signalMemoryEvents, ltfData, htf1Data, htf2Data)

    string h1Name = ctx.htf1Name
    string h2Name = ctx.htf2Name
    int h1Bias = h1Name == "15" ? ctx.b15 : h1Name == "240" ? ctx.b240 : h1Name == "1D" ? ctx.b1d : h1Name == "1W" ? ctx.b1w : ctx.b0
    int h2Bias = h2Name == "15" ? ctx.b15 : h2Name == "240" ? ctx.b240 : h2Name == "1D" ? ctx.b1d : h2Name == "1W" ? ctx.b1w : ctx.b0
    int h1Trend = h1Name == "15" ? ctx.dir15 : h1Name == "240" ? ctx.dir240 : h1Name == "1D" ? ctx.dir1d : h1Name == "1W" ? ctx.dir1w : ctx.dir0
    int h2Trend = h2Name == "15" ? ctx.dir15 : h2Name == "240" ? ctx.dir240 : h2Name == "1D" ? ctx.dir1d : h2Name == "1W" ? ctx.dir1w : ctx.dir0
    array.set(tradeBiasVals, 0, ctx.b0)
    array.set(tradeBiasVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.b0 : h1Bias)
    array.set(tradeBiasVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.b0 : h2Bias)
    array.set(tradeTrendVals, 0, ctx.dir0)
    array.set(tradeTrendVals, 1, na(h1Name) ? 0 : h1Name == timeframe.period ? ctx.dir0 : h1Trend)
    array.set(tradeTrendVals, 2, na(h2Name) ? 0 : h2Name == timeframe.period ? ctx.dir0 : h2Trend)
    [memScore, memDir, bullCount, bearCount] = SMC.compute_signal_memory_bias(signalMemoryEvents, 20)
    ctx.signalMemoryScore := memScore
    ctx.signalMemoryDir := memDir
    ctx.signalBullCount := bullCount
    ctx.signalBearCount := bearCount
    int effBias = ctx.activeBias
    if memDir != 0
        if effBias == 0
            effBias := memDir
        else if effBias != memDir
            effBias := 0
    ctx.biasVal := effBias
    ctx

process_barrier_touch_setup(CORE.ChartContext ctx) =>
    [btEnabled, btScore, shortName, btType, btWhen] = get_strategy_meta_by_key("REJECTION")
    if not btEnabled or signalEntryMode == ENTRY_MODE_OFF
        bool(na)
    else
        [aboveBarrier, belowBarrier, aboveH, belowH] = SMC.get_nearest_barriers(pdArrays, close, syminfo.mintick)
        bool hasRes = not na(aboveBarrier) and not na(aboveH)
        bool hasSup = not na(belowBarrier) and not na(belowH)
        if hasRes
            bool touchedRes = SMC.check_touch(aboveBarrier + aboveH, aboveBarrier, detCfg.basis, open, high, low, close)
            bool validSell = entry_direction_allowed("Sell", ctx.biasVal)
            int scoreSell = btScore + (chartCfg.useBias and validSell ? sigCfg.scoreHtf : 0)
            CORE.ConfluenceResult adjSell = CORE.apply_candle_pattern_confluence("Sell", "Barrier Touch (resistance touch)", scoreSell, cpCfg)
            if touchedRes and validSell and adjSell.score >= limCfg.signalMinConfluenceScore
                if btWhen == TRIGGER_WHEN_TOUCH and btType == TRIGGER_TYPE_TRADE
                    add_entry(shortName, "Sell", adjSell.reason, aboveBarrier + aboveH, aboveBarrier, na, adjSell.score)
                else
                    SMC.add_signal(triggersQueue, signalMemoryEvents, shortName, "Sell", adjSell.reason, aboveBarrier + aboveH, aboveBarrier, float(na), adjSell.score, bar_index, syminfo.mintick, 80)
        if hasSup
            bool touchedSup = SMC.check_touch(belowBarrier, belowBarrier - belowH, detCfg.basis, open, high, low, close)
            bool validBuy = entry_direction_allowed("Buy", ctx.biasVal)
            int scoreBuy = btScore + (chartCfg.useBias and validBuy ? sigCfg.scoreHtf : 0)
            CORE.ConfluenceResult adjBuy = CORE.apply_candle_pattern_confluence("Buy", "Barrier Touch (support touch)", scoreBuy, cpCfg)
            if touchedSup and validBuy and adjBuy.score >= limCfg.signalMinConfluenceScore
                if btWhen == TRIGGER_WHEN_TOUCH and btType == TRIGGER_TYPE_TRADE
                    add_entry(shortName, "Buy", adjBuy.reason, belowBarrier, belowBarrier - belowH, na, adjBuy.score)
                else
                    SMC.add_signal(triggersQueue, signalMemoryEvents, shortName, "Buy", adjBuy.reason, belowBarrier, belowBarrier - belowH, float(na), adjBuy.score, bar_index, syminfo.mintick, 80)
        bool(na)

// Core: Process active entries, update lifecycle state, refresh visuals.
// Core: Trade lifecycle manager (pending/live/tp/sl) + visuals/stats.
process_trades() =>
    bool doResolve = true
    float rHi = high
    float rLo = low
    int rBar = bar_index
    if doResolve and array.size(trades) > 0
        for i = array.size(trades) - 1 to 0
            CORE.Trade e = array.get(trades, i)
            [eResolved, outcome] = CORE.resolve_trade_state(e, rHi, rLo, rBar, SETTINGS.ENTRY_REQUIRE_NEXT_BAR, SETTINGS.ENTRY_SL_FIRST_ON_DUAL_HIT, CONST)
            e := eResolved
            if outcome == 2
                UI.delete_trade_visuals(e)
                array.remove(trades, i)
                continue
            if outcome == 1 or outcome == -1
                float exitPrice = outcome > 0 ? e.takeprofit : e.stoploss
                float denom = math.max(math.abs(e.entry - e.stoploss), syminfo.mintick)
                float realizedR = math.abs(exitPrice - e.entry) / denom
                float rrForStats = chartCfg.dynamicTp ? math.max(0.1, realizedR) : e.rrValue
                e.rrValue := rrForStats
            string entryDisplayMode = (e.state == CONST.SIGNAL_STATE_TP or e.state == CONST.SIGNAL_STATE_SL) ? "RESULT_LINES" : "NORMAL"
            bool signalShowActive = e.state == CONST.SIGNAL_STATE_PENDING ? chartCfg.showPending : e.state == CONST.SIGNAL_STATE_START ? chartCfg.showStart : false
            e := UI.draw_trade_visual(e, CONST, THEME, ENTRY_VIS_CFG, true, signalShowActive, chartCfg.showTp, chartCfg.showSl, perfLookbackBars, 0, entryDisplayMode, "RESULT_LINES", 0)
            array.set(trades, i, e)
    if signalLimitStartEntries
        int startCount = CORE.count_start_trades(trades, CONST)
        if startCount >= chartCfg.maxStartEntries
            UI.prune_pending_trades(trades, CONST)
    bool(na)

// Core: Unified event queue processor (setup-confirm, sweep-reclaim, break-retest).
process_events_queue(array<CORE.Event> events, CORE.ChartContext ctx, int breakRetestWindowBars) =>
    if events.size() > 0
        for i = events.size() - 1 to 0
            e = events.get(i)
            bool isBreakRetestEvent = not na(e.barBreak)
            bool isSignalEvent = not isBreakRetestEvent
            if isSignalEvent
                if e.type == "SWEEP"
                    // SWEEP triggers are processed by the LSR state machine, not here immediately.
                    continue
                string signalModelKey = (e.type == "OB" or e.type == "FVG" or e.type == "SD" or e.type == "TR" or e.type == "TREND") ? "TREND" :
                 (e.type == "BB" or e.type == "IFVG" or e.type == "RJB" or e.type == "BO" or e.type == "BREAK_OUT") ? "BREAK_OUT" :
                 (e.type == "RJ" or e.type == "REJECTION") ? "REJECTION" :
                 (e.type == "SW" or e.type == "SWEEP") ? "SWEEP" : e.type
                [sigEnabled, _, _, sigTriggerType, sigTriggerWhen] = get_strategy_meta_by_key(signalModelKey)
                if not sigEnabled
                    events.remove(i)
                    continue
                if sigTriggerType != TRIGGER_TYPE_TRADE
                    // Signal-type model: keep marker/event behavior only, never convert to Trade.
                    events.remove(i)
                    continue
                if e.direction == "Buy" and close > e.zoneTop
                    CORE.ConfluenceResult adjBuy = CORE.apply_candle_pattern_confluence("Buy", e.reason + " (close reclaimed zone top)", e.score + sigCfg.scoreConfirm, cpCfg)
                    if signalEntryMode == ENTRY_MODE_AFTER_RETEST and sigTriggerWhen == TRIGGER_WHEN_RETEST
                        add_entry(e.type, "Buy", adjBuy.reason, e.zoneTop, e.zoneBtm, e.quality, adjBuy.score)
                    events.remove(i)
                    continue
                else if e.direction == "Sell" and close < e.zoneBtm
                    CORE.ConfluenceResult adjSell = CORE.apply_candle_pattern_confluence("Sell", e.reason + " (close rejected below zone bottom)", e.score + sigCfg.scoreConfirm, cpCfg)
                    if signalEntryMode == ENTRY_MODE_AFTER_RETEST and sigTriggerWhen == TRIGGER_WHEN_RETEST
                        add_entry(e.type, "Sell", adjSell.reason, e.zoneTop, e.zoneBtm, e.quality, adjSell.score)
                    events.remove(i)
                    continue
            else
                int age = bar_index - e.barBreak
                if age > breakRetestWindowBars
                    events.remove(i)
                    continue
                bool isBuy = e.direction == "Buy"
                string modelKey = (e.type == "OB" or e.type == "FVG" or e.type == "SD") ? "TREND" : (e.type == "BB" or e.type == "IFVG" or e.type == "RJB") ? "BREAK_OUT" : (e.type == "SWEEP") ? "SWEEP" : e.type
                [stratEnabled, stratScore, shortName, triggerType, triggerWhen] = get_strategy_meta_by_key(modelKey)
                bool allowedPdArray = (e.type == "OB" and plotOB) or (e.type == "FVG" and plotFVG) or (e.type == "SD" and plotSD) or (e.type == "BB" and useBB) or (e.type == "IFVG" and useIFVG) or (e.type == "RJB") or (e.type == "SWEEP")
                bool validType = stratEnabled and allowedPdArray
                bool validDirection = entry_direction_allowed(e.direction, ctx.biasVal)
                bool touched = SMC.check_touch(e.zoneTop, e.zoneBtm, detCfg.basis, open, high, low, close)
                if touched
                    e.retestSeen := true
                    events.set(i, e)
                bool confirmed = e.retestSeen and (isBuy ? (close > e.zoneTop) : (close < e.zoneBtm))
                bool invalidated = isBuy ? (close < e.zoneBtm) : (close > e.zoneTop)
                if invalidated
                    events.remove(i)
                    continue
                int baseScore = stratScore + sigCfg.scoreConfirm + (chartCfg.useBias and validDirection ? sigCfg.scoreHtf : 0)
                string reason = e.type + " Break-Retest confirmed"
                CORE.ConfluenceResult adj = CORE.apply_candle_pattern_confluence(e.direction, reason, baseScore, cpCfg)
                if validType and confirmed and validDirection and adj.score >= limCfg.signalMinConfluenceScore and signalEntryMode != ENTRY_MODE_OFF and triggerWhen == TRIGGER_WHEN_RETEST and triggerType == TRIGGER_TYPE_TRADE
                    add_entry(shortName, e.direction, adj.reason, e.zoneTop, e.zoneBtm, e.quality, adj.score)
                    events.remove(i)
                    continue
                if confirmed
                    events.remove(i)
                    continue
    bool(na)

register_pdarray_retest_signal(array<CORE.Event> _triggersQueue, CORE.PDArray z, int biasVal, string reasonOverride, string setupOverride) =>
    string type = z.type
    string modelKey = (type == "OB" or type == "FVG" or type == "SD") ? "TREND" : (type == "BB" or type == "IFVG" or type == "RJB") ? "BREAK_OUT" : (type == "SWEEP") ? "SWEEP" : type
    [stratEnabled, stratScore, shortName, triggerType, triggerWhen] = get_strategy_meta_by_key(modelKey)
    bool allowedPdArray = (type == "OB" and plotOB) or (type == "FVG" and plotFVG) or (type == "SD" and plotSD) or (type == "BB" and useBB) or (type == "IFVG" and useIFVG) or (type == "RJB") or (type == "SWEEP")
    bool enabledType = stratEnabled and allowedPdArray
    string direction = z.isBullish ? "Buy" : "Sell"
    bool validBias = entry_direction_allowed(direction, biasVal)
    int baseScore = stratScore
    int biasScore = chartCfg.useBias and validBias ? sigCfg.scoreHtf : 0
    int totalScore = baseScore + biasScore
    string reason = reasonOverride == "" ? SMC.signal_reason_text(type, z.isBullish) : reasonOverride
    reason := reason + (chartCfg.useBias ? " (HTF Bias Confirmed)" : "")
    CORE.ConfluenceResult retestAdj = CORE.apply_candle_pattern_confluence(direction, reason, totalScore, cpCfg)
    string setup = setupOverride == "" ? shortName : setupOverride
    bool passMinScore = retestAdj.score >= limCfg.signalMinConfluenceScore
    if enabledType and validBias and passMinScore and not SMC.has_pending_trade_signal(_triggersQueue, setup, direction, z.top, z.bottom, syminfo.mintick)
        if triggerWhen == TRIGGER_WHEN_TOUCH and triggerType == TRIGGER_TYPE_TRADE
            add_entry(setup, direction, retestAdj.reason, z.top, z.bottom, z.qualityPct, retestAdj.score)
        else if triggerType == TRIGGER_TYPE_SIGNAL or triggerWhen == TRIGGER_WHEN_RETEST
            SMC.add_signal(_triggersQueue, signalMemoryEvents, setup, direction, retestAdj.reason, z.top, z.bottom, z.qualityPct, retestAdj.score, bar_index, syminfo.mintick, 80)
    bool(na)

// ==================== LIQUIDITY SWEEP RTO (LSR) LIFECYCLE ====================
// Tracks sweeps -> MS Shift (CHOCH) -> Extreme Origin Zone tagging.
var array<int> lsrBarState = array.new<int>(2, na) // 0: bear, 1: bull

process_lsr_model(CORE.ChartContext ctx) =>
    [lsrEnabled, lsrScore, shortName, _, _] = get_strategy_meta_by_key("SWEEP")
    if lsrEnabled
        int bearBar = array.get(lsrBarState, 0)
        int bullBar = array.get(lsrBarState, 1)
        int evSize = array.size(triggersQueue)
        if evSize > 0
            for i = evSize - 1 to 0
                CORE.Event e = array.get(triggersQueue, i)
                if e.type == "SWEEP"
                    if e.direction == "Sell"
                        bearBar := e.barDetected
                        array.set(lsrBarState, 0, bearBar)
                    else if e.direction == "Buy"
                        bullBar := e.barDetected
                        array.set(lsrBarState, 1, bullBar)
                    array.remove(triggersQueue, i)
                    
        int chochBarsLimit = 50
        bool bearSweepValid = not na(bearBar) and (bar_index - bearBar) <= chochBarsLimit
        int lastLtfLegBar = CORE.closest_bar_index_from_time(ltfData.legEventTime)
        bool bearChoch = bearSweepValid and ltfData.msBias == -1 and lastLtfLegBar > bearBar
        if bearSweepValid and bearChoch // Seek Bearish extreme zone
            CORE.PDArray extremeOrigin = na
            float highestTop = -999999.0
            if array.size(pdArrays) > 0
                for i = 0 to array.size(pdArrays) - 1
                    CORE.PDArray z = array.get(pdArrays, i)
                    bool isTrendZone = z.type == "OB" or z.type == "FVG" or z.type == "SD"
                    if isTrendZone and not z.isBullish
                        if z.barStart >= bearBar - 2 and z.barStart <= lastLtfLegBar + 2
                            if z.top > highestTop // highest structure near top
                                extremeOrigin := z
                                highestTop := z.top
            if not na(extremeOrigin)
                register_pdarray_retest_signal(triggersQueue, extremeOrigin, ctx.biasVal, "LSR Swept: Bearish Origin RTO", shortName)
                array.set(lsrBarState, 0, na) // Flush memory
                
        bool bullSweepValid = not na(bullBar) and (bar_index - bullBar) <= chochBarsLimit
        bool bullChoch = bullSweepValid and ltfData.msBias == 1 and lastLtfLegBar > bullBar
        if bullSweepValid and bullChoch // Seek Bullish extreme zone
            CORE.PDArray extremeOrigin = na
            float lowestBtm = 999999.0
            if array.size(pdArrays) > 0
                for i = 0 to array.size(pdArrays) - 1
                    CORE.PDArray z = array.get(pdArrays, i)
                    bool isTrendZone = z.type == "OB" or z.type == "FVG" or z.type == "SD"
                    if isTrendZone and z.isBullish
                        if z.barStart >= bullBar - 2 and z.barStart <= lastLtfLegBar + 2
                            if z.bottom < lowestBtm // deepest structure near dip
                                extremeOrigin := z
                                lowestBtm := z.bottom
            if not na(extremeOrigin)
                register_pdarray_retest_signal(triggersQueue, extremeOrigin, ctx.biasVal, "LSR Swept: Bullish Origin RTO", shortName)
                array.set(lsrBarState, 1, na) // Flush memory

    bool(na)

update_pdarray_box_label(CORE.PDArray z, float boxHigh, float boxLow) =>
    if not na(z.visualLabel)
        float zoneH = math.max(boxHigh - boxLow, syminfo.mintick)
        float labelY = ((boxHigh + boxLow) * 0.5) - (zoneH * 0.12)
        int labelXRaw = box.get_right(z.visualBox) - math.max(1, 1)
        int minLabelX = math.max(bar_index - 4000, 0)
        int maxLabelX = bar_index + 500
        int labelX = math.min(math.max(labelXRaw, minLabelX), maxLabelX)
        if z.visualLabel.get_x() != labelX
            z.visualLabel.set_x(labelX)
        if z.visualLabel.get_y() != labelY
            z.visualLabel.set_y(labelY)
        z.visualLabel.set_textalign(text.align_right)
        if z.visualLabel.get_text() != z.labelText
            z.visualLabel.set_text(z.labelText)
    if not na(z.visualBox)
        string nextBorderStyle = SMC.get_pdarray_border_style(z.type, z.labelText, line.style_solid, CONST)
        z.visualBox.set_border_style(nextBorderStyle)
    z

mark_pdarray_mitigated_visual(CORE.PDArray z) =>
    bool isHtfZone = z.sourceTfRank >= 2
    color mitClr = isHtfZone ? (z.sourceTfRank >= 3 ? color.new(htf2Cfg.zigzagColor, 0) : color.new(htf1Cfg.zigzagColor, 0)) : THEME.COLOR_NEUTRAL
    z.visualBox.set_bgcolor(color.new(mitClr, 90))
    z.visualBox.set_border_color(z.type == "IFVG" ? na : color.new(mitClr, 85))
    z.labelText := mark_pdarray_label_mitigated(z.type, z.labelText)
    if not na(z.visualLabel)
        z.visualLabel.set_textcolor(color.new(mitClr, 40))
        if z.type == "OB"
            z.visualLabel.set_tooltip(CORE.tt_side(z.isBullish, "Mitigation Block"))
    z.mitigated := true
    z.lifeState := CONST.LIFE_TOUCHED
    z.touchCount := math.max(z.touchCount, 0) + 1
    z.barEnd := bar_index
    z.rejectCount := math.max(z.rejectCount, 0)
    z

// Core: Zone lifecycle controller (mitigate/respect/break/spawn).
// Core: Zone lifecycle engine (mitigation/retest/break/reclaim/signals).
_controlZone(array<CORE.PDArray> zones, float _atr, int _biasVal) =>
    float o0 = open
    float h0 = high
    float l0 = low
    float c0 = close
    float o1 = open[1]
    float h1 = high[1]
    float l1 = low[1]
    float c1 = close[1]
    if zones.size() > 0
        for i = zones.size() - 1 to 0
            z = zones.get(i)
            z := SMC.normalize_pricezone_state(z, CONST)
            if not na(z.barStart) and (bar_index - z.barStart > effectiveCurrLookbackBars)
                if not na(z.visualLabel)
                    z.visualLabel.delete()
                if not na(z.visualBox)
                    z.visualBox.delete()
                zones.remove(i)
                continue
            if not na(z.visualBox) and not z.broken
                _boxLow  = z.visualBox.get_bottom()
                _boxHigh = z.visualBox.get_top()
                z := update_pdarray_box_label(z, _boxHigh, _boxLow)
                if z.type == "SD"
                    int sdRight = CORE.get_pdarray_min_right_idx(z, bar_index + z.extendBars, uiCfg.zoneCurrMinWidthBars)
                    if box.get_right(z.visualBox) != sdRight
                        z.visualBox.set_right(sdRight)
                    bool sdTouched = SMC.check_touch(_boxHigh, _boxLow, detCfg.basis, o0, h0, l0, c0)
                    bool canEmitSd = na(z.barEnd) or z.barEnd != bar_index
                    if sdTouched and canEmitSd
                        register_pdarray_retest_signal(triggersQueue, z, _biasVal, "", "")
                        z.barEnd := bar_index
                    zones.set(i, z)
                    continue
                bool isBull = z.isBullish
                if not z.mitigated
                    bool derivedNeedsDelay = z.type == "BB" or z.type == "IFVG"
                    bool canCheckMitigation = not derivedNeedsDelay or bar_index > z.barStart
                    entered = canCheckMitigation and SMC.check_mitigation(z.type, z.isBullish, _boxHigh, _boxLow, detCfg.method, detCfg.methodCross, detCfg.basis, detCfg.useImpulse, _atr, detCfg.impulseAtr, o0, h0, l0, c0, o1, h1, l1, c1)

                    if not entered
                        ext = z.extendBars
                        int nextRight = CORE.get_pdarray_min_right_idx(z, bar_index + ext, uiCfg.zoneCurrMinWidthBars)
                        if box.get_right(z.visualBox) != nextRight
                            z.visualBox.set_right(nextRight)
                        zones.set(i, z)
                    else
                        register_pdarray_retest_signal(triggersQueue, z, _biasVal, "", "")
                        z := mark_pdarray_mitigated_visual(z)
                        zones.set(i, z)
                else
                    breakLevel = isBull ? _boxLow : _boxHigh
                    respected = SMC.check_pdarray_respect(isBull, _boxHigh, _boxLow, h0, l0, c0)
                    [stratEnabled, _, _, _, _] = get_strategy_meta_by_key(str.upper(z.type))
                    canEmitRespect = na(z.barEnd) and stratEnabled
                    // For mitigated zones, keep extending to the latest touch bar (not first touch only).
                    if respected
                        z.barEnd := bar_index
                        z.lifeState := CONST.LIFE_RESPECTED
                        z.rejectCount := math.max(z.rejectCount, 0) + 1
                        int latestTouchRight = CORE.get_pdarray_min_right_idx(z, z.barEnd + 10, uiCfg.zoneCurrMinWidthBars)
                        if box.get_right(z.visualBox) != latestTouchRight
                            z.visualBox.set_right(latestTouchRight)
                    if respected and canEmitRespect
                        register_pdarray_retest_signal(triggersQueue, z, _biasVal, z.type + " touch respected", z.type + " R")
                        z.barEnd := bar_index
                        if not na(z.visualLabel)
                            z.visualLabel.set_tooltip(CORE.tt_side(isBull, z.type + " touch respected"))
                    isBroken = SMC.check_break(not isBull, breakLevel, detCfg.method, detCfg.methodCross, detCfg.basis, detCfg.useImpulse, _atr, detCfg.impulseAtr, o0, h0, l0, c0, o1, h1, l1, c1)
                    if isBroken
                        string breakDirection = z.isBullish ? "Sell" : "Buy"
                        SMC.register_break_retest_event(triggersQueue, z.type, breakDirection, z.top, z.bottom, bar_index, z.qualityPct, syminfo.mintick)
                        if z.type == "FVG" and plotFVG
                            spawn_derived_zone(zones, "IFVG", not z.isBullish, _boxHigh, _boxLow, z.qualityPct)
                        if z.type == "OB" and plotOB
                            spawn_derived_zone(zones, "BB", not z.isBullish, _boxHigh, _boxLow, z.qualityPct)
                        z.broken := true
                        z.lifeState := CONST.LIFE_BROKEN
                        if not na(z.visualLabel)
                            z.visualLabel.delete()
                        z.visualBox.delete()
                        zones.remove(i)
                        continue
                    else
                        zones.set(i, z)
                if z.mitigated and z.lifeState == CONST.LIFE_FORMED
                    z.lifeState := CONST.LIFE_TOUCHED
                    zones.set(i, z)
    bool(na)

process_data_entries(int breakRetestWindowBars, bool canEmitSignals) =>
    CORE.ChartContext ctx = chartCtx
    // Always run zone lifecycle/draw; only event emission remains gated by canEmitSignals.
    _controlZone(pdArrays, commonAtr, ctx.biasVal)
    if canEmitSignals
        process_barrier_touch_setup(ctx)
        process_events_queue(triggersQueue, ctx, breakRetestWindowBars)
        process_lsr_model(ctx)
    process_trades()
    bool(na)

draw_data_trades_dashboard() =>
    int maxTypes = math.max(1, array.size(trades))
    UI.render_entries_dashboard_from_entries(true, signalStatsTableTopRight, trades, maxTypes, THEME, CONST, SIG_METRIC_COUNT)
    UI.draw_bias_row_under_trades(signalStatsTableTopRight, 23, chartCtx, THEME, SETTINGS, CONST)
    bool(na)

draw_debug_table() =>
    if not signalShowDebug
        table.clear(debugTableTopCenter, 0, 0, 1, 5)
    else
        int pdMit = 0
        int pdAct = 0
        int pdActCurr = 0
        int pdActTf1 = 0
        int pdActTf2 = 0
        [dbgHtf1, dbgHtf2] = CORE.get_htf_pair()
        string tfCurr = str.upper(timeframe.period)
        string tf1 = str.upper(na(dbgHtf1) ? "" : dbgHtf1)
        string tf2 = str.upper(na(dbgHtf2) ? "" : dbgHtf2)
        if array.size(pdArrays) > 0
            for i = 0 to array.size(pdArrays) - 1
                CORE.PDArray z = array.get(pdArrays, i)
                if z.mitigated
                    pdMit += 1
                else if not z.broken
                    pdAct += 1
                    string src = str.upper(na(z.sourceTf) ? "" : z.sourceTf)
                    if src == "" or src == tfCurr
                        pdActCurr += 1
                    else if tf1 != "" and src == tf1
                        pdActTf1 += 1
                    else if tf2 != "" and src == tf2
                        pdActTf2 += 1
        color bgHdr = color.new(THEME.COLOR_UI_BG, 40)
        color bgRow = color.new(THEME.COLOR_UI_BG, 72)
        table.cell(debugTableTopCenter, 0, 0, "DEBUG", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(debugTableTopCenter, 1, 0, "Count", text_color = color.white, bgcolor = bgHdr, text_size = size.tiny)
        table.cell(debugTableTopCenter, 0, 1, "PD Active", text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 1, 1, str.tostring(pdAct), text_color = THEME.COLOR_BULLISH, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 0, 2, "PD Mitigated", text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 1, 2, str.tostring(pdMit), text_color = THEME.COLOR_BEARISH, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 0, 3, "PD " + CORE.get_friendly_tf(timeframe.period), text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 1, 3, str.tostring(pdActCurr), text_color = color.white, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 0, 4, "PD " + (na(dbgHtf1) ? "-" : CORE.get_friendly_tf(dbgHtf1)), text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 1, 4, str.tostring(pdActTf1), text_color = color.white, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 0, 5, "PD " + (na(dbgHtf2) ? "-" : CORE.get_friendly_tf(dbgHtf2)), text_color = THEME.COLOR_UI_FG, bgcolor = bgRow, text_size = size.tiny)
        table.cell(debugTableTopCenter, 1, 5, str.tostring(pdActTf2), text_color = color.white, bgcolor = bgRow, text_size = size.tiny)
    bool(na)

draw_data_htf_pdarray_set(array<box> store, int tfSlot, bool showTf, string tfLabel, string tfStr,
 float top0, float btm0, int start0, float q0, bool bull0, string type0,
 float top1, float btm1, int start1, float q1, bool bull1, string type1,
 float top2, float btm2, int start2, float q2, bool bull2, string type2,
 float top3, float btm3, int start3, float q3, bool bull3, string type3) =>
    float adOb = na
    int aiOb = na
    float adFvg = na
    int aiFvg = na
    float bdOb = na
    int biOb = na
    float bdFvg = na
    int biFvg = na
    // Buffer-safe: avoid `time[bar_index]` (can request thousands of bars back). Early bars treat all as "recent".
    int htfLookbackOffSafe = math.max(1, math.min(limCfg.htfZoneLookbackBars, 90))
    int recentTsCut = bar_index >= htfLookbackOffSafe ? time[htfLookbackOffSafe] : 0

    for i = 0 to 3
        float top = i == 0 ? top0 : i == 1 ? top1 : i == 2 ? top2 : top3
        float btm = i == 0 ? btm0 : i == 1 ? btm1 : i == 2 ? btm2 : btm3
        int st = i == 0 ? start0 : i == 1 ? start1 : i == 2 ? start2 : start3
        float q = i == 0 ? q0 : i == 1 ? q1 : i == 2 ? q2 : q3
        string zType = i == 0 ? type0 : i == 1 ? type1 : i == 2 ? type2 : type3
        bool showType = zType == "OB" ? plotOB : plotFVG
        bool isBull = i == 0 ? bull0 : i == 1 ? bull1 : i == 2 ? bull2 : bull3
        bool unmitigated = isBull ? (low > top) : (high < btm)
        bool recent = not na(st) and st >= recentTsCut
        bool valid = showTf and showType and recent and not na(st) and not na(top) and not na(btm) and top > btm and nz(q, 0) >= limCfg.htfProjectionMinQualityPct and unmitigated
        if valid
            float mid = (top + btm) * 0.5
            float dist = math.abs(mid - close)
            bool isAbove = mid > close
            string fam = SMC.get_pdarray_cap_family(zType)
            if isAbove
                if fam == "OB_FAMILY"
                    if na(adOb) or dist < adOb
                        adOb := dist
                        aiOb := i
                else if fam == "FVG_FAMILY"
                    if na(adFvg) or dist < adFvg
                        adFvg := dist
                        aiFvg := i
            else
                if fam == "OB_FAMILY"
                    if na(bdOb) or dist < bdOb
                        bdOb := dist
                        biOb := i
                else if fam == "FVG_FAMILY"
                    if na(bdFvg) or dist < bdFvg
                        bdFvg := dist
                        biFvg := i

    bool obFirst = true // HTF_FAMILY_PRIORITY_OB >= HTF_FAMILY_PRIORITY_FVG
    int aboveFirst = obFirst ? (not na(aiOb) ? aiOb : aiFvg) : (not na(aiFvg) ? aiFvg : aiOb)
    int aboveSecond = obFirst ? (not na(aiOb) and not na(aiFvg) ? aiFvg : na) : (not na(aiFvg) and not na(aiOb) ? aiOb : na)
    int belowFirst = obFirst ? (not na(biOb) ? biOb : biFvg) : (not na(biFvg) ? biFvg : biOb)
    int belowSecond = obFirst ? (not na(biOb) and not na(biFvg) ? biFvg : na) : (not na(biFvg) and not na(biOb) ? biOb : na)

    float dAbove = na
    if not na(aboveFirst)
        float topA = aboveFirst == 0 ? top0 : aboveFirst == 1 ? top1 : aboveFirst == 2 ? top2 : top3
        float btmA = aboveFirst == 0 ? btm0 : aboveFirst == 1 ? btm1 : aboveFirst == 2 ? btm2 : btm3
        dAbove := math.abs(((topA + btmA) * 0.5) - close)
    float dBelow = na
    if not na(belowFirst)
        float topB = belowFirst == 0 ? top0 : belowFirst == 1 ? top1 : belowFirst == 2 ? top2 : top3
        float btmB = belowFirst == 0 ? btm0 : belowFirst == 1 ? btm1 : belowFirst == 2 ? btm2 : btm3
        dBelow := math.abs(((topB + btmB) * 0.5) - close)

    int p0 = na
    int p1 = na
    if not na(aboveFirst) and not na(belowFirst)
        bool aboveNearest = dAbove <= dBelow
        p0 := aboveNearest ? aboveFirst : belowFirst
        p1 := aboveNearest ? belowFirst : aboveFirst
    else
        p0 := not na(aboveFirst) ? aboveFirst : belowFirst
        p1 := na
    int p2 = not na(p1) and p1 == aboveFirst ? belowSecond : p1 == belowFirst ? aboveSecond : aboveSecond
    int p3 = not na(p2) and p2 == aboveSecond ? belowSecond : belowSecond

    int outMax = math.max(1, math.min(HTF_pdarray_PER_TF, 8))
    for outPos = 0 to outMax - 1
        int cand = na
        if outPos == 0
            cand := p0
        else if outPos == 1
            cand := p1
        else if outPos == 2
            cand := p2
        else if outPos == 3
            cand := p3
        int boxIdx = tfSlot * HTF_pdarray_PER_TF + outPos
        if not na(cand)
            float top = cand == 0 ? top0 : cand == 1 ? top1 : cand == 2 ? top2 : top3
            float btm = cand == 0 ? btm0 : cand == 1 ? btm1 : cand == 2 ? btm2 : btm3
            int st = cand == 0 ? start0 : cand == 1 ? start1 : cand == 2 ? start2 : start3
            float q = cand == 0 ? q0 : cand == 1 ? q1 : cand == 2 ? q2 : q3
            bool isBull = cand == 0 ? bull0 : cand == 1 ? bull1 : cand == 2 ? bull2 : bull3
            string zType = cand == 0 ? type0 : cand == 1 ? type1 : cand == 2 ? type2 : type3
            int ext = SMC.get_htf_pdarray_extend(tfSlot, 14, 25)
            color txtCol = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 0) : color.new(htf2Cfg.zigzagColor, 0)
            string txt = str.upper(zType)
            color htfFill = color.new(THEME.COLOR_NEUTRAL, uiCfg.htfZoneBgTransp)
            color tfBorder = tfSlot == 0 ? color.new(htf1Cfg.zigzagColor, 85) : color.new(htf2Cfg.zigzagColor, 85)
            UI.update_projected_box_slot(store, boxIdx, showTf, st, ext, top, btm, htfFill, txtCol, txt, bar_index, time, time[1], htfProjectionSpanBars, CORE.is_in_draw_lookback_current(perfLookbackBars), tfBorder, line.style_dotted, HTF_BOX_VIS_CFG)
        else
            UI.update_projected_box_slot(store, boxIdx, false, int(na), 0, float(na), float(na), color.new(THEME.COLOR_NEUTRAL, uiCfg.htfZoneBgTransp), THEME.COLOR_NEUTRAL, "", bar_index, time, time[1], htfProjectionSpanBars, CORE.is_in_draw_lookback_current(perfLookbackBars), color.new(THEME.COLOR_NEUTRAL, 15), line.style_dotted, HTF_BOX_VIS_CFG)

// Bias dashboard removed from ICT file. Bias/dashboard lives in indicator module.

get_data_htf_pdarray_snapshots(string htf1, string htf2, bool zshow0, bool reqHtf2Zones, SMC.ZoneQualityCfg zqCfg) =>
    int srPivotLen = int(math.max(PIVOT_LEN_BASE + 2, 3))
    [h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1ObUpQ, h1ObDnQ, h1FvgUpQ, h1FvgDnQ, h1SrHiDummy, h1SrHiTDummy, h1SrLoDummy, h1SrLoTDummy] = if zshow0
        request.security(syminfo.tickerid, htf1, SMC.get_htf_pdarray_sr_snapshot(limCfg.zoneFormationLockBars, zqCfg, 14, srPivotLen))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), float(na), float(na), float(na), int(na), float(na), int(na)]
    [h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2ObUpQ, h2ObDnQ, h2FvgUpQ, h2FvgDnQ, h2SrHi, h2SrHiT, h2SrLo, h2SrLoT] = if reqHtf2Zones
        request.security(syminfo.tickerid, htf2, SMC.get_htf_pdarray_sr_snapshot(limCfg.zoneFormationLockBars, zqCfg, 14, srPivotLen))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), int(na), float(na), float(na), float(na), float(na), float(na), int(na), float(na), int(na)]
    [h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1ObUpQ, h1ObDnQ, h1FvgUpQ, h1FvgDnQ, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2ObUpQ, h2ObDnQ, h2FvgUpQ, h2FvgDnQ, h2SrHi, h2SrHiT, h2SrLo, h2SrLoT]

[htf1, htf2] = CORE.get_htf_pair()

// Optimized HTF requests: only request data for the selected HTFs (no 15/240/1D/1W prefetch).
zshow0 = uiCfg.htfShowProjectedZones and not na(htf1)
zshow1 = uiCfg.htfShowProjectedZones and not na(htf2)
// Always keep projected HTF visuals on; merge-to-active is independent.
zdraw0 = zshow0
zdraw1 = zshow1
bool needHtf2Anchors = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf2)

// Heavy data snapshots (cached between strict-run ticks).
var float h1ObUpTop = na
var float h1ObUpBtm = na
var int h1ObUpStart = na
var float h1ObDnTop = na
var float h1ObDnBtm = na
var int h1ObDnStart = na
var float h1FvgUpTop = na
var float h1FvgUpBtm = na
var int h1FvgUpStart = na
var float h1FvgDnTop = na
var float h1FvgDnBtm = na
var int h1FvgDnStart = na
var float h1ObUpQ = na
var float h1ObDnQ = na
var float h1FvgUpQ = na
var float h1FvgDnQ = na
var float h1SdSupTop = na
var float h1SdSupBtm = na
var int h1SdSupStart = na
var float h1SdDemTop = na
var float h1SdDemBtm = na
var int h1SdDemStart = na
var float h2ObUpTop = na
var float h2ObUpBtm = na
var int h2ObUpStart = na
var float h2ObDnTop = na
var float h2ObDnBtm = na
var int h2ObDnStart = na
var float h2FvgUpTop = na
var float h2FvgUpBtm = na
var int h2FvgUpStart = na
var float h2FvgDnTop = na
var float h2FvgDnBtm = na
var int h2FvgDnStart = na
var float h2ObUpQ = na
var float h2ObDnQ = na
var float h2FvgUpQ = na
var float h2FvgDnQ = na
var float h2SdSupTop = na
var float h2SdSupBtm = na
var int h2SdSupStart = na
var float h2SdDemTop = na
var float h2SdDemBtm = na
var int h2SdDemStart = na

bool reqHtf2Zones = zshow1 or needHtf2Anchors
var bool prevZshow0 = false
var bool prevReqHtf2Zones = false
bool htf1BarChanged = zshow0 and not na(htf1) and ta.change(time(htf1)) != 0
bool htf2BarChanged = reqHtf2Zones and not na(htf2) and ta.change(time(htf2)) != 0
bool htfCfgChanged = barstate.isfirst or zshow0 != prevZshow0 or reqHtf2Zones != prevReqHtf2Zones
bool needRefreshHtfSnapshots = htfCfgChanged or htf1BarChanged or htf2BarChanged
if needRefreshHtfSnapshots
    [_h1ObUpTop, _h1ObUpBtm, _h1ObUpStart, _h1ObDnTop, _h1ObDnBtm, _h1ObDnStart, _h1FvgUpTop, _h1FvgUpBtm, _h1FvgUpStart, _h1FvgDnTop, _h1FvgDnBtm, _h1FvgDnStart, _h1ObUpQ, _h1ObDnQ, _h1FvgUpQ, _h1FvgDnQ, _h2ObUpTop, _h2ObUpBtm, _h2ObUpStart, _h2ObDnTop, _h2ObDnBtm, _h2ObDnStart, _h2FvgUpTop, _h2FvgUpBtm, _h2FvgUpStart, _h2FvgDnTop, _h2FvgDnBtm, _h2FvgDnStart, _h2ObUpQ, _h2ObDnQ, _h2FvgUpQ, _h2FvgDnQ, _, _, _, _] = get_data_htf_pdarray_snapshots(htf1, htf2, zshow0, reqHtf2Zones, zqCfg)
    h1ObUpTop := _h1ObUpTop
    h1ObUpBtm := _h1ObUpBtm
    h1ObUpStart := _h1ObUpStart
    h1ObDnTop := _h1ObDnTop
    h1ObDnBtm := _h1ObDnBtm
    h1ObDnStart := _h1ObDnStart
    h1FvgUpTop := _h1FvgUpTop
    h1FvgUpBtm := _h1FvgUpBtm
    h1FvgUpStart := _h1FvgUpStart
    h1FvgDnTop := _h1FvgDnTop
    h1FvgDnBtm := _h1FvgDnBtm
    h1FvgDnStart := _h1FvgDnStart
    h1ObUpQ := _h1ObUpQ
    h1ObDnQ := _h1ObDnQ
    h1FvgUpQ := _h1FvgUpQ
    h1FvgDnQ := _h1FvgDnQ
    h2ObUpTop := _h2ObUpTop
    h2ObUpBtm := _h2ObUpBtm
    h2ObUpStart := _h2ObUpStart
    h2ObDnTop := _h2ObDnTop
    h2ObDnBtm := _h2ObDnBtm
    h2ObDnStart := _h2ObDnStart
    h2FvgUpTop := _h2FvgUpTop
    h2FvgUpBtm := _h2FvgUpBtm
    h2FvgUpStart := _h2FvgUpStart
    h2FvgDnTop := _h2FvgDnTop
    h2FvgDnBtm := _h2FvgDnBtm
    h2FvgDnStart := _h2FvgDnStart
    h2ObUpQ := _h2ObUpQ
    h2ObDnQ := _h2ObDnQ
    h2FvgUpQ := _h2FvgUpQ
    h2FvgDnQ := _h2FvgDnQ
prevZshow0 := zshow0
prevReqHtf2Zones := reqHtf2Zones
int htfSdLookback = math.max(20, math.min(limCfg.htfZoneLookbackBars, 300))
var bool prevZshow0Sd = false
var bool prevZshow1 = false
var bool prevPlotSd = false
bool sdCfgChanged = barstate.isfirst or zshow0 != prevZshow0Sd or zshow1 != prevZshow1 or plotSD != prevPlotSd
bool refreshHtf1Sd = sdCfgChanged or (zshow0 and plotSD and not na(htf1) and ta.change(time(htf1)) != 0)
bool refreshHtf2Sd = sdCfgChanged or (zshow1 and plotSD and not na(htf2) and ta.change(time(htf2)) != 0)
if refreshHtf1Sd
    [h1SdSupTopRaw, h1SdSupBtmRaw, h1SdSupStartRaw, h1SdDemTopRaw, h1SdDemBtmRaw, h1SdDemStartRaw] = if zshow0 and plotSD
        request.security(syminfo.tickerid, htf1, get_data_htf_sd_snapshot(10.0, 50, htfSdLookback))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na)]
    h1SdSupTop := h1SdSupTopRaw
    h1SdSupBtm := h1SdSupBtmRaw
    h1SdSupStart := h1SdSupStartRaw
    h1SdDemTop := h1SdDemTopRaw
    h1SdDemBtm := h1SdDemBtmRaw
    h1SdDemStart := h1SdDemStartRaw
if refreshHtf2Sd
    [h2SdSupTopRaw, h2SdSupBtmRaw, h2SdSupStartRaw, h2SdDemTopRaw, h2SdDemBtmRaw, h2SdDemStartRaw] = if zshow1 and plotSD
        request.security(syminfo.tickerid, htf2, get_data_htf_sd_snapshot(10.0, 50, htfSdLookback))
    else
        [float(na), float(na), int(na), float(na), float(na), int(na)]
    h2SdSupTop := h2SdSupTopRaw
    h2SdSupBtm := h2SdSupBtmRaw
    h2SdSupStart := h2SdSupStartRaw
    h2SdDemTop := h2SdDemTopRaw
    h2SdDemBtm := h2SdDemBtmRaw
    h2SdDemStart := h2SdDemStartRaw
prevZshow1 := zshow1
prevPlotSd := plotSD
prevZshow0Sd := zshow0

int htf2ObAnchorTs = CORE.get_latest_time4(h2ObUpStart, h2ObDnStart, h2FvgUpStart, h2FvgDnStart)
int htf2SrAnchorTs = na
bool canEmitSignals = barstate.isconfirmed

// Global VPVR execution buffers removed to save tokens and align with model refactor.

// Keep TF swing ledgers updated in SMC (data-only; no market-structure drawing here).
int currPivotLen = PIVOT_LEN_BASE
int maxSafeHistOff = 90
int currPivotOffSafe = math.max(0, math.min(currPivotLen, maxSafeHistOff))
int htf1MimicPivotLen = not na(htf1) ? CORE.get_mimic_pivot_len(timeframe.period, htf1, PIVOT_LEN_BASE, PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION) : na
int htf2MimicPivotLen = not na(htf2) ? CORE.get_mimic_pivot_len(timeframe.period, htf2, PIVOT_LEN_BASE, PIVOT_LEN_SCALP, PIVOT_LEN_INTRADAY, PIVOT_LEN_MULTI_DAY, PIVOT_LEN_SWING, PIVOT_LEN_POSITION) : na
int htf1PivotOffSafe = not na(htf1MimicPivotLen) ? math.max(0, math.min(htf1MimicPivotLen, maxSafeHistOff)) : na
int htf2PivotOffSafe = not na(htf2MimicPivotLen) ? math.max(0, math.min(htf2MimicPivotLen, maxSafeHistOff)) : na
float currSh = ta.pivothigh(high, currPivotLen, currPivotLen)
float currSl = ta.pivotlow(low, currPivotLen, currPivotLen)
int htf1LenSafe = not na(htf1MimicPivotLen) ? htf1MimicPivotLen : currPivotLen
float sh1Raw = ta.pivothigh(high, htf1LenSafe, htf1LenSafe)
float sl1Raw = ta.pivotlow(low, htf1LenSafe, htf1LenSafe)
float sh1Mimic = not na(htf1MimicPivotLen) ? sh1Raw : na
float sl1Mimic = not na(htf1MimicPivotLen) ? sl1Raw : na
int sh1MimicT = not na(sh1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
int sl1MimicT = not na(sl1Mimic) and not na(htf1PivotOffSafe) ? time[htf1PivotOffSafe] : na
int htf2LenSafe = not na(htf2MimicPivotLen) ? htf2MimicPivotLen : currPivotLen
float sh2Raw = ta.pivothigh(high, htf2LenSafe, htf2LenSafe)
float sl2Raw = ta.pivotlow(low, htf2LenSafe, htf2LenSafe)
float sh2Mimic = not na(htf2MimicPivotLen) ? sh2Raw : na
float sl2Mimic = not na(htf2MimicPivotLen) ? sl2Raw : na
int sh2MimicT = not na(sh2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
int sl2MimicT = not na(sl2Mimic) and not na(htf2PivotOffSafe) ? time[htf2PivotOffSafe] : na
CORE.process_tf_armed_state(ltfData, true, currSh, not na(currSh) ? int(time[currPivotOffSafe]) : na, currSl, not na(currSl) ? int(time[currPivotOffSafe]) : na, SETTINGS.SWING_HISTORY_MAX)
CORE.process_tf_armed_state(htf1Data, not na(htf1), sh1Mimic, int(sh1MimicT), sl1Mimic, int(sl1MimicT), SETTINGS.SWING_HISTORY_MAX)
CORE.process_tf_armed_state(htf2Data, not na(htf2), sh2Mimic, int(sh2MimicT), sl2Mimic, int(sl2MimicT), SETTINGS.SWING_HISTORY_MAX)
process_tf_ms_trend_light(ltfData, true)
process_tf_ms_trend_light(htf1Data, not na(htf1))
process_tf_ms_trend_light(htf2Data, not na(htf2))
int h2LastHiT = array.size(htf2Data.swingHighTimes) > 0 ? array.get(htf2Data.swingHighTimes, array.size(htf2Data.swingHighTimes) - 1) : na
int h2LastLoT = array.size(htf2Data.swingLowTimes) > 0 ? array.get(htf2Data.swingLowTimes, array.size(htf2Data.swingLowTimes) - 1) : na
int htf2SwingAnchorTs = CORE.get_latest_time4(h2LastHiT, h2LastLoT, int(na), int(na))
int htf2AnchorTsFinal = CORE.get_dynamic_anchor_ts("OB_FIRST", "SR_FIRST", "SWING_FIRST", htf2ObAnchorTs, htf2SrAnchorTs, htf2SwingAnchorTs)
bool recalcByHtf2 = not na(htf2) and ta.change(time(htf2)) != 0
bool recalcByN = false
bool shouldDynRecalc = SETTINGS.DYN_LOOKBACK_ENABLE and (barstate.isfirst or recalcByHtf2 or recalcByN) // Controls how often dynamic lookback/candle widths update.
if shouldDynRecalc
    int dynHtf1Candles = SETTINGS.DYN_LOOKBACK_ENABLE and not na(htf1) ? CORE.get_candles_to_anchor(htf1, htf2AnchorTsFinal, SETTINGS.DYN_HTF1_CANDLES_MIN, SETTINGS.DYN_HTF1_CANDLES_MAX, SETTINGS.HTF_CANDLES_BASE) : SETTINGS.HTF_CANDLES_BASE
    int htf1SecForDyn = not na(htf1) ? math.max(CORE.get_tf_seconds(htf1), 1) : na
    int htf2SecForDyn = not na(htf2) ? math.max(CORE.get_tf_seconds(htf2), 1) : na
    float htf2PerHtf1Dyn = not na(htf1SecForDyn) and not na(htf2SecForDyn) and htf2SecForDyn > htf1SecForDyn ? float(htf2SecForDyn) / float(htf1SecForDyn) : na
    // Keep HTF1/HTF2 panels on equivalent time span:
    // pass-1: derive HTF2 from HTF1 / ratio
    int dynHtf2Candles = not na(htf2PerHtf1Dyn) ? int(math.round(float(dynHtf1Candles) / htf2PerHtf1Dyn)) : SETTINGS.DYN_HTF2_CANDLES_FALLBACK
    dynHtf2Candles := math.max(SETTINGS.DYN_HTF2_CANDLES_MIN, math.min(dynHtf2Candles, SETTINGS.DYN_HTF2_CANDLES_MAX))
    // pass-2: back-project HTF1 from HTF2 * ratio and keep the larger (stability against rounding loss)
    int dynHtf1FromHtf2 = not na(htf2PerHtf1Dyn) ? int(math.ceil(float(dynHtf2Candles) * htf2PerHtf1Dyn)) : dynHtf1Candles
    dynHtf1Candles := math.max(dynHtf1Candles, dynHtf1FromHtf2)
    dynHtf1Candles := math.max(SETTINGS.DYN_HTF1_CANDLES_MIN, math.min(dynHtf1Candles, SETTINGS.DYN_HTF1_CANDLES_MAX))
    int dynCurrLookbackBars = CORE.get_curr_lookback_from_htf2(htf2, dynHtf2Candles, SETTINGS.DYN_CURR_LOOKBACK_MIN_BARS, SETTINGS.DYN_CURR_LOOKBACK_MAX_BARS)
    dynCachedCurrLookbackBars := dynCurrLookbackBars
effectiveCurrLookbackBars := SETTINGS.DYN_LOOKBACK_ENABLE ? dynCachedCurrLookbackBars : LOOKBACK_BARS_WORK // Master working lookback for pruning + keylevel lifecycle.
perfLookbackBars := effectiveCurrLookbackBars
htfProjectionSpanBars := effectiveCurrLookbackBars
chartCtx := process_data_chart_context()


// S/R, Swing Liquidity, EqH/EqL, PDH/PDL, and local SD density were moved to Hung - MSS.
// Keep `levels` only as an empty ChartContext placeholder in SMC.

int ltfZoneStartIdx = array.size(pdArrays)

if canEmitSignals and plotOB and SMC.smc_is_ob(true, 1, limCfg.zoneFormationLockBars)
    _t = high[2]
    _b = math.min(low[2], low[1])
    [qOk, qPct, _] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, "", false)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig obCfgBull = get_pdarray_cfg("OB")
        _ext = obCfgBull.extendBarsCurr > 0 ? obCfgBull.extendBarsCurr : SMC.get_current_pdarray_extend("OB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _obCls = SMC.classify_new_ob(pdArrays, true, _t, _b, _q, CONST)
        _obTxt = normalize_pdarray_label_text("OB", SMC.ob_label_text(_obCls))
        string obTipBase = CORE.tt_side(true, SMC.ob_class_name(_obCls, CONST))
        [_, _, _tt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, obTipBase, uiCfg.zoneTooltipEnable)
        _borderColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBullish, 55)
        _borderStyle = SMC.get_ob_border_style(_obCls, THEME.STYLE_STRONG, CONST)
        add_primary_zone(pdArrays, "OB", true, _t, _b, bar_index - 2, _ext, _obTxt, bar_index + 3, _t, uiCfg.colorBullish, _borderColor, _borderStyle, _q, _tt, -1)

if canEmitSignals and plotOB and SMC.smc_is_ob(false, 1, limCfg.zoneFormationLockBars)
    _t = math.max(high[2], high[1])
    _b = low[2]
    [qOk, qPct, _] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, "", false)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig obCfgBear = get_pdarray_cfg("OB")
        _ext = obCfgBear.extendBarsCurr > 0 ? obCfgBear.extendBarsCurr : SMC.get_current_pdarray_extend("OB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _obCls = SMC.classify_new_ob(pdArrays, false, _t, _b, _q, CONST)
        _obTxt = normalize_pdarray_label_text("OB", SMC.ob_label_text(_obCls))
        string obTipBase = CORE.tt_side(false, SMC.ob_class_name(_obCls, CONST))
        [_, _, _tt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, obTipBase, uiCfg.zoneTooltipEnable)
        _borderStyle = SMC.get_ob_border_style(_obCls, THEME.STYLE_STRONG, CONST)
        add_primary_zone(pdArrays, "OB", false, _t, _b, bar_index - 2, _ext, _obTxt, bar_index + 3, _b, color.new(uiCfg.colorBearish, 20), color.new(uiCfg.colorBearish, 55), _borderStyle, _q, _tt, -1)

// OB-driven RJB execution.
if canEmitSignals and plotOB and SMC.smc_is_ob(true, 1, limCfg.zoneFormationLockBars)
    isRjb1 = (low[1] > (close[2] - 0.2 * (close[2] - low[2])))
    isRjb2 = (low[1] < low[2])
    if isRjb1 or isRjb2
        _top = isRjb1 ? close[2] : open[1]
        _btm = isRjb1 ? low[2] : low[1]
        _impOff = isRjb1 ? 2 : 1
        [qOk, qPct, qTt] = SMC.zone_quality_eval(_top, _btm, _impOff, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(true, "Bull RJB"), uiCfg.zoneTooltipEnable)
        if qOk
            _lx  = isRjb1 ? bar_index - 2 : bar_index - 1
            if not SMC.has_nearby_ob(pdArrays, true, _top, _btm, _lx, 2)
                _q = qPct
                SMC.ZoneTypeConfig rjbCfgBull = get_pdarray_cfg("RJB")
                _ext = rjbCfgBull.extendBarsCurr > 0 ? rjbCfgBull.extendBarsCurr : SMC.get_current_pdarray_extend("RJB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
                _rjbTxt = "rjb"
                _borderColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBullish, 55)
                _borderStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
                add_primary_zone(pdArrays, "RJB", true, _top, _btm, _lx, _ext, _rjbTxt, bar_index + 11, _top, uiCfg.colorBullish, _borderColor, _borderStyle, _q, qTt, -1)

if canEmitSignals and plotOB and SMC.smc_is_ob(false, 1, limCfg.zoneFormationLockBars)
    isRjb1 = (high[1] < (close[2] + 0.2 * (high[2] - close[2])))
    isRjb2 = (high[1] > high[2])
    if isRjb1 or isRjb2
        _top = isRjb1 ? high[2] : high[1]
        _btm = isRjb1 ? close[2] : open[1]
        _impOff = isRjb1 ? 2 : 1
        [qOk, qPct, qTt] = SMC.zone_quality_eval(_top, _btm, _impOff, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(false, "Bear RJB"), uiCfg.zoneTooltipEnable)
        if qOk
            _lx  = isRjb1 ? bar_index - 2 : bar_index - 1
            if not SMC.has_nearby_ob(pdArrays, false, _top, _btm, _lx, 2)
                _q = qPct
                SMC.ZoneTypeConfig rjbCfgBear = get_pdarray_cfg("RJB")
                _ext = rjbCfgBear.extendBarsCurr > 0 ? rjbCfgBear.extendBarsCurr : SMC.get_current_pdarray_extend("RJB", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
                _rjbTxt = "rjb"
                _borderColor = THEME.STYLE_STRONG == "None" ? na : color.new(uiCfg.colorBearish, 55)
                _borderStyle = THEME.STYLE_STRONG == "None" ? line.style_solid : THEME.STYLE_STRONG
                add_primary_zone(pdArrays, "RJB", false, _top, _btm, _lx, _ext, _rjbTxt, bar_index + 11, _btm, color.new(uiCfg.colorBearish, THEME.T_LOW), _borderColor, _borderStyle, _q, qTt, -1)

// ==================== LOCAL (PER BAR) ====================
float hv = ta.valuewhen(not na(ta.pivothigh(high, PIVOT_LEN_BASE, PIVOT_LEN_BASE)), high[PIVOT_LEN_BASE], 0)
float lv = ta.valuewhen(not na(ta.pivotlow(low, PIVOT_LEN_BASE, PIVOT_LEN_BASE)), low[PIVOT_LEN_BASE], 0)

if canEmitSignals and plotFVG and SMC.smc_is_fvg(true, 0, limCfg.zoneFormationLockBars)
    isSB = (close[1] > hv) and (low[1] < hv) and (high[2] < hv) and (low > hv)
    _t = low[0]
    _b = high[2]
    [qOk, qPct, qTt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(true, isSB ? "SB FVG" : "FVG"), uiCfg.zoneTooltipEnable)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig fvgCfgBull = get_pdarray_cfg("FVG")
        _ext = fvgCfgBull.extendBarsCurr > 0 ? fvgCfgBull.extendBarsCurr : SMC.get_current_pdarray_extend("FVG", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _fvgBaseTxt = "fvg" + (isSB ? "*" : "")
        _fvgTxt = _fvgBaseTxt
        add_primary_zone(pdArrays, "FVG", true, _t, _b, bar_index - 2, _ext, _fvgTxt, bar_index + 7, (_t + _b) / 2.0, uiCfg.colorBullish, na, line.style_solid, _q, qTt, -1)

if canEmitSignals and plotFVG and SMC.smc_is_fvg(false, 0, limCfg.zoneFormationLockBars)
    isSB = (close[1] < lv) and (high[1] > lv) and (low[2] > lv) and (high < lv)
    _t = low[2]
    _b = high[0]
    [qOk, qPct, qTt] = SMC.zone_quality_eval(_t, _b, 1, commonAtr, syminfo.mintick, zqCfg, CORE.tt_side(false, isSB ? "SB FVG" : "FVG"), uiCfg.zoneTooltipEnable)
    if qOk
        _q = qPct
        SMC.ZoneTypeConfig fvgCfgBear = get_pdarray_cfg("FVG")
        _ext = fvgCfgBear.extendBarsCurr > 0 ? fvgCfgBear.extendBarsCurr : SMC.get_current_pdarray_extend("FVG", uiCfg.ltfBarsExt - 4, uiCfg.ltfBarsExt)
        _fvgBaseTxt = "fvg" + (isSB ? "*" : "")
        _fvgTxt = _fvgBaseTxt
        add_primary_zone(pdArrays, "FVG", false, _t, _b, bar_index - 2, _ext, _fvgTxt, bar_index + 7, (_t + _b) / 2.0, color.new(uiCfg.colorBearish, THEME.T_LOW), na, line.style_solid, _q, qTt, -1)

annotate_new_pricezones(pdArrays, ltfZoneStartIdx, timeframe.period, 1, ltfData)

SMC.prune_old_current_zones(pdArrays, effectiveCurrLookbackBars, last_bar_index)
SMC.prune_current_pdarray_side_caps(pdArrays, limCfg.zoneCurrMaxPerTypeSide, close, bar_index, limCfg.zonePriorityAgeDecay)
if true
    string htf1Label = zshow0 ? CORE.get_friendly_tf(htf1) : ""
    string htf2Label = zshow1 ? CORE.get_friendly_tf(htf2) : ""
    int htf1ZoneStartIdx = array.size(pdArrays)
    add_htf_pdarray_if_valid(pdArrays, htf1Label, 0, zshow0, plotOB, "OB", true, h1ObUpTop, h1ObUpBtm, h1ObUpStart, h1ObUpQ)
    add_htf_pdarray_if_valid(pdArrays, htf1Label, 0, zshow0, plotOB, "OB", false, h1ObDnTop, h1ObDnBtm, h1ObDnStart, h1ObDnQ)
    add_htf_pdarray_if_valid(pdArrays, htf1Label, 0, zshow0, plotFVG, "FVG", true, h1FvgUpTop, h1FvgUpBtm, h1FvgUpStart, h1FvgUpQ)
    add_htf_pdarray_if_valid(pdArrays, htf1Label, 0, zshow0, plotFVG, "FVG", false, h1FvgDnTop, h1FvgDnBtm, h1FvgDnStart, h1FvgDnQ)
    add_htf_pdarray_if_valid(pdArrays, htf1Label, 0, zshow0, plotSD, "SD", false, h1SdSupTop, h1SdSupBtm, h1SdSupStart, 100.0)
    add_htf_pdarray_if_valid(pdArrays, htf1Label, 0, zshow0, plotSD, "SD", true, h1SdDemTop, h1SdDemBtm, h1SdDemStart, 100.0)
    annotate_new_pricezones(pdArrays, htf1ZoneStartIdx, htf1, 2, htf1Data)
    int htf2ZoneStartIdx = array.size(pdArrays)
    add_htf_pdarray_if_valid(pdArrays, htf2Label, 1, zshow1, plotOB, "OB", true, h2ObUpTop, h2ObUpBtm, h2ObUpStart, h2ObUpQ)
    add_htf_pdarray_if_valid(pdArrays, htf2Label, 1, zshow1, plotOB, "OB", false, h2ObDnTop, h2ObDnBtm, h2ObDnStart, h2ObDnQ)
    add_htf_pdarray_if_valid(pdArrays, htf2Label, 1, zshow1, plotFVG, "FVG", true, h2FvgUpTop, h2FvgUpBtm, h2FvgUpStart, h2FvgUpQ)
    add_htf_pdarray_if_valid(pdArrays, htf2Label, 1, zshow1, plotFVG, "FVG", false, h2FvgDnTop, h2FvgDnBtm, h2FvgDnStart, h2FvgDnQ)
    add_htf_pdarray_if_valid(pdArrays, htf2Label, 1, zshow1, plotSD, "SD", false, h2SdSupTop, h2SdSupBtm, h2SdSupStart, 100.0)
    add_htf_pdarray_if_valid(pdArrays, htf2Label, 1, zshow1, plotSD, "SD", true, h2SdDemTop, h2SdDemBtm, h2SdDemStart, 100.0)
    annotate_new_pricezones(pdArrays, htf2ZoneStartIdx, htf2, 3, htf2Data)
int breakRetestWindowBars = CORE.get_dynamic_confirmation_window_bars(timeframe.period, false, limCfg.sweepReclaimMinBars, limCfg.sweepReclaimMaxBars, limCfg.breakRetestMinBars, limCfg.breakRetestMaxBars)
process_data_entries(breakRetestWindowBars, canEmitSignals)
int mitigatedKeepMax = get_mitigated_keep_max(scoreProfileId)
prune_mitigated_pdarrays(pdArrays, mitigatedKeepMax, limCfg.zonePriorityAgeDecay)
if barstate.islast
    draw_data_trades_dashboard()
    draw_debug_table()
