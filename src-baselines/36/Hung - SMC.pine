tradeEntriesInput = input.bool(true, "Trades", inline = "tc0", group = GROUP_TRADES_CONFIG)
strategyOrdersInput = input.bool(false, "Strategy", inline = "tc0", group = GROUP_TRADES_CONFIG)
propPreset = input.string("None", "Trade rules", options = ["None", "FTMO 2-Step", "FTMO 1-Step", "The5ers HS", "The5ers HG"], tooltip = "FTMO 2-Step: 2.5% daily cap, 0.5%/trade | FTMO 1-Step: 1.5%/0.5% | The5ers HS: 2.5%/0.5% | The5ers HG: 1.5%/0.5% | None: unlimited", inline = "tc0", group = GROUP_TRADES_CONFIG)
tradeRiskValue = input.float(1.0, "1R", minval = 0.01, maxval = 100.0, step = 0.1, inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeRiskMode  = input.string("%", "", options = ["%", "$"], inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeSpreadTicks = input.float(0.0, "Spread", minval = 0.0, step = 0.5, inline = "tc1", group = GROUP_TRADES_CONFIG)
tradeShowPending = input.bool(false, "Pending", inline = "tc2", group = GROUP_TRADES_CONFIG)
tradeShowStart = input.bool(false, "Start -> Active", inline = "tc2", group = GROUP_TRADES_CONFIG)
tradeShowTp = input.bool(false, "TP", inline = "tc2", group = GROUP_TRADES_CONFIG)
tradeShowSl = input.bool(false, "SL", inline = "tc2", group = GROUP_TRADES_CONFIG)
gateUsePreTouchTpCut = input.bool(false, "Pre-touch TP cut", inline = "tc3", group = GROUP_TRADES_CONFIG)
